      }

      .pz-result-receipt-summary {
        padding: 20px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(219, 231, 255, 0.96);
        box-shadow: 0 20px 46px rgba(6, 22, 66, 0.09);
      }

      .pz-result-receipt-summary.is-preview {
        display: none;
      }

      .pz-result-receipt-summary h3 {
        margin: 0 0 14px;
        color: var(--pz-blue-dark);
        font-size: 16px;
        font-weight: 1000;
      }

      .pz-result-receipt-summary dl {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px 18px;
        margin: 0;
      }

      .pz-result-receipt-summary div {
        min-width: 0;
        display: grid;
        gap: 4px;
      }

      .pz-result-receipt-summary dt {
        color: #60708f;
        font-size: 12px;
        font-weight: 900;
      }

      .pz-result-receipt-summary dd {
        min-width: 0;
        margin: 0;
        color: var(--pz-blue-dark);
        font-size: 13px;
        font-weight: 950;
      }

      .pz-result-receipt-summary a {
        color: var(--pz-blue);
        text-decoration: none;
        overflow-wrap: anywhere;
      }

      .pz-result-celebration-sky {
        position: absolute;
        inset: 0;
        overflow: hidden;
        border-radius: 24px;
        pointer-events: none;
        z-index: 2;
      }

      .pz-result-confetti-piece {
        position: absolute;
        top: -24px;
        left: var(--x);
        width: 8px;
        height: 16px;
        border-radius: 3px;
        background: #13b94d;
        opacity: 0;
        transform: translateY(-20px) rotate(var(--r));
        animation: pzResultConfetti 2600ms ease-out both;
        animation-delay: var(--d);
      }

      .pz-result-confetti-piece:nth-child(3n) {
        background: #126cff;
      }

      .pz-result-confetti-piece:nth-child(4n) {
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: #f5b84b;
      }

      .pz-result-confetti-piece:nth-child(5n) {
        background: #22c55e;
      }

      .pz-result-firework {
        position: absolute;
        width: 120px;
        height: 120px;
        opacity: 0;
        pointer-events: none;
        animation: pzFireworkFade 1800ms ease-out 260ms both;
      }

      .pz-result-firework-left {
        left: 22%;
        top: 32px;
      }

      .pz-result-firework-right {
        right: 18%;
        top: 42px;
      }

      .pz-result-firework::before,
      .pz-result-firework::after,
      .pz-result-firework b {
        content: "";
        position: absolute;
        left: 50%;
        top: 50%;
        width: 96px;
        height: 2px;
        border-radius: 999px;
        background: linear-gradient(90deg, transparent, rgba(7, 91, 234, 0.78), transparent);
        transform-origin: center;
      }

      .pz-result-firework::before {
        transform: translate(-50%, -50%) rotate(0deg);
      }

      .pz-result-firework::after {
        transform: translate(-50%, -50%) rotate(60deg);
        background: linear-gradient(90deg, transparent, rgba(8, 168, 62, 0.76), transparent);
      }

      .pz-result-firework b {
        transform: translate(-50%, -50%) rotate(120deg);
        background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.78), transparent);
      }

      .pz-result-star {
        position: absolute;
        width: 18px;
        height: 18px;
        opacity: 0.9;
        clip-path: polygon(50% 0, 62% 34%, 98% 35%, 68% 56%, 79% 91%, 50% 70%, 21% 91%, 32% 56%, 2% 35%, 38% 34%);
        background: #f5b84b;
        filter: drop-shadow(0 8px 12px rgba(245, 158, 11, 0.28));
        animation: pzStarPulse 1600ms ease-out 420ms both;
      }

      .pz-result-star-one {
        left: 8%;
        top: 34%;
      }

      .pz-result-star-two {
        right: 9%;
        top: 24%;
        width: 14px;
        height: 14px;
        background: #126cff;
      }

      .pz-result-star-three {
        left: 48%;
        bottom: 14%;
        width: 22px;
        height: 22px;
      }

      .pz-raffle-result-stage.has-result-animation .pz-result-winner-number {
        animation: pzWinnerReveal 900ms cubic-bezier(0.2, 0.82, 0.2, 1) both;
      }

      .pz-raffle-result-stage.has-result-animation .pz-result-medal-ring {
        animation: pzMedalGlow 1200ms ease-out both;
      }

      @keyframes pzWinnerReveal {
        0% {
          opacity: 0;
          transform: translateY(24px) scale(0.78);
          filter: brightness(1);
        }

        62% {
          opacity: 1;
          transform: translateY(-8px) scale(1.08);
          filter: brightness(1.12);
        }

        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
          filter: brightness(1);
        }
      }

      @keyframes pzMedalGlow {
        0% {
          opacity: 0.4;
          transform: scale(0.86);
        }

        70% {
          opacity: 1;
          transform: scale(1.04);
        }

        100% {
          opacity: 1;
          transform: scale(1);
        }
      }

      @keyframes pzResultConfetti {
        0% {
          opacity: 0;
          transform: translateY(-20px) rotate(var(--r));
        }

        14% {
          opacity: 0.95;
        }

        100% {
          opacity: 0;
          transform: translateY(390px) rotate(280deg);
        }
      }

      @keyframes pzFireworkFade {
        0% {
          opacity: 0;
          transform: scale(0.5);
        }

        32% {
          opacity: 0.9;
        }

        100% {
          opacity: 0;
          transform: scale(1.3);
        }
      }

      @keyframes pzStarPulse {
        0% {
          opacity: 0;
          transform: scale(0.4) rotate(-18deg);
        }

        55% {
          opacity: 1;
          transform: scale(1.2) rotate(10deg);
        }

        100% {
          opacity: 0.82;
          transform: scale(1) rotate(0deg);
        }
      }

