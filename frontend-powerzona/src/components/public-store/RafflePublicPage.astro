---
import SocialMeta from '../SocialMeta.astro';
import {
  RAFFLE_STATUSES,
  buildRaffleWhatsappReceiptHref,
  cleanWhatsappNumber,
  formatRaffleNumber,
  getCalculatedRaffleStatus,
  getEffectiveRafflePrizeDisplayMode,
  isRaffleConfigured,
  isRaffleLinkEnabled,
  isRaffleShownInStore,
  isValidRaffleNumber,
  raffleAcceptsEntries,
  rafflePrizeCards,
  type RaffleRecord,
} from '../../lib/raffles';

interface Props {
  store: any;
  settings?: any;
  raffle: RaffleRecord | null;
  occupiedNumbers?: string[];
  canonicalPath: string;
}

const {
  store,
  settings = null,
  raffle,
  occupiedNumbers = [],
  canonicalPath,
} = Astro.props;

const storeSlug = String(store?.slug || '').trim().toLowerCase();
const storeName = String(settings?.store_name || store?.name || 'Tu tienda').trim();
const whatsapp = cleanWhatsappNumber(settings?.whatsapp_number || store?.owner_phone);
const storeUrl = `/t/${encodeURIComponent(storeSlug)}`;
const raffleSlug = String(raffle?.slug || '').trim();
const raffleUrl = raffleSlug
  ? `/t/${encodeURIComponent(storeSlug)}/rifa/${encodeURIComponent(raffleSlug)}`
  : `/t/${encodeURIComponent(storeSlug)}/rifa`;
const fullRaffleUrl = new URL(raffleUrl, Astro.url).toString();
const contactHref = whatsapp ? `https://wa.me/${whatsapp}` : storeUrl;
const title = raffle?.title || `Rifa ${storeName}`;
const description = String(raffle?.description || '').trim();
const conditionsText = String(raffle?.conditions || '').trim();
const customConditions = conditionsText
  .split(/\r?\n/)
  .map((line) => line.replace(/^[-*]\s*/, '').trim())
  .filter(Boolean)
  .slice(0, 4);
const conditions = [
  'Debes pertenecer al grupo de WhatsApp',
  'Introduce el código exclusivo del grupo',
  'Cada teléfono puede escoger un solo número',
  'La rifa es gratis para miembros del grupo',
  'Los números van del 00 al 99',
  'Cuando reserves tu número dejará de estar disponible',
  ...customConditions,
].slice(0, 8);
const calculatedStatus = raffle ? getCalculatedRaffleStatus(raffle) : RAFFLE_STATUSES.ARCHIVED;
const linkEnabled = Boolean(raffle && isRaffleLinkEnabled(raffle));
const showInStore = Boolean(raffle && isRaffleShownInStore(raffle));
const configured = Boolean(raffle && isRaffleConfigured(raffle));
const hasAvailableRaffle = Boolean(raffle && configured && linkEnabled);
const shouldNoindex = Boolean(!hasAvailableRaffle || !showInStore);
const isActive = Boolean(raffle && raffleAcceptsEntries(raffle));
const isScheduled = calculatedStatus === RAFFLE_STATUSES.SCHEDULED;
const isSelectionClosed = calculatedStatus === RAFFLE_STATUSES.SELECTION_CLOSED;
const isResultPending = calculatedStatus === RAFFLE_STATUSES.RESULT_PENDING;
const isWinnerPublished = calculatedStatus === RAFFLE_STATUSES.WINNER_PUBLISHED;
const isNoWinnerPublished = calculatedStatus === RAFFLE_STATUSES.NO_WINNER_PUBLISHED;
const isFinalized = calculatedStatus === RAFFLE_STATUSES.FINALIZED;
const winnerNumberDisplay = formatRaffleNumber(raffle?.winner_number) || '--';
const noWinnerNumberDisplay = formatRaffleNumber(raffle?.no_winner_number) || '--';
const hasPublishedWinnerNumber = winnerNumberDisplay !== '--';
const hasPublishedNoWinnerNumber = noWinnerNumberDisplay !== '--';
const isPublishedWinnerResult = isWinnerPublished || (isFinalized && hasPublishedWinnerNumber);
const isPublishedNoWinnerResult = isNoWinnerPublished || (isFinalized && !hasPublishedWinnerNumber && hasPublishedNoWinnerNumber);
const isPublishedResult = isPublishedWinnerResult || isPublishedNoWinnerResult;
const shouldAnimateWinnerResult = isPublishedWinnerResult && hasPublishedWinnerNumber;
const numbers = Array.from({ length: 100 }, (_, index) => String(index).padStart(2, '0'));
const occupiedSet = new Set(occupiedNumbers.filter(isValidRaffleNumber));
const prizeCards = raffle ? rafflePrizeCards(raffle, storeName, description) : [];
const prizesDisplayMode = getEffectiveRafflePrizeDisplayMode(raffle?.prizes_display_mode, prizeCards.length);
const usePrizeCarousel = prizesDisplayMode === 'carousel';
const showPrizeCarouselControls = usePrizeCarousel && prizeCards.length > 1;
const prizeLayoutClass = usePrizeCarousel ? 'is-carousel' : 'is-fixed';
const drawLabel = raffle?.draw_at
  ? new Intl.DateTimeFormat('es', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(raffle.draw_at))
  : 'Por anunciar';
const startsLabel = raffle?.starts_at
  ? new Intl.DateTimeFormat('es', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(raffle.starts_at))
  : 'Por anunciar';
const countdownCaption = calculatedStatus === RAFFLE_STATUSES.SCHEDULED
  ? 'para comenzar la selección de números'
  : calculatedStatus === RAFFLE_STATUSES.SELECTION_CLOSED
  ? 'para anunciar el ganador'
  : calculatedStatus === RAFFLE_STATUSES.RESULT_PENDING
    ? 'resultado pendiente de publicación'
    : calculatedStatus === RAFFLE_STATUSES.WINNER_PUBLISHED || calculatedStatus === RAFFLE_STATUSES.NO_WINNER_PUBLISHED
      ? 'resultado publicado'
      : calculatedStatus === RAFFLE_STATUSES.FINALIZED
        ? 'rifa finalizada'
        : calculatedStatus === RAFFLE_STATUSES.ACTIVE
          ? 'para cerrar la selección de números'
          : 'rifa no disponible';
const closesAt = raffle?.closes_at || '';
const drawAt = raffle?.draw_at || '';
const startsAt = raffle?.starts_at || '';
const seoDescription = description || `Rifa gratis exclusiva para miembros del grupo de WhatsApp de ${storeName}.`;
const initialWhatsappReceipt = raffle ? buildRaffleWhatsappReceiptHref({
  whatsapp,
  storeName,
  raffleTitle: title,
  chosenNumber: '--',
  phone: '53________',
  receiptCode: 'RF',
  raffleUrl: fullRaffleUrl,
}) : '';
const faviconVersion = '2';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" href={`/favicon.ico?v=${faviconVersion}`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32x32.png?v=${faviconVersion}`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16x16.png?v=${faviconVersion}`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${faviconVersion}`} />
    <SocialMeta
      title={`${title} | ${storeName}`}
      description={seoDescription}
      canonical={canonicalPath || raffleUrl}
      siteName={storeName}
      type="website"
      image={prizeCards[0]?.imageUrl || store?.bannerUrl || store?.logoUrl || '/brand/tusenda84-bazzar-logo.webp'}
    />
    {shouldNoindex && <meta name="robots" content="noindex,nofollow" />}
  </head>
  <body>
    <main
      class="pz-raffle-page"
      data-raffle-root
      data-raffle-status={calculatedStatus}
      data-starts-at={startsAt}
      data-closes-at={closesAt}
      data-draw-at={drawAt}
      data-store-slug={storeSlug}
      data-raffle-slug={raffleSlug}
    >
      <section class="pz-raffle-shell">
        <header class="pz-raffle-hero">
          <div class="pz-raffle-hero-copy">
            <span class="pz-raffle-badge">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2 2.8 6 6.2.8-4.6 4.5 1.1 6.2L12 16.5 6.5 19.5l1.1-6.2L3 8.8 9.2 8 12 2Z"></path></svg>
              Promoción exclusiva
            </span>

            <h1 class="pz-raffle-title">
              <span>Rifa</span>
              <strong>{storeName}</strong>
            </h1>

            <p class="pz-raffle-subtitle">
              Exclusiva para clientes del grupo de WhatsApp.
            </p>

            <p class="pz-raffle-note">
              {description || 'Agradecemos tu preferencia y fidelidad.'}
            </p>

            <div class="pz-raffle-actions">
              <a class="pz-raffle-btn pz-raffle-btn-blue" href={storeUrl}>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4V5Zm2 2v10h12V7H6Zm2 2h8v2H8V9Zm0 4h5v2H8v-2Z"></path></svg>
                Ver tienda
              </a>

              <a class="pz-raffle-btn pz-raffle-btn-green" href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined}>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a8.5 8.5 0 0 0-7.4 12.7L3.5 21l5.4-1.1A8.5 8.5 0 1 0 12 3Zm0 2a6.5 6.5 0 0 1 0 13c-1 0-2-.2-2.9-.7l-.3-.2-2.6.5.5-2.5-.2-.3A6.5 6.5 0 0 1 12 5Zm-2.4 3.3c-.2 0-.5.1-.7.4-.2.3-.8.8-.8 2s.8 2.3 1 2.5c.1.2 1.7 2.7 4.2 3.6 2.1.8 2.5.5 3 .5.4 0 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1-.1-.1-.2-.2-.5-.3l-1.7-.8c-.2-.1-.4-.1-.6.2l-.7.9c-.1.2-.3.2-.6.1a5.4 5.4 0 0 1-2.7-2.4c-.2-.3 0-.5.1-.6l.5-.6c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.6l-.8-1.8c-.2-.4-.4-.4-.7-.4Z"></path></svg>
                Contactar por WhatsApp
              </a>
            </div>
          </div>

          {!isPublishedResult ? (
            <article class="pz-raffle-countdown-card" aria-live="polite">
              <p class="pz-countdown-eyebrow">Faltan</p>

              <div class="pz-countdown-grid" data-countdown>
                <div class="pz-countdown-unit">
                  <strong data-days>00</strong>
                  <span>días</span>
                </div>

                <b class="pz-countdown-separator">:</b>

                <div class="pz-countdown-unit">
                  <strong data-hours>00</strong>
                  <span>horas</span>
                </div>

                <b class="pz-countdown-separator">:</b>

                <div class="pz-countdown-unit">
                  <strong data-minutes>00</strong>
                  <span>minutos</span>
                </div>

                <b class="pz-countdown-separator">:</b>

                <div class="pz-countdown-unit">
                  <strong data-seconds>00</strong>
                  <span>segundos</span>
                </div>
              </div>

              <p class="pz-countdown-caption" data-countdown-caption>
                {countdownCaption}
              </p>

              <p class="pz-countdown-date">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 8H4v10h16V10ZM6 6v2h12V6H6Z"></path></svg>
                Fecha del sorteo: <time data-draw-label>{drawLabel}</time>
              </p>
            </article>
          ) : (
            <article class:list={['pz-raffle-result-status-card', isPublishedWinnerResult && 'is-winner-result', isPublishedNoWinnerResult && 'is-no-winner-result']} aria-live="polite">
              <span>Resultado publicado</span>
              <strong>{isPublishedWinnerResult ? 'Sorteo completado' : 'Sorteo publicado'}</strong>
              <p>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 8H4v10h16V10ZM6 6v2h12V6H6Z"></path></svg>
                Fecha del sorteo: <time>{drawLabel}</time>
              </p>
            </article>
          )}
        </header>

        {!hasAvailableRaffle && (
          <section class="pz-raffle-state-card pz-raffle-state-empty">
            <strong>Rifa no disponible</strong>
            <p>Esta rifa todavía no está activa.</p>
          </section>
        )}

        {hasAvailableRaffle && isScheduled && (
          <section class="pz-raffle-state-card pz-raffle-state-warning">
            <strong>La rifa todavía no ha comenzado</strong>
            <p>Comenzaremos a tomar números el día {startsLabel}.</p>
            <div class="pz-state-actions">
              <a href={storeUrl}>Ver tienda</a>
              <a href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined}>Contactar por WhatsApp</a>
            </div>
          </section>
        )}

        {hasAvailableRaffle && isSelectionClosed && (
          <section class="pz-raffle-state-card pz-raffle-state-warning">
            <strong>Selección de números cerrada</strong>
            <p>Ya no se pueden reservar más números para esta rifa. El resultado será anunciado el día {drawLabel}.</p>
            <div class="pz-state-actions">
              <a href={storeUrl}>Ver tienda</a>
              <a href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined}>Contactar por WhatsApp</a>
            </div>
          </section>
        )}

        {hasAvailableRaffle && isResultPending && (
          <section class="pz-raffle-state-card pz-raffle-state-warning">
            <strong>Sorteo cerrado</strong>
            <p>El resultado está pendiente de ser publicado por la tienda.</p>
            <div class="pz-state-actions">
              <a href={storeUrl}>Ver tienda</a>
              <a href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined}>Contactar por WhatsApp</a>
            </div>
          </section>
        )}

        {hasAvailableRaffle && isFinalized && !isPublishedResult && (
          <section class="pz-raffle-state-card pz-raffle-state-empty">
            <strong>Rifa finalizada</strong>
            <p>Esta rifa ya finalizó. Mantente atento a la próxima rifa de {storeName}.</p>
            <div class="pz-state-actions">
              <a href={storeUrl}>Ver tienda</a>
              <a href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined}>Contactar por WhatsApp</a>
            </div>
          </section>
        )}

        {hasAvailableRaffle && (
          <section class:list={['pz-raffle-content', isPublishedResult && 'is-result-mode']}>
            <div class="pz-raffle-main-column">
              {isPublishedWinnerResult && (
                <section class:list={['pz-raffle-result-stage', 'is-public-result', shouldAnimateWinnerResult && 'has-result-animation']} data-result-stage>
                  <article class="pz-result-celebration-card">
                    {shouldAnimateWinnerResult && (
                      <div class="pz-result-celebration-sky" aria-hidden="true">
                        {Array.from({ length: 28 }, (_, index) => (
                          <i
                            class="pz-result-confetti-piece"
                            style={`--x:${4 + index * 3.4}%; --d:${index * 48}ms; --r:${(index % 7) * 22}deg;`}
                          ></i>
                        ))}
                        <span class="pz-result-firework pz-result-firework-left"><b></b></span>
                        <span class="pz-result-firework pz-result-firework-right"><b></b></span>
                        <span class="pz-result-star pz-result-star-one"></span>
                        <span class="pz-result-star pz-result-star-two"></span>
                        <span class="pz-result-star pz-result-star-three"></span>
                      </div>
                    )}

                    <div class="pz-result-message">
                      <span class="pz-result-badge">Resultado publicado</span>
                      <h2 data-result-title>¡Número ganador!</h2>
                      <p class="pz-result-subtitle" data-result-subtitle>Felicidades al ganador. Contacta con la tienda para reclamar tu premio.</p>
                      <p class="pz-result-copy" data-result-copy hidden></p>

                      <a class="pz-raffle-btn pz-raffle-btn-green pz-result-action" href={contactHref} target={whatsapp ? '_blank' : undefined} rel={whatsapp ? 'noopener' : undefined} data-result-action>
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a8.5 8.5 0 0 0-7.4 12.7L3.5 21l5.4-1.1A8.5 8.5 0 1 0 12 3Zm0 2a6.5 6.5 0 0 1 0 13c-1 0-2-.2-2.9-.7l-.3-.2-2.6.5.5-2.5-.2-.3A6.5 6.5 0 0 1 12 5Z"></path></svg>
                        <span data-result-action-label>Contactar por WhatsApp</span>
                      </a>
                    </div>

                    <div class="pz-result-winner-spotlight">
                      <div class="pz-result-medal" aria-hidden="true">
                        <span class="pz-result-medal-ring"></span>
                        <span class="pz-result-laurel pz-result-laurel-left"></span>
                        <span class="pz-result-laurel pz-result-laurel-right"></span>
                        <span class="pz-result-podium"></span>
                      </div>
                      <span>Número ganador</span>
                      <strong class="pz-result-winner-number" data-result-winner-number>{winnerNumberDisplay}</strong>
                      <small>Ganador</small>
                    </div>

                    <aside class="pz-result-client-card" data-result-client-card hidden>
                      <span>Tu número</span>
                      <strong data-result-client-number data-receipt-number>--</strong>
                      <p data-result-client-status>¡Coincide con el ganador!</p>
                    </aside>
                  </article>

                  <article class="pz-result-receipt-summary is-preview" data-result-receipt-card>
                    <h3>Resumen del comprobante</h3>

                    <dl>
                      <div>
                        <dt>Rifa:</dt>
                        <dd>{title}</dd>
                      </div>

                      <div>
                        <dt>Número reservado:</dt>
                        <dd data-receipt-number-text>--</dd>
                      </div>

                      <div>
                        <dt>Teléfono:</dt>
                        <dd data-receipt-phone>53________</dd>
                      </div>

                      <div>
                        <dt>Comprobante:</dt>
                        <dd data-receipt-code>--</dd>
                      </div>

                      <div>
                        <dt>Fecha y hora:</dt>
                        <dd data-receipt-date>--</dd>
                      </div>

                      <div>
                        <dt>Enlace directo:</dt>
                        <dd>
                          <a href={raffleUrl} data-receipt-link>{raffleUrl}</a>
                          <button type="button" class="pz-copy-link" data-copy-raffle-link aria-label="Copiar enlace">Copiar</button>
                        </dd>
                      </div>
                    </dl>
                  </article>
                </section>
              )}

              {isPublishedNoWinnerResult && (
                <section class="pz-raffle-result-stage is-no-winner-result">
                  <article class="pz-result-published-card pz-result-no-winner-card">
                    <div class="pz-result-message">
                      <span class="pz-result-badge">Resultado publicado</span>
                      <h2>No hubo ganador esta vez</h2>
                      <p class="pz-result-subtitle">El número sorteado fue {noWinnerNumberDisplay}, pero no estaba reservado.</p>
                      <p class="pz-result-copy">Mantente atento a la próxima rifa de {storeName}.</p>
                    </div>

                    <div class="pz-result-winner-spotlight">
                      <span>Número sorteado</span>
                      <strong class="pz-result-winner-number">{noWinnerNumberDisplay}</strong>
                      <small>Sin reserva activa</small>
                    </div>
                  </article>
                </section>
              )}

              <article class:list={['pz-raffle-card pz-prizes-card', prizeLayoutClass]}>
                <div class="pz-section-heading">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 12v8H4v-8H3V7h4.2A3 3 0 1 1 12 3.5 3 3 0 1 1 16.8 7H21v5h-1ZM6 18h5v-6H6v6Zm7 0h5v-6h-5v6ZM6.5 5a1 1 0 0 0 0 2H11C9.8 5.7 8.3 5 6.5 5Zm11 0c-1.8 0-3.3.7-4.5 2h4.5a1 1 0 0 0 0-2ZM5 9v1h14V9H5Z"></path></svg>
                  <h2>Premios increíbles</h2>
                </div>

                {showPrizeCarouselControls && (
                  <button class="pz-carousel-arrow pz-carousel-prev" type="button" aria-label="Premio anterior">‹</button>
                )}

                <div class="pz-prize-carousel-viewport">
                  <div class="pz-prize-track" data-prize-track>
                    {prizeCards.map((prize) => (
                      <article class="pz-prize-card">
                        <span class="pz-prize-label">{prize.label}</span>
                        <div class="pz-prize-image-wrap">
                          {prize.imageUrl ? (
                            <img src={prize.imageUrl} alt={prize.name} loading="lazy" />
                          ) : (
                            <div class="pz-prize-placeholder" aria-hidden="true">{storeName.slice(0, 2).toUpperCase()}</div>
                          )}
                        </div>
                        <h3>{prize.name}</h3>
                        <p>{prize.description}</p>
                      </article>
                    ))}
                  </div>
                </div>

                {showPrizeCarouselControls && (
                  <button class="pz-carousel-arrow pz-carousel-next" type="button" aria-label="Premio siguiente">›</button>
                )}

                {showPrizeCarouselControls && (
                  <div class="pz-carousel-dots" aria-label="Premios del carrusel">
                    {prizeCards.map((_, index) => (
                      <button
                        class:list={[index === 0 && 'is-active']}
                        type="button"
                        data-prize-dot
                        aria-label={`Ver premio ${index + 1}`}
                        aria-current={index === 0 ? 'true' : undefined}
                      ></button>
                    ))}
                  </div>
                )}
              </article>

              {!isPublishedResult && (
                <article class="pz-raffle-card pz-numbers-card" data-participation-panel>
                  <div class="pz-numbers-head">
                    <h2>Selecciona tu número (00 al 99)</h2>

                    <div class="pz-number-legend">
                      <span><i class="legend-dot legend-available"></i> Disponible</span>
                      <span><i class="legend-dot legend-occupied"></i> Ocupado</span>
                      <span><i class="legend-dot legend-selected"></i> Seleccionado</span>
                    </div>
                  </div>

                  <div class="pz-number-grid" data-number-grid>
                    {numbers.map((number) => {
                      const isOccupied = occupiedSet.has(number);

                      return (
                        <button
                          type="button"
                          class:list={[
                            'pz-number-btn',
                            isOccupied && 'is-occupied',
                          ]}
                          data-number={number}
                          disabled={isOccupied || !isActive}
                          aria-label={`Número ${number}`}
                        >
                          {number}
                        </button>
                      );
                    })}
                  </div>
                </article>
              )}
            </div>

            {!isPublishedResult && (
              <aside class="pz-raffle-side-column">
                <article class="pz-raffle-card pz-conditions-card">
                  <div class="pz-section-heading">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 6v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V6l-8-4Zm0 4 4 2v4c0 2.6-1.5 4.8-4 5.9-2.5-1.1-4-3.3-4-5.9V8l4-2Zm3.7 4.3-4.4 4.4-2.5-2.5 1.4-1.4 1.1 1.1 3-3 1.4 1.4Z"></path></svg>
                    <h2>Condiciones para participar</h2>
                  </div>

                  <ul class="pz-condition-list">
                    {conditions.map((condition) => <li>{condition}</li>)}
                  </ul>
                </article>

                {isActive && (
                  <article class="pz-raffle-card pz-form-card" data-participation-panel>
                    <div class="pz-section-heading">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5v5h4v2h-6V7h2Z"></path></svg>
                      <h2>Participa ahora</h2>
                    </div>

                    <form class="pz-raffle-form" data-raffle-form>
                      <label class="pz-field">
                        <span>Código del grupo de WhatsApp</span>
                        <input type="text" name="access_code" placeholder="Ej: PZ-AB12CD" autocomplete="off" required />
                      </label>

                      <label class="pz-field">
                        <span>Número de celular cubano</span>
                        <div class="pz-phone-field">
                          <strong>CU +53</strong>
                          <input type="tel" name="phone" placeholder="Ej: 59224567" inputmode="numeric" required />
                        </div>
                        <small>Solo se permiten números de Cuba porque la rifa es exclusiva para miembros del grupo.</small>
                      </label>

                      <input type="hidden" name="chosen_number" data-selected-number-input />

                      <p class="pz-form-error" data-form-error hidden></p>

                      <button class="pz-confirm-btn" type="submit">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2Z"></path></svg>
                        Confirmar número
                      </button>

                      <button class="pz-whatsapp-outline" type="button" data-send-receipt-button disabled>
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a8.5 8.5 0 0 0-7.4 12.7L3.5 21l5.4-1.1A8.5 8.5 0 1 0 12 3Zm0 2a6.5 6.5 0 0 1 0 13c-1 0-2-.2-2.9-.7l-.3-.2-2.6.5.5-2.5-.2-.3A6.5 6.5 0 0 1 12 5Z"></path></svg>
                        Enviar comprobante por WhatsApp
                      </button>
                    </form>
                  </article>
                )}

              </aside>
            )}

            {!isPublishedResult && (
              <article class="pz-reservation-wait-card is-preview" data-receipt-card>
              <div class="pz-reservation-wait-grid">
                <section class="pz-reservation-confirmation">
                  <span class="pz-reservation-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2Z"></path></svg>
                  </span>

                  <div>
                    <h2>Tu número ya está reservado</h2>
                    <p class="pz-reservation-subtitle">No necesitas volver a seleccionar un número.</p>
                  </div>

                  <div class="pz-reservation-number-box">
                    <span>Número reservado</span>
                    <strong data-receipt-number>--</strong>
                  </div>

                  <p class="pz-reservation-wait-message">Estamos en espera del ganador. Te deseamos mucha suerte.</p>
                  <p class="pz-reservation-confirmed-line">Tu reserva fue registrada correctamente.</p>
                </section>

                <section class="pz-receipt-summary pz-reservation-summary">
                  <h3>Resumen para tu comprobante</h3>

                  <dl>
                    <div>
                      <dt>Rifa:</dt>
                      <dd>{title}</dd>
                    </div>

                    <div>
                      <dt>Número reservado:</dt>
                      <dd data-receipt-number-text>--</dd>
                    </div>

                    <div>
                      <dt>Teléfono:</dt>
                      <dd data-receipt-phone>53________</dd>
                    </div>

                    <div>
                      <dt>Comprobante:</dt>
                      <dd data-receipt-code>--</dd>
                    </div>

                    <div>
                      <dt>Fecha y hora:</dt>
                      <dd data-receipt-date>--</dd>
                    </div>

                    <div>
                      <dt>Enlace directo:</dt>
                      <dd>
                        <a href={raffleUrl} data-receipt-link>{raffleUrl}</a>
                        <button type="button" class="pz-copy-link" data-copy-raffle-link aria-label="Copiar enlace">Copiar</button>
                      </dd>
                    </div>
                  </dl>
                </section>
              </div>

              <a class="pz-receipt-whatsapp pz-reservation-whatsapp" href={initialWhatsappReceipt || contactHref} target="_blank" rel="noopener" data-receipt-whatsapp>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a8.5 8.5 0 0 0-7.4 12.7L3.5 21l5.4-1.1A8.5 8.5 0 1 0 12 3Zm0 2a6.5 6.5 0 0 1 0 13c-1 0-2-.2-2.9-.7l-.3-.2-2.6.5.5-2.5-.2-.3A6.5 6.5 0 0 1 12 5Z"></path></svg>
                Enviar comprobante por WhatsApp
              </a>

              <p class="pz-safe-note">
                Tu información está segura y no será compartida.
              </p>
              </article>
            )}
          </section>
        )}
      </section>
    </main>

    <style>
      :root {
        --pz-blue: #075bea;
        --pz-blue-2: #0047c7;
        --pz-blue-dark: #061642;
        --pz-green: #08a83e;
        --pz-text: #061642;
        --pz-muted: #667085;
        --pz-border: #dbe7ff;
        --pz-shadow: 0 20px 50px rgba(6, 22, 66, 0.11);
        --pz-shadow-soft: 0 12px 34px rgba(6, 22, 66, 0.08);
        --pz-radius-lg: 20px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body { background: #f7fbff; }
      button, input { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: 0.68; }

      .pz-raffle-page {
        min-height: 100vh;
        color: var(--pz-text);
        background: linear-gradient(135deg, #ffffff 0%, #f7fbff 42%, #eef6ff 100%);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      .pz-raffle-shell {
        width: min(1440px, calc(100% - 64px));
        margin: 0 auto;
        padding: 44px 0 58px;
      }

      .pz-raffle-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 560px;
        gap: 38px;
        align-items: center;
        margin-bottom: 30px;
      }

      .pz-raffle-badge {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        width: fit-content;
        padding: 9px 16px;
        border-radius: 999px;
        color: var(--pz-blue);
        background: #eaf2ff;
        font-weight: 900;
        font-size: 15px;
        box-shadow: inset 0 0 0 1px rgba(7, 91, 234, 0.08);
      }

      .pz-raffle-badge svg,
      .pz-raffle-btn svg,
      .pz-countdown-date svg,
      .pz-section-heading svg,
      .pz-confirm-btn svg,
      .pz-whatsapp-outline svg,
      .pz-receipt-whatsapp svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
        flex: 0 0 auto;
      }

      .pz-raffle-title {
        margin: 18px 0 8px;
        font-size: clamp(54px, 6vw, 86px);
        line-height: 0.93;
        letter-spacing: 0;
        color: #080b13;
        font-weight: 1000;
      }

      .pz-raffle-title span,
      .pz-raffle-title strong {
        display: block;
      }

      .pz-raffle-title strong {
        color: var(--pz-blue);
        font-weight: 1000;
      }

      .pz-raffle-subtitle,
      .pz-raffle-note {
        margin: 0;
        font-size: 20px;
        line-height: 1.45;
        color: #18254a;
        font-weight: 650;
      }

      .pz-raffle-note {
        color: #354064;
        font-weight: 520;
        max-width: 740px;
      }

      .pz-raffle-actions {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .pz-raffle-btn,
      .pz-state-actions a {
        min-height: 58px;
        padding: 0 34px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        color: #fff;
        font-weight: 900;
        text-decoration: none;
        border: 0;
        box-shadow: 0 16px 30px rgba(7, 91, 234, 0.22);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }

      .pz-raffle-btn:hover,
      .pz-state-actions a:hover {
        transform: translateY(-2px);
      }

      .pz-raffle-btn-blue {
        background: linear-gradient(180deg, #126cff 0%, #0057e6 100%);
      }

      .pz-raffle-btn-green {
        background: linear-gradient(180deg, #13b94d 0%, #079639 100%);
        box-shadow: 0 16px 30px rgba(8, 168, 62, 0.22);
      }

      .pz-raffle-countdown-card {
        border: 1px solid rgba(7, 91, 234, 0.34);
        border-radius: var(--pz-radius-lg);
        background: rgba(255, 255, 255, 0.92);
        box-shadow: var(--pz-shadow);
        padding: 28px 34px 30px;
        overflow: hidden;
      }

      .pz-countdown-eyebrow {
        margin: 0 0 8px;
        font-size: 19px;
        font-weight: 750;
      }

      .pz-countdown-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
        align-items: center;
        gap: 14px;
        text-align: center;
      }

      .pz-countdown-unit strong {
        display: block;
        font-size: clamp(38px, 4.5vw, 58px);
        line-height: 1;
        color: var(--pz-blue-dark);
        letter-spacing: 0;
      }

      .pz-countdown-unit span {
        display: block;
        margin-top: 6px;
        color: #18254a;
        font-size: 16px;
        font-weight: 650;
      }

      .pz-countdown-separator {
        color: var(--pz-blue);
        font-size: 44px;
        line-height: 1;
        padding-bottom: 22px;
      }

      .pz-countdown-caption {
        margin: 16px 0 18px;
        text-align: center;
        color: #18254a;
        font-size: 17px;
        font-weight: 800;
      }

      .pz-countdown-date {
        width: fit-content;
        max-width: 100%;
        margin: 0 auto;
        padding: 11px 18px;
        border-radius: 10px;
        background: #f4f6fb;
        border: 1px solid #e4e9f5;
        color: #354064;
        font-size: 15px;
        font-weight: 650;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      .pz-raffle-result-status-card {
        position: relative;
        min-height: 128px;
        overflow: hidden;
        display: grid;
        align-content: center;
        justify-items: start;
        gap: 12px;
        padding: 24px 28px;
        border: 1px solid rgba(125, 211, 252, 0.72);
        border-radius: 20px;
        background:
          radial-gradient(circle at 92% 70%, rgba(7, 91, 234, 0.12), transparent 34%),
          radial-gradient(circle at 78% 14%, rgba(8, 168, 62, 0.16), transparent 34%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(239, 255, 246, 0.94));
        box-shadow: 0 22px 52px rgba(6, 22, 66, 0.12);
      }

      .pz-raffle-result-status-card span {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 0 12px;
        border-radius: 999px;
        color: #07512a;
        background: rgba(220, 252, 231, 0.9);
        border: 1px solid rgba(8, 168, 62, 0.22);
        font-size: 11px;
        font-weight: 1000;
        text-transform: uppercase;
      }

      .pz-raffle-result-status-card strong {
        position: relative;
        z-index: 1;
        color: var(--pz-blue-dark);
        font-size: 26px;
        line-height: 1.05;
        font-weight: 1000;
      }

      .pz-raffle-result-status-card p {
        position: relative;
        z-index: 1;
        width: fit-content;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0;
        padding: 9px 12px;
        border-radius: 10px;
        color: #263456;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(219, 231, 255, 0.9);
        font-size: 13px;
        font-weight: 850;
      }

      .pz-raffle-result-status-card svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
        opacity: 0.78;
      }

      .pz-raffle-content {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(360px, 0.85fr);
        gap: 18px;
        align-items: start;
      }

      .pz-raffle-content.is-result-mode {
        grid-template-columns: minmax(0, 1fr);
      }

      .pz-raffle-main-column,
      .pz-raffle-side-column {
        min-width: 0;
        display: grid;
        gap: 18px;
      }

      .pz-raffle-content.is-result-mode .pz-raffle-main-column {
        gap: 22px;
      }

      .pz-raffle-result-stage {
        position: relative;
        min-width: 0;
        display: grid;
        gap: 18px;
        isolation: isolate;
      }

      .pz-result-celebration-card,
      .pz-result-published-card {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.05fr);
        gap: 28px;
        align-items: stretch;
        min-height: 390px;
        padding: 34px;
        border: 1px solid rgba(125, 211, 252, 0.72);
        border-radius: 24px;
        background:
          radial-gradient(circle at 14% 18%, rgba(7, 91, 234, 0.10), transparent 30%),
          radial-gradient(circle at 86% 14%, rgba(8, 168, 62, 0.16), transparent 28%),
          radial-gradient(circle at 50% 100%, rgba(8, 168, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #ffffff 0%, #f8fbff 50%, #effff6 100%);
        box-shadow: 0 28px 70px rgba(6, 22, 66, 0.15);
      }

      .pz-raffle-result-stage.has-client-number .pz-result-celebration-card {
        grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr) minmax(230px, 0.68fr);
      }

      .pz-result-celebration-card::before {
        content: "";
        position: absolute;
        inset: 18px;
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.72);
        pointer-events: none;
        z-index: 0;
      }

      .pz-result-celebration-card::after {
        content: "";
        position: absolute;
        width: 290px;
        height: 290px;
        right: -96px;
        top: -106px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(8, 168, 62, 0.14), transparent 68%);
        pointer-events: none;
        z-index: 0;
      }

      .pz-result-no-winner-card {
        background:
          radial-gradient(circle at 88% 12%, rgba(7, 91, 234, 0.12), transparent 32%),
          linear-gradient(135deg, #ffffff 0%, #f8fbff 58%, #eef6ff 100%);
      }

      .pz-result-message {
        position: relative;
        z-index: 3;
        min-width: 0;
        display: grid;
        align-content: center;
        justify-items: start;
        gap: 14px;
      }

      .pz-result-badge {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 15px;
        border-radius: 999px;
        color: #07512a;
        background: rgba(220, 252, 231, 0.94);
        border: 1px solid rgba(8, 168, 62, 0.24);
        box-shadow: 0 10px 22px rgba(8, 168, 62, 0.08);
        font-size: 12px;
        font-weight: 1000;
        text-transform: uppercase;
      }

      .pz-result-message h2 {
        max-width: 520px;
        margin: 0;
        color: var(--pz-blue-dark);
        font-size: clamp(36px, 4.4vw, 58px);
        line-height: 0.98;
        letter-spacing: 0;
        font-weight: 1000;
      }

      .pz-raffle-result-stage.is-client-not-winner .pz-result-message h2 {
        color: var(--pz-blue);
      }

      .pz-result-subtitle,
      .pz-result-copy {
        max-width: 500px;
        margin: 0;
        color: #233355;
        font-size: 17px;
        line-height: 1.45;
        font-weight: 850;
      }

      .pz-result-copy {
        color: #50607e;
        font-size: 15px;
        font-weight: 760;
      }

      .pz-result-action {
        margin-top: 8px;
        min-width: 260px;
        min-height: 54px;
        box-shadow: 0 18px 34px rgba(8, 168, 62, 0.28);
      }

      .pz-result-action[hidden],
      .pz-result-receipt-summary[hidden],
      .pz-result-client-card[hidden] {
        display: none !important;
      }

      .pz-result-winner-spotlight {
        position: relative;
        z-index: 3;
        min-width: 0;
        min-height: 318px;
        display: grid;
        place-items: center;
        align-content: center;
        text-align: center;
        padding: 28px 18px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(219, 231, 255, 0.98);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82), 0 22px 45px rgba(6, 22, 66, 0.10);
      }

      .pz-result-medal {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        pointer-events: none;
        z-index: 0;
      }

      .pz-result-medal-ring {
        width: min(260px, 82%);
        aspect-ratio: 1;
        border-radius: 999px;
        background:
          radial-gradient(circle, rgba(255, 255, 255, 0.94) 0 48%, transparent 49%),
          conic-gradient(from 25deg, rgba(245, 158, 11, 0.48), rgba(8, 168, 62, 0.24), rgba(7, 91, 234, 0.26), rgba(245, 158, 11, 0.48));
        filter: drop-shadow(0 24px 44px rgba(8, 168, 62, 0.16));
      }

      .pz-result-laurel {
        position: absolute;
        bottom: 42px;
        width: 58px;
        height: 132px;
        border-radius: 999px;
        opacity: 0.86;
        background:
          radial-gradient(ellipse at 50% 12%, rgba(8, 168, 62, 0.82) 0 12%, transparent 13%),
          radial-gradient(ellipse at 34% 30%, rgba(8, 168, 62, 0.78) 0 11%, transparent 12%),
          radial-gradient(ellipse at 66% 30%, rgba(8, 168, 62, 0.78) 0 11%, transparent 12%),
          radial-gradient(ellipse at 30% 50%, rgba(8, 168, 62, 0.70) 0 10%, transparent 11%),
          radial-gradient(ellipse at 70% 50%, rgba(8, 168, 62, 0.70) 0 10%, transparent 11%),
          radial-gradient(ellipse at 42% 70%, rgba(8, 168, 62, 0.58) 0 9%, transparent 10%);
      }

      .pz-result-laurel-left {
        left: 12%;
        transform: rotate(-20deg);
      }

      .pz-result-laurel-right {
        right: 12%;
        transform: scaleX(-1) rotate(-20deg);
      }

      .pz-result-podium {
        position: absolute;
        bottom: 28px;
        left: 50%;
        width: min(220px, 70%);
        height: 38px;
        border-radius: 50%;
        transform: translateX(-50%);
        background:
          radial-gradient(ellipse at center, rgba(255, 255, 255, 0.98) 0 44%, rgba(220, 252, 231, 0.82) 45% 70%, transparent 71%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 255, 246, 0.85));
        box-shadow: 0 18px 36px rgba(8, 168, 62, 0.16);
      }

      .pz-result-winner-spotlight > span,
      .pz-result-winner-spotlight > small,
      .pz-result-winner-number,
      .pz-result-client-card span,
      .pz-result-client-card p {
        position: relative;
        z-index: 2;
      }

      .pz-result-winner-spotlight > span,
      .pz-result-client-card span {
        color: var(--pz-blue);
        font-size: 13px;
        font-weight: 1000;
        text-transform: uppercase;
      }

      .pz-result-winner-number {
        color: var(--pz-green);
        font-size: clamp(126px, 11vw, 178px);
        line-height: 0.82;
        font-weight: 1000;
        letter-spacing: 0;
        text-shadow:
          0 10px 0 rgba(255, 255, 255, 0.72),
          0 18px 40px rgba(8, 168, 62, 0.32);
      }

      .pz-raffle-result-stage.is-client-not-winner .pz-result-winner-number,
      .pz-raffle-result-stage.is-no-winner-result .pz-result-winner-number {
        color: var(--pz-blue);
        text-shadow:
          0 10px 0 rgba(255, 255, 255, 0.72),
          0 18px 40px rgba(7, 91, 234, 0.30);
      }

      .pz-result-winner-spotlight small {
        margin-top: 8px;
        color: #64728e;
        font-size: 13px;
        font-weight: 900;
      }

      .pz-result-client-card {
        position: relative;
        z-index: 3;
        min-width: 0;
        display: grid;
        place-items: center;
        align-content: center;
        gap: 8px;
        text-align: center;
        padding: 24px 18px;
        border-radius: 22px;
        background:
          radial-gradient(circle at 50% 24%, rgba(8, 168, 62, 0.16), transparent 40%),
          linear-gradient(180deg, rgba(239, 255, 245, 0.96) 0%, #ffffff 100%);
        border: 1px solid rgba(187, 247, 208, 0.96);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84), 0 18px 36px rgba(6, 22, 66, 0.08);
      }

      .pz-result-client-card::after {
        content: "✓";
        position: absolute;
        top: 28%;
        right: 18%;
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        color: #ffffff;
        background: var(--pz-green);
        box-shadow: 0 12px 24px rgba(8, 168, 62, 0.24);
        font-size: 20px;
        font-weight: 1000;
      }

      .pz-result-client-card strong {
        color: var(--pz-green);
        font-size: 86px;
        line-height: 0.9;
        font-weight: 1000;
        letter-spacing: 0;
      }

      .pz-raffle-result-stage.is-client-not-winner .pz-result-client-card {
        background:
          radial-gradient(circle at 50% 24%, rgba(7, 91, 234, 0.13), transparent 40%),
          linear-gradient(180deg, rgba(238, 246, 255, 0.96) 0%, #ffffff 100%);
        border-color: rgba(191, 219, 254, 0.96);
      }

      .pz-raffle-result-stage.is-client-not-winner .pz-result-client-card::after {
        content: "•";
        color: #ffffff;
        background: #94a3b8;
        box-shadow: 0 12px 24px rgba(100, 116, 139, 0.18);
      }

      .pz-raffle-result-stage.is-client-not-winner .pz-result-client-card strong {
        color: var(--pz-blue);
      }

      .pz-result-client-card p {
