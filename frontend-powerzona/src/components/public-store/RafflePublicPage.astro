    </style>

    <script define:vars={{ storeSlug, raffleSlug, fullRaffleUrl, storeName, contactHref, winnerNumberDisplay, isPublishedResult, isPublishedWinnerResult }}>
      (() => {
        const root = document.querySelector('[data-raffle-root]');
        if (!root) return;

        const status = root.dataset.raffleStatus || 'active';
        const publishedResultMode = Boolean(isPublishedResult);
        const startsAt = root.dataset.startsAt ? new Date(root.dataset.startsAt) : null;
        const closesAt = root.dataset.closesAt ? new Date(root.dataset.closesAt) : null;
        const drawAt = root.dataset.drawAt ? new Date(root.dataset.drawAt) : null;

        const daysNode = root.querySelector('[data-days]');
        const hoursNode = root.querySelector('[data-hours]');
        const minutesNode = root.querySelector('[data-minutes]');
        const secondsNode = root.querySelector('[data-seconds]');
        const captionNode = root.querySelector('[data-countdown-caption]');

        const getTargetDate = () => {
          if (status === 'scheduled') return startsAt;
          if (status === 'active') return closesAt;
          if (status === 'selection_closed') return drawAt;
          return null;
        };

        const pad = (value) => String(Math.max(0, value)).padStart(2, '0');
        const normalizeRaffleNumber = (value) => {
          const digits = String(value || '').replace(/\D/g, '');
          if (!digits) return '';
          const number = Number(digits);
          if (!Number.isInteger(number) || number < 0 || number > 99) return '';
          return pad(number);
        };
        const publishedWinnerNumber = normalizeRaffleNumber(winnerNumberDisplay);

        const renderCountdown = () => {
          const target = getTargetDate();
          if (captionNode) {
            const captions = {
              scheduled: 'para comenzar la selección de números',
              active: 'para cerrar la selección de números',
              selection_closed: 'para anunciar el ganador',
              result_pending: 'resultado pendiente de publicación',
              winner_published: 'resultado publicado',
              no_winner_published: 'resultado publicado',
              finalized: 'rifa finalizada',
            };
            captionNode.textContent = captions[status] || 'rifa no disponible';
          }

          if (!target || Number.isNaN(target.getTime())) return;

          const diff = Math.max(0, target.getTime() - Date.now());
          const totalSeconds = Math.floor(diff / 1000);
          const days = Math.floor(totalSeconds / 86400);
          const hours = Math.floor((totalSeconds % 86400) / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;

          if (daysNode) daysNode.textContent = pad(days);
          if (hoursNode) hoursNode.textContent = pad(hours);
          if (minutesNode) minutesNode.textContent = pad(minutes);
          if (secondsNode) secondsNode.textContent = pad(seconds);

        };

        if (!publishedResultMode) {
          renderCountdown();
          window.setInterval(renderCountdown, 1000);
        }

        const grid = root.querySelector('[data-number-grid]');
        const selectedInput = root.querySelector('[data-selected-number-input]');
        const receiptCard = root.querySelector('[data-receipt-card]');
        const receiptNumber = root.querySelector('[data-receipt-number]');
        const receiptNumberText = root.querySelector('[data-receipt-number-text]');
        const receiptPhone = root.querySelector('[data-receipt-phone]');
        const receiptCode = root.querySelector('[data-receipt-code]');
        const receiptDate = root.querySelector('[data-receipt-date]');
        const receiptWhatsapp = root.querySelector('[data-receipt-whatsapp]');
        const sendReceiptButton = root.querySelector('[data-send-receipt-button]');
        const resultStage = root.querySelector('[data-result-stage]');
        const resultTitle = root.querySelector('[data-result-title]');
        const resultSubtitle = root.querySelector('[data-result-subtitle]');
        const resultCopy = root.querySelector('[data-result-copy]');
        const resultClientCard = root.querySelector('[data-result-client-card]');
        const resultClientNumber = root.querySelector('[data-result-client-number]');
        const resultClientStatus = root.querySelector('[data-result-client-status]');
        const resultReceiptCard = root.querySelector('[data-result-receipt-card]');
        const resultAction = root.querySelector('[data-result-action]');
        const resultActionLabel = root.querySelector('[data-result-action-label]');
        const bottomWhatsappButtons = Array.from(root.querySelectorAll('[data-receipt-whatsapp], [data-whatsapp-receipt], .pz-receipt-whatsapp, .pz-result-bottom-whatsapp'));
        const participationPanels = Array.from(root.querySelectorAll('[data-participation-panel]'));
        const errorNode = root.querySelector('[data-form-error]');
        let currentWhatsappUrl = '';
        const receiptStoragePrefix = `pz-raffle-receipt:${storeSlug}:${raffleSlug}`;
        const legacyReceiptStorageKey = receiptStoragePrefix;
        const isReservationMode = () => root.classList.contains('has-existing-reservation');

        const setError = (message) => {
          if (!errorNode) return;
          if (isReservationMode()) {
            errorNode.textContent = '';
            errorNode.hidden = true;
            return;
          }
          errorNode.textContent = message || '';
          errorNode.hidden = !message;
        };

        const setReservationMode = (active) => {
          root.classList.toggle('has-existing-reservation', Boolean(active));
          participationPanels.forEach((panel) => {
            panel.hidden = Boolean(active);
          });
          if (active) setError('');
        };

        const setSelectedNumber = (number) => {
          const displayNumber = normalizeRaffleNumber(number) || String(number || '').trim();
          if (selectedInput) selectedInput.value = displayNumber;
          if (receiptNumber) receiptNumber.textContent = displayNumber || '--';
          if (receiptNumberText) receiptNumberText.textContent = displayNumber || '--';
        };

        const hidePublishedResultBottomWhatsapp = () => {
          if (!publishedResultMode) return;
          bottomWhatsappButtons.forEach((button) => {
            button.hidden = true;
            button.setAttribute('aria-hidden', 'true');
          });
        };

        const setResultAction = (label, href, visible = true) => {
          if (!resultAction) return;
          const nextHref = href || contactHref || window.location.href;
          if (resultActionLabel) resultActionLabel.textContent = label;
          resultAction.href = nextHref;
          resultAction.hidden = !visible;
          if (visible) resultAction.removeAttribute('aria-hidden');
          else resultAction.setAttribute('aria-hidden', 'true');
          if (/^https?:\/\//i.test(nextHref)) {
            resultAction.target = '_blank';
            resultAction.rel = 'noopener';
          } else {
            resultAction.removeAttribute('target');
            resultAction.removeAttribute('rel');
          }
        };

        const resetPublishedResult = () => {
          if (!publishedResultMode || !resultStage || !isPublishedWinnerResult) return;
          resultStage.classList.add('is-public-result');
          resultStage.classList.remove('has-client-number', 'is-client-winner', 'is-client-not-winner');
          if (resultTitle) resultTitle.textContent = '¡Número ganador!';
          if (resultSubtitle) resultSubtitle.textContent = 'Felicidades al ganador. Contacta con la tienda para reclamar tu premio.';
          if (resultCopy) {
            resultCopy.textContent = '';
            resultCopy.hidden = true;
          }
          if (resultClientCard) resultClientCard.hidden = true;
          resultReceiptCard?.classList.add('is-preview');
          setResultAction('Contactar por WhatsApp', contactHref);
          hidePublishedResultBottomWhatsapp();
        };

        const updatePublishedResultPersonalization = (receipt = {}) => {
          if (!publishedResultMode || !resultStage || !isPublishedWinnerResult) return;
          const clientNumber = normalizeRaffleNumber(receipt.chosen_number || receipt.selected_number);
          if (!clientNumber || !publishedWinnerNumber) {
            resetPublishedResult();
            return;
          }

          const clientIsWinner = clientNumber === publishedWinnerNumber;
          resultStage.classList.remove('is-public-result');
          resultStage.classList.add('has-client-number');
          resultStage.classList.toggle('is-client-winner', clientIsWinner);
          resultStage.classList.toggle('is-client-not-winner', !clientIsWinner);

          if (resultClientCard) resultClientCard.hidden = false;
          if (resultClientNumber) resultClientNumber.textContent = clientNumber;
          if (resultReceiptCard) resultReceiptCard.classList.remove('is-preview');

          if (clientIsWinner) {
            if (resultTitle) resultTitle.textContent = '¡Felicidades, eres nuestro ganador!';
            if (resultSubtitle) resultSubtitle.textContent = 'Tu número coincide con el número ganador.';
            if (resultCopy) {
              resultCopy.textContent = 'Contacta con la tienda para reclamar tu premio.';
              resultCopy.hidden = false;
            }
            if (resultClientStatus) resultClientStatus.textContent = '¡Coincide con el ganador!';
            setResultAction('Reclamar mi premio por WhatsApp', contactHref);
            hidePublishedResultBottomWhatsapp();
            return;
          }

          if (resultTitle) resultTitle.textContent = 'Tú eres el próximo';
          if (resultSubtitle) resultSubtitle.textContent = 'Tu número no coincidió esta vez.';
          if (resultCopy) {
            resultCopy.textContent = `Gracias por ser parte de ${storeName}.`;
            resultCopy.hidden = false;
          }
          if (resultClientStatus) resultClientStatus.textContent = 'Esta vez no coincidió';
          setResultAction('', contactHref, false);
          hidePublishedResultBottomWhatsapp();
        };

        resetPublishedResult();

        if (grid) {
          grid.addEventListener('click', (event) => {
            const button = event.target.closest('.pz-number-btn');
            if (!button || button.disabled || button.classList.contains('is-occupied')) return;

            grid.querySelectorAll('.pz-number-btn.is-selected').forEach((item) => {
              item.classList.remove('is-selected');
            });

            button.classList.add('is-selected');
            setSelectedNumber(button.dataset.number || '');
            setError('');
          });
        }

        const markOccupied = (number) => {
          if (!grid || !number) return;
          const button = grid.querySelector(`.pz-number-btn[data-number="${CSS.escape(number)}"]`);
          if (!button) return;
          button.classList.remove('is-selected');
          button.classList.add('is-occupied');
          button.disabled = true;
        };

        const lockNumberGrid = (number = '') => {
          if (!grid) return;
          grid.querySelectorAll('.pz-number-btn').forEach((button) => {
            const isSelectedNumber = number && button.dataset.number === number;
            button.disabled = true;
            button.classList.toggle('is-selected', Boolean(isSelectedNumber));
            if (isSelectedNumber) button.classList.remove('is-occupied');
          });
        };

        const unlockNumberGrid = () => {
          if (!grid) return;
          grid.querySelectorAll('.pz-number-btn').forEach((button) => {
            button.classList.remove('is-selected');
            button.disabled = status !== 'active' || button.classList.contains('is-occupied');
          });
        };

        const normalizePhone = (value) => {
          const digits = String(value || '').replace(/\D/g, '');
          if (/^\d{8}$/.test(digits)) return `53${digits}`;
          if (/^53\d{8}$/.test(digits)) return digits;
          return '';
        };

        const form = root.querySelector('[data-raffle-form]');
        const setFormLocked = (locked) => {
          if (!form) return;
          form.querySelectorAll('input').forEach((input) => {
            input.disabled = locked;
          });
          const submitButton = form.querySelector('.pz-confirm-btn');
          if (submitButton) {
            submitButton.disabled = locked;
            submitButton.hidden = locked;
          }
        };

        const receiptKeyForPhone = (phone) => `${receiptStoragePrefix}:${normalizePhone(phone)}`;

        const saveLocalReceipt = (receipt) => {
          try {
            const phone = normalizePhone(receipt.phone_normalized || receipt.phone);
            const key = phone ? receiptKeyForPhone(phone) : legacyReceiptStorageKey;
            window.localStorage.setItem(key, JSON.stringify({
              storeSlug,
              raffleSlug,
              chosen_number: receipt.chosen_number || receipt.selected_number || '',
              selected_number: receipt.chosen_number || receipt.selected_number || '',
              phone,
              phone_normalized: phone,
              receipt_code: receipt.receipt_code || '',
              created: receipt.created || receipt.created_at || new Date().toISOString(),
              created_at: receipt.created || receipt.created_at || new Date().toISOString(),
              status: receipt.status || '',
              whatsapp_url: receipt.whatsapp_url || '',
            }));
            if (phone) window.localStorage.removeItem(legacyReceiptStorageKey);
          } catch (_) {
          }
        };

        const readLocalReceipt = () => {
          try {
            const candidates = [];
            const legacy = window.localStorage.getItem(legacyReceiptStorageKey);
            if (legacy) candidates.push({ key: legacyReceiptStorageKey, raw: legacy });
            for (let index = 0; index < window.localStorage.length; index += 1) {
              const key = window.localStorage.key(index) || '';
              if (!key.startsWith(`${receiptStoragePrefix}:`)) continue;
              const raw = window.localStorage.getItem(key);
              if (raw) candidates.push({ key, raw });
            }
            for (const candidate of candidates) {
              try {
                const parsed = JSON.parse(candidate.raw);
                if (parsed && typeof parsed === 'object') return { ...parsed, storageKey: candidate.key };
              } catch (_) {
              }
            }
            return null;
          } catch (_) {
            return null;
          }
        };

        const removeLocalReceipt = (receipt = {}) => {
          try {
            if (receipt.storageKey) window.localStorage.removeItem(receipt.storageKey);
            const phone = normalizePhone(receipt.phone_normalized || receipt.phone);
            if (phone) window.localStorage.removeItem(receiptKeyForPhone(phone));
            window.localStorage.removeItem(legacyReceiptStorageKey);
          } catch (_) {
          }
        };

        const showReceipt = (receipt = {}, message = '') => {
          const chosenNumber = normalizeRaffleNumber(receipt.chosen_number || receipt.selected_number);
          if (chosenNumber) setSelectedNumber(chosenNumber);
          if (receiptPhone) receiptPhone.textContent = receipt.phone || receipt.phone_masked || '--';
          if (receiptCode) receiptCode.textContent = receipt.receipt_code || '--';
          if (receiptDate) {
            const date = receipt.created ? new Date(receipt.created) : new Date();
            receiptDate.textContent = Number.isNaN(date.getTime())
              ? '--'
              : new Intl.DateTimeFormat('es', { dateStyle: 'medium', timeStyle: 'short' }).format(date);
          }
          currentWhatsappUrl = receipt.whatsapp_url || currentWhatsappUrl || '';
          if (receiptWhatsapp && currentWhatsappUrl) receiptWhatsapp.href = currentWhatsappUrl;
          if (sendReceiptButton) sendReceiptButton.disabled = !currentWhatsappUrl;
          if (publishedResultMode) updatePublishedResultPersonalization({ ...receipt, chosen_number: chosenNumber });
          else receiptCard?.classList.remove('is-preview');
          if (message && !chosenNumber) setError(message);
        };

        const hideReceipt = () => {
          if (publishedResultMode) resetPublishedResult();
          else receiptCard?.classList.add('is-preview');
          setSelectedNumber('');
          currentWhatsappUrl = '';
          if (sendReceiptButton) sendReceiptButton.disabled = true;
        };

        const lockParticipation = (receipt = {}, message = '') => {
          const chosenNumber = String(receipt.chosen_number || receipt.selected_number || '').trim();
          lockNumberGrid(chosenNumber);
          setFormLocked(true);
          setReservationMode(Boolean(chosenNumber));
          if (chosenNumber) showReceipt(receipt, '');
          else {
            hideReceipt();
            if (message) setError(message);
          }
        };

        const unlockParticipation = (message = '') => {
          setReservationMode(false);
          hideReceipt();
          unlockNumberGrid();
          setFormLocked(false);
          if (selectedInput) selectedInput.value = '';
          setError(message || '');
        };

        const validateStoredReceipt = async (receipt) => {
          const phone = normalizePhone(receipt?.phone_normalized || receipt?.phone);
          if (!phone) {
            removeLocalReceipt(receipt);
            unlockParticipation('');
            return;
          }
          try {
            const response = await fetch('/api/raffles/status', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ storeSlug, raffleSlug, phone, receipt_code: receipt.receipt_code || '' }),
            });
            const result = await response.json().catch(() => null);
            if (!response.ok || !result?.ok) throw new Error(result?.message || 'No se pudo validar tu participación.');

            if (result.status === 'active' && result.receipt) {
              saveLocalReceipt(result.receipt);
              lockParticipation(result.receipt, 'Ya tienes un número reservado.');
              return;
            }

            if (result.status === 'cancelled') {
              saveLocalReceipt({ phone, status: 'cancelled' });
              lockParticipation({}, result.message || 'Tu participación fue cancelada por la tienda. Contacta con la tienda si crees que fue un error.');
              return;
            }

            if (result.status === 'reentry_allowed') {
              removeLocalReceipt(receipt);
              unlockParticipation(result.message || 'Puedes participar nuevamente. Escoge un número disponible.');
              return;
            }

            removeLocalReceipt(receipt);
            unlockParticipation('');
          } catch (error) {
            lockParticipation(receipt, error?.message || 'No se pudo validar tu participación. Intenta nuevamente.');
          }
        };

        const storedReceipt = readLocalReceipt();
        if (storedReceipt?.chosen_number) {
          lockParticipation(storedReceipt, 'Ya tienes un número reservado.');
          validateStoredReceipt(storedReceipt);
        } else if (storedReceipt?.phone || storedReceipt?.phone_normalized) {
          lockParticipation({}, '');
          validateStoredReceipt(storedReceipt);
        }

        if (form) {
          form.addEventListener('submit', async (event) => {
            event.preventDefault();
            setError('');

            const formData = new FormData(form);
            const phone = normalizePhone(formData.get('phone'));
            const accessCode = String(formData.get('access_code') || '').trim();
            const chosenNumber = String(formData.get('chosen_number') || '');

            if (!chosenNumber) {
              setError('Escoge un número disponible antes de confirmar.');
              return;
            }

            if (!phone) {
              setError('Escribe un número cubano válido de 8 dígitos.');
              return;
            }

            if (!accessCode) {
              setError('Introduce el código exclusivo del grupo de WhatsApp.');
              return;
            }

            const submitButton = form.querySelector('.pz-confirm-btn');
            const originalSubmitHtml = submitButton ? submitButton.innerHTML : '';
            if (submitButton) {
              submitButton.disabled = true;
              submitButton.textContent = 'Reservando...';
            }

            try {
              const response = await fetch('/api/raffles/enter', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  storeSlug,
                  raffleSlug,
                  access_code: accessCode,
                  phone,
                  chosen_number: chosenNumber,
                }),
              });
              const result = await response.json().catch(() => null);
              if (!response.ok || !result?.ok) {
                const occupied = result?.occupiedNumber || '';
                if (occupied) markOccupied(occupied);
                if (result?.reservedNumber) {
                  const duplicateReceipt = result.receipt || {
                    chosen_number: result.reservedNumber,
                    phone,
                    created: new Date().toISOString(),
                  };
                  saveLocalReceipt(duplicateReceipt);
                  lockParticipation(duplicateReceipt, result?.message || 'Ya tienes una participación registrada en esta rifa.');
                } else if (result?.participationBlocked) {
                  saveLocalReceipt({ phone, status: 'cancelled' });
                  lockParticipation({}, result?.message || 'Tu participación fue cancelada por la tienda. Contacta con la tienda si crees que fue un error.');
                }
                throw new Error(result?.message || 'No se pudo reservar el número. Intenta nuevamente.');
              }

              const receipt = result.receipt || {};
              saveLocalReceipt(receipt);
              lockParticipation(receipt, '');
              form.reset();
              if (selectedInput) selectedInput.value = '';
            } catch (error) {
              setError(error?.message || 'No se pudo reservar el número. Intenta nuevamente.');
            } finally {
              if (submitButton) {
                submitButton.disabled = form.querySelector('.pz-confirm-btn')?.hidden === true;
                submitButton.innerHTML = originalSubmitHtml;
              }
            }
          });
        }

        sendReceiptButton?.addEventListener('click', () => {
          if (currentWhatsappUrl) window.open(currentWhatsappUrl, '_blank', 'noopener');
        });

        const copyButton = root.querySelector('[data-copy-raffle-link]');
        const receiptLink = root.querySelector('[data-receipt-link]');
        copyButton?.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(receiptLink?.href || fullRaffleUrl || window.location.href);
            copyButton.textContent = 'Copiado';
            window.setTimeout(() => { copyButton.textContent = 'Copiar'; }, 1200);
          } catch (_) {
            copyButton.textContent = 'Copiar';
          }
        });

        const carouselCard = root.querySelector('.pz-prizes-card.is-carousel');
        const track = carouselCard?.querySelector('[data-prize-track]');
        if (carouselCard && track) {
          const cards = Array.from(track.querySelectorAll('.pz-prize-card'));
          const prevButton = carouselCard.querySelector('.pz-carousel-prev');
          const nextButton = carouselCard.querySelector('.pz-carousel-next');
          const dotsContainer = carouselCard.querySelector('.pz-carousel-dots');
          const dots = Array.from(carouselCard.querySelectorAll('[data-prize-dot]'));
          const reducedMotionQuery = typeof window.matchMedia === 'function'
            ? window.matchMedia('(prefers-reduced-motion: reduce)')
            : null;
          const autoplayDelay = 4500;
          const resumeDelay = 6500;
          let positions = [];
          let activePositionIndex = 0;
          let autoplayTimer = 0;
          let resumeTimer = 0;
          let scrollFrame = 0;
          let resizeFrame = 0;

          const shouldReduceMotion = () => Boolean(reducedMotionQuery?.matches);

          const setControlVisibility = (enabled) => {
            [prevButton, nextButton].forEach((button) => {
              if (!button) return;
              button.hidden = !enabled;
              button.disabled = !enabled;
            });
            if (dotsContainer) dotsContainer.hidden = !enabled;
          };

          const updateDots = () => {
            const labelType = positions.length === cards.length ? 'premio' : 'grupo';
            dots.forEach((dot, index) => {
              const isAvailable = index < positions.length;
              dot.hidden = !isAvailable;
              dot.classList.toggle('is-active', isAvailable && index === activePositionIndex);
              if (!isAvailable) {
                dot.removeAttribute('aria-current');
                return;
              }
              dot.dataset.prizeDotIndex = String(index);
              dot.setAttribute('aria-label', `Ver ${labelType} ${index + 1}`);
              if (index === activePositionIndex) {
                dot.setAttribute('aria-current', 'true');
              } else {
                dot.removeAttribute('aria-current');
              }
            });
          };

          const getNearestPositionIndex = () => {
            if (!positions.length) return 0;
            const currentLeft = track.scrollLeft;
            return positions.reduce((nearestIndex, position, index) => {
              const currentDistance = Math.abs(position.left - currentLeft);
              const nearestDistance = Math.abs(positions[nearestIndex].left - currentLeft);
              return currentDistance < nearestDistance ? index : nearestIndex;
            }, 0);
          };

          const refreshPositions = () => {
            const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
            const trackRect = track.getBoundingClientRect();
            const nextPositions = [];

            cards.forEach((card) => {
              const cardRect = card.getBoundingClientRect();
              const rawLeft = cardRect.left - trackRect.left + track.scrollLeft;
              const left = Math.min(Math.max(0, Math.round(rawLeft)), Math.round(maxScroll));
              const isDuplicate = nextPositions.some((position) => Math.abs(position.left - left) < 2);
              if (!isDuplicate) nextPositions.push({ left });
            });

            positions = nextPositions.length ? nextPositions : [{ left: 0 }];
            activePositionIndex = getNearestPositionIndex();
            setControlVisibility(positions.length > 1);
            updateDots();
          };

          const goTo = (positionIndex, behavior = 'smooth') => {
            if (!positions.length) return;
            activePositionIndex = (positionIndex + positions.length) % positions.length;
            updateDots();
            track.scrollTo({
              left: positions[activePositionIndex]?.left || 0,
              behavior: shouldReduceMotion() ? 'auto' : behavior,
            });
          };

          const next = () => goTo(activePositionIndex + 1);
          const previous = () => goTo(activePositionIndex - 1);

          const clearResumeTimer = () => {
            if (!resumeTimer) return;
            window.clearTimeout(resumeTimer);
            resumeTimer = 0;
          };

          const stopAutoplay = () => {
            if (!autoplayTimer) return;
            window.clearInterval(autoplayTimer);
            autoplayTimer = 0;
          };

          const startAutoplay = () => {
            stopAutoplay();
            clearResumeTimer();
            if (positions.length <= 1 || shouldReduceMotion()) return;
            autoplayTimer = window.setInterval(next, autoplayDelay);
          };

          const scheduleAutoplayResume = (delay = resumeDelay) => {
            clearResumeTimer();
            if (positions.length <= 1 || shouldReduceMotion()) return;
            resumeTimer = window.setTimeout(startAutoplay, delay);
          };

          const pauseAutoplay = (delay = resumeDelay) => {
            stopAutoplay();
            scheduleAutoplayResume(delay);
          };

          const scheduleRefresh = () => {
            if (resizeFrame) window.cancelAnimationFrame(resizeFrame);
            resizeFrame = window.requestAnimationFrame(() => {
              const targetIndex = activePositionIndex;
              resizeFrame = 0;
              refreshPositions();
              goTo(Math.min(targetIndex, Math.max(0, positions.length - 1)), 'auto');
              startAutoplay();
            });
          };

          if (cards.length <= 1) {
            setControlVisibility(false);
          } else {
            refreshPositions();
            goTo(0, 'auto');
            startAutoplay();

            prevButton?.addEventListener('click', () => {
              pauseAutoplay();
              previous();
            });
            nextButton?.addEventListener('click', () => {
              pauseAutoplay();
              next();
            });
            dots.forEach((dot, index) => {
              dot.addEventListener('click', () => {
                pauseAutoplay();
                goTo(Number(dot.dataset.prizeDotIndex || index));
              });
            });

            track.addEventListener('scroll', () => {
              if (scrollFrame) return;
              scrollFrame = window.requestAnimationFrame(() => {
                scrollFrame = 0;
                activePositionIndex = getNearestPositionIndex();
                updateDots();
              });
            }, { passive: true });
            track.addEventListener('pointerdown', () => pauseAutoplay(), { passive: true });
            track.addEventListener('touchstart', () => pauseAutoplay(), { passive: true });
            track.addEventListener('wheel', () => pauseAutoplay(), { passive: true });

            carouselCard.addEventListener('pointerenter', () => {
              stopAutoplay();
              clearResumeTimer();
            });
            carouselCard.addEventListener('pointerleave', () => scheduleAutoplayResume(1200));
            carouselCard.addEventListener('focusin', () => {
              stopAutoplay();
              clearResumeTimer();
            });
            carouselCard.addEventListener('focusout', (event) => {
              const nextFocus = event.relatedTarget;
              if (!nextFocus || !carouselCard.contains(nextFocus)) scheduleAutoplayResume(1200);
            });

            if ('ResizeObserver' in window) {
              const resizeObserver = new ResizeObserver(scheduleRefresh);
              resizeObserver.observe(carouselCard);
              resizeObserver.observe(track);
            } else {
              window.addEventListener('resize', scheduleRefresh);
            }

            if (reducedMotionQuery?.addEventListener) {
              reducedMotionQuery.addEventListener('change', () => {
                if (shouldReduceMotion()) {
                  stopAutoplay();
                  clearResumeTimer();
                } else {
                  startAutoplay();
                }
              });
            } else if (reducedMotionQuery?.addListener) {
              reducedMotionQuery.addListener(() => {
                if (shouldReduceMotion()) {
                  stopAutoplay();
                  clearResumeTimer();
                } else {
                  startAutoplay();
                }
              });
            }
          }
        }
      })();
    </script>
  </body>
</html>
