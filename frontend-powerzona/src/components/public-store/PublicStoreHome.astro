    .public-gift-banner-link:hover .public-gift-banner img { transform: scale(1.035); }
    .public-gift-banner-fallback { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: radial-gradient(circle at top left, #334155, #111827); color: rgba(255,255,255,.35); font-size: 74px; font-weight: 1000; }
