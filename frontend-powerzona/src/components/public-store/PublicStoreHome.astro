  </style>

  <div class="public-store-head" aria-label="Acciones principales">
    <a class="public-store-brand" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>
      <div class="public-store-logo">{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : storeInitials(storeName)}</div>
    </a>
    <div class="public-header-actions">
      <a class="public-action-btn" href={searchPath} aria-label="Buscar productos y categorías">⌕</a>
      <button id="public-menu-open" class="public-action-btn public-menu-btn" type="button" aria-label="Abrir menú" aria-expanded="false">⋯</button>
    </div>
  </div>

  <div id="public-drawer-overlay" class="public-drawer-overlay" hidden></div>
  <aside id="public-drawer" class="public-drawer" aria-hidden="true">
    <div class="drawer-head">
      <a class="drawer-logo" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : storeInitials(storeName)}</a>
      <button id="public-menu-close" class="drawer-close" type="button" aria-label="Cerrar menú">×</button>
    </div>
    <nav class="drawer-nav">
      <a class="drawer-link" href={giftsPath}>Regalos <span>›</span></a>
      <a class="drawer-link" href={categoryAnchorPath}>Categorías <span>›</span></a>
      <a class="drawer-link" href={productAnchorPath}>Productos destacados <span>›</span></a>
      <div class="drawer-currency-card" data-pz-currency-menu hidden>
        <div class="drawer-currency-head">Moneda <span>⌄</span></div>
        <select class="drawer-currency-select" data-pz-currency-select aria-label="Moneda visual en menú"></select>
      </div>
      {hasBusinessHoursInfo && <button id="hours-info-open" class="drawer-link" type="button" aria-haspopup="dialog" aria-controls="hours-info-modal">Horarios <span>›</span></button>}
      <a class="drawer-link" href={whatsappStoreHref} target="_blank" rel="noreferrer">WhatsApp <span>↗</span></a>
    </nav>
    <div class="drawer-admin-action">
      <a class="drawer-link drawer-admin-link" href={adminLoginPath}>Ir al panel de administración</a>
    </div>
  </aside>

  <section class="public-hero">
    <div class="public-hero-cover" data-hero-carousel={heroCarouselImages.length >= 2 ? 'true' : 'false'}>
      {heroImages.map((imageUrl, index) => (
        <div class={`public-hero-slide ${index === 0 ? 'active' : ''}`}>
          <img src={imageUrl} alt={`Portada de ${storeName}`} loading={index === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
    <div class="public-hero-content">
      <h1 class="public-hero-title">{storeName}</h1>
    </div>
  </section>

  <div class="public-hero-actions" aria-label="Acciones después de la portada">
    {publicLocationText && (
      <div class="public-location-line" aria-label={`Ubicaci\u00f3n: ${publicLocationText}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 5.5-8 11-8 11s-8-5.5-8-11a8 8 0 1 1 16 0Z"></path>
          <circle cx="12" cy="10" r="2.5"></circle>
        </svg>
        <span>{publicLocationText}</span>
      </div>
    )}
    {showStoreRating && storeReviewSummary.count > 0 && (
      <a class="public-rating-link" href={reviewsAnchorPath} aria-label={`${storeReviewSummary.average.toFixed(1)} de 5 con ${reviewCountLabel(storeReviewSummary.count)}`}>
        <span>{storeReviewSummary.average.toFixed(1)}</span>
        <span class="public-rating-stars" aria-hidden="true">{reviewStars(storeReviewSummary.roundedAverage)}</span>
        <span>({reviewCountLabel(storeReviewSummary.count)})</span>
      </a>
    )}
    {showStoreRating && storeReviewSummary.count === 0 && storeReviewsEnabled && (
      <a class="public-rating-link" href={reviewsAnchorPath}>Sé el primero en dejar una reseña</a>
    )}
    {welcomeText && <p class="public-welcome-text">{welcomeText}</p>}
    {storeDescription && <p class="public-store-description">{storeDescription}</p>}
    {businessHoursStatus.mode === 'custom' && businessHoursStatus.isAvailable && <div class="business-status"><strong>Disponible ahora</strong></div>}
    {businessHoursStatus.isClosed && (
      <div class="business-status closed">
        <strong>{businessHoursStatus.title}</strong>
        <p>{businessHoursStatus.message}</p>
      </div>
