  {giftsPublicActive && gifts.length > 0 && (
    <section id="regalos" class="mb-8 scroll-mt-24" aria-label={giftsPublicTitle}>
      <a href={giftsPath} class="public-gift-banner-link" aria-label={`Abrir ${giftsPublicTitle}`}>
        <div class="public-gift-copy">
          <span class="public-gift-kicker">Especial para tu compra</span>
          <div class="public-gift-copy-top">
            <div class="public-gift-copy-main">
              <h2 class="public-gift-title">{giftsPublicTitle}</h2>
              <p class="public-gift-text">Descubre los regalos disponibles y elige uno cuando tu pedido califique.</p>
            </div>
            <span class="public-gift-cta">Ver regalos <span aria-hidden="true">›</span></span>
          </div>
          <div class="public-gift-meta">
            <span class="public-gift-pill">{gifts.length} regalos</span>
            <span class="public-gift-pill">1 por orden</span>
