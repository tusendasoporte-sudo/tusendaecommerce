      {reviewsText && <p class="store-info-description">{reviewsText}</p>}
      <div class="store-info-actions">
        <a class="hero-btn" href={whatsappStoreHref} target="_blank" rel="noreferrer">Contactar por WhatsApp</a>
        <button id="store-info-close" class="hero-btn secondary" type="button">Cerrar</button>
      </div>
    </section>
  </div>

  {hasBusinessHoursInfo && (
    <div id="hours-info-overlay" class="hours-info-overlay" hidden>
      <section id="hours-info-modal" class="store-info-card" role="dialog" aria-modal="true" aria-labelledby="hours-info-title">
