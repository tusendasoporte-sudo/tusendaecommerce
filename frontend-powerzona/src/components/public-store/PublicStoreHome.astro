        </div>
        <div class="public-gift-banner">
          {giftsPublicImageUrl ? <img src={giftsPublicImageUrl} alt={giftsPublicTitle} loading="lazy" /> : <div class="public-gift-banner-fallback">🎁</div>}
        </div>
      </a>
    </section>
  )}

  {normalCategories.length > 0 && (
    <section id="categorias" class="mb-8 scroll-mt-24">
      <div class="section-head">
        <div>
          <h2 class="section-title">Categorías</h2>
        </div>
      </div>
      <div class={`public-category-grid columns-${publicCategoryColumns}`}>
        {normalCategories.map((category) => {
          const categoryProducts = productsByCategoryTotal(category.id);
          return (
            <a href={getPublicPath(`/categoria/${category.slug}`, currentStore, currentPathname)} class="public-category-link" aria-label={`Abrir categoría ${category.name}`}>
              <h3 class="public-category-title-outside">{category.name}</h3>
              <div class="public-category-card">
                {category.imageUrl ? <img src={category.imageUrl} alt={category.name} /> : <div class="public-category-fallback">PZ</div>}
                <span class="public-category-go">›</span>
              </div>
              <div class="public-category-meta">
                <span class="public-category-pill">{productCountLabel(categoryProducts.length)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {homepageProducts.length > 0 && (
    <section class="mb-8">
      <div class="section-head">
        <div>
          <h2 class="section-title">Productos</h2>
          <p class="section-subtitle">Productos publicados directamente en portada.</p>
        </div>
      </div>
      <div class="homepage-products-grid">
        {homepageProducts.map((product) => (
          <a href={getPublicPath(`/producto/${product.slug}`, currentStore, currentPathname)} class="block">
            <ProductCard view="compact" title={product.name} price={String(getProductOfferView(product).price)} regularPrice={String(getProductOfferView(product).regularPrice)} isOffer={getProductOfferView(product).isOffer} image={product.imageUrls?.[0] ?? 'https://placehold.co/500x500?text=PowerZona'} stock={product.stock} allowPreorder={product.allow_preorder} trackStock={product.track_stock !== false} hasVariations={Boolean(product.has_variations)} onlyUsd={Boolean(product.only_usd)} promoText={getProductAutomaticPromotionText(product, automaticPromotions)} showRating={showProductRating} ratingAverage={productReviewSummaries[product.id]?.average || 0} ratingCount={productReviewSummaries[product.id]?.count || 0} />
          </a>
        ))}
      </div>
    </section>
  )}

  {reviewsEnabled && (storeReviews.length > 0 || storeReviewsEnabled) && (
    <section id="resenas" class="public-reviews-section">
      <div class="section-head">
        <div>
          <h2 class="section-title">Reseñas de clientes</h2>
          <p class="section-subtitle">Opiniones aprobadas de personas que compraron o visitaron la tienda.</p>
        </div>
      </div>

      {storeReviews.length > 0 && (
        <div class="public-reviews-grid">
          {storeReviews.map((review) => (
            <article class="public-review-card">
              <div class="public-review-top">
                <span class="public-review-stars" aria-label={`${Number(review.rating || 0)} de 5`}>{reviewStars(Number(review.rating || 0))}</span>
                {showVerifiedBadge && review.verified_purchase === true && <span class="verified-badge">Compra verificada</span>}
              </div>
              {review.comment && <p class="public-review-comment">{review.comment}</p>}
              <p class="public-review-name">{review.customer_name || 'Cliente'}</p>
            </article>
          ))}
        </div>
      )}

      {storeReviewsEnabled && (
        <form id="public-store-review-form" class="public-review-form">
          <h3 class="public-review-form-title">Dejar reseña</h3>
          <label class="public-review-field">
            <span>Nombre</span>
            <input id="public-review-name" name="customer_name" type="text" maxlength="120" required />
          </label>
          <div class="public-review-field">
            <span>Rating</span>
            <div class="public-review-rating" data-public-rating>
              <input id="public-review-rating" type="hidden" value="0" />
              <button type="button" data-value="1" aria-label="1 estrella">★</button>
              <button type="button" data-value="2" aria-label="2 estrellas">★</button>
              <button type="button" data-value="3" aria-label="3 estrellas">★</button>
              <button type="button" data-value="4" aria-label="4 estrellas">★</button>
              <button type="button" data-value="5" aria-label="5 estrellas">★</button>
            </div>
          </div>
          <label class="public-review-field">
            <span>Comentario</span>
            <textarea id="public-review-comment" name="comment" rows="4" maxlength="1200" required></textarea>
          </label>
          <label class="public-review-honeypot" aria-hidden="true">
            Sitio web
            <input id="public-review-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </label>
          <div id="public-review-alert" class="public-review-alert hidden"></div>
          <button id="public-review-submit" class="public-review-submit" type="submit">Enviar reseña</button>
        </form>
      )}
    </section>
  )}

  <PublicFooter settings={settings} />

  <script define:vars={{ pocketbaseUrl, currentStoreId }}>
    (() => {
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const form = document.getElementById('public-store-review-form');
      if (!form) return;

      const ratingInput = document.getElementById('public-review-rating');
      const ratingGroup = form.querySelector('[data-public-rating]');
      const alertBox = document.getElementById('public-review-alert');
      const submitBtn = document.getElementById('public-review-submit');

      function setPublicReviewAlert(message, type = 'error') {
        if (!alertBox) return;
        alertBox.textContent = message || '';
        alertBox.className = message ? `public-review-alert ${type}` : 'public-review-alert hidden';
      }

      function setRating(value) {
        const rating = Math.max(0, Math.min(5, Number(value || 0)));
        if (ratingInput) ratingInput.value = String(rating);
        ratingGroup?.querySelectorAll('button').forEach((button) => {
          button.classList.toggle('active', Number(button.dataset.value || 0) <= rating);
        });
      }

      ratingGroup?.querySelectorAll('button').forEach((button) => {
        button.addEventListener('click', () => setRating(button.dataset.value));
      });

      async function createStoreReview(payload) {
        const response = await fetch(`${POCKETBASE_URL}/api/collections/reviews/records`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(result?.message || 'No se pudo enviar la reseña.');
        return result;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        setPublicReviewAlert('');

        if (!POCKETBASE_URL || !CURRENT_STORE_ID) {
          setPublicReviewAlert('No se pudo conectar con la tienda. Inténtalo más tarde.');
          return;
        }

        const honeypot = String(document.getElementById('public-review-website')?.value || '').trim();
        if (honeypot) {
          form.reset();
          setRating(0);
          setPublicReviewAlert('Gracias por dejar tu reseña. Será publicada cuando la tienda la apruebe.', 'success');
          return;
        }

        const customerName = String(document.getElementById('public-review-name')?.value || '').trim();
        const rating = Number(ratingInput?.value || 0);
        const comment = String(document.getElementById('public-review-comment')?.value || '').trim().slice(0, 1200);

        if (!customerName) {
          setPublicReviewAlert('Escribe tu nombre para enviar la reseña.');
          return;
        }
        if (!Number.isInteger(rating) || rating < 1 || rating > 5) {
          setPublicReviewAlert('Elige un rating entre 1 y 5 estrellas.');
          return;
        }
        if (!comment) {
          setPublicReviewAlert('Escribe un comentario para enviar la reseña.');
          return;
        }

        const payload = {
          store: CURRENT_STORE_ID,
          type: 'store',
          source: 'public_store',
          verified_purchase: false,
          status: 'pending',
          featured: false,
          rating,
          customer_name: customerName,
          comment,
        };

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Enviando...';
        }

        try {
          await createStoreReview(payload);
          form.reset();
          setRating(0);
          setPublicReviewAlert('Gracias por dejar tu reseña. Será publicada cuando la tienda la apruebe.', 'success');
        } catch (error) {
          console.error(error);
          setPublicReviewAlert(error?.message || 'No se pudo enviar la reseña.');
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Enviar reseña';
          }
        }
      });
    })();
  </script>

  <script>
    const heroCarousel = document.querySelector('[data-hero-carousel="true"]');
    const heroSlides = heroCarousel ? Array.from(heroCarousel.querySelectorAll('.public-hero-slide')) : [];
    if (heroSlides.length > 1) {
      let heroSlideIndex = 0;
      window.setInterval(() => {
        heroSlides[heroSlideIndex]?.classList.remove('active');
        heroSlideIndex = (heroSlideIndex + 1) % heroSlides.length;
        heroSlides[heroSlideIndex]?.classList.add('active');
      }, 6000);
    }

    const storeInfoOpenBtn = document.getElementById('store-info-open');
    const storeInfoOverlay = document.getElementById('store-info-overlay');
    const storeInfoCloseBtn = document.getElementById('store-info-close');
    const storeInfoCloseXBtn = document.getElementById('store-info-close-x');
    function openStoreInfo() {
      if (!storeInfoOverlay) return;
      storeInfoOverlay.hidden = false;
      requestAnimationFrame(() => document.body.classList.add('store-info-open'));
    }
    function closeStoreInfo() {
      if (!document.body.classList.contains('store-info-open')) return;
      document.body.classList.remove('store-info-open');
      setTimeout(() => {
        if (!document.body.classList.contains('store-info-open') && storeInfoOverlay) storeInfoOverlay.hidden = true;
      }, 200);
    }
    storeInfoOpenBtn?.addEventListener('click', openStoreInfo);
    storeInfoCloseBtn?.addEventListener('click', closeStoreInfo);
    storeInfoCloseXBtn?.addEventListener('click', closeStoreInfo);
    storeInfoOverlay?.addEventListener('click', (event) => {
      if (event.target === storeInfoOverlay) closeStoreInfo();
    });

    const hoursInfoOpenBtn = document.getElementById('hours-info-open');
    const hoursInfoOverlay = document.getElementById('hours-info-overlay');
    const hoursInfoCloseBtn = document.getElementById('hours-info-close');
    const hoursInfoCloseXBtn = document.getElementById('hours-info-close-x');
    function openHoursInfo() {
      if (!hoursInfoOverlay) return;
      closePublicMenu();
      hoursInfoOverlay.hidden = false;
      requestAnimationFrame(() => document.body.classList.add('hours-info-open'));
    }
    function closeHoursInfo() {
      if (!document.body.classList.contains('hours-info-open')) return;
      document.body.classList.remove('hours-info-open');
      setTimeout(() => {
        if (!document.body.classList.contains('hours-info-open') && hoursInfoOverlay) hoursInfoOverlay.hidden = true;
      }, 200);
    }
    hoursInfoOpenBtn?.addEventListener('click', openHoursInfo);
    hoursInfoCloseBtn?.addEventListener('click', closeHoursInfo);
    hoursInfoCloseXBtn?.addEventListener('click', closeHoursInfo);
    hoursInfoOverlay?.addEventListener('click', (event) => {
      if (event.target === hoursInfoOverlay) closeHoursInfo();
    });

    const openPublicMenuBtn = document.getElementById('public-menu-open');
    const closePublicMenuBtn = document.getElementById('public-menu-close');
    const publicDrawer = document.getElementById('public-drawer');
    const publicOverlay = document.getElementById('public-drawer-overlay');
    function openPublicMenu() {
      document.body.classList.add('public-menu-open');
      publicDrawer?.setAttribute('aria-hidden', 'false');
      openPublicMenuBtn?.setAttribute('aria-expanded', 'true');
      if (publicOverlay) publicOverlay.hidden = false;
    }
    function closePublicMenu() {
      document.body.classList.remove('public-menu-open');
      publicDrawer?.setAttribute('aria-hidden', 'true');
      openPublicMenuBtn?.setAttribute('aria-expanded', 'false');
      setTimeout(() => { if (!document.body.classList.contains('public-menu-open') && publicOverlay) publicOverlay.hidden = true; }, 220);
    }
    openPublicMenuBtn?.addEventListener('click', openPublicMenu);
    closePublicMenuBtn?.addEventListener('click', closePublicMenu);
    publicOverlay?.addEventListener('click', closePublicMenu);
    publicDrawer?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closePublicMenu));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') { closePublicMenu(); closeStoreInfo(); closeHoursInfo(); } });

    const quickCategoriesOpenBtn = document.getElementById('quick-categories-open');
    const quickCategoriesCloseBtn = document.getElementById('quick-categories-close');
    const quickCategoriesOverlay = document.getElementById('quick-categories-overlay');
    const quickCategoriesModal = document.getElementById('quick-categories-modal');
    const quickCategoriesList = quickCategoriesModal?.querySelector('.quick-categories-modal-grid');
    let quickCategoriesScrollY = 0;
    function openQuickCategories() {
      if (!quickCategoriesOverlay) return;
      quickCategoriesScrollY = window.scrollY || window.pageYOffset || 0;
      quickCategoriesOverlay.hidden = false;
      document.body.style.top = `-${quickCategoriesScrollY}px`;
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      requestAnimationFrame(() => document.body.classList.add('quick-categories-open'));
    }
    function closeQuickCategories() {
      if (!document.body.classList.contains('quick-categories-open')) return;
      const scrollY = quickCategoriesScrollY;
      document.body.classList.remove('quick-categories-open');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, scrollY);
      setTimeout(() => {
        if (!document.body.classList.contains('quick-categories-open') && quickCategoriesOverlay) quickCategoriesOverlay.hidden = true;
      }, 200);
    }
    quickCategoriesOpenBtn?.addEventListener('click', openQuickCategories);
    quickCategoriesCloseBtn?.addEventListener('click', closeQuickCategories);
    quickCategoriesOverlay?.addEventListener('click', (event) => {
      if (event.target === quickCategoriesOverlay) closeQuickCategories();
    });
    quickCategoriesOverlay?.addEventListener('touchmove', (event) => {
      if (!quickCategoriesList?.contains(event.target)) event.preventDefault();
    }, { passive: false });
    quickCategoriesModal?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeQuickCategories));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeQuickCategories(); });

    function getStoreCartFallbackKey() {
      return window.PZ_CART_STORAGE_KEY || `tusenda84_cart_${window.PZ_CURRENT_STORE_ID || 'powerzona'}`;
    }
    function getStoreCheckoutCartFallbackKey() {
      return window.PZ_CHECKOUT_CART_STORAGE_KEY || `${getStoreCartFallbackKey()}_checkout`;
    }
    function getGiftCart() {
      if (window.PZCartStorage?.readCart) return window.PZCartStorage.readCart();
      try { return JSON.parse(localStorage.getItem(getStoreCartFallbackKey()) || '[]'); } catch (_) { return []; }
    }
    function saveGiftCart(cart) {
      const currentStoreId = String(window.PZ_CURRENT_STORE_ID || '');
      const nextCart = Array.isArray(cart)
        ? cart.map((item) => ({ ...item, store_id: item?.store_id || currentStoreId }))
        : [];
      if (window.PZCartStorage?.writeCart) {
        window.PZCartStorage.writeCart(nextCart);
      } else {
        const payload = JSON.stringify(nextCart);
        localStorage.setItem(getStoreCartFallbackKey(), payload);
        if (nextCart.length) sessionStorage.setItem(getStoreCheckoutCartFallbackKey(), payload);
        else sessionStorage.removeItem(getStoreCheckoutCartFallbackKey());
      }
      window.dispatchEvent(new Event('cart-updated'));
    }
    function getGiftCartSubtotal(cart = getGiftCart()) {
      return cart.filter((item) => !item.is_gift).reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 1), 0);
    }
    function showGiftInfo(message) {
      const alert = document.getElementById('gift-info-alert');
      if (!alert) return;
      alert.textContent = message;
      alert.style.display = message ? 'block' : 'none';
      if (message) alert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function syncGiftButtons() {
      const subtotal = getGiftCartSubtotal();
      document.querySelectorAll('[data-gift-card]').forEach((card) => {
        const min = Number(card.dataset.giftMin || 0);
        const stock = Number(card.dataset.giftStock || 0);
        const btn = card.querySelector('[data-gift-button]');
        if (!btn) return;
        const canAdd = subtotal >= min && stock > 0;
        btn.disabled = !canAdd;
        btn.textContent = stock <= 0 ? 'Agotado' : canAdd ? 'Agregar regalo' : `Disponible desde $${min.toFixed(2)} USD`;
      });
    }
    function addGiftFromCard(card) {
      const cart = getGiftCart();
      const min = Number(card.dataset.giftMin || 0);
      const subtotal = getGiftCartSubtotal(cart);
      if (subtotal < min) {
        showGiftInfo(`Este regalo estará disponible cuando tu carrito llegue a $${min.toFixed(2)} USD.`);
        return;
      }
      const existingGift = cart.find((item) => item.is_gift);
      if (existingGift && existingGift.gift_id !== card.dataset.giftId) {
        const replace = window.confirm('Ya tienes un regalo seleccionado. ¿Quieres reemplazarlo por este?');
        if (!replace) return;
      }
      const withoutGifts = cart.filter((item) => !item.is_gift);
      withoutGifts.push({
        id: `gift-${card.dataset.giftId}`,
        gift_id: card.dataset.giftId,
        title: card.dataset.giftName || 'Regalo',
        image: card.dataset.giftImage || 'https://placehold.co/500x500?text=Regalo',
        price: 0,
        quantity: 1,
        stock: Number(card.dataset.giftStock || 0),
        min_order_usd: min,
        is_gift: true,
        track_stock: true,
      });
      saveGiftCart(withoutGifts);
      showGiftInfo('Regalo agregado al carrito. Solo puedes llevar 1 regalo por orden.');
    }
    document.querySelectorAll('[data-gift-button]').forEach((button) => {
      button.addEventListener('click', () => {
        const card = button.closest('[data-gift-card]');
        if (card) addGiftFromCard(card);
      });
    });
    window.addEventListener('cart-updated', syncGiftButtons);
    syncGiftButtons();

  </script>
</Layout>
