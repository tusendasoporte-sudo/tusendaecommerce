      .public-presentation-actions { grid-template-columns: 1fr; }
    }

    /* Categorias tipo regalos: texto e imagen viven en zonas separadas. */
    .public-category-grid {
      align-items: stretch;
      gap: 18px;
    }
    .public-category-grid.columns-1 {
      grid-template-columns: 1fr;
    }
    .public-category-grid.columns-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .public-category-link {
      min-height: clamp(270px, 27vw, 360px);
      display: grid !important;
      grid-template-columns: minmax(0, .88fr) minmax(180px, 1.12fr);
      align-items: stretch;
      gap: 0;
      overflow: hidden;
      padding: 0;
      border-radius: 18px;
      border: 1px solid #d7e4f5;
      background: #fff;
      box-shadow: 0 20px 52px rgba(37,99,235,.10);
    }
    .public-category-grid.columns-1 .public-category-link {
      min-height: clamp(300px, 28vw, 380px);
      grid-template-columns: minmax(260px, .78fr) minmax(0, 1.22fr);
    }
    .public-category-copy {
      min-width: 0;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 11px;
      padding: clamp(22px, 3vw, 40px);
      background: linear-gradient(135deg, #fff 0%, #f8fbff 100%);
    }
    .public-category-title-outside {
      max-width: none;
      margin: 0;
      padding: 0;
      color: #08133f;
      font-size: clamp(23px, 2.7vw, 36px);
      line-height: 1.08;
      letter-spacing: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .public-category-meta {
      margin: 0;
      padding: 0;
    }
    .public-category-pill {
      border-radius: 999px;
      border: 1px solid #dbe7f6;
      background: rgba(255,255,255,.82);
      color: #33446f;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 950;
    }
    .public-category-description {
      max-width: 360px;
      margin: 0;
      padding: 0;
      color: #33446f;
      font-size: 14px;
      line-height: 1.5;
      font-weight: 800;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .public-category-button {
      width: max-content;
      margin: auto 0 0;
      border-radius: 8px;
      border: 1px solid #0b63f6;
      background: #0b63f6;
      color: #fff;
      padding: 12px 15px;
      font-size: 13px;
      font-weight: 1000;
      box-shadow: 0 14px 30px rgba(11,99,246,.18);
    }
    .public-category-card {
      position: relative;
      inset: auto;
      width: 100%;
      height: 100%;
      min-height: 100%;
      aspect-ratio: auto;
      overflow: hidden;
      border-radius: 0;
      border: 0;
      background: #eff6ff;
      box-shadow: none;
      z-index: 0;
    }
    .public-category-card::after {
      content: none !important;
      display: none !important;
    }
    .public-category-card img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      opacity: 1 !important;
      filter: none !important;
      transform: none;
    }
    .public-category-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 50% 35%, #fff, #eaf4ff 58%, #dbeafe);
      color: #0b63f6;
      font-size: 64px;
      font-weight: 1000;
    }
    .public-category-go {
      display: none;
    }
    @media (max-width: 980px) {
      .public-category-grid.columns-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .public-category-link,
      .public-category-grid.columns-1 .public-category-link {
        min-height: auto;
        grid-template-columns: 1fr;
        align-content: start;
        gap: 0;
        padding: 0;
      }
      .public-category-copy {
        order: 2;
        padding: 16px;
      }
      .public-category-card {
        order: 1;
        min-height: 180px;
        aspect-ratio: 16 / 10;
      }
      .public-category-title-outside {
        font-size: 21px;
      }
      .public-category-description {
        max-width: none;
        -webkit-line-clamp: 2;
      }
    }
    @media (max-width: 560px) {
      .public-category-grid.columns-2 {
        gap: 10px;
      }
      .public-category-grid.columns-2 .public-category-link {
        border-radius: 14px;
      }
      .public-category-grid.columns-2 .public-category-copy {
        padding: 10px;
        gap: 6px;
      }
      .public-category-grid.columns-2 .public-category-card {
        min-height: 0;
        aspect-ratio: 1.12 / 1;
      }
      .public-category-grid.columns-2 .public-category-title-outside {
        font-size: 15px;
        line-height: 1.15;
      }
      .public-category-grid.columns-2 .public-category-description {
        display: none;
      }
      .public-category-grid.columns-2 .public-category-pill {
        padding: 0;
        border: 0;
        background: transparent;
        font-size: 11px;
      }
      .public-category-grid.columns-2 .public-category-button {
        width: 100%;
        margin-top: 2px;
        padding: 9px 8px;
        text-align: center;
        font-size: 11px;
      }
      .public-category-grid.columns-1 .public-category-card {
        min-height: 190px;
      }
    }

    /* Mini categorias: conservan miniatura, con lenguaje visual premium. */
    .quick-categories-strip {
      grid-auto-columns: minmax(210px, 250px);
      gap: 14px;
      padding: 2px 2px 12px;
    }
    .quick-category-card {
      grid-template-columns: 68px minmax(0, 1fr);
      align-items: center;
      gap: 13px;
      min-height: 94px;
      padding: 12px;
      border-radius: 18px;
      border: 1px solid #d7e4f5;
      background: #fff;
      box-shadow: 0 16px 36px rgba(37,99,235,.08);
    }
    .quick-category-thumb {
      width: 68px;
      aspect-ratio: 1;
      border-radius: 14px;
      overflow: hidden;
      background: #eff6ff;
      box-shadow: inset 0 0 0 1px #dbe7f6;
    }
    .quick-category-thumb img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 1 !important;
      filter: none !important;
    }
    .quick-category-name,
    .quick-category-count {
      text-align: left;
    }
    .quick-category-name {
      color: #08133f;
      font-size: 14px;
      line-height: 1.18;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .quick-category-count {
      color: #52648f;
      font-size: 12px;
    }
    @media (max-width: 560px) {
      .quick-categories-strip {
        grid-auto-columns: minmax(170px, 70vw);
        gap: 10px;
      }
      .quick-category-card {
        grid-template-columns: 56px minmax(0, 1fr);
        min-height: 78px;
        padding: 10px;
        border-radius: 14px;
      }
      .quick-category-thumb {
        width: 56px;
        border-radius: 12px;
      }
      .quick-category-name { font-size: 13px; }
      .quick-category-count { font-size: 11px; }
    }

    /* V3: categorias grandes con clases nuevas, sin heredar las reglas public-category antiguas. */
    .category-showcase-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }
    .category-showcase-grid.columns-1 {
      grid-template-columns: 1fr;
    }
    .category-showcase-grid.columns-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .category-showcase-card {
      min-height: 292px;
      display: grid;
      grid-template-columns: minmax(240px, 42%) minmax(0, 58%);
      align-items: stretch;
      overflow: hidden;
      border-radius: 18px;
      border: 1px solid #dbe7f6;
      background: linear-gradient(100deg, #eaf4ff, #fff);
      color: #08133f;
      text-decoration: none;
      box-shadow: 0 20px 52px rgba(37,99,235,.10);
    }
    .category-showcase-grid.columns-1 .category-showcase-card {
      min-height: 340px;
      grid-template-columns: minmax(280px, 38%) minmax(0, 62%);
    }
    .category-showcase-copy {
      min-width: 0;
      height: 100%;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 14px;
      padding: clamp(28px, 5vw, 48px);
      background: transparent;
      border: 0;
      box-shadow: none;
      backdrop-filter: none;
    }
    .category-showcase-grid.columns-2 .category-showcase-copy {
      padding: clamp(22px, 3vw, 34px);
    }
    .category-showcase-title {
      margin: 0;
      color: #08133f;
      font-size: clamp(24px, 2.7vw, 38px);
      line-height: 1.08;
      font-weight: 1000;
      letter-spacing: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .category-showcase-count {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
    }
    .category-showcase-count span {
      display: inline-flex;
      width: max-content;
      max-width: 100%;
      border-radius: 999px;
      border: 1px solid #dbe7f6;
      background: rgba(255,255,255,.88);
      color: #33446f;
      padding: 7px 10px;
      font-size: 12px;
      line-height: 1;
      font-weight: 950;
      box-shadow: 0 8px 20px rgba(37,99,235,.06);
    }
    .category-showcase-description {
      max-width: 390px;
      margin: 0;
      color: #33446f;
      font-size: 14px;
      line-height: 1.55;
      font-weight: 780;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .category-showcase-button {
      width: max-content;
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: #0b63f6;
      color: #fff;
      padding: 12px 16px;
      font-size: 13px;
      line-height: 1;
      font-weight: 1000;
      box-shadow: 0 14px 30px rgba(11,99,246,.20);
    }
    .category-showcase-media {
      position: relative;
      width: 100%;
      height: auto;
      min-height: 0;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: #f6f9ff;
      border-radius: 0;
      box-shadow: none;
    }
    .category-showcase-grid.columns-1 .category-showcase-media {
      min-height: 0;
    }
    .category-showcase-media::after {
      content: none !important;
      display: none !important;
    }
    .category-showcase-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      opacity: 1 !important;
      filter: none !important;
      transition: transform .35s ease;
      display: block;
    }
    .category-showcase-card:hover .category-showcase-image {
      transform: scale(1.04);
    }
    .category-showcase-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 50% 34%, #fff 0%, #eaf4ff 52%, #dbeafe 100%);
      color: #0b63f6;
      font-size: 68px;
      font-weight: 1000;
    }
    @media (max-width: 980px) {
      .category-showcase-grid.columns-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .category-showcase-card,
      .category-showcase-grid.columns-1 .category-showcase-card {
        min-height: auto;
        grid-template-columns: 1fr;
      }
      .category-showcase-copy {
        order: 1;
        min-height: auto;
        padding: 18px;
      }
      .category-showcase-media,
      .category-showcase-grid.columns-1 .category-showcase-media {
        order: 2;
        min-height: 0;
        aspect-ratio: 16 / 9;
      }
      .category-showcase-title {
        font-size: 22px;
      }
    }
    @media (max-width: 560px) {
      .category-showcase-grid.columns-2 {
        gap: 10px;
      }
      .category-showcase-grid.columns-2 .category-showcase-card {
        border-radius: 14px;
      }
      .category-showcase-grid.columns-2 .category-showcase-media {
        order: 1;
        min-height: 0;
        aspect-ratio: 16 / 9;
      }
      .category-showcase-grid.columns-2 .category-showcase-copy {
        order: 2;
        padding: 10px;
        gap: 7px;
      }
      .category-showcase-grid.columns-2 .category-showcase-title {
        font-size: 15px;
        line-height: 1.15;
      }
      .category-showcase-grid.columns-2 .category-showcase-count span {
        border: 0;
        background: transparent;
        padding: 0;
        color: #52648f;
        font-size: 11px;
      }
      .category-showcase-grid.columns-2 .category-showcase-description {
        display: none;
      }
      .category-showcase-grid.columns-2 .category-showcase-button {
        width: 100%;
        padding: 9px 8px;
        text-align: center;
        font-size: 11px;
      }
      .category-showcase-grid.columns-1 .category-showcase-media {
        min-height: 0;
        aspect-ratio: 16 / 9;
      }
    }

    /* V3: mini categorias visibles con clases nuevas. */
    .quick-categories-strip {
      grid-auto-columns: minmax(210px, 252px);
      gap: 14px;
      padding: 2px 2px 12px;
    }
    .quick-category-premium-card {
      scroll-snap-align: start;
      min-width: 0;
      min-height: 94px;
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr);
      align-items: center;
      gap: 13px;
      padding: 12px;
      border-radius: 18px;
      border: 1px solid rgba(194,211,233,.72);
      background:
        radial-gradient(circle at 0% 0%, rgba(255,255,255,.74), rgba(255,255,255,0) 44%),
        linear-gradient(135deg, rgba(255,255,255,.66), rgba(244,249,255,.54));
      color: #08133f;
      text-decoration: none;
      box-shadow: 0 16px 36px rgba(37,99,235,.075), inset 0 1px 0 rgba(255,255,255,.70);
      backdrop-filter: blur(8px);
    }
    .quick-category-premium-thumb {
      width: 68px;
      aspect-ratio: 1;
      overflow: hidden;
      border-radius: 14px;
      background: #eff6ff;
      box-shadow: inset 0 0 0 1px #dbe7f6, 0 10px 20px rgba(37,99,235,.08);
      display: grid;
      place-items: center;
    }
    .quick-category-premium-thumb img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 1 !important;
      filter: none !important;
      display: block;
    }
    .quick-category-premium-copy {
      min-width: 0;
      display: grid;
      gap: 5px;
    }
    .quick-category-premium-name {
      margin: 0;
      color: #08133f;
      font-size: 14px;
      line-height: 1.18;
      font-weight: 1000;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .quick-category-premium-count {
      margin: 0;
      color: #52648f;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 900;
    }
    @media (max-width: 560px) {
      .quick-categories-strip {
        grid-auto-columns: minmax(170px, 70vw);
        gap: 10px;
      }
      .quick-category-premium-card {
        min-height: 78px;
        grid-template-columns: 56px minmax(0, 1fr);
        padding: 10px;
        border-radius: 14px;
      }
      .quick-category-premium-thumb {
        width: 56px;
        border-radius: 12px;
      }
      .quick-category-premium-name {
        font-size: 13px;
      }
      .quick-category-premium-count {
        font-size: 11px;
      }
    }
    .store-normal-hidden {
      display: none !important;
    }
    .store-temporary-closed-page {
      min-height: min(760px, calc(100vh - 48px));
      display: grid;
      place-items: center;
      padding: 36px 14px;
      background: #f8fafc;
    }
    .store-temporary-closed-card {
      width: min(560px, 100%);
      border: 1px solid #e2e8f0;
      border-radius: 28px;
      background: #fff;
      padding: 34px;
      text-align: center;
      box-shadow: 0 24px 60px rgba(15,23,42,.12);
    }
    .store-temporary-closed-logo {
      width: 74px;
      height: 74px;
      margin: 0 auto 18px;
      display: grid;
      place-items: center;
      border-radius: 24px;
      overflow: hidden;
      background: #111827;
      color: #fff;
      font-size: 22px;
      font-weight: 1000;
    }
    .store-temporary-closed-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .store-temporary-closed-kicker {
      margin: 0 0 8px;
      color: #dc2626;
      font-size: 12px;
      font-weight: 1000;
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .store-temporary-closed-card h1 {
      margin: 0;
      color: #0f172a;
      font-size: clamp(30px, 7vw, 48px);
      line-height: 1;
      font-weight: 1000;
    }
    .store-temporary-closed-card p:last-child {
      max-width: 420px;
      margin: 14px auto 0;
      color: #475569;
      font-size: 16px;
      line-height: 1.5;
      font-weight: 800;
    }
  </style>

  {isTemporarilyClosed && (
    <main class="store-temporary-closed-page">
      <section class="store-temporary-closed-card" aria-labelledby="store-temporary-closed-title">
        <div class="store-temporary-closed-logo">{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : storeInitials(storeName)}</div>
        <p class="store-temporary-closed-kicker">Tienda no disponible</p>
        <h1 id="store-temporary-closed-title">Negocio cerrado temporalmente</h1>
        <p>{temporarilyClosedMessage}</p>
      </section>
    </main>
  )}
  <div class={isTemporarilyClosed ? 'store-normal-hidden' : ''}>

  <div class="public-store-head" aria-label="Acciones principales">
    <a class="public-store-brand" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>
      <div class="public-store-logo">{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : storeInitials(storeName)}</div>
      <div>
        <strong class="public-store-name">{storeName}</strong>
      </div>
    </a>
    <a class="public-search-shell" href={searchPath} aria-label="Buscar productos y categorias">
      <span>Buscar productos, marcas...</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
    </a>
    <div class="public-header-actions">
      <a class="public-action-btn public-mobile-search" href={searchPath} aria-label="Buscar productos y categorias">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="21" height="21" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
      </a>
      <button id="public-menu-open" class="public-action-btn public-menu-btn" type="button" aria-label="Abrir menú" aria-expanded="false">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="21" height="21" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
        <span class="public-action-label">Menú</span>
      </button>
    </div>
  </div>

  <div id="public-drawer-overlay" class="public-drawer-overlay" hidden></div>
  <aside id="public-drawer" class="public-drawer" aria-hidden="true">
    <div class="drawer-head">
      <a class="drawer-logo" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : storeInitials(storeName)}</a>
      <button id="public-menu-close" class="drawer-close" type="button" aria-label="Cerrar menú">×</button>
    </div>
    <nav class="drawer-nav">
      <a class="drawer-link" href={giftsPath}>Regalos <span>›</span></a>
      <a class="drawer-link" href={categoryAnchorPath}>Categorías <span>›</span></a>
      <a class="drawer-link" href={productAnchorPath}>Productos destacados <span>›</span></a>
      <div class="drawer-currency-card" data-pz-currency-menu hidden>
        <div class="drawer-currency-head">Moneda <span>⌄</span></div>
        <select class="drawer-currency-select" data-pz-currency-select aria-label="Moneda visual en menú"></select>
      </div>
      {hasBusinessHoursInfo && <button id="hours-info-open" class="drawer-link" type="button" aria-haspopup="dialog" aria-controls="hours-info-modal">Horarios <span>›</span></button>}
      <a class="drawer-link" href={whatsappStoreHref} target="_blank" rel="noreferrer">WhatsApp <span>↗</span></a>
    </nav>
    <div class="drawer-admin-action">
      <a class="drawer-link drawer-admin-link" href={adminLoginPath}>Ir al panel de administración</a>
    </div>
  </aside>

  <section class="public-hero">
    <div class="public-hero-cover" data-hero-carousel={heroCarouselImages.length >= 2 ? 'true' : 'false'}>
      {heroImages.map((imageUrl, index) => (
        <div class={`public-hero-slide ${index === 0 ? 'active' : ''}`}>
          <img src={imageUrl} alt={`Portada de ${storeName}`} loading={index === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
    {heroCarouselImages.length > 1 && (
      <>
        <button class="hero-arrow prev" type="button" data-hero-prev aria-label="Foto anterior">‹</button>
        <button class="hero-arrow next" type="button" data-hero-next aria-label="Foto siguiente">›</button>
        <div class="hero-dots" aria-hidden="true">
          {heroCarouselImages.map((_, index) => <span class={`hero-dot ${index === 0 ? 'active' : ''}`}></span>)}
        </div>
      </>
    )}
  </section>

  <section class="public-presentation-card" aria-labelledby="public-presentation-title">
    <div class="public-presentation-copy">
