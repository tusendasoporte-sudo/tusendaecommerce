            {quickCategories.map((category) => {
              const categoryProducts = productsByCategoryTotal(category.id);
              return (
                <a href={getPublicPath(`/categoria/${category.slug}`, currentStore, currentPathname)} class="quick-categories-modal-card" aria-label={`Abrir categoría ${category.name}`}>
                  <div class="quick-categories-modal-thumb">
