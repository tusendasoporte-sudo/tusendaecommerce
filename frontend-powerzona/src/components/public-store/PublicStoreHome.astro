    .public-hero {
      width: 100%;
      aspect-ratio: 16 / 9;
      min-height: 0;
      margin-bottom: 18px;
      background: linear-gradient(120deg, #eaf4ff, #f8fbff 52%, #dceeff);
    }
    .public-hero-cover,
