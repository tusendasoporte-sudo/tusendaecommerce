---
const {
  title,
  price,
  regularPrice = price,
  isOffer = false,
  image,
  stock = 0,
  allowPreorder = false,
  trackStock = true,
  hasVariations = false,
  onlyUsd = false,
  promoText = '',
  ratingAverage = 0,
  ratingCount = 0,
  showRating = false,
  view = 'standard',
  buttonText = 'Comprar',
  pricePrefix = '',
  variationAvailable = null,
} = Astro.props;

const stockNumber = Number(stock || 0);
const tracksStock = trackStock !== false;
const preorderEnabled = Boolean(allowPreorder);
const hasKnownVariationAvailability = variationAvailable !== null && variationAvailable !== undefined;
const variationsAvailable = !hasVariations || !hasKnownVariationAvailability || Boolean(variationAvailable);
const isOutOfStock = hasVariations && hasKnownVariationAvailability
  ? tracksStock && !variationsAvailable
  : tracksStock && stockNumber <= 0;
const canPreorder = tracksStock && isOutOfStock && preorderEnabled;
const isCompact = view === 'compact';
const isLarge = view === 'large';
const regularPriceNumber = Number(regularPrice || price || 0);
const finalPriceNumber = Number(price || 0);
const cleanPricePrefix = String(pricePrefix || '').trim();
const hasValidOffer = Boolean(isOffer) && regularPriceNumber > 0 && finalPriceNumber > 0 && finalPriceNumber < regularPriceNumber;
const savingsNumber = hasValidOffer ? regularPriceNumber - finalPriceNumber : 0;
const ratingAverageNumber = Number(ratingAverage || 0);
const ratingCountNumber = Number(ratingCount || 0);
const shouldShowRating = Boolean(showRating) && ratingCountNumber > 0 && ratingAverageNumber > 0;
---

<div class={`product-card ${isCompact ? 'product-card-compact' : ''} ${isLarge ? 'product-card-large' : ''} bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full ${isOutOfStock && !canPreorder ? 'opacity-90' : ''}`}>
  <style>
    .product-card {
      transform: translateY(0);
      border-radius: 8px !important;
      border-color: #dbe7f6 !important;
      box-shadow: 0 16px 38px rgba(37,99,235,.07) !important;
      color: #08133f;
    }
    .product-card:hover { transform: translateY(-2px); box-shadow: 0 20px 48px rgba(37,99,235,.12) !important; }
    .product-card-image-wrap { position: relative; width: 100%; padding-top: 100%; overflow: hidden; background: linear-gradient(180deg, #fff, #f4f9ff); }
    .product-card-compact .product-card-image-wrap { padding-top: 78%; }
    .product-card-large .product-card-image-wrap { padding-top: 104%; }
    .product-buy-chip { margin-top: auto; display: inline-flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border-radius: 8px; background: #0b63f6; color: #fff; padding: 12px 12px; font-size: 13px; font-weight: 1000; box-shadow: 0 14px 26px rgba(11,99,246,.22); }
    .product-card-compact .product-buy-chip { padding: 10px 10px; font-size: 12px; border-radius: 8px; }
    .product-status-text { min-height: 18px; }
    .offer-ribbon { position: absolute; top: 10px; left: 10px; z-index: 2; display: inline-flex; align-items: center; border-radius: 999px; background: #dc2626; color: #fff; padding: 6px 9px; font-size: 10px; font-weight: 1000; letter-spacing: .03em; text-transform: uppercase; box-shadow: 0 12px 24px rgba(220,38,38,.22); }
    .price-stack { display: flex; flex-direction: column; gap: 2px; margin-top: 5px; }
    .regular-price { width: fit-content; color: #94a3b8; font-size: 12px; font-weight: 900; text-decoration: line-through; }
    .save-price { width: fit-content; color: #16a34a; font-size: 11px; font-weight: 1000; }
    .automatic-promo-chip { display: inline-grid; gap: 1px; width: fit-content; margin-top: 7px; border-radius: 8px; background: #ecfdf5; border: 1px solid #bbf7d0; color: #166534; padding: 6px 8px; font-size: 10px; font-weight: 1000; line-height: 1.15; }
    .automatic-promo-chip span:first-child { color: #047857; text-transform: uppercase; letter-spacing: .04em; font-size: 9px; }
    .product-rating-chip { display: inline-flex; align-items: center; gap: 4px; width: fit-content; margin-top: 7px; border-radius: 999px; background: #fffbeb; border: 1px solid #fde68a; color: #92400e; padding: 5px 8px; font-size: 11px; line-height: 1; font-weight: 1000; }
    @media (max-width: 640px) {
      .product-buy-chip { padding: 9px 10px; font-size: 12px; border-radius: 8px; }
    }
  </style>

  <div class="product-card-image-wrap">
    <img
      src={image}
      alt={title}
      class="absolute top-0 left-0 w-full h-full object-contain transition-transform duration-500 hover:scale-105 p-2"
      loading="lazy"
    />

    {hasValidOffer && (
      <span class="offer-ribbon">Oferta</span>
    )}

    {isOutOfStock && (
      <div class="absolute inset-0 bg-black/35 flex items-center justify-center">
        <span class={`${canPreorder ? 'bg-blue-600 text-white' : 'bg-white text-red-600'} text-[11px] sm:text-xs font-black uppercase tracking-wide px-3 py-2 rounded-full shadow-lg`}>
          {canPreorder ? 'Preorden disponible' : 'Agotado'}
        </span>
      </div>
    )}
  </div>

  <div class={`${isCompact ? 'p-3' : isLarge ? 'p-4 sm:p-5' : 'p-3 sm:p-5'} flex flex-col flex-grow`}>
    <h3 class={`${isCompact ? 'text-sm' : isLarge ? 'text-base sm:text-xl' : 'text-sm sm:text-lg'} font-black text-gray-900 line-clamp-2 leading-snug`}>
      {title}
    </h3>

    <div class="price-stack">
      {hasValidOffer && (
        <span class="regular-price" data-pz-price-usd={regularPriceNumber} data-pz-only-usd={onlyUsd ? 'true' : 'false'}>
          {`$${regularPriceNumber.toFixed(2)} USD`}
        </span>
      )}
      <p class={`${isCompact ? 'text-sm' : 'text-sm sm:text-base'} ${hasValidOffer ? 'text-red-600' : 'text-blue-600'} font-extrabold m-0`} data-pz-price-usd={finalPriceNumber} data-pz-price-prefix={cleanPricePrefix} data-pz-only-usd={onlyUsd ? 'true' : 'false'}>
        {`${cleanPricePrefix ? `${cleanPricePrefix} ` : ''}$${finalPriceNumber.toFixed(2)} USD`}
      </p>
      {hasValidOffer && (
        <span class="save-price">
          {`Ahorras $${savingsNumber.toFixed(2)} USD`}
        </span>
      )}
    </div>

    {onlyUsd && (
      <span class="inline-flex w-fit mt-1 text-[10px] font-black bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full">
        Solo USD
      </span>
    )}

    {shouldShowRating && (
      <span class="product-rating-chip" aria-label={`${ratingAverageNumber.toFixed(1)} de 5 con ${ratingCountNumber} reseñas`}>
        ⭐ {ratingAverageNumber.toFixed(1)} ({ratingCountNumber})
      </span>
    )}

    {promoText && (
      <span class="automatic-promo-chip">
        <span>Promo</span>
        <span>{promoText}</span>
      </span>
    )}

    <p class={`product-status-text mt-2 text-[11px] sm:text-xs font-bold ${!tracksStock ? 'text-green-700' : canPreorder ? 'text-blue-700' : isOutOfStock ? 'text-red-600' : 'text-green-700'}`}>
      {hasVariations ? (isOutOfStock && !canPreorder ? 'Agotado' : 'Varias opciones') : !tracksStock ? 'Disponible' : canPreorder ? 'Disponible por preorder' : isOutOfStock ? 'Agotado' : `${stockNumber} disponibles`}
    </p>

    <span class="product-buy-chip mt-3">
      {hasVariations ? (isOutOfStock && !canPreorder ? 'Agotado' : 'Ver opciones') : buttonText}
    </span>
  </div>
</div>
