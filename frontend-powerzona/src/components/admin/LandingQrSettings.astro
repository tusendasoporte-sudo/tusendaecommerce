    publicUrlFields.forEach((field) => {
      field.value = PUBLIC_URL;
    });
    if (urlHostLabel) urlHostLabel.textContent = new URL(PUBLIC_URL).host;
    if (qrImage) qrImage.src = QR_SVG_PATH;

    function escapePocketBaseValue(value) {
      return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function iconSvg(icon) {
      const name = ICON_PATHS[icon] ? icon : 'link';
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">${ICON_PATHS[name]}</svg>`;
    }

    function getLinkBackground(type) {
      const key = String(type || '').toLowerCase();
      return LINK_BACKGROUNDS[key] || LINK_BACKGROUNDS.link;
    }

    function iconStyle(type) {
      return `--link-bg:${escapeHtml(getLinkBackground(type))};`;
    }

    function shortenUrl(value) {
      const text = String(value || '').trim();
      if (!text) return 'Sin URL';
      if (text.length <= 46) return text;
      return `${text.slice(0, 24)}...${text.slice(-16)}`;
    }

    function cleanText(value, max = 120) {
      return String(value ?? '')
        .replace(/<[^>]*>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim()
        .slice(0, max);
    }

    function isLandingQrEnabled(value) {
      return value === true || value === 1 || String(value).toLowerCase() === 'true' || String(value) === '1';
    }

    function isLandingQrDisabled(value) {
      return value === false || value === 0 || String(value).toLowerCase() === 'false' || String(value) === '0';
    }

    function isHeroImageFieldMissingError(error) {
      const text = `${error?.message || ''} ${JSON.stringify(error?.payload || {})}`;
      return /landing_qr_hero_image|hero_image/i.test(text) && /unknown|not found|missing|field/i.test(text);
    }

    function getSettingsFileName(value) {
      if (Array.isArray(value)) return value[0] || '';
      return value || '';
    }

    function settingsFileUrl(record, fieldName, thumb = '') {
      const filename = getSettingsFileName(record?.[fieldName]);
      if (!record?.id || !filename) return '';
      const base = `${POCKETBASE_URL}/api/files/settings/${record.id}/${encodeURIComponent(filename)}`;
      const params = new URLSearchParams();
      if (thumb) params.set('thumb', thumb);
      if (record.updated) params.set('t', record.updated);
      const query = params.toString();
      return query ? `${base}?${query}` : base;
    }

    function parseJsonArray(value) {
      if (Array.isArray(value)) return value;
      if (typeof value !== 'string' || !value.trim()) return [];
      try {
        const parsed = JSON.parse(value);
        return Array.isArray(parsed) ? parsed : [];
      } catch (_) {
        return [];
      }
    }

    function parseJsonObject(value) {
      if (value && typeof value === 'object' && !Array.isArray(value)) return value;
      if (typeof value !== 'string' || !value.trim()) return {};
      try {
        const parsed = JSON.parse(value);
        return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
      } catch (_) {
        return {};
      }
    }

    function normalizeWhatsAppUrl(value) {
      const raw = String(value || '').trim();
      if (!raw) return '';
      if (/^(wa\.me|api\.whatsapp\.com|web\.whatsapp\.com|chat\.whatsapp\.com)\//i.test(raw)) return `https://${raw}`;
      if (/^https?:\/\//i.test(raw)) {
        try {
          const url = new URL(raw);
          if (/(^|\.)whatsapp\.com$/i.test(url.hostname) || /^wa\.me$/i.test(url.hostname)) return url.toString();
        } catch (_) {
          return '';
        }
      }
      if (/^\+?\d[\d\s().-]{5,}$/.test(raw)) {
        const digits = raw.replace(/\D/g, '');
        return digits.length >= 7 ? `https://wa.me/${digits}` : '';
      }
      return '';
    }

    function normalizeUrl(value) {
      const raw = String(value || '').trim();
      if (!raw) return '';
      const whatsappUrl = normalizeWhatsAppUrl(raw);
      if (whatsappUrl) return whatsappUrl;
      if (raw.startsWith('/')) return raw.startsWith('//') ? '' : raw;
      if (/^(javascript|data|vbscript):/i.test(raw)) return '';
      if (/^(https?|mailto|tel):/i.test(raw)) {
        try {
          const parsed = new URL(raw);
          return /^(https?:|mailto:|tel:)$/i.test(parsed.protocol) ? raw : '';
        } catch (_) {
          return '';
        }
      }
      return '';
    }

    function getStoreInitials(name) {
      const parts = cleanText(name, 80).split(/\s+/).filter(Boolean).slice(0, 2);
      const initials = parts.map((part) => part[0]).join('').toUpperCase();
      return initials || 'TS';
    }

    function showAlert(message, type = 'info') {
      if (!alertBox) return;
      alertBox.textContent = message;
      alertBox.classList.remove('hidden', 'is-error', 'is-success');
      if (type === 'error') alertBox.classList.add('is-error');
      if (type === 'success') alertBox.classList.add('is-success');
    }

    function hideAlert() {
      alertBox?.classList.add('hidden');
    }

    function updateSaveButtonState() {
      if (!saveButton) return;
      saveButton.disabled = !hasUnsavedChanges || isSaving;
      if (isSaving) {
        saveButton.textContent = 'Guardando...';
      } else if (hasUnsavedChanges) {
        saveButton.textContent = 'Guardar cambios';
      } else {
        saveButton.textContent = 'Guardado';
      }
    }

    function markDirty() {
      hasUnsavedChanges = true;
      updateSaveButtonState();
