          type: 'facebook',
          icon: 'facebook',
          label: 'Facebook',
          subtitle: 'Síguenos en Facebook',
          url: normalizeUrl(socialLinks.facebook),
          active: Boolean(normalizeUrl(socialLinks.facebook)),
        },
        tiktok: {
          id: 'tiktok',
          type: 'tiktok',
          icon: 'tiktok',
          label: 'TikTok',
          subtitle: 'Videos y novedades',
          url: normalizeUrl(socialLinks.tiktok),
          active: Boolean(normalizeUrl(socialLinks.tiktok)),
        },
        offer: {
          id: 'ofertas',
          type: 'offer',
          icon: 'offer',
          label: 'Ofertas del día',
          subtitle: 'No te pierdas nuestras ofertas',
          url: PUBLIC_STORE_PATH,
          active: true,
        },
        location: {
          id: 'ubicacion-horarios',
          type: 'location',
          icon: 'location',
          label: 'Ubicación y horarios',
          subtitle: 'Encuéntranos fácilmente',
          url: PUBLIC_STORE_PATH,
          active: true,
        },
      };
      return suggestions[type] || {
        id: `link-${Date.now()}`,
        type: 'link',
        icon: 'link',
        label: 'Enlace personalizado',
        subtitle: '',
        url: '',
        active: false,
      };
    }

    function suggestedLinks() {
      return ['store', 'whatsapp', 'group', 'instagram', 'facebook', 'tiktok'].map((type, index) => ({
        ...suggestedLink(type),
        order: index + 1,
      }));
    }

    function normalizeLinksForEditor(value) {
      const items = parseJsonArray(value);
      return items.slice(0, MAX_LINKS).map((entry, index) => {
        const item = entry && typeof entry === 'object' ? entry : {};
        const icon = cleanText(item.icon || item.type || 'link', 24).toLowerCase();
        const type = cleanText(item.type || icon || 'link', 24).toLowerCase();
        const order = Number(item.order);
        return {
          id: cleanText(item.id || `${type}-${index + 1}`, 60) || `link-${index + 1}`,
          type,
          icon: ICON_OPTIONS.some(([value]) => value === icon) ? icon : 'link',
          label: cleanText(item.label, 60),
          subtitle: cleanText(item.subtitle, 90),
          url: String(item.url || '').trim(),
          active: item.active !== false,
          order: Number.isFinite(order) && order > 0 ? order : index + 1,
          editing: false,
        };
      }).sort((a, b) => a.order - b.order);
    }

    function getVisibleLinks() {
      return links
        .map((link, index) => ({
          ...link,
          label: cleanText(link.label, 60),
          subtitle: cleanText(link.subtitle, 90),
          url: normalizeUrl(link.url),
          order: index + 1,
        }))
        .filter((link) => link.active && link.label && link.url)
        .slice(0, MAX_LINKS);
    }

    function renderPreview() {
      if (previewTitle) previewTitle.textContent = cleanText(titleField?.value, 80) || 'Escanea y conecta con nosotros';
      if (previewSubtitle) previewSubtitle.textContent = cleanText(subtitleField?.value, 140) || 'Calidad, ofertas y atención rápida en un solo lugar';
      renderPreviewLogo();
      renderHeroPreview();
      if (!previewLinks) return;

      const visible = getVisibleLinks();
      previewLinks.innerHTML = visible.length
        ? visible.map((link) => {
          const icon = link.icon || 'link';
          const linkType = link.type || icon;
          return `
            <div class="landing-preview-link" style="${iconStyle(linkType)}">
              <span class="landing-preview-link__icon">${iconSvg(icon)}</span>
              <div><strong>${escapeHtml(link.label)}</strong>${link.subtitle ? `<small>${escapeHtml(link.subtitle)}</small>` : ''}</div>
              <span class="landing-preview-link__arrow">›</span>
            </div>
          `;
        }).join('')
        : '<div class="landing-empty">Sin enlaces activos</div>';
    }

    function updateSummary() {
      const activeCount = getVisibleLinks().length;
      if (activeCountLabel) activeCountLabel.textContent = String(activeCount);
      if (statusLabel) {
        const enabled = enabledField?.checked === true;
        statusLabel.classList.remove('is-hidden', 'is-pending');

        if (hasUnsavedChanges) {
          const visibilityChanged = enabled !== lastSavedLandingQrEnabled;
          statusLabel.textContent = visibilityChanged
            ? (enabled ? 'Publicado pendiente' : 'Oculto pendiente')
            : 'Cambios sin guardar';
          statusLabel.classList.add('is-pending');
          return;
        }

        statusLabel.textContent = enabled ? 'Publicado' : 'Oculto';
        if (!enabled) statusLabel.classList.add('is-hidden');
      }
    }

    function renderLinks() {
      if (!linksList) return;
      links = links.slice(0, MAX_LINKS).map((link, index) => ({ ...link, order: index + 1 }));
      linksList.innerHTML = links.map((link, index) => {
        const title = cleanText(link.label, 60) || 'Enlace sin título';
        const activeId = `landing-link-active-${index}`;
        const icon = ICON_OPTIONS.some(([value]) => value === link.icon) ? link.icon : 'link';
        const linkType = link.type || icon;
        const subtitle = cleanText(link.subtitle, 90);
        const statusText = link.active ? 'Activo' : 'Oculto';
        const fieldsClass = link.editing ? 'landing-link-row__grid' : 'landing-link-row__grid hidden';
        return `
          <article class="landing-link-row" data-link-index="${index}" style="${iconStyle(linkType)}">
            <div class="landing-link-row__top">
              <span class="landing-link-row__index">${index + 1}</span>
              <span class="landing-link-row__icon" aria-hidden="true">${iconSvg(icon)}</span>
              <span class="landing-link-row__copy">
                <strong class="landing-link-row__title">${escapeHtml(title)}</strong>
                <small class="landing-link-row__meta">${escapeHtml(subtitle || 'Sin texto secundario')}</small>
                <small class="landing-link-row__url">${escapeHtml(shortenUrl(link.url))}</small>
              </span>
              <span class="landing-link-status${link.active ? '' : ' is-muted'}">${escapeHtml(statusText)}</span>
              <div class="landing-link-row__actions">
                <button class="landing-link-edit" type="button" data-link-edit>${link.editing ? 'Cerrar' : 'Editar'}</button>
                <button type="button" data-link-move="up" aria-label="Subir enlace" ${index === 0 ? 'disabled' : ''}>↑</button>
                <button type="button" data-link-move="down" aria-label="Bajar enlace" ${index === links.length - 1 ? 'disabled' : ''}>↓</button>
                <button class="danger" type="button" data-link-delete aria-label="Eliminar enlace">×</button>
              </div>
            </div>
            <div class="${fieldsClass}">
              <label>
                <span>Icono</span>
                <select data-link-field="icon">
                  ${ICON_OPTIONS.map(([value, label]) => `<option value="${escapeHtml(value)}" ${link.icon === value ? 'selected' : ''}>${escapeHtml(label)}</option>`).join('')}
                </select>
              </label>
              <label>
                <span>Título</span>
                <input data-link-field="label" type="text" maxlength="60" value="${escapeHtml(link.label)}" placeholder="Ver tienda online" />
              </label>
              <label class="wide">
                <span>Texto secundario</span>
                <input data-link-field="subtitle" type="text" maxlength="90" value="${escapeHtml(link.subtitle)}" placeholder="Explora nuestros productos" />
              </label>
              <label class="wide">
                <span>URL</span>
                <input data-link-field="url" type="text" value="${escapeHtml(link.url)}" placeholder="https://... o /t/${escapeHtml(CURRENT_STORE_SLUG)}" />
              </label>
              <label class="landing-switch landing-link-toggle" for="${activeId}">
                <input id="${activeId}" data-link-field="active" type="checkbox" ${link.active ? 'checked' : ''} />
                <span aria-hidden="true"></span>
              </label>
            </div>
          </article>
        `;
      }).join('');
      emptyState?.classList.toggle('hidden', links.length > 0);
      updateSummary();
      renderPreview();
    }

    function syncLinkFromField(target) {
      const row = target.closest('[data-link-index]');
      if (!row) return;
      const index = Number(row.dataset.linkIndex);
      if (!Number.isInteger(index) || !links[index]) return;
      const field = target.dataset.linkField;
      markDirty();
      if (field === 'active') links[index].active = target.checked === true;
      else if (field === 'icon') {
        links[index].icon = target.value || 'link';
        links[index].type = target.value || 'link';
      } else if (field) {
        links[index][field] = target.value;
      }
      if (field === 'active' || field === 'icon') {
        hideAlert();
        updateSummary();
        renderPreview();
        renderLinks();
        return;
      }
      if (field === 'label') {
        const title = row.querySelector('.landing-link-row__title');
        if (title) title.textContent = cleanText(target.value, 60) || 'Enlace sin título';
      }
      if (field === 'subtitle') {
        const subtitle = row.querySelector('.landing-link-row__meta');
        if (subtitle) subtitle.textContent = cleanText(target.value, 90) || 'Sin texto secundario';
      }
      if (field === 'url') {
        const url = row.querySelector('.landing-link-row__url');
        if (url) url.textContent = shortenUrl(target.value);
      }
      hideAlert();
      updateSummary();
      renderPreview();
    }

    function addLink(link) {
      if (links.length >= MAX_LINKS) {
        showAlert('Puedes configurar hasta 10 enlaces.', 'error');
        return;
      }
      const next = {
        id: `link-${Date.now()}`,
        type: 'link',
        icon: 'link',
        label: '',
        subtitle: '',
        url: '',
        active: false,
        editing: true,
        ...link,
        order: links.length + 1,
      };
      links.push(next);
      markDirty();
      renderLinks();
    }

    function collectLinksForSave() {
      return links.slice(0, MAX_LINKS).map((link, index) => {
        const label = cleanText(link.label, 60);
        const subtitle = cleanText(link.subtitle, 90);
        const icon = ICON_OPTIONS.some(([value]) => value === link.icon) ? link.icon : 'link';
        const url = normalizeUrl(link.url);
        const active = link.active === true;

        if (active && !label) throw new Error(`El enlace ${index + 1} está activo y necesita título.`);
        if (active && !url) throw new Error(`El enlace "${label || index + 1}" está activo y necesita una URL válida.`);

        return {
          id: cleanText(link.id, 60) || `${icon}-${index + 1}`,
          type: cleanText(link.type || icon, 24) || icon,
          icon,
          label,
          subtitle,
          url: url || '',
          active,
          order: index + 1,
        };
      });
    }

    async function loadSettings(options = {}) {
      if (!options.keepAlert) hideAlert();
      const record = await findLatestSettingsRecord();
      settingsRecordId = record?.id || '';
      lastSettingsRecord = record || {};

      const savedEnabled = isLandingQrEnabled(record?.landing_qr_enabled);
      if (enabledField) enabledField.checked = savedEnabled;
      lastSavedLandingQrEnabled = savedEnabled;
      if (titleField) titleField.value = cleanText(record?.landing_qr_title, 80) || CURRENT_STORE_NAME;
      if (subtitleField) subtitleField.value = cleanText(record?.landing_qr_subtitle, 140) || cleanText(record?.welcome_text, 140) || 'Calidad, ofertas y atención rápida en un solo lugar';

      currentLogoUrl = settingsFileUrl(record, 'logo_image', '160x160');
      heroImageFieldAvailable = true;
      currentHeroImageName = getSettingsFileName(record?.landing_qr_hero_image);
      currentHeroImageUrl = settingsFileUrl(record, 'landing_qr_hero_image', '600x338');
      pendingHeroImageFile = null;
      removeHeroImage = false;
      revokePendingHeroPreview();
      if (heroImageInput) heroImageInput.value = '';

      const storedLinks = normalizeLinksForEditor(record?.landing_qr_links);
      links = storedLinks.length ? storedLinks : suggestedLinks();
      hasUnsavedChanges = false;
      updateSaveButtonState();
      renderLinks();
    }

    async function saveSettings() {
      if (isSaving || !hasUnsavedChanges) return;
      isSaving = true;
      updateSaveButtonState();

      try {
        const safeLinks = collectLinksForSave();
        const expectedEnabled = enabledField?.checked === true;
        const existing = await findLatestSettingsRecord();
        const targetSettingsId = existing?.id || settingsRecordId;
        if (existing?.id) {
          settingsRecordId = existing.id;
          lastSettingsRecord = existing;
          heroImageFieldAvailable = true;
        }

        const basePayload = {
          store: CURRENT_STORE_ID,
          active: true,
          store_name: CURRENT_STORE_NAME,
          landing_qr_enabled: expectedEnabled,
          landing_qr_title: cleanText(titleField?.value, 80),
          landing_qr_subtitle: cleanText(subtitleField?.value, 140),
          landing_qr_accent_color: FALLBACK_ACCENT,
          landing_qr_links: safeLinks,
        };

        const saveJsonPayload = () => (
          targetSettingsId
            ? apiRequest(`/api/collections/settings/records/${targetSettingsId}`, { method: 'PATCH', body: JSON.stringify(basePayload) })
            : apiRequest('/api/collections/settings/records', { method: 'POST', body: JSON.stringify(basePayload) })
        );

        const saveFormDataPayload = async () => {
          const formData = new FormData();
          Object.entries(basePayload).forEach(([key, value]) => {
            formData.append(key, key === 'landing_qr_links' ? JSON.stringify(value) : String(value ?? ''));
          });

          if (removeHeroImage && currentHeroImageName) {
            formData.append('landing_qr_hero_image-', currentHeroImageName);
          }

          if (pendingHeroImageFile) {
            if (currentHeroImageName) formData.append('landing_qr_hero_image-', currentHeroImageName);
            formData.append('landing_qr_hero_image', await optimizeLandingHeroImageFile(pendingHeroImageFile));
          }

          return targetSettingsId
            ? apiRequest(`/api/collections/settings/records/${targetSettingsId}`, { method: 'PATCH', body: formData })
            : apiRequest('/api/collections/settings/records', { method: 'POST', body: formData });
        };

        const hadPendingHeroImageFile = Boolean(pendingHeroImageFile);
        const shouldSendHeroImage = hadPendingHeroImageFile || (removeHeroImage && Boolean(currentHeroImageName));
        let heroImageSaveUnavailable = false;
        let savedRecord = null;

        if (shouldSendHeroImage) {
          try {
            savedRecord = await saveFormDataPayload();
          } catch (error) {
            if (hadPendingHeroImageFile) {
              throw new Error('La imagen destacada no se pudo guardar. Verifica que PocketBase tenga aplicado el campo landing_qr_hero_image.');
            }
            if (!isHeroImageFieldMissingError(error)) throw error;
            heroImageSaveUnavailable = true;
            heroImageFieldAvailable = false;
            removeHeroImage = false;
            renderHeroPreview();
            savedRecord = await saveJsonPayload();
          }
        } else {
          savedRecord = await saveJsonPayload();
        }

        const savedRecordId = savedRecord?.id || targetSettingsId;
        const verifyRecord = savedRecordId
          ? await fetchSettingsRecordById(savedRecordId)
          : await findLatestSettingsRecord();

        if (!verifyRecord?.id) {
          throw new Error('No se pudo verificar el registro de Landing QR en PocketBase.');
        }

        const savedEnabled = isLandingQrEnabled(verifyRecord?.landing_qr_enabled);

        if (savedEnabled !== expectedEnabled) {
          throw new Error('La Landing QR no se guardo correctamente en PocketBase.');
        }

        if (hadPendingHeroImageFile) {
          const savedHeroImage = getSettingsFileName(verifyRecord?.landing_qr_hero_image);
          if (!savedHeroImage) {
            throw new Error('La imagen destacada no se guardo en PocketBase. Verifica que la migracion landing_qr_hero_image este aplicada.');
          }
        }

        settingsRecordId = verifyRecord.id;
        lastSettingsRecord = verifyRecord;
        lastSavedLandingQrEnabled = savedEnabled;
        currentHeroImageName = getSettingsFileName(verifyRecord?.landing_qr_hero_image);
        currentHeroImageUrl = settingsFileUrl(verifyRecord, 'landing_qr_hero_image', '600x338');
        pendingHeroImageFile = null;
        removeHeroImage = false;
        revokePendingHeroPreview();
        if (heroImageInput) heroImageInput.value = '';
        hasUnsavedChanges = false;
        updateSaveButtonState();
        renderHeroPreview();
        renderPreview();
        updateSummary();
        if (heroImageSaveUnavailable) {
          heroImageFieldAvailable = false;
          renderHeroPreview();
          showAlert('La imagen destacada estara disponible cuando se aplique la migracion de Landing QR.', 'error');
        } else {
          showAlert('Landing QR guardada correctamente.', 'success');
        }
      } catch (error) {
        const errorText = `${error?.message || ''} ${JSON.stringify(error?.payload || {})}`;
        const migrationError = /landing_qr_|hero_image/i.test(errorText) && /unknown|not found|missing|field/i.test(errorText);
        showAlert(
          migrationError
            ? 'La migracion de Landing QR no esta aplicada. Reinicia PocketBase o aplica las migraciones antes de continuar.'
            : error?.message || 'No se pudo guardar la Landing QR.',
          'error'
        );
      } finally {
        isSaving = false;
        updateSaveButtonState();
      }
    }

    function copyPublicUrl() {
      const done = () => showAlert('URL copiada.', 'success');
      if (navigator.clipboard?.writeText) {
        navigator.clipboard.writeText(PUBLIC_URL).then(done).catch(() => {
          publicUrlFields[0]?.select();
          document.execCommand('copy');
          done();
        });
        return;
      }
      publicUrlFields[0]?.select();
      document.execCommand('copy');
      done();
    }

    function openLandingPage() {
      if (enabledField?.checked !== true) {
        showAlert('La Landing QR está oculta. Actívala y guarda los cambios para abrir la página pública.', 'error');
        return;
      }

      if (hasUnsavedChanges) {
        showAlert('Guarda los cambios antes de abrir la Landing QR.', 'error');
        return;
      }

      window.open(PUBLIC_PATH, '_blank', 'noopener,noreferrer');
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      saveSettings();
    });

    root.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches('[data-link-field]')) {
        syncLinkFromField(target);
        return;
      }
      markDirty();
      hideAlert();
      updateSummary();
      renderPreview();
    });

    root.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches('[data-link-field]')) syncLinkFromField(target);
      if (target === heroImageInput) {
        const file = heroImageInput?.files?.[0] || null;
        if (!file) return;
        if (file && !file.type.startsWith('image/')) {
          showAlert('Selecciona una imagen JPG, PNG o WebP.', 'error');
          return;
        }
        pendingHeroImageFile = file;
        removeHeroImage = false;
        revokePendingHeroPreview();
        if (pendingHeroImageFile) pendingHeroImagePreviewUrl = URL.createObjectURL(pendingHeroImageFile);
        markDirty();
        hideAlert();
        renderHeroPreview();
        renderPreview();
        return;
      }
      if (target === enabledField) {
        markDirty();
        updateSummary();
        hideAlert();
      }
    });

    root.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const addSuggested = target.closest('[data-add-suggested]');
      const row = target.closest('[data-link-index]');

      if (target.closest('[data-save-landing]')) {
        saveSettings();
        return;
      }

      if (target.closest('[data-select-hero-image]')) {
        heroImageInput?.click();
        return;
      }

      if (target.closest('[data-add-link]')) {
        addLink(suggestedLink('link'));
        return;
      }

      if (target.closest('[data-remove-hero-image]')) {
        pendingHeroImageFile = null;
        removeHeroImage = true;
        revokePendingHeroPreview();
        if (heroImageInput) heroImageInput.value = '';
        markDirty();
        hideAlert();
        renderHeroPreview();
        renderPreview();
        return;
      }

      if (target.closest('[data-restore-suggested]')) {
        links = suggestedLinks();
        markDirty();
        renderLinks();
        showAlert('Enlaces sugeridos restaurados. Revisa URLs vacías antes de guardar.', 'success');
        return;
      }

      if (addSuggested) {
        addLink(suggestedLink(addSuggested.dataset.addSuggested || 'link'));
        return;
      }

      if (target.closest('[data-copy-public-url]')) {
        copyPublicUrl();
        return;
      }

      if (target.closest('[data-open-landing]')) {
        openLandingPage();
        return;
      }

      if (!row) return;
      const index = Number(row.dataset.linkIndex);
      if (!Number.isInteger(index) || !links[index]) return;

      if (target.closest('[data-link-edit]')) {
        links[index].editing = !links[index].editing;
        markDirty();
        renderLinks();
        return;
      }

      if (target.closest('[data-link-delete]')) {
        links.splice(index, 1);
        markDirty();
        renderLinks();
        return;
      }

      const moveButton = target.closest('[data-link-move]');
      if (moveButton) {
        const direction = moveButton.dataset.linkMove;
        const targetIndex = direction === 'up' ? index - 1 : index + 1;
        if (targetIndex < 0 || targetIndex >= links.length) return;
        const current = links[index];
        links[index] = links[targetIndex];
        links[targetIndex] = current;
        markDirty();
        renderLinks();
      }
    });

    window.addEventListener('pz:store-settings:save', () => {
      const tab = document.getElementById('tab-landing');
      if (tab && !tab.classList.contains('hidden')) saveSettings();
    });

    loadSettings().catch((error) => {
      showAlert(error?.message || 'No se pudo cargar la configuración de Landing QR.', 'error');
      links = suggestedLinks();
      renderLinks();
    });
  })();
</script>
