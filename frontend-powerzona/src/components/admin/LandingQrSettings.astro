    async function optimizeLandingHeroImageFile(file) {
      if (!file || !file.type || !file.type.startsWith('image/')) return file;
      if (file.type === 'image/webp' && file.size <= 700000) return file;

      try {
        const bitmap = await createImageBitmap(file);
        const targetWidth = 1200;
        const targetHeight = 675;
        const sourceRatio = bitmap.width / bitmap.height;
        const targetRatio = targetWidth / targetHeight;

        let sx = 0;
        let sy = 0;
        let sw = bitmap.width;
        let sh = bitmap.height;

        if (sourceRatio > targetRatio) {
          sw = Math.round(bitmap.height * targetRatio);
          sx = Math.round((bitmap.width - sw) / 2);
        } else if (sourceRatio < targetRatio) {
          sh = Math.round(bitmap.width / targetRatio);
          sy = Math.round((bitmap.height - sh) / 2);
        }

        const canvas = document.createElement('canvas');
        canvas.width = targetWidth;
        canvas.height = targetHeight;

        const ctx = canvas.getContext('2d');
        if (!ctx) return file;
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(bitmap, sx, sy, sw, sh, 0, 0, targetWidth, targetHeight);

        const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/webp', 0.82));
        if (typeof bitmap.close === 'function') bitmap.close();
        if (!blob) return file;

        const safeName = (file.name || 'landing_qr')
          .replace(/\.[^.]+$/, '')
          .replace(/[^a-zA-Z0-9_-]+/g, '_')
          .slice(0, 42) || 'landing_qr';

        return new File([blob], `${safeName}_landing_qr.webp`, {
          type: 'image/webp',
          lastModified: Date.now(),
        });
      } catch (_) {
        return file;
      }
    }

    async function apiRequest(path, options = {}) {
      if (!POCKETBASE_URL) throw new Error('No se encontró la URL de PocketBase.');
      const headers = new Headers(options.headers || {});
      if (ADMIN_AUTH_TOKEN) headers.set('Authorization', `Bearer ${ADMIN_AUTH_TOKEN}`);
      if (options.body && !(options.body instanceof FormData) && !headers.has('Content-Type')) {
        headers.set('Content-Type', 'application/json');
      }

      const response = await fetch(`${POCKETBASE_URL}${path}`, {
        ...options,
        headers,
      });
      const text = await response.text();
      let payload = null;
      try {
        payload = text ? JSON.parse(text) : null;
      } catch (_) {
        payload = text;
      }
      if (!response.ok) {
        const message = payload?.message || 'No se pudo completar la operación.';
        const error = new Error(message);
        error.payload = payload;
        throw error;
      }
      return payload;
    }

    async function findLatestSettingsRecord() {
      const filter = `store="${escapePocketBaseValue(CURRENT_STORE_ID)}" && active=true`;
      const params = new URLSearchParams({
        filter,
        perPage: '1',
        sort: '-updated,-created',
      });
      const payload = await apiRequest(`/api/collections/settings/records?${params.toString()}`);
      return payload?.items?.[0] || null;
    }

    async function fetchSettingsRecordById(recordId) {
