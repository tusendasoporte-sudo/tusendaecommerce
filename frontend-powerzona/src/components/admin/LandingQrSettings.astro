---
type Props = {
  pocketbaseUrl: string;
  currentStoreId: string;
  currentStoreSlug: string;
  currentStoreName: string;
  adminAuthToken: string;
};

const {
  pocketbaseUrl,
  currentStoreId,
  currentStoreSlug,
  currentStoreName,
  adminAuthToken,
} = Astro.props as Props;

const safeStoreSlug = currentStoreSlug || 'powerzona';
const publicPath = `/t/${encodeURIComponent(safeStoreSlug)}/links`;
const publicStorePath = `/t/${encodeURIComponent(safeStoreSlug)}`;
const qrSvgPath = `${publicPath}/qr.svg`;
const qrPngPath = `${publicPath}/qr.png`;
---

<section
  class="landing-qr-admin"
  data-landing-qr-root
  aria-label="Configuración de Landing QR"
>
  <div class="landing-qr-admin__grid">
    <div class="landing-qr-admin__editor">
      <div class="landing-qr-summary" aria-label="Resumen Landing QR">
        <article>
          <span>Estado</span>
          <strong data-landing-status>Publicado</strong>
          <small>Visibilidad pública</small>
        </article>
        <article>
          <span>Botones activos</span>
          <strong data-active-count>0</strong>
          <small>Máximo 10 enlaces</small>
        </article>
        <article>
          <span>URL fija</span>
          <strong data-url-host>...</strong>
          <small>El QR apunta siempre aquí</small>
        </article>
      </div>

      <form class="landing-qr-form" data-landing-form>
        <section class="landing-qr-panel">
          <div class="landing-qr-panel__head landing-qr-panel__head--state">
            <div>
              <h3>Estado y contenido</h3>
              <p>Configura la página que verán tus clientes al escanear el QR.</p>
            </div>
            <div class="landing-state-actions">
              <label class="landing-switch" for="landing-qr-enabled">
                <input id="landing-qr-enabled" data-field="enabled" type="checkbox" />
                <span aria-hidden="true"></span>
              </label>
              <button class="landing-btn landing-btn--primary landing-save-btn" type="button" data-save-landing disabled>Guardado</button>
            </div>
          </div>

          <div class="landing-fields">
            <label>
              <span>Título principal</span>
              <input data-field="title" type="text" maxlength="80" placeholder="Escanea y conecta con nosotros" />
            </label>
            <label>
              <span>Subtítulo</span>
              <input data-field="subtitle" type="text" maxlength="140" placeholder="Calidad, ofertas y atención rápida en un solo lugar" />
            </label>
            <div class="landing-hero-editor">
              <div>
                <span class="landing-field-title">Imagen destacada 16:9</span>
                <p>Opcional. Recomendada 1200 x 675 px. Se optimiza automaticamente a WebP.</p>
              </div>

              <button class="landing-hero-preview" type="button" data-hero-preview data-select-hero-image>
                <span>Sin imagen destacada</span>
              </button>

              <div class="landing-hero-actions">
                <button class="landing-btn" type="button" data-select-hero-image>Subir imagen</button>
                <input data-field="heroImage" class="landing-file-input" type="file" accept="image/jpeg,image/png,image/webp" />
                <button class="landing-btn landing-btn--danger hidden" type="button" data-remove-hero-image>Quitar imagen</button>
              </div>
            </div>
          </div>
        </section>

        <section class="landing-qr-panel">
          <div class="landing-qr-panel__head">
            <div>
              <h3>Enlaces</h3>
              <p>Activa, edita y ordena hasta 10 botones para la landing.</p>
            </div>
            <button class="landing-btn landing-btn--primary" type="button" data-add-link>Agregar enlace</button>
          </div>

          <div class="landing-suggestion-row" aria-label="Acciones rápidas de enlaces">
            <button class="landing-chip" type="button" data-restore-suggested>Restaurar sugeridos</button>
            <button class="landing-chip" type="button" data-add-suggested="store">Tienda</button>
            <button class="landing-chip" type="button" data-add-suggested="whatsapp">WhatsApp</button>
            <button class="landing-chip" type="button" data-add-suggested="group">Grupo</button>
            <button class="landing-chip" type="button" data-add-suggested="instagram">Instagram</button>
            <button class="landing-chip" type="button" data-add-suggested="facebook">Facebook</button>
          </div>

          <div class="landing-links-list" data-links-list></div>
          <div class="landing-empty hidden" data-links-empty>No hay enlaces configurados.</div>
        </section>

        <div class="landing-actions">
          <button class="landing-btn" type="button" data-open-landing>Abrir página</button>
          <button class="landing-btn" type="button" data-copy-public-url>Copiar URL</button>
        </div>

        <div class="landing-alert hidden" data-landing-alert></div>
      </form>
    </div>

    <aside class="landing-qr-admin__side">
      <section class="landing-qr-panel landing-preview-panel">
        <div class="landing-qr-panel__head">
          <div>
            <h3>Vista previa móvil</h3>
            <p>Así se verá al abrir el enlace desde un teléfono.</p>
          </div>
        </div>
        <div class="landing-phone-preview">
          <div class="landing-phone-preview__screen" data-preview-screen>
            <div class="landing-preview-logo" data-preview-logo>{currentStoreName.slice(0, 2).toUpperCase()}</div>
            <p class="landing-preview-store">{currentStoreName || 'Tienda'}</p>
            <h4 data-preview-title>Escanea y conecta con nosotros</h4>
            <p data-preview-subtitle>Calidad, ofertas y atención rápida en un solo lugar</p>
            <div class="landing-preview-hero hidden" data-preview-hero></div>
            <div class="landing-preview-links" data-preview-links></div>
            <footer>
              <strong>{currentStoreName || 'Tienda'}</strong>
              <span>Tu Senda 84</span>
            </footer>
          </div>
        </div>
      </section>

      <section class="landing-qr-panel landing-qr-download">
        <div class="landing-qr-panel__head">
          <div>
            <h3>Tu página y QR</h3>
            <p>Imprime este QR y cambia los enlaces cuando quieras.</p>
          </div>
        </div>
        <label class="landing-url-field">
          <span>URL fija de tu Landing QR</span>
          <input data-public-url type="text" value="" readonly />
        </label>
        <div class="landing-qr-box">
          <img src={qrSvgPath} alt="QR de Landing QR" loading="lazy" decoding="async" data-qr-image />
        </div>
        <div class="landing-qr-download__actions">
          <a class="landing-btn" href={qrPngPath} download={`landing-qr-${safeStoreSlug}.png`}>Descargar PNG</a>
          <a class="landing-btn" href={qrSvgPath} download={`landing-qr-${safeStoreSlug}.svg`}>Descargar SVG</a>
        </div>
      </section>
    </aside>
  </div>
</section>

<style is:global>
  .landing-qr-admin,
  .landing-qr-admin * {
    box-sizing: border-box;
  }

  .landing-qr-admin {
    color: #0f172a;
  }

  .landing-qr-admin .landing-qr-admin__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 18px;
    align-items: start;
  }

  .landing-qr-admin .landing-qr-admin__editor,
  .landing-qr-admin .landing-qr-admin__side,
  .landing-qr-admin .landing-qr-form {
    display: grid;
    gap: 16px;
  }

  .landing-qr-admin .landing-qr-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .landing-qr-admin .landing-qr-summary article,
  .landing-qr-admin .landing-qr-panel {
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
  }

  .landing-qr-admin .landing-qr-summary article {
    min-width: 0;
    padding: 14px;
  }

  .landing-qr-admin .landing-qr-summary span,
  .landing-qr-admin .landing-qr-summary small {
    display: block;
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    overflow-wrap: anywhere;
  }

  .landing-qr-admin .landing-qr-summary strong {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: #dcfce7;
    color: #166534;
    padding: 5px 10px;
    margin: 5px 0 3px;
    font-size: 14px;
    font-weight: 1000;
    overflow-wrap: anywhere;
  }

  .landing-qr-admin .landing-qr-summary strong.is-hidden {
    background: #f1f5f9;
    color: #64748b;
  }

  .landing-qr-admin .landing-qr-summary strong.is-pending {
    background: #fef3c7;
    color: #92400e;
  }

  .landing-qr-admin .landing-qr-panel {
    padding: 16px;
  }

  .landing-qr-admin .landing-qr-panel__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 14px;
  }

  .landing-qr-admin .landing-qr-panel__head h3 {
    margin: 0;
    font-size: 17px;
    font-weight: 1000;
  }

  .landing-qr-admin .landing-qr-panel__head p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 12px;
    font-weight: 750;
    line-height: 1.35;
  }

  .landing-qr-admin .landing-qr-panel__head--state {
    align-items: flex-start;
  }

  .landing-qr-admin .landing-state-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
    padding-right: 6px;
    flex-shrink: 0;
  }

  .landing-qr-admin .landing-save-btn {
    min-height: 38px;
    padding: 0 16px;
    border-radius: 14px;
    white-space: nowrap;
  }

  .landing-qr-admin .landing-switch {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    margin-right: 0;
  }

  .landing-qr-admin .landing-switch input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .landing-qr-admin .landing-switch span {
    width: 50px;
    height: 28px;
    border-radius: 999px;
    padding: 3px;
    background: #cbd5e1;
    transition: background 0.2s ease;
  }

  .landing-qr-admin .landing-switch span::before {
    content: "";
    display: block;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.22);
    transition: transform 0.2s ease;
  }

  .landing-qr-admin .landing-switch input:checked + span {
    background: #2563eb;
  }

  .landing-qr-admin .landing-switch input:checked + span::before {
    transform: translateX(22px);
  }

  .landing-qr-admin .landing-fields {
    display: grid;
    gap: 12px;
  }

  .landing-qr-admin .landing-fields label,
  .landing-qr-admin .landing-url-field {
    display: grid;
    gap: 6px;
    color: #334155;
    font-size: 12px;
    font-weight: 900;
  }

  .landing-qr-admin .landing-fields input,
  .landing-qr-admin .landing-fields select,
  .landing-qr-admin .landing-fields textarea,
  .landing-qr-admin .landing-url-field input,
  .landing-qr-admin .landing-link-row input,
  .landing-qr-admin .landing-link-row select {
    width: 100%;
    min-height: 42px;
    border: 1px solid #dbe4f0;
    border-radius: 12px;
    background: #fff;
    color: #0f172a;
    padding: 10px 12px;
    font: inherit;
    font-size: 13px;
    font-weight: 750;
    outline: none;
  }

  .landing-qr-admin .landing-fields input:focus,
  .landing-qr-admin .landing-url-field input:focus,
  .landing-qr-admin .landing-link-row input:focus,
  .landing-qr-admin .landing-link-row select:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }

  .landing-qr-admin .landing-field-title {
    color: #334155;
    font-size: 12px;
    font-weight: 950;
  }

  .landing-qr-admin .landing-hero-editor {
    display: grid;
    gap: 10px;
  }

  .landing-qr-admin .landing-hero-editor p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 12px;
    font-weight: 750;
    line-height: 1.35;
  }

  .landing-qr-admin .landing-hero-preview {
    appearance: none;
    width: min(100%, 360px);
    aspect-ratio: 16 / 9;
    border: 1px dashed #bfd1e8;
    border-radius: 18px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #f8fbff, #eef6ff);
    color: #64748b;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.35;
    cursor: pointer;
    padding: 0;
    text-align: center;
    font: inherit;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.76);
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .landing-qr-admin .landing-hero-preview:hover {
    border-color: #2563eb;
    box-shadow: 0 14px 32px rgba(37, 99, 235, 0.14);
    transform: translateY(-1px);
  }

  .landing-qr-admin .landing-hero-preview span {
    padding: 12px;
  }

  .landing-qr-admin .landing-hero-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .landing-qr-admin .landing-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .landing-qr-admin .landing-file-input {
    position: absolute;
    width: 1px;
    height: 1px;
    min-height: 1px;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    border: 0;
    margin: 0;
    padding: 0;
  }

  .landing-qr-admin .landing-suggestion-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .landing-qr-admin .landing-btn,
  .landing-qr-admin .landing-chip {
    border: 1px solid #dbe4f0;
    border-radius: 12px;
    background: #fff;
    color: #1d4ed8;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 9px 13px;
    font-size: 13px;
    font-weight: 950;
    text-decoration: none;
  }

  .landing-qr-admin .landing-btn--primary {
    border-color: #2563eb;
    background: #2563eb;
    color: #fff;
    box-shadow: 0 14px 28px rgba(37, 99, 235, 0.2);
  }

  .landing-qr-admin .landing-btn--danger {
    border-color: #fecaca;
    color: #b91c1c;
  }

  .landing-qr-admin .landing-btn:disabled,
  .landing-qr-admin .landing-chip:disabled {
    cursor: not-allowed;
    opacity: 0.58;
  }

  .landing-qr-admin [data-save-landing][disabled] {
    opacity: 0.68;
    box-shadow: none;
  }

  .landing-qr-admin .landing-chip {
    min-height: 34px;
    border-radius: 999px;
    color: #334155;
    padding: 7px 11px;
    font-size: 12px;
  }

  .landing-qr-admin .landing-links-list {
    display: grid;
    gap: 10px;
  }

  .landing-qr-admin .landing-link-row {
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    background: linear-gradient(180deg, #fff, #f8fafc);
    padding: 10px;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
  }

  .landing-qr-admin .landing-link-row__top {
    display: grid;
    grid-template-columns: 32px 42px minmax(0, 1fr) auto auto;
    gap: 10px;
    align-items: center;
  }

  .landing-qr-admin .landing-link-row__index {
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
    color: #2563eb;
    font-size: 13px;
    font-weight: 900;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .landing-qr-admin .landing-link-row__icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: var(--link-bg, linear-gradient(180deg, #3b82f6 0%, #2563eb 100%));
    color: #ffffff;
    box-shadow:
      0 10px 20px rgba(15, 23, 42, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.24);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  .landing-qr-admin .landing-link-row__icon svg {
    width: 18px;
    height: 18px;
    display: block;
    color: currentColor;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .landing-qr-admin .landing-link-row__copy {
    min-width: 0;
  }

  .landing-qr-admin .landing-link-row__title {
    display: block;
    color: #0f172a;
    font-size: 13px;
    font-weight: 1000;
    overflow-wrap: anywhere;
  }

  .landing-qr-admin .landing-link-row__meta,
  .landing-qr-admin .landing-link-row__url {
    display: block;
    margin-top: 2px;
    color: #64748b;
    font-size: 11px;
    font-weight: 800;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .landing-qr-admin .landing-link-status {
    border-radius: 999px;
    background: #e0f2fe;
    color: #0369a1;
    padding: 6px 9px;
    font-size: 11px;
    font-weight: 1000;
    white-space: nowrap;
  }

  .landing-qr-admin .landing-link-status.is-muted {
    background: #f1f5f9;
    color: #64748b;
  }

  .landing-qr-admin .landing-link-row__actions {
    display: flex;
    gap: 6px;
    justify-content: flex-end;
  }

  .landing-qr-admin .landing-link-row__actions button {
    min-width: 32px;
    height: 32px;
    border: 1px solid #dbe4f0;
    border-radius: 10px;
    background: #fff;
    color: #334155;
    cursor: pointer;
    font-size: 14px;
    font-weight: 1000;
    padding: 0 9px;
  }

  .landing-qr-admin .landing-link-row__actions .danger {
    color: #dc2626;
  }

  .landing-qr-admin .landing-link-row__actions .landing-link-edit {
    width: auto;
    color: #1d4ed8;
    font-size: 12px;
  }

  .landing-qr-admin .landing-link-row__grid {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 10px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #e2e8f0;
  }

  .landing-qr-admin .landing-link-row__grid .wide {
    grid-column: 1 / -1;
  }

  .landing-qr-admin .landing-link-toggle {
    justify-self: end;
  }

  .landing-qr-admin .landing-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .landing-qr-admin .landing-qr-download__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .landing-qr-admin .landing-alert {
    border-radius: 14px;
    padding: 12px 14px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 850;
  }

  .landing-qr-admin .landing-alert.is-error {
    background: #fef2f2;
    color: #b91c1c;
  }

  .landing-qr-admin .landing-alert.is-success {
    background: #ecfdf5;
    color: #047857;
  }

  .landing-qr-admin .landing-empty {
    border: 1px dashed #cbd5e1;
    border-radius: 14px;
    padding: 18px;
    color: #64748b;
    text-align: center;
    font-size: 13px;
    font-weight: 850;
  }

  .landing-qr-admin .hidden {
    display: none !important;
  }

  .landing-qr-admin .landing-phone-preview {
    display: grid;
    place-items: center;
    padding: 10px 0 4px;
  }

  .landing-qr-admin .landing-phone-preview__screen {
    display: flex;
    flex-direction: column;
    width: 280px;
    max-height: 640px;
    min-height: 560px;
    border: 10px solid #0f172a;
    border-radius: 36px;
    background:
      radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 12rem),
      linear-gradient(180deg, #f8fbff 0%, #eef5ff 62%, #ffffff 100%);
    box-shadow: 0 22px 46px rgba(15, 23, 42, 0.2);
    padding: 22px 14px 0;
    text-align: center;
    overflow: hidden;
  }

  .landing-qr-admin .landing-preview-logo {
    width: 66px;
    height: 66px;
    margin: 0 auto 8px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #2563eb, #0f172a);
    color: #fff;
    font-size: 18px;
    font-weight: 1000;
  }

  .landing-qr-admin .landing-preview-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .landing-qr-admin .landing-preview-store {
    margin: 0;
    color: #2563eb;
    font-size: 11px;
    font-weight: 1000;
  }

  .landing-qr-admin .landing-phone-preview h4 {
    margin: 4px 0 4px;
    color: #0f172a;
    font-size: 22px;
    line-height: 1.05;
    font-weight: 1000;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .landing-qr-admin .landing-phone-preview p {
    margin: 0;
    color: #334155;
    font-size: 11px;
    font-weight: 800;
    line-height: 1.35;
  }

  .landing-qr-admin .landing-preview-hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 18px;
    overflow: hidden;
    margin: 12px 0 4px;
    background: linear-gradient(135deg, #dbeafe, #f8fafc);
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.1);
  }

