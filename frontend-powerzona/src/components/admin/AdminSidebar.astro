---
import { getPublicStorePath, getStoreAdminPath } from '../../lib/adminRoutes';

interface Props {
  storeSlug?: string;
  storeName?: string;
  activeSection?: string;
  activeSubsection?: string;
  planName?: string;
  daysRemaining?: string | number;
  mobileTitle?: string;
  mobileActionLabel?: string;
  mobileActionHref?: string;
  mobileActionTarget?: string;
  mobileActionEvent?: string;
  mobileActionAriaLabel?: string;
  mobileBackHref?: string;
  mobileBackLabel?: string;
  storeId?: string;
  pocketbaseUrl?: string;
  authToken?: string;
}

const {
  storeSlug = 'powerzona',
  storeName = 'PowerZona',
  activeSection = '',
  activeSubsection = '',
  planName = 'Básico',
  daysRemaining = '—',
  mobileTitle = '',
  mobileActionLabel = '',
  mobileActionHref = '',
  mobileActionTarget = '',
  mobileActionEvent = '',
  mobileActionAriaLabel = '',
  mobileBackHref = '',
  mobileBackLabel = '',
  storeId = '',
  pocketbaseUrl = '',
  authToken = '',
} = Astro.props;

const adminBasePath = getStoreAdminPath(storeSlug);
const adminCatalogPath = getStoreAdminPath(storeSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(storeSlug, 'products');
const adminOrdersPath = getStoreAdminPath(storeSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(storeSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(storeSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(storeSlug, 'shipping');
const adminPromosPath = getStoreAdminPath(storeSlug, 'promos');
const adminNotificationsPath = getStoreAdminPath(storeSlug, 'notifications');
const publicStorePath = getPublicStorePath(storeSlug);
const notificationsAdminOrdersPath = adminOrdersPath;
const notificationsAdminProductsPath = adminProductsPath;

const defaultMobileTitleBySection: Record<string, string> = {
  overview: 'Resumen',
  orders: 'Pedidos',
  catalog: 'Categorías',
  products: 'Productos',
  gifts: 'Regalos',
  shipping: 'Envíos',
  settings: 'Ajustes',
  marketing: 'Promociones',
};

const resolvedMobileTitle =
  mobileTitle ||
  defaultMobileTitleBySection[activeSection || ''] ||
  storeName ||
  'Admin';

const hasMobileAction = Boolean(
  mobileActionLabel &&
  (mobileActionHref || mobileActionTarget || mobileActionEvent)
);

const mobileTopbarClass = `pz-admin-mobile-topbar${hasMobileAction ? ' has-action' : ' no-action'}`;
const resolvedMobileActionAriaLabel = mobileActionAriaLabel || mobileActionLabel || 'Acción principal';
const hasMobileBack = Boolean(mobileBackHref && mobileBackLabel);

const mobileBottomClass = (target: 'overview' | 'orders' | 'shipping' | 'settings') => {
  const directMatch =
    (target === 'overview' && activeSection === 'overview') ||
    (target === 'orders' && activeSection === 'orders') ||
    (target === 'shipping' && activeSection === 'shipping') ||
    (target === 'settings' && activeSection === 'settings');

  const fallbackSettingsActive =
    target === 'settings' &&
    !['overview', 'orders', 'shipping'].includes(activeSection || '');

  return `pz-admin-mobile-bottom-nav__link${directMatch || fallbackSettingsActive ? ' is-active' : ''}`;
};

const isSettingsActive = activeSection === 'settings';
const isMarketingVisualActive = activeSection === 'marketing';
const normalizedSubsection = activeSubsection === 'schedule' ? 'horario' : activeSubsection;
const supportWhatsapp = String(import.meta.env.PUBLIC_MASTER_SUPPORT_WHATSAPP || '').replace(/[^0-9]/g, '');
const supportEmail = String(import.meta.env.PUBLIC_MASTER_SUPPORT_EMAIL || '').trim();
const supportMessage = `Hola soporte de Tu Senda 84, necesito ayuda con el admin de ${storeName} (${storeSlug || 'sin-slug'}).`;
const masterSupportHref = supportWhatsapp
  ? `https://wa.me/${supportWhatsapp}?text=${encodeURIComponent(supportMessage)}`
  : (supportEmail ? `mailto:${supportEmail}?subject=${encodeURIComponent('Soporte Tu Senda 84')}&body=${encodeURIComponent(supportMessage)}` : '');

const navClass = (section: string) => `pz-admin-sidebar__nav-item${activeSection === section ? ' is-active' : ''}`;
const settingsToggleClass = `pz-admin-sidebar__nav-item pz-admin-sidebar__settings-toggle${isSettingsActive ? ' is-active' : ''}`;
const settingsSubnavClass = `pz-admin-sidebar__settings-subnav${isSettingsActive ? '' : ' is-collapsed'}`;
const marketingVisualToggleClass = `pz-admin-sidebar__nav-item pz-admin-sidebar__settings-toggle${isMarketingVisualActive ? ' is-active' : ''}`;
const marketingVisualSubnavClass = `pz-admin-sidebar__settings-subnav${isMarketingVisualActive ? '' : ' is-collapsed'}`;
const subClass = (subsection: string) => {
  const isGeneral = subsection === 'generales' && ['general', 'generales', ''].includes(normalizedSubsection);
  return `pz-admin-sidebar__settings-subitem${isSettingsActive && (normalizedSubsection === subsection || isGeneral) ? ' is-active' : ''}`;
};
const marketingVisualSubClass = (subsection: string) => {
  const isDefaultMarketing = activeSection === 'marketing' && subsection === 'destacados';
  return `pz-admin-sidebar__settings-subitem${isDefaultMarketing ? ' is-active' : ''}`;
};
---

<aside
  id="pz-admin-sidebar"
  class="pz-admin-sidebar"
  data-admin-sidebar-root
  aria-label="Panel lateral de administración"
  aria-hidden="true"
>
  <div class="pz-admin-sidebar__inner">
    <div class="pz-admin-sidebar__brand">
      <span class="pz-admin-sidebar__brand-logo">PZ</span>
      <div>
        <p class="pz-admin-sidebar__brand-title">{storeName || 'PowerZona'}</p>
        <p class="pz-admin-sidebar__brand-subtitle">Admin Panel</p>
        <div class="pz-admin-sidebar__plan" aria-label="Información del plan">
          <p><strong>Plan:</strong> {planName || 'Básico'}</p>
          <p><strong>Días restantes:</strong> {daysRemaining ?? '—'}</p>
        </div>
      </div>
      <button class="pz-admin-sidebar__close" type="button" aria-label="Cerrar menú" data-sidebar-close>&times;</button>
    </div>

    <p class="pz-admin-sidebar__section-label">Principal</p>
    <nav class="pz-admin-sidebar__nav-list">
      <a class={navClass('overview')} href={adminBasePath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"/></svg></span><span>Resumen</span></a>
      <a class={navClass('orders')} href={adminOrdersPath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Zm3 5h6V6H9v2Zm0 4h6v-2H9v2Zm0 4h4v-2H9v2Z"/></svg></span><span>Pedidos</span></a>
      <a class={navClass('catalog')} href={adminCatalogPath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3V6Zm0 5h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7Z"/></svg></span><span>Categorías</span></a>
    </nav>

    <p class="pz-admin-sidebar__section-label">Tienda</p>
    <nav class="pz-admin-sidebar__nav-list">
      <a class={navClass('products')} href={adminProductsPath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 7.5 12 3 3 7.5l9 4.5 9-4.5ZM5 10.7V17l6 3v-6.3l-6-3Zm8 9.3 6-3v-6.3l-6 3V20Z"/></svg></span><span>Productos</span></a>
      <a class={navClass('gifts')} href={adminGiftsPath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Regalos</span></a>
      <a class={navClass('shipping')} href={adminShippingPath}><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Zm2 0v7.17A3 3 0 0 1 8.83 16H13V7H5Zm12 6h2v1h-2v-1ZM6 17a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/></svg></span><span>Envíos</span></a>

      <div class="pz-admin-sidebar__settings-group">
        <button class={settingsToggleClass} type="button" aria-expanded={isSettingsActive ? 'true' : 'false'} aria-controls="pz-admin-sidebar-settings-subnav" data-settings-sidebar-toggle><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Ajustes de tienda</span><span class="pz-admin-sidebar__settings-chevron" aria-hidden="true">v</span></button>
        <div id="pz-admin-sidebar-settings-subnav" class={settingsSubnavClass} aria-label="Secciones de ajustes de tienda">
          <a class={subClass('generales')} data-settings-subitem="generales" href={`${adminStoreSettingsPath}#generales`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a7.5 7.5 0 0 0-2.6-1.5L14 2h-4l-.4 2.5A7.5 7.5 0 0 0 7 6L4.6 5l-2 3.5 2 1.5c-.1.5-.1 1-.1 1.5s0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a7.5 7.5 0 0 0 2.6 1.5L10 22h4l.4-2.5A7.5 7.5 0 0 0 17 18l2.4 1 2-3.5-2-1.5ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z"/></svg></span><span>Ajustes generales</span></a>
          <a class={subClass('footer')} data-settings-subitem="footer" href={`${adminStoreSettingsPath}#footer`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 2h9l5 5v15H6V2Zm8 2.5V8h3.5L14 4.5ZM8 11h8v2H8v-2Zm0 4h8v2H8v-2Z"/></svg></span><span>Footer público</span></a>
          <a class={subClass('monedas')} data-settings-subitem="monedas" href={`${adminStoreSettingsPath}#monedas`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M13 3v2.1c2.3.4 4 1.8 4 3.9h-3c0-.8-.8-1.3-2-1.3s-2 .5-2 1.2c0 .8.7 1.1 2.8 1.6 2.8.7 4.7 1.7 4.7 4.3 0 2.1-1.7 3.7-4.5 4.1V21h-2v-2.1c-2.7-.4-4.6-2-4.7-4.4h3c.1 1 1 1.7 2.5 1.7s2.4-.6 2.4-1.4c0-.9-.8-1.2-3-1.8-2.7-.7-4.4-1.7-4.4-4 0-2 1.6-3.5 4.2-3.9V3h2Z"/></svg></span><span>Monedas</span></a>
          <a class={subClass('horario')} data-settings-subitem="horario" href={`${adminStoreSettingsPath}#horario`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5v4.6l3.2 3.2-1.4 1.4L11 12.4V7h2Z"/></svg></span><span>Horarios</span></a>
          <a class={subClass('rating')} data-settings-subitem="rating" href={`${adminStoreSettingsPath}#rating`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 2 2.9 6 6.6.9-4.8 4.7 1.1 6.6L12 17.1l-5.8 3.1 1.1-6.6-4.8-4.7 6.6-.9L12 2Z"/></svg></span><span>Rating y reseñas</span></a>
          <a class={subClass('landing')} data-settings-subitem="landing" href={`${adminStoreSettingsPath}#landing`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 4h7v7H4V4Zm2 2v3h3V6H6Zm7-2h7v7h-7V4Zm2 2v3h3V6h-3ZM4 13h7v7H4v-7Zm2 2v3h3v-3H6Zm9-2h2v2h-2v-2Zm3 0h2v4h-2v-4Zm-5 4h2v3h-2v-3Zm3 1h2v2h-2v-2Zm3 1h1v1h-1v-1Z"/></svg></span><span>Landing QR</span></a>
        </div>
      </div>
    </nav>

    <p class="pz-admin-sidebar__section-label">PROMOS</p>
    <nav class="pz-admin-sidebar__nav-list">
      <div class="pz-admin-sidebar__settings-group">
        <button class={marketingVisualToggleClass} type="button" aria-expanded={isMarketingVisualActive ? 'true' : 'false'} aria-controls="pz-admin-sidebar-marketing-visual-subnav" data-marketing-visual-sidebar-toggle><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v4H5V4Zm0 6h9v4H5v-4Zm0 6h14v4H5v-4Z"/></svg></span><span>Promociones</span><span class="pz-admin-sidebar__settings-chevron" aria-hidden="true">v</span></button>
        <div id="pz-admin-sidebar-marketing-visual-subnav" class={marketingVisualSubnavClass} aria-label="Secciones de marketing y organización visual">
          <a class={marketingVisualSubClass('destacados')} data-marketing-visual-subitem="destacados" href={`${adminPromosPath}#destacados`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 2 2.9 6 6.6.9-4.8 4.7 1.1 6.6L12 17.1l-5.8 3.1 1.1-6.6-4.8-4.7 6.6-.9L12 2Z"/></svg></span><span>Destacados visuales</span></a>
          <a class={marketingVisualSubClass('promociones')} data-marketing-visual-subitem="promociones" href={`${adminPromosPath}#promociones`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 5h16v4H4V5Zm0 6h7v8H4v-8Zm9 0h7v8h-7v-8Zm4.8-7.8 1.4 1.4L5.6 18.2l-1.4-1.4L17.8 3.2Z"/></svg></span><span>Promociones automáticas</span></a>
          <a class={marketingVisualSubClass('cupones')} data-marketing-visual-subitem="cupones" href={`${adminPromosPath}#cupones`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 5h16v5a2 2 0 0 0 0 4v5H4v-5a2 2 0 0 0 0-4V5Zm5 3h2v2H9V8Zm0 4h2v2H9v-2Zm0 4h2v2H9v-2Zm5.5-7.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm0 5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/></svg></span><span>Cupones</span></a>
          <a class={marketingVisualSubClass('cintillo')} data-marketing-visual-subitem="cintillo" href={`${adminPromosPath}#cintillo`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 6h18v5H3V6Zm2 7h14v5H5v-5Zm3-5v1h8V8H8Zm0 7v1h8v-1H8Z"/></svg></span><span>Cintillo promocional</span></a>
          <a class={marketingVisualSubClass('visuales')} data-marketing-visual-subitem="visuales" href={`${adminPromosPath}#visuales`}><span class="pz-admin-sidebar__settings-subicon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z"/></svg></span><span>Accesos rápidos</span></a>
        </div>
      </div>
    </nav>

    <div class="pz-admin-sidebar__bottom">
      <a class="pz-admin-sidebar__action" href={publicStorePath} target="_blank" rel="noopener noreferrer"><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 5c5 0 9 5.2 9 7s-4 7-9 7-9-5.2-9-7 4-7 9-7Zm0 3.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5Z"/></svg></span><span>Ver catálogo público</span></a>
      <button id="logout-btn" class="pz-admin-sidebar__action pz-admin-sidebar__action--danger" type="button"><span class="pz-admin-sidebar__nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10 17v-3H3v-4h7V7l5 5-5 5Zm1-14h8a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-8v-2h8V5h-8V3Z"/></svg></span><span>Cerrar sesión</span></button>
      <div class="pz-admin-sidebar__support-card">
        <strong>Soporte Tu Senda 84</strong>
        <span>¿Necesitas ayuda?</span>
        {masterSupportHref ? (
          <a class="pz-admin-sidebar__support-btn" href={masterSupportHref} target="_blank" rel="noreferrer">Contactar a soporte</a>
        ) : (
          <button class="pz-admin-sidebar__support-btn" type="button" disabled>Contactar a soporte</button>
        )}
      </div>
    </div>
  </div>
</aside>

<header class={mobileTopbarClass} aria-label="Panel superior móvil del admin">
  <button
    id="sidebar-open"
    class="pz-admin-mobile-topbar__menu"
    type="button"
    aria-controls="pz-admin-sidebar"
    aria-expanded="false"
    aria-label="Abrir menú de navegación"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z"></path>
    </svg>
  </button>

  <strong class="pz-admin-mobile-topbar__title">{resolvedMobileTitle}</strong>

  {hasMobileAction && mobileActionHref ? (
    <a
      class="pz-admin-mobile-topbar__action"
      href={mobileActionHref}
      aria-label={resolvedMobileActionAriaLabel}
    >
      {mobileActionLabel}
    </a>
  ) : hasMobileAction ? (
    <button
      class="pz-admin-mobile-topbar__action"
      type="button"
      aria-label={resolvedMobileActionAriaLabel}
      data-pz-mobile-action
      data-pz-mobile-action-target={mobileActionTarget || undefined}
      data-pz-mobile-action-event={mobileActionEvent || undefined}
    >
      {mobileActionLabel}
    </button>
  ) : null}

  <button class="pz-admin-mobile-topbar__notification" type="button" aria-label="Notificaciones" aria-expanded="false" data-pz-admin-notification-trigger>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 22a2.8 2.8 0 0 0 2.7-2h-5.4a2.8 2.8 0 0 0 2.7 2Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"></path>
    </svg>
    <span class="pz-admin-notification-count hidden" data-pz-admin-notification-count></span>
  </button>
</header>

<section
  id="pz-admin-notifications-panel"
  class="pz-admin-notifications-panel hidden"
  role="dialog"
  aria-label="Notificaciones"
  aria-hidden="true"
  data-pz-admin-notifications-panel
>
  <div class="pz-admin-notifications-panel__head">
    <div>
      <h2>Notificaciones</h2>
      <p data-pz-admin-notifications-summary>Avisos importantes de tu tienda</p>
    </div>

    <div class="pz-admin-notifications-panel__actions">
      <a
        href={adminNotificationsPath}
        class="pz-admin-notifications-panel__view-all hidden"
        data-pz-admin-notifications-view-all
      >
        Ver todas
      </a>

      <button type="button" class="pz-admin-notifications-panel__mark-all" data-pz-admin-mark-all>
        Marcar leidas
      </button>

      <button type="button" class="pz-admin-notifications-panel__delete-all" data-pz-admin-archive-all>
        Eliminar todas
      </button>
    </div>
  </div>
  <div class="pz-admin-notifications-panel__body" data-pz-admin-notifications-list>
    <p class="pz-admin-notifications-empty">Cargando notificaciones...</p>
  </div>
</section>

{hasMobileBack && (
  <a
    class="pz-admin-mobile-back-link"
    href={mobileBackHref}
    data-pz-admin-mobile-back
    aria-label={mobileBackLabel}
  >
    <span class="pz-admin-mobile-back-link__icon" aria-hidden="true">←</span>
    <span>{mobileBackLabel}</span>
  </a>
)}

<nav class="pz-admin-mobile-bottom-nav" aria-label="Navegación móvil principal del admin">
  <a class={mobileBottomClass('overview')} href={adminBasePath}>
    <span class="pz-admin-mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"></path>
      </svg>
    </span>
    <span>Resumen</span>
  </a>

  <a class={mobileBottomClass('orders')} href={adminOrdersPath}>
    <span class="pz-admin-mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Zm3 5h6V6H9v2Zm0 4h6v-2H9v2Zm0 4h4v-2H9v2Z"></path>
      </svg>
    </span>
    <span>Pedidos</span>
  </a>

  <a class={mobileBottomClass('shipping')} href={adminShippingPath}>
    <span class="pz-admin-mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Zm2 0v7.17A3 3 0 0 1 8.83 16H13V7H5Zm12 6h2v1h-2v-1ZM6 17a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"></path>
      </svg>
    </span>
    <span>Envíos</span>
  </a>

  <a class={mobileBottomClass('settings')} href={adminStoreSettingsPath}>
    <span class="pz-admin-mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a7.5 7.5 0 0 0-2.6-1.5L14 2h-4l-.4 2.5A7.5 7.5 0 0 0 7 6L4.6 5l-2 3.5 2 1.5c-.1.5-.1 1-.1 1.5s0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a7.5 7.5 0 0 0 2.6 1.5L10 22h4l.4-2.5A7.5 7.5 0 0 0 17 18l2.4 1 2-3.5-2-1.5ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z"></path>
      </svg>
    </span>
    <span>Ajustes</span>
  </a>
</nav>

<div id="pz-admin-toast-root" class="pz-admin-toast-root" aria-live="polite" aria-atomic="true"></div>

<div id="pz-admin-confirm-overlay" class="pz-admin-confirm-overlay hidden" aria-hidden="true">
  <section
    class="pz-admin-confirm-card"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pz-admin-confirm-title"
    aria-describedby="pz-admin-confirm-message"
  >
    <button id="pz-admin-confirm-close" class="pz-admin-confirm-close" type="button" aria-label="Cerrar">&times;</button>
    <p id="pz-admin-confirm-kicker" class="pz-admin-confirm-kicker">Confirmar accion</p>
    <h2 id="pz-admin-confirm-title" class="pz-admin-confirm-title">Eliminar</h2>
    <p id="pz-admin-confirm-message" class="pz-admin-confirm-message">Esta accion no se puede deshacer.</p>
    <div class="pz-admin-confirm-actions">
      <button id="pz-admin-confirm-cancel" class="pz-admin-confirm-btn pz-admin-confirm-btn--secondary" type="button">Cancelar</button>
      <button id="pz-admin-confirm-submit" class="pz-admin-confirm-btn pz-admin-confirm-btn--danger" type="button">Eliminar</button>
    </div>
  </section>
</div>

<script define:vars={{ storeId, pocketbaseUrl, authToken, notificationsAdminOrdersPath, notificationsAdminProductsPath, adminNotificationsPath }}>
  window.PZ_ADMIN_NOTIFICATIONS_CONFIG = {
    storeId: String(storeId || ''),
    pocketbaseUrl: String(pocketbaseUrl || '').replace(/\/$/, ''),
    authToken: String(authToken || ''),
    ordersPath: String(notificationsAdminOrdersPath || ''),
    productsPath: String(notificationsAdminProductsPath || ''),
    notificationsPath: String(adminNotificationsPath || ''),
  };
</script>

<script>
  import {
    loadNotifications,
    loadVisibleNotificationCount,
    loadUnreadNotificationPrioritySummary,
    markNotificationRead,
    archiveNotification,
    archiveAllNotifications,
    markAllNotificationsRead,
    ensureStoreNotificationAnyStatus,
    findStoreNotificationAnyStatus,
    ensureStoreNotificationAfterSourceChange,
    deleteArchivedNotificationsBefore,
  } from '../../lib/adminNotifications.js';

  (() => {
    if (window.__pzAdminNotificationsReady) return;
    window.__pzAdminNotificationsReady = true;

    const config = window.PZ_ADMIN_NOTIFICATIONS_CONFIG || {};
    const storeId = String(config.storeId || '');
    const baseUrl = String(config.pocketbaseUrl || '').replace(/\/$/, '');
    const token = String(config.authToken || '');
    const ordersPath = String(config.ordersPath || '');
    const productsPath = String(config.productsPath || '');
    const notificationsPath = String(config.notificationsPath || '');
    const pb = { baseUrl, token };
    const panel = document.querySelector('[data-pz-admin-notifications-panel]');
    const list = document.querySelector('[data-pz-admin-notifications-list]');
    const markAllButton = document.querySelector('[data-pz-admin-mark-all]');
    const viewAllLink = document.querySelector('[data-pz-admin-notifications-view-all]');
    const archiveAllButton = document.querySelector('[data-pz-admin-archive-all]');
    const panelSummary = document.querySelector('[data-pz-admin-notifications-summary]');
    let isOpen = false;
    let isLoading = false;

    if (!panel || !list || !storeId || !baseUrl) return;

    function escapeHtml(value) {
      return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    function escapeFilterValue(value) {
      return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
    }

    async function api(path, options = {}) {
      const headers = Object.assign({}, options.headers || {});
      if (token) headers.Authorization = `Bearer ${token}`;
      const response = await fetch(`${baseUrl}${path}`, Object.assign({}, options, { headers }));
      const result = await response.json().catch(() => null);
      if (!response.ok) throw new Error(result?.message || 'PocketBase request failed.');
      return result;
    }

    function setButtonsExpanded(value) {
      document.querySelectorAll('[data-pz-admin-notification-trigger]').forEach((button) => {
        button.setAttribute('aria-expanded', value ? 'true' : 'false');
      });
    }

    function timeAgo(value) {
      const date = value ? new Date(value) : null;
      const diff = date && !Number.isNaN(date.getTime()) ? Date.now() - date.getTime() : 0;
      const minutes = Math.max(0, Math.floor(diff / 60000));
      if (minutes < 1) return 'Ahora';
      if (minutes < 60) return `Hace ${minutes} min`;
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return `Hace ${hours} h`;
      const days = Math.floor(hours / 24);
      return `Hace ${days} d`;
    }

    function iconFor(type) {
      if (type === 'new_order') return '$';
      if (type === 'pending_order') return '!';
      if (type === 'low_stock') return '📦';
      if (type === 'out_of_stock') return '⛔';
      if (String(type || '').includes('expired')) return '⚠️';
      if (String(type || '').includes('expiring')) return '⏳';
      return 'i';
    }

    function normalizePriority(priority) {
      return ['normal', 'important', 'critical'].includes(priority) ? priority : 'normal';
    }

    function priorityLabel(priority) {
      const value = normalizePriority(priority);
      if (value === 'critical') return 'Alta prioridad';
      if (value === 'important') return 'Importante';
      return 'Normal';
    }

    function formatNotificationUsd(value) {
      const amount = Math.max(0, Number(value || 0));
      return `$${amount.toFixed(2)} USD`;
    }

    function getOrderProductsSubtotalUSD(order) {
      const candidates = [
        order?.subtotal_after_discount_usd,
        order?.subtotal,
        order?.subtotal_original_usd,
      ];

      for (const candidate of candidates) {
        const value = Number(candidate || 0);
        if (value > 0) return value;
      }

      const total = Number(order?.usd_total || order?.total || 0);
      const shipping = Number(order?.shipping || order?.shipping_usd || order?.shipping_original_usd || 0);
      return Math.max(0, total - shipping);
    }

    function getNotificationPrioritySettings(settings = {}) {
      const importantMin = Math.max(0, Number(settings?.notification_priority_important_min_usd ?? 50));
      const criticalRaw = Math.max(0, Number(settings?.notification_priority_critical_min_usd ?? 100));
      const criticalMin = Math.max(importantMin, criticalRaw);

      return {
        enabled: settings?.notification_priority_enabled !== false,
        importantMin,
        criticalMin,
        showOrderSubtotal: settings?.notification_show_order_subtotal !== false,
        bellPriorityColors: settings?.notification_bell_priority_colors !== false,
      };
    }

    function getOrderNotificationPriority(order, settings, fallback = 'important') {
      const config = getNotificationPrioritySettings(settings);
      if (!config.enabled) return normalizePriority(fallback);

      const subtotal = getOrderProductsSubtotalUSD(order);
      if (subtotal >= config.criticalMin) return 'critical';
      if (subtotal >= config.importantMin) return 'important';
      return 'normal';
    }

    function buildOrderProductsText(order, settings) {
      const config = getNotificationPrioritySettings(settings);
      if (!config.showOrderSubtotal) return '';

      const subtotal = getOrderProductsSubtotalUSD(order);
      if (subtotal <= 0) return '';

      return ` - Productos: ${formatNotificationUsd(subtotal)} sin envio`;
    }

    function buildOrderUrl(orderId) {
      if (!orderId) return ordersPath || '';
      return `${ordersPath.replace(/\/$/, '')}/${encodeURIComponent(orderId)}`;
    }

    function getOrderNotificationUrl(item) {
      const entityCollection = String(item?.entityCollection || item?.raw?.entity_collection || '');
      const entityId = String(item?.entityId || item?.raw?.entity_id || '');

      if (entityCollection === 'orders' && entityId) {
        return buildOrderUrl(entityId);
      }

      return String(item?.targetUrl || '');
    }

    function getInventoryNotificationSettings(settings = {}) {
      const daysBefore = Math.max(1, Number(settings?.product_expiring_days_before ?? 30));
      const criticalRaw = Math.max(0, Number(settings?.product_expiring_critical_days ?? 7));
      const criticalDays = Math.min(daysBefore, criticalRaw);
      const lowStockThreshold = Math.max(1, Number(settings?.low_stock_threshold ?? 3));

      return {
        productExpiring: settings?.notify_product_expiring !== false,
        productExpired: settings?.notify_product_expired !== false,
        variationExpiration: settings?.notify_variation_expiration !== false,
        lowStock: settings?.notify_low_stock !== false,
        outOfStock: settings?.notify_out_of_stock !== false,
        daysBefore,
        criticalDays,
        lowStockThreshold,
      };
    }

    function normalizeDateOnly(value) {
      if (!value) return null;
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return null;
      date.setHours(0, 0, 0, 0);
      return date;
    }

    function daysUntilDate(value) {
      const target = normalizeDateOnly(value);
      if (!target) return null;

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      return Math.ceil((target.getTime() - today.getTime()) / 86400000);
    }

    function formatDateOnly(value) {
      const date = normalizeDateOnly(value);
      if (!date) return 'Sin fecha';
      return date.toLocaleDateString('es-US', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
      });
    }

    function expirationDaysText(daysLeft) {
      if (daysLeft === null || daysLeft === undefined) return '';
      if (daysLeft < 0) return `venció hace ${Math.abs(daysLeft)} día${Math.abs(daysLeft) === 1 ? '' : 's'}`;
      if (daysLeft === 0) return 'vence hoy';
      if (daysLeft === 1) return 'vence mañana';
      return `vence en ${daysLeft} días`;
    }

    function productTracksStockRecord(product = {}) {
      if (Object.prototype.hasOwnProperty.call(product, 'track_stock')) return product.track_stock !== false;
      return true;
    }

    function stockNumber(value) {
      return Math.max(0, Math.floor(Number(value || 0)));
    }

    function buildProductAdminUrl(productId) {
      if (!productId || !productsPath) return productsPath || '';
      return `${productsPath}?product=${encodeURIComponent(productId)}`;
    }

    function buildVariationAdminUrl(productId, variationId) {
      if (!productId || !productsPath) return productsPath || '';
      const url = new URL(productsPath, window.location.origin);
      url.searchParams.set('product', productId);
      if (variationId) url.searchParams.set('variation', variationId);
      return `${url.pathname}${url.search}`;
    }

    async function loadAllCollectionRecords(collectionName, query = {}) {
      const params = new URLSearchParams();
      Object.entries(query || {}).forEach(([key, value]) => {
        if (value !== undefined && value !== null && String(value) !== '') {
          params.set(key, String(value));
        }
      });

      params.set('page', '1');
      params.set('perPage', String(query.perPage || 200));

      let page = 1;
      let totalPages = 1;
      const items = [];

      do {
        params.set('page', String(page));
        const result = await api(`/api/collections/${collectionName}/records?${params.toString()}`);
        items.push(...(result.items || []));
        totalPages = Number(result.totalPages || 1);
        page += 1;
      } while (page <= totalPages && page <= 20);

      return items;
    }

    function setUnreadState(summary, settings = {}) {
      const count = Number(summary?.count || 0);
      const config = getNotificationPrioritySettings(settings);
      const highestPriority = count > 0 && config.bellPriorityColors
        ? normalizePriority(summary?.highestPriority || 'normal')
        : 'normal';

      const paintedPriority = highestPriority === 'important' || highestPriority === 'critical'
        ? highestPriority
        : '';

      document.querySelectorAll('[data-pz-admin-notification-trigger]').forEach((button) => {
        button.classList.remove('priority-normal', 'priority-important', 'priority-critical');
        button.classList.toggle('has-unread', count > 0);

        if (paintedPriority) {
          button.classList.add(`priority-${paintedPriority}`);
          button.setAttribute('data-pz-notification-priority', paintedPriority);
        } else {
          button.removeAttribute('data-pz-notification-priority');
        }
      });

      document.querySelectorAll('[data-pz-admin-notification-count]').forEach((badge) => {
        badge.classList.remove('priority-normal', 'priority-important', 'priority-critical');
        badge.textContent = count > 99 ? '99+' : String(count);
        badge.classList.toggle('hidden', count <= 0);

        if (paintedPriority) {
          badge.classList.add(`priority-${paintedPriority}`);
          badge.setAttribute('data-pz-notification-priority', paintedPriority);
        } else {
          badge.removeAttribute('data-pz-notification-priority');
        }
      });
    }

    function setPanelSummary({ total = 0, shown = 0 } = {}) {
      const totalValue = Number(total || 0);
      const shownValue = Number(shown || 0);

      if (panelSummary) {
        panelSummary.textContent = totalValue > 12
          ? `Mostrando ${shownValue} de ${totalValue}`
          : 'Avisos importantes de tu tienda';
      }

      if (viewAllLink) {
        viewAllLink.classList.toggle('hidden', totalValue <= 12);
        if (notificationsPath) viewAllLink.setAttribute('href', notificationsPath);
      }
    }

    function render(items) {
      if (!items.length) {
        list.innerHTML = '<p class="pz-admin-notifications-empty">No hay notificaciones nuevas.</p>';
        return;
      }
      list.innerHTML = items.map((item) => {
        const priority = normalizePriority(item.priority);
        const unreadClass = item.status === 'unread' ? ' is-unread' : '';
        const priorityClass = ` priority-${priority}`;
        const openUrl = getOrderNotificationUrl(item);
        const openAction = openUrl
          ? `<a href="${escapeHtml(openUrl)}" data-pz-notification-open="${escapeHtml(item.id)}">Abrir</a>`
          : '';
        const readAction = item.status === 'unread'
          ? `<button type="button" data-pz-notification-read="${escapeHtml(item.id)}">Marcar leida</button>`
          : '';
        const archiveAction = `<button type="button" class="pz-admin-notification-delete" data-pz-notification-archive="${escapeHtml(item.id)}" aria-label="Eliminar notificacion">Eliminar</button>`;
        const priorityBadge = `<span class="pz-admin-notification-priority is-${escapeHtml(priority)}">${escapeHtml(priorityLabel(priority))}</span>`;
        return `
          <article class="pz-admin-notification-item${unreadClass}${priorityClass}" data-pz-notification-id="${escapeHtml(item.id)}">
            <span class="pz-admin-notification-icon" aria-hidden="true">${escapeHtml(iconFor(item.type))}</span>
            <div class="pz-admin-notification-content">
              <h3 class="pz-admin-notification-title">${escapeHtml(item.title)}</h3>
              <p class="pz-admin-notification-message">${escapeHtml(item.message)}</p>
              <div class="pz-admin-notification-meta">
                ${priorityBadge}
                <span class="pz-admin-notification-time">${escapeHtml(timeAgo(item.created))}</span>
              </div>
              <div class="pz-admin-notification-actions">${openAction}${readAction}${archiveAction}</div>
            </div>
          </article>
        `;
      }).join('');
    }

    async function loadAll({ detectNewOrders = false, detectPending = false } = {}) {
      if (isLoading) return;
      isLoading = true;
      try {
        const settings = await loadSettings();

        if (detectPending) {
          await runNotificationCleanup(settings);
        }

        if (detectNewOrders || detectPending) {
          await detectMissingNewOrderNotifications(settings);
        }
        if (detectPending) {
          await detectPendingOrders(settings);
          await detectInventoryNotifications(settings);
        }

        const [items, unreadSummary, visibleCount] = await Promise.all([
          loadNotifications({ pb, storeId, limit: 12 }),
          loadUnreadNotificationPrioritySummary({ pb, storeId }),
          loadVisibleNotificationCount({ pb, storeId }),
        ]);

        render(items);
        setUnreadState(unreadSummary, settings);
        setPanelSummary({ total: visibleCount, shown: items.length });
      } catch (error) {
        list.innerHTML = '<p class="pz-admin-notifications-empty">No se pudieron cargar las notificaciones.</p>';
      } finally {
        isLoading = false;
      }
    }

    async function loadSettings() {
      const filter = encodeURIComponent(`active = true && store="${escapeFilterValue(storeId)}"`);
      const result = await api(`/api/collections/settings/records?filter=${filter}&sort=-updated&perPage=1`);
      return (result.items || [])[0] || null;
    }

    function shouldRunNotificationCleanup(settings = {}) {
      if (!settings || settings.notification_cleanup_enabled === false) return false;

      const lastRun = settings.notification_cleanup_last_run_at
        ? new Date(settings.notification_cleanup_last_run_at)
        : null;

      if (!lastRun || Number.isNaN(lastRun.getTime())) return true;

      const elapsed = Date.now() - lastRun.getTime();
      return elapsed >= 23 * 60 * 60 * 1000;
    }

    async function updateNotificationCleanupLastRun(settingsId, dateIso) {
      if (!settingsId) return;

      await api(`/api/collections/settings/records/${encodeURIComponent(settingsId)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          notification_cleanup_last_run_at: dateIso,
        }),
      });
    }

    async function runNotificationCleanup(settings = {}) {
      try {
        if (!settings?.id) return;
        if (!shouldRunNotificationCleanup(settings)) return;

        const days = Math.max(1, Math.min(365, Number(settings.notification_cleanup_days || 15)));
        const cutoffIso = new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString();

        await deleteArchivedNotificationsBefore({
          pb,
          storeId,
          cutoffIso,
        });

        await updateNotificationCleanupLastRun(settings.id, new Date().toISOString());
      } catch (error) {
      }
    }

    async function detectPendingOrders(settingsRecord = null) {
      try {
        const settings = settingsRecord || await loadSettings();
        if (!settings || settings.notifications_enabled === false || settings.notify_pending_order === false) return;

        const hours = Math.max(1, Number(settings.pending_order_hours || 2));
        const cutoff = new Date(Date.now() - hours * 60 * 60 * 1000).toISOString();
        const filter = encodeURIComponent(`store="${escapeFilterValue(storeId)}" && status="pending" && created <= "${cutoff}"`);
        const result = await api(`/api/collections/orders/records?filter=${filter}&sort=created&perPage=50`);
        const orders = result.items || [];

        await Promise.all(orders.map(async (order) => {
          const existingNewOrderNotification = await findStoreNotificationAnyStatus({
            pb,
            storeId,
            type: 'new_order',
            entityCollection: 'orders',
            entityId: order.id,
          });

          if (existingNewOrderNotification) return null;

          const orderNumber = order.order_number || order.id;
          const productsSubtotalUSD = getOrderProductsSubtotalUSD(order);
          const priority = getOrderNotificationPriority(order, settings, 'important');
          const productsText = buildOrderProductsText(order, settings);

          return ensureStoreNotificationAnyStatus({
            pb,
            storeId,
            type: 'pending_order',
            entityCollection: 'orders',
            entityId: order.id,
            title: 'Pedido pendiente sin atender',
            message: `Pedido #${orderNumber} lleva mas de ${hours} horas pendiente${productsText}.`,
            priority,
            targetUrl: buildOrderUrl(order.id),
            metadata: {
              order_number: order.order_number || '',
              hours,
              products_subtotal_usd: productsSubtotalUSD,
              shipping_excluded: true,
              priority_rule: priority,
            },
          });
        }));
      } catch (error) {
      }
    }

    async function detectMissingNewOrderNotifications(settingsRecord = null) {
      try {
        const settings = settingsRecord || await loadSettings();

        if (settings?.notifications_enabled === false || settings?.notify_new_order === false) return;

        const since = new Date(Date.now() - 48 * 60 * 60 * 1000).toISOString();
        const filter = encodeURIComponent(`store="${escapeFilterValue(storeId)}" && created >= "${since}"`);
        const result = await api(`/api/collections/orders/records?filter=${filter}&sort=-created&perPage=50`);
        const orders = result.items || [];

        await Promise.all(orders.map((order) => {
          const orderNumber = order.order_number || order.id;
          const customerName = order.customer_name || order.name || 'cliente';
          const productsSubtotalUSD = getOrderProductsSubtotalUSD(order);
          const priority = getOrderNotificationPriority(order, settings, 'important');
          const productsText = buildOrderProductsText(order, settings);

          return ensureStoreNotificationAnyStatus({
            pb,
            storeId,
            type: 'new_order',
            entityCollection: 'orders',
            entityId: order.id,
            title: 'Nuevo pedido recibido',
            message: `Pedido #${orderNumber} por ${customerName}${productsText}`,
            priority,
            targetUrl: buildOrderUrl(order.id),
            metadata: {
              order_number: order.order_number || '',
              customer_name: customerName,
              products_subtotal_usd: productsSubtotalUSD,
              shipping_excluded: true,
              priority_rule: priority,
            },
          });
        }));
      } catch (error) {
      }
    }

    async function detectProductExpirationNotifications(settingsRecord = null, products = []) {
      const settings = settingsRecord || await loadSettings();
      if (!settings || settings.notifications_enabled === false) return;

      const config = getInventoryNotificationSettings(settings);
      if (!config.productExpiring && !config.productExpired) return;

      await Promise.all(products.map((product) => {
        const daysLeft = daysUntilDate(product.expiration_date);
        if (daysLeft === null) return null;

        const name = product.name || 'Producto sin nombre';
        const formattedDate = formatDateOnly(product.expiration_date);
        const visibleText = product.active !== false ? ' · Visible en tienda' : ' · Oculto';
        const stockText = productTracksStockRecord(product) ? ` · Stock: ${stockNumber(product.stock)}` : '';

        let type = '';
        let title = '';
        let message = '';
        let priority = 'important';

        if (daysLeft < 0) {
          if (!config.productExpired) return null;
          type = 'product_expired';
          title = 'Producto vencido';
          message = `${name} está vencido desde ${formattedDate}${stockText}${visibleText}.`;
          priority = 'critical';
        } else if (daysLeft <= config.criticalDays) {
          if (!config.productExpiring) return null;
          type = 'product_expiring_critical';
          title = 'Producto por vencer urgente';
          message = `${name} ${expirationDaysText(daysLeft)} · Vence: ${formattedDate}${stockText}${visibleText}.`;
          priority = 'critical';
        } else if (daysLeft <= config.daysBefore) {
          if (!config.productExpiring) return null;
          type = 'product_expiring_soon';
          title = 'Producto próximo a vencer';
          message = `${name} ${expirationDaysText(daysLeft)} · Vence: ${formattedDate}${stockText}${visibleText}.`;
          priority = 'important';
        } else {
          return null;
        }

        return ensureStoreNotificationAfterSourceChange({
          pb,
          storeId,
          type,
          entityCollection: 'products',
          entityId: product.id,
          title,
          message,
          priority,
          targetUrl: buildProductAdminUrl(product.id),
          sourceUpdated: product.updated || product.created || '',
          metadata: {
            product_id: product.id,
            product_name: name,
            expiration_date: product.expiration_date || '',
            days_left: daysLeft,
            stock: stockNumber(product.stock),
            visible: product.active !== false,
          },
        });
      }));
    }

    async function detectVariationExpirationNotifications(settingsRecord = null, products = [], variations = []) {
      const settings = settingsRecord || await loadSettings();
      if (!settings || settings.notifications_enabled === false) return;

      const config = getInventoryNotificationSettings(settings);
      if (!config.variationExpiration) return;

      const productById = new Map(products.map((product) => [product.id, product]));

      await Promise.all(variations.map((variation) => {
        const daysLeft = daysUntilDate(variation.expiration_date);
        if (daysLeft === null) return null;

        const product = productById.get(variation.product) || variation.expand?.product || null;
        if (!product) return null;

        const productName = product.name || 'Producto';
        const variationName = `${variation.variation_type || 'Variación'}: ${variation.value || 'Sin valor'}`;
        const formattedDate = formatDateOnly(variation.expiration_date);
        const visibleText = product.active !== false && variation.active !== false ? ' · Visible en tienda' : ' · Oculta';
        const stockText = ` · Stock: ${stockNumber(variation.stock)}`;

        let type = '';
        let title = '';
        let message = '';
        let priority = 'important';

        if (daysLeft < 0) {
          if (!config.productExpired) return null;
          type = 'variation_expired';
          title = 'Variación vencida';
          message = `${productName} · ${variationName} está vencida desde ${formattedDate}${stockText}${visibleText}.`;
          priority = 'critical';
        } else if (daysLeft <= config.criticalDays) {
          type = 'variation_expiring_critical';
          title = 'Variación por vencer urgente';
          message = `${productName} · ${variationName} ${expirationDaysText(daysLeft)} · Vence: ${formattedDate}${stockText}${visibleText}.`;
          priority = 'critical';
        } else if (daysLeft <= config.daysBefore) {
          type = 'variation_expiring_soon';
          title = 'Variación próxima a vencer';
          message = `${productName} · ${variationName} ${expirationDaysText(daysLeft)} · Vence: ${formattedDate}${stockText}${visibleText}.`;
          priority = 'important';
        } else {
          return null;
        }

        return ensureStoreNotificationAfterSourceChange({
          pb,
          storeId,
          type,
          entityCollection: 'product_variations',
          entityId: variation.id,
          title,
          message,
          priority,
          targetUrl: buildVariationAdminUrl(product.id, variation.id),
          sourceUpdated: variation.updated || variation.created || '',
          metadata: {
            product_id: product.id,
            product_name: productName,
            variation_id: variation.id,
            variation_name: variationName,
            expiration_date: variation.expiration_date || '',
            days_left: daysLeft,
            stock: stockNumber(variation.stock),
            visible: product.active !== false && variation.active !== false,
          },
        });
      }));
    }

    async function detectProductStockNotifications(settingsRecord = null, products = []) {
      const settings = settingsRecord || await loadSettings();
      if (!settings || settings.notifications_enabled === false) return;

      const config = getInventoryNotificationSettings(settings);
      if (!config.lowStock && !config.outOfStock) return;

      await Promise.all(products.map((product) => {
        if (!productTracksStockRecord(product)) return null;
        if (product.has_variations === true) return null;

        const stock = stockNumber(product.stock);
        const name = product.name || 'Producto sin nombre';
        const visible = product.active !== false;
        const preorder = Boolean(product.allow_preorder);

        if (stock <= 0) {
          if (!config.outOfStock) return null;

          return ensureStoreNotificationAfterSourceChange({
            pb,
            storeId,
            type: 'out_of_stock',
            entityCollection: 'products',
            entityId: product.id,
            title: 'Producto agotado',
            message: `${name} está agotado${preorder ? ' y permite preorder' : ''}${visible ? ' · Visible en tienda.' : ' · Oculto.'}`,
            priority: visible && !preorder ? 'critical' : 'important',
            targetUrl: buildProductAdminUrl(product.id),
            sourceUpdated: product.updated || product.created || '',
            metadata: {
              product_id: product.id,
              product_name: name,
              stock,
              visible,
              preorder,
            },
          });
        }

        if (stock <= config.lowStockThreshold) {
          if (!config.lowStock) return null;

          return ensureStoreNotificationAfterSourceChange({
            pb,
            storeId,
            type: 'low_stock',
            entityCollection: 'products',
            entityId: product.id,
            title: 'Stock bajo',
            message: `${name} tiene ${stock} unidad${stock === 1 ? '' : 'es'} disponible${stock === 1 ? '' : 's'}.`,
            priority: 'important',
            targetUrl: buildProductAdminUrl(product.id),
            sourceUpdated: product.updated || product.created || '',
            metadata: {
              product_id: product.id,
              product_name: name,
              stock,
              threshold: config.lowStockThreshold,
              visible,
            },
          });
        }

        return null;
      }));
    }

    async function detectVariationStockNotifications(settingsRecord = null, products = [], variations = []) {
      const settings = settingsRecord || await loadSettings();
      if (!settings || settings.notifications_enabled === false) return;

      const config = getInventoryNotificationSettings(settings);
      if (!config.lowStock && !config.outOfStock) return;

      const productById = new Map(products.map((product) => [product.id, product]));

      await Promise.all(variations.map((variation) => {
        const product = productById.get(variation.product) || variation.expand?.product || null;
        if (!product) return null;
        if (product.has_variations !== true) return null;
        if (!productTracksStockRecord(product)) return null;

        const stock = stockNumber(variation.stock);
        const productName = product.name || 'Producto';
        const variationName = `${variation.variation_type || 'Variación'}: ${variation.value || 'Sin valor'}`;
        const visible = product.active !== false && variation.active !== false;
        const preorder = Boolean(variation.allow_preorder);

        if (stock <= 0) {
          if (!config.outOfStock) return null;

          return ensureStoreNotificationAfterSourceChange({
            pb,
            storeId,
            type: 'out_of_stock',
            entityCollection: 'product_variations',
            entityId: variation.id,
            title: 'Variación agotada',
            message: `${productName} · ${variationName} está agotada${preorder ? ' y permite preorder' : ''}${visible ? ' · Visible en tienda.' : ' · Oculta.'}`,
            priority: visible && !preorder ? 'critical' : 'important',
            targetUrl: buildVariationAdminUrl(product.id, variation.id),
            sourceUpdated: variation.updated || variation.created || '',
            metadata: {
              product_id: product.id,
              product_name: productName,
              variation_id: variation.id,
              variation_name: variationName,
              stock,
              visible,
              preorder,
            },
          });
        }

        if (stock <= config.lowStockThreshold) {
          if (!config.lowStock) return null;

          return ensureStoreNotificationAfterSourceChange({
            pb,
            storeId,
            type: 'low_stock',
            entityCollection: 'product_variations',
            entityId: variation.id,
            title: 'Stock bajo de variación',
            message: `${productName} · ${variationName} tiene ${stock} unidad${stock === 1 ? '' : 'es'} disponible${stock === 1 ? '' : 's'}.`,
            priority: 'important',
            targetUrl: buildVariationAdminUrl(product.id, variation.id),
            sourceUpdated: variation.updated || variation.created || '',
            metadata: {
              product_id: product.id,
              product_name: productName,
              variation_id: variation.id,
              variation_name: variationName,
              stock,
              threshold: config.lowStockThreshold,
              visible,
            },
          });
        }

        return null;
      }));
    }

    async function detectInventoryNotifications(settingsRecord = null) {
      try {
        const settings = settingsRecord || await loadSettings();
        if (!settings || settings.notifications_enabled === false) return;

        const products = await loadAllCollectionRecords('products', {
          filter: `store="${escapeFilterValue(storeId)}"`,
          sort: 'expiration_date',
          perPage: 200,
        });

        const productIds = new Set(products.map((product) => product.id).filter(Boolean));

        const variationsRaw = await loadAllCollectionRecords('product_variations', {
          sort: 'expiration_date',
          expand: 'product',
          perPage: 200,
        });

        const variations = variationsRaw.filter((variation) => {
          if (productIds.has(variation.product)) return true;
          return variation.expand?.product?.store === storeId;
        });

        await detectProductExpirationNotifications(settings, products);
        await detectVariationExpirationNotifications(settings, products, variations);
        await detectProductStockNotifications(settings, products);
        await detectVariationStockNotifications(settings, products, variations);
      } catch (error) {
      }
    }

    function positionPanel(button) {
      const isMobile = window.matchMedia('(max-width: 1023px)').matches;
      if (isMobile || !button) {
        panel.style.top = '';
        panel.style.left = '';
        panel.style.right = '';
        return;
      }
      const rect = button.getBoundingClientRect();
      const width = Math.min(360, window.innerWidth - 24);
      const left = Math.max(12, Math.min(window.innerWidth - width - 12, rect.right - width));
      panel.style.top = `${Math.round(rect.bottom + 10)}px`;
      panel.style.left = `${Math.round(left)}px`;
      panel.style.right = 'auto';
    }

    function openPanel(button) {
      isOpen = true;
      positionPanel(button);
      panel.classList.remove('hidden');
      panel.setAttribute('aria-hidden', 'false');
      setButtonsExpanded(true);
      loadAll({ detectNewOrders: true, detectPending: true }).catch((error) => {
      });
    }

    function closePanel() {
      isOpen = false;
      panel.classList.add('hidden');
      panel.setAttribute('aria-hidden', 'true');
      setButtonsExpanded(false);
    }

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const trigger = target?.closest('[data-pz-admin-notification-trigger]');
      if (trigger) {
        event.preventDefault();
        event.stopPropagation();
        isOpen ? closePanel() : openPanel(trigger);
        return;
      }
      if (target?.closest('[data-pz-admin-notifications-panel]')) return;
      if (isOpen) closePanel();
    });

    list.addEventListener('click', async (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const readButton = target?.closest('[data-pz-notification-read]');
      const archiveButton = target?.closest('[data-pz-notification-archive]');
      const openLink = target?.closest('[data-pz-notification-open]');
      if (readButton) {
        event.preventDefault();
        await markNotificationRead({ pb, notificationId: readButton.getAttribute('data-pz-notification-read') || '' });
        await loadAll();
      } else if (archiveButton) {
        event.preventDefault();
        await archiveNotification({ pb, notificationId: archiveButton.getAttribute('data-pz-notification-archive') || '' });
        await loadAll();
      } else if (openLink) {
        await markNotificationRead({ pb, notificationId: openLink.getAttribute('data-pz-notification-open') || '' });
      }
    });

    markAllButton?.addEventListener('click', async () => {
      await markAllNotificationsRead({ pb, storeId });
      await loadAll();
    });

    archiveAllButton?.addEventListener('click', async () => {
      const confirmed = window.confirm('Eliminar todas las notificaciones? Se archivaran y dejaran de mostrarse en la campana.');
      if (!confirmed) return;

      archiveAllButton.disabled = true;
      archiveAllButton.textContent = 'Eliminando...';

      try {
        await archiveAllNotifications({ pb, storeId });
        await loadAll();
      } finally {
        archiveAllButton.disabled = false;
        archiveAllButton.textContent = 'Eliminar todas';
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen) closePanel();
    });
    window.addEventListener('resize', () => {
      if (isOpen) positionPanel(document.querySelector('[data-pz-admin-notification-trigger][aria-expanded="true"]'));
    });
    window.addEventListener('focus', () => {
      loadAll({ detectNewOrders: true, detectPending: true }).catch((error) => {
      });
    });

    loadAll({ detectNewOrders: true, detectPending: true }).catch((error) => {
    });
    window.setInterval(() => {
      loadAll({ detectNewOrders: true, detectPending: false }).catch((error) => {
      });
    }, 30000);
  })();
</script>

<script is:inline>
  (() => {
    if (window.__pzAdminSidebarReady) return;
    window.__pzAdminSidebarReady = true;

    const getSidebar = () => document.querySelector('[data-admin-sidebar-root]');
    const getOverlay = () => {
      let overlay = document.getElementById('sidebar-overlay');
      if (!overlay && document.body) {
        overlay = document.createElement('div');
        overlay.id = 'sidebar-overlay';
        overlay.className = 'sidebar-overlay';
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.body.appendChild(overlay);
      }
      return overlay;
    };
    const openButtons = ['#sidebar-open', '#sidebar-open-legacy', '#sidebar-open-btn', '[data-sidebar-open]'];
    const isMobileSidebar = () => window.matchMedia('(max-width: 1023px)').matches;

    const setExpanded = (value) => {
      openButtons.forEach((selector) => {
        document.querySelectorAll(selector).forEach((button) => button.setAttribute('aria-expanded', value ? 'true' : 'false'));
      });
    };

    const moveFocusOutOfSidebar = (sidebar) => {
      if (!sidebar || !sidebar.contains(document.activeElement)) return;

      const mobileButton = document.getElementById('sidebar-open')
        || document.querySelector('[data-admin-sidebar-toggle]')
        || document.querySelector('.pz-admin-mobile-topbar__menu')
        || document.querySelector('.pz-admin-mobile-menu-btn');

      if (mobileButton && typeof mobileButton.focus === 'function') {
        mobileButton.focus({ preventScroll: true });
      } else if (document.activeElement instanceof HTMLElement) {
        document.activeElement.blur();
      }
    };

    const syncSidebarA11y = () => {
      const sidebar = getSidebar();
      if (!sidebar) return;

      if (isMobileSidebar() && !document.body.classList.contains('sidebar-open')) {
        moveFocusOutOfSidebar(sidebar);
        sidebar.setAttribute('aria-hidden', 'true');
        sidebar.setAttribute('inert', '');
      } else {
        sidebar.setAttribute('aria-hidden', 'false');
        sidebar.removeAttribute('inert');
      }
    };

    const openSidebar = () => {
      const sidebar = getSidebar();
      const overlay = getOverlay();
      document.body.classList.add('sidebar-open');
      sidebar?.removeAttribute('inert');
      sidebar?.setAttribute('aria-hidden', 'false');
      if (overlay) {
        overlay.hidden = false;
        overlay.setAttribute('aria-hidden', 'false');
      }
      setExpanded(true);
    };

    const closeSidebar = () => {
      const sidebar = getSidebar();
      const overlay = getOverlay();
      moveFocusOutOfSidebar(sidebar);
      document.body.classList.remove('sidebar-open');
      syncSidebarA11y();
      setExpanded(false);
      if (overlay) {
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
      }
    };

    const isOpenButton = (target) => target instanceof Element && openButtons.some((selector) => target.closest(selector));
    const hydrateOpenButtons = () => {
      openButtons.forEach((selector) => {
        document.querySelectorAll(selector).forEach((button) => {
          button.setAttribute('aria-controls', 'pz-admin-sidebar');
          button.setAttribute('aria-expanded', document.body.classList.contains('sidebar-open') ? 'true' : 'false');
        });
      });
    };

    const hydrateMobileBackLink = () => {
      document.body.classList.toggle(
        'has-pz-admin-mobile-back',
        Boolean(document.querySelector('[data-pz-admin-mobile-back]'))
      );
    };

    hydrateOpenButtons();
    hydrateMobileBackLink();
    syncSidebarA11y();
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', hydrateOpenButtons, { once: true });
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', hydrateMobileBackLink, { once: true });
    window.addEventListener('resize', syncSidebarA11y);
    window.addEventListener('pz:admin-sidebar-close', closeSidebar);

    document.addEventListener('click', (event) => {
      if (isOpenButton(event.target)) {
        event.preventDefault();
        event.stopImmediatePropagation();
        openSidebar();
        return;
      }

      const closeButton = event.target instanceof Element ? event.target.closest('[data-sidebar-close]') : null;
      if (closeButton) {
        event.preventDefault();
        closeSidebar();
        return;
      }

      const sidebarLink = event.target instanceof Element
        ? event.target.closest('[data-admin-sidebar-root] a[href]')
        : null;

      if (sidebarLink && document.body.classList.contains('sidebar-open')) {
        if (isMobileSidebar()) {
          window.setTimeout(() => {
            closeSidebar();
          }, 0);
        }
      }
    }, true);

    getOverlay()?.addEventListener('click', closeSidebar);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeSidebar();
    });

    document.addEventListener('click', (event) => {
      const actionButton = event.target instanceof Element
        ? event.target.closest('[data-pz-mobile-action]')
        : null;

      if (!actionButton) return;

      const targetSelector = actionButton.getAttribute('data-pz-mobile-action-target') || '';
      const eventName = actionButton.getAttribute('data-pz-mobile-action-event') || '';

      if (targetSelector) {
        const target = document.querySelector(targetSelector);
        if (target && typeof target.click === 'function') {
          event.preventDefault();
          target.click();
          return;
        }
      }

      if (eventName) {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent(eventName, {
          bubbles: true,
          detail: {
            source: 'pz-admin-mobile-topbar',
          },
        }));
      }
    }, true);

    document.getElementById('logout-btn')?.addEventListener('click', () => {
      document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax';
      window.location.assign('/login');
    });

    const settingsToggle = document.querySelector('[data-settings-sidebar-toggle]');
    const settingsSubnav = document.getElementById('pz-admin-sidebar-settings-subnav');
    settingsToggle?.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopImmediatePropagation();
      const willOpen = settingsSubnav?.classList.contains('is-collapsed');
      settingsSubnav?.classList.toggle('is-collapsed', !willOpen);
      settingsToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    }, true);

    const marketingVisualToggle = document.querySelector('[data-marketing-visual-sidebar-toggle]');
    const marketingVisualSubnav = document.getElementById('pz-admin-sidebar-marketing-visual-subnav');
    marketingVisualToggle?.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopImmediatePropagation();
      const willOpen = marketingVisualSubnav?.classList.contains('is-collapsed');
      marketingVisualSubnav?.classList.toggle('is-collapsed', !willOpen);
      marketingVisualToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    }, true);

    const syncMarketingVisualActiveItem = () => {
      const items = document.querySelectorAll('[data-marketing-visual-subitem]');
      if (!items.length) return;
      const path = window.location.pathname.replace(/\/+$/, '');
      const hashMap = {
        '#destacados': 'destacados',
        '#promociones': 'promociones',
        '#cupones': 'cupones',
        '#cintillo': 'cintillo',
        '#visuales': 'visuales',
      };
      const isPromos = /\/admin\/promos$/.test(path);
      const activeKey = isPromos ? (hashMap[window.location.hash] || 'destacados') : '';
      items.forEach((item) => item.classList.toggle('is-active', item.getAttribute('data-marketing-visual-subitem') === activeKey));
    };

    const syncSettingsActiveItem = () => {
      const items = document.querySelectorAll('[data-settings-subitem]');
      if (!items.length) return;

      const path = window.location.pathname.replace(/\/+$/, '');
      const isSettings = /\/admin\/store-settings$/.test(path);

      const hashMap = {
        '#generales': 'generales',
        '#general': 'generales',
        '#footer': 'footer',
        '#monedas': 'monedas',
        '#horario': 'horario',
        '#schedule': 'horario',
        '#rating': 'rating',
        '#landing': 'landing',
      };

      const activeKey = isSettings ? (hashMap[window.location.hash] || 'generales') : '';

      items.forEach((item) => {
        item.classList.toggle(
          'is-active',
          item.getAttribute('data-settings-subitem') === activeKey
        );
      });
    };

    syncMarketingVisualActiveItem();
    syncSettingsActiveItem();
    window.addEventListener('hashchange', syncMarketingVisualActiveItem);
    window.addEventListener('hashchange', syncSettingsActiveItem);

    const confirmOverlay = document.getElementById('pz-admin-confirm-overlay');
    const confirmCard = confirmOverlay?.querySelector('.pz-admin-confirm-card');
    const confirmTitle = document.getElementById('pz-admin-confirm-title');
    const confirmMessage = document.getElementById('pz-admin-confirm-message');
    const confirmKicker = document.getElementById('pz-admin-confirm-kicker');
    const confirmClose = document.getElementById('pz-admin-confirm-close');
    const confirmCancel = document.getElementById('pz-admin-confirm-cancel');
    const confirmSubmit = document.getElementById('pz-admin-confirm-submit');
    const toastRoot = document.getElementById('pz-admin-toast-root');
    let confirmResolver = null;
    let lastFocusedElement = null;

    const closeAdminConfirm = (value) => {
      if (!confirmOverlay || !confirmResolver) return;
      const resolve = confirmResolver;
      confirmResolver = null;
      confirmOverlay.classList.add('hidden');
      confirmOverlay.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('pz-admin-confirm-open');
      if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') lastFocusedElement.focus();
      lastFocusedElement = null;
      resolve(Boolean(value));
    };

    window.adminConfirm = (options = {}) => {
      if (!confirmOverlay) return Promise.resolve(false);
      if (confirmResolver) closeAdminConfirm(false);
      const tone = options.tone || 'danger';
      lastFocusedElement = document.activeElement;
      confirmOverlay.dataset.tone = tone;
      if (confirmKicker) confirmKicker.textContent = options.kicker || (tone === 'danger' ? 'Accion destructiva' : 'Confirmar accion');
      if (confirmTitle) confirmTitle.textContent = options.title || 'Confirmar accion';
      if (confirmMessage) confirmMessage.textContent = options.message || 'Esta accion no se puede deshacer.';
      if (confirmCancel) confirmCancel.textContent = options.cancelText || 'Cancelar';
      if (confirmSubmit) confirmSubmit.textContent = options.confirmText || 'Eliminar';
      confirmOverlay.classList.remove('hidden');
      confirmOverlay.setAttribute('aria-hidden', 'false');
      document.body.classList.add('pz-admin-confirm-open');
      window.setTimeout(() => confirmSubmit?.focus(), 0);
      return new Promise((resolve) => {
        confirmResolver = resolve;
      });
    };

    window.adminToast = (message, type = 'info') => {
      if (!toastRoot || !message) return;
      const toast = document.createElement('div');
      toast.className = `pz-admin-toast pz-admin-toast--${type}`;
      toast.setAttribute('role', type === 'error' ? 'alert' : 'status');
      toast.textContent = message;
      toastRoot.appendChild(toast);
      window.setTimeout(() => toast.classList.add('is-visible'), 20);
      window.setTimeout(() => {
        toast.classList.remove('is-visible');
        window.setTimeout(() => toast.remove(), 220);
      }, type === 'error' ? 4600 : 2800);
    };

    confirmCancel?.addEventListener('click', () => closeAdminConfirm(false));
    confirmClose?.addEventListener('click', () => closeAdminConfirm(false));
    confirmSubmit?.addEventListener('click', () => closeAdminConfirm(true));
    confirmOverlay?.addEventListener('click', (event) => {
      if (event.target === confirmOverlay) closeAdminConfirm(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && confirmResolver) closeAdminConfirm(false);
      if (event.key !== 'Tab' || !confirmResolver || !confirmCard) return;
      const focusable = Array.from(confirmCard.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
        .filter((item) => !item.disabled && item.getAttribute('aria-hidden') !== 'true');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  })();
</script>

<script is:inline>
  (() => {
    if (window.__pzAdminScrollHintReady) return;
    window.__pzAdminScrollHintReady = true;

    const SELECTORS = [
      '[data-pz-scroll-hint]',
      '.summary-period-actions',
      '.period-tabs',
      '.analytics-tabs',
      '.visit-analytics-tabs',
      '.business-summary-tabs',
      '.expiration-tabs',
      '.profits-period-tabs',
      '.settings-tabs',
      '.marketing-tabs',
      '.rating-reviews-table-wrap',
      '.hours-table-wrap'
    ];

    const enhanced = new WeakSet();
    const updaters = new WeakMap();

    const shouldEnhance = (track) => {
      if (!(track instanceof HTMLElement)) return false;
      if (track.closest('.pz-scroll-hint-shell')) return false;
      if (track.closest('#pz-admin-sidebar')) return false;
      if (track.closest('.pz-admin-mobile-bottom-nav')) return false;
      if (track.closest('.pz-admin-mobile-topbar')) return false;
      if (track.matches('.tabs')) return false;
      return true;
    };

    const scrollTrackByArrow = (track, side, update) => {
      if (!(track instanceof HTMLElement)) return;

      const distance = Math.max(140, Math.floor(track.clientWidth * 0.72));
      const left = side === 'right' ? distance : -distance;

      track.scrollBy({
        left,
        behavior: 'smooth'
      });

      window.setTimeout(update, 80);
      window.setTimeout(update, 240);
      window.setTimeout(update, 520);
    };

    const createArrow = (side, track, update) => {
      const arrow = document.createElement('button');
      arrow.type = 'button';
      arrow.className = `pz-scroll-hint-arrow pz-scroll-hint-arrow--${side}`;
      arrow.setAttribute('aria-label', side === 'right' ? 'Desplazar a la derecha' : 'Desplazar a la izquierda');
      arrow.setAttribute('tabindex', '-1');

      arrow.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        scrollTrackByArrow(track, side, update);
      });

      arrow.addEventListener('touchend', (event) => {
        event.preventDefault();
        event.stopPropagation();
        scrollTrackByArrow(track, side, update);
      }, { passive: false });

      return arrow;
    };

    const updateShellState = (shell, track) => {
      if (!shell || !track) return;

      const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
      const hasOverflow = maxScroll > 6;
      const canLeft = hasOverflow && track.scrollLeft > 3;
      const canRight = hasOverflow && track.scrollLeft < maxScroll - 3;

      shell.dataset.hasOverflow = hasOverflow ? 'true' : 'false';
      shell.dataset.canLeft = canLeft ? 'true' : 'false';
      shell.dataset.canRight = canRight ? 'true' : 'false';
    };

    const enhanceTrack = (track) => {
      if (!shouldEnhance(track) || enhanced.has(track)) return;

      const parent = track.parentNode;
      if (!parent) return;

      const shell = document.createElement('div');
      shell.className = 'pz-scroll-hint-shell';
      shell.dataset.hasOverflow = 'false';
      shell.dataset.canLeft = 'false';
      shell.dataset.canRight = 'false';

      parent.insertBefore(shell, track);
      shell.appendChild(track);

      track.classList.add('pz-scroll-hint-track');
      enhanced.add(track);

      const update = () => updateShellState(shell, track);
      updaters.set(track, update);

      shell.appendChild(createArrow('left', track, update));
      shell.appendChild(createArrow('right', track, update));

      track.addEventListener('scroll', update, { passive: true });

      window.requestAnimationFrame(update);
      window.setTimeout(update, 150);
      window.setTimeout(update, 450);
      window.setTimeout(update, 1000);

      if ('ResizeObserver' in window) {
        const observer = new ResizeObserver(update);
        observer.observe(track);
        observer.observe(shell);
      }
    };

    const initScrollHints = () => {
      const tracks = new Set();

      SELECTORS.forEach((selector) => {
        document.querySelectorAll(selector).forEach((track) => tracks.add(track));
      });

      tracks.forEach((track) => enhanceTrack(track));

      window.requestAnimationFrame(() => {
        document.querySelectorAll('.pz-scroll-hint-track').forEach((track) => {
          const update = updaters.get(track);
          if (typeof update === 'function') update();
        });
      });
    };

    const refreshScrollHints = () => {
      window.requestAnimationFrame(() => {
        document.querySelectorAll('.pz-scroll-hint-track').forEach((track) => {
          const update = updaters.get(track);
          if (typeof update === 'function') update();
        });
      });
    };

    const boot = () => {
      initScrollHints();

      window.addEventListener('resize', refreshScrollHints, { passive: true });
      window.addEventListener('orientationchange', () => window.setTimeout(refreshScrollHints, 250), { passive: true });
      window.addEventListener('hashchange', () => window.setTimeout(refreshScrollHints, 150), { passive: true });

      document.addEventListener('click', () => {
        window.setTimeout(initScrollHints, 80);
        window.setTimeout(refreshScrollHints, 220);
      }, true);

      if ('MutationObserver' in window) {
        const observer = new MutationObserver(() => {
          window.requestAnimationFrame(initScrollHints);
        });

        observer.observe(document.body, {
          childList: true,
          subtree: true
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }
  })();
</script>

