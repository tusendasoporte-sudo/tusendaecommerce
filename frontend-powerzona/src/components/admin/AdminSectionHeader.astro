---
interface Props {
  kicker: string;
  title: string;
  description: string;
  titleId?: string;
  descriptionId?: string;
  kickerValueId?: string;
  kickerValue?: string;
  bellId: string;
  actionId?: string;
  actionLabel?: string;
  actionHref?: string;
  actionClass?: string;
  actionType?: 'button' | 'submit' | 'reset';
}

const {
  kicker,
  title,
  description,
  titleId = `${bellId}-title`,
  descriptionId = '',
  kickerValueId = '',
  kickerValue = '',
  bellId,
  actionId = '',
  actionLabel = '',
  actionHref = '',
  actionClass = '',
  actionType = 'button',
} = Astro.props;

const dropdownId = `${bellId}-dropdown`;
const notificationTitleId = `${bellId}-notifications-title`;
const actionClasses = ['admin-primary-action', 'admin-header-primary-action', actionClass].filter(Boolean).join(' ');
---

<section class="admin-section-header" aria-labelledby={titleId}>
  <div class="admin-section-heading">
    <span class="admin-section-kicker">
      {kicker}
      {kickerValue ? <span id={kickerValueId || undefined}>{kickerValue}</span> : null}
    </span>
    <h1 id={titleId} class="admin-section-title">{title}</h1>
    <p id={descriptionId || undefined} class="admin-section-description">{description}</p>
  </div>

  <div class="admin-section-actions admin-header-actions">
    <button
      id={bellId}
      class="admin-bell-button admin-header-bell"
      type="button"
      aria-label="Notificaciones del admin"
      aria-expanded="false"
      aria-controls="pz-admin-notifications-panel"
      data-pz-admin-notification-trigger
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18 9a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Z"></path>
        <path d="M10 21a2 2 0 0 0 4 0"></path>
      </svg>
      <span class="admin-bell-count hidden" data-pz-admin-notification-count></span>
    </button>
    <div
      id={dropdownId}
      class="admin-bell-dropdown hidden"
      role="dialog"
      aria-labelledby={notificationTitleId}
    >
      <h3 id={notificationTitleId}>Notificaciones</h3>
      <p>Aun no tienes notificaciones.</p>
    </div>

    {Astro.slots.has('action') ? (
      <slot name="action" />
    ) : actionHref && actionLabel ? (
      <a id={actionId || undefined} class={actionClasses} href={actionHref}>
        <span aria-hidden="true">+</span>
        <span>{actionLabel}</span>
      </a>
    ) : actionLabel ? (
      <button id={actionId || undefined} class={actionClasses} type={actionType}>
        <span aria-hidden="true">+</span>
        <span>{actionLabel}</span>
      </button>
    ) : null}
  </div>
</section>

<style is:global>
  .admin-section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 18px;
    margin-bottom: 24px;
    position: relative;
    z-index: 5;
  }

  .admin-section-heading {
    min-width: 0;
  }

  .admin-section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    border-radius: 999px;
    padding: 0 12px;
    background: rgba(34, 197, 94, 0.14);
    color: #166534;
    font-size: 0.78rem;
    font-weight: 900;
    margin-bottom: 8px;
  }

  .admin-section-title {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2rem, 1.5rem + 1.2vw, 3rem);
    line-height: 1;
    font-weight: 950;
    letter-spacing: 0;
  }

  .admin-section-description {
    margin: 10px 0 0;
    color: #64748b;
    font-size: 1rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .admin-section-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
    flex: 0 0 auto;
    position: relative;
  }

  .admin-header-bell,
  .admin-bell-button {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: #ffffff;
    color: #0f172a;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
    position: relative;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .admin-header-bell:hover,
  .admin-bell-button:hover {
    transform: translateY(-1px);
    border-color: rgba(37, 99, 235, 0.34);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.11);
  }

  .admin-header-bell svg,
  .admin-bell-button svg {
    width: 21px;
    height: 21px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .admin-bell-dot {
    position: absolute;
    top: 9px;
    right: 9px;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #ef4444;
    border: 2px solid #ffffff;
  }

  .admin-header-primary-action,
  .admin-primary-action {
    min-height: 48px;
    border: 0;
    border-radius: 15px;
    background: linear-gradient(135deg, #2563eb, #4f7df3);
    color: #ffffff;
    padding: 0 20px;
    font-size: 0.95rem;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    cursor: pointer;
    box-shadow: 0 16px 34px rgba(37, 99, 235, 0.24);
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .admin-header-primary-action:hover,
  .admin-primary-action:hover {
    transform: translateY(-1px);
    box-shadow: 0 20px 40px rgba(37, 99, 235, 0.28);
  }

  .admin-header-primary-action svg,
  .admin-primary-action svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .admin-bell-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    width: min(320px, calc(100vw - 28px));
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: #ffffff;
    box-shadow: 0 22px 55px rgba(15, 23, 42, 0.16);
    padding: 14px;
    z-index: 120;
  }

  .admin-bell-dropdown.hidden {
    display: none;
  }

  .admin-bell-dropdown h3 {
    margin: 0;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 950;
  }

  .admin-bell-dropdown p {
    margin: 8px 0 0;
    color: #64748b;
    font-size: 0.88rem;
    font-weight: 650;
    line-height: 1.4;
  }

  @media (max-width: 760px) {
    .admin-section-header {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
      margin-bottom: 18px;
    }

    .admin-section-actions {
      justify-content: flex-start;
    }

    .admin-primary-action {
      flex: 1;
      padding-inline: 14px;
    }

    .admin-bell-button {
      flex: 0 0 48px;
    }

    .admin-section-title {
      font-size: clamp(1.8rem, 1.5rem + 1vw, 2.3rem);
    }
  }

  @media (max-width: 1023px) {
    .admin-section-header {
      display: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    if (window.__adminSectionBellReady) return;
    window.__adminSectionBellReady = true;

    const closeAdminBellDropdowns = () => {
      document.querySelectorAll('.admin-bell-dropdown').forEach((dropdown) => {
        dropdown.classList.add('hidden');
      });
      document.querySelectorAll('[data-admin-bell]').forEach((button) => {
        button.setAttribute('aria-expanded', 'false');
      });
    };

    document.addEventListener('click', (event) => {
      const button = event.target.closest('[data-admin-bell]');
      if (button) {
        event.stopPropagation();
        const dropdown = document.getElementById(button.getAttribute('data-admin-bell'));
        const willOpen = dropdown?.classList.contains('hidden');

        closeAdminBellDropdowns();

        if (dropdown && willOpen) {
          dropdown.classList.remove('hidden');
          button.setAttribute('aria-expanded', 'true');
        }
        return;
      }

      const dropdown = event.target.closest('.admin-bell-dropdown');
      if (!dropdown) closeAdminBellDropdowns();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAdminBellDropdowns();
    });
  })();
</script>
