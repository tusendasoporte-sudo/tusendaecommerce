---
// PZ-PUBLIC-FOOTER-V5-CONFIGURABLE-TUSENDA84-CTA-20260617
import { getCurrencies } from '../lib/api';
import { getCurrentStore, getPublicPath } from '../lib/stores';
import { BUSINESS_TYPE_GROUPS } from '../lib/businessTypes';

const { settings = {}, showPlatformCta = true } = Astro.props;

const currentStore = await getCurrentStore(Astro);
const currentStoreId = currentStore?.id || settings?.store || '';
const storeName = currentStore?.name || settings?.store_name || settings?.stored_name || 'Tienda';
const homePath = getPublicPath('/', currentStore, Astro.url.pathname);
const logoImageUrl = currentStore?.logoUrl || settings?.logoImageUrl || '';
const whatsappRaw = settings?.whatsapp_number || currentStore?.owner_phone || '';
const whatsappNumber = cleanPhone(whatsappRaw);
const whatsappStoreHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`Hola ${storeName}, quiero información.`)}`
  : '';

const creatorStoreHref = 'https://wa.me/13068006341?text=Hola%2C%20quiero%20crear%20mi%20tienda%20en%20Tu%20Senda%2084.';
const creatorStoreTarget = '_blank';

const socialLinks = normalizeSocialLinks(settings?.footer_social_links);
const socialItems = Object.entries(socialLinks)
  .map(([key, value]) => ({ key, href: normalizeSocialHref(key, value), label: socialLabel(key) }))
  .filter((item) => item.href);
const extraLinks = normalizeExtraLinks(settings);

const trustItems = parseTrustItems(settings?.footer_trust_items);
const province = String(settings?.province || '').trim();
const municipality = String(settings?.municipality || '').trim();
const addressDetail = String(settings?.address_detail || '').trim();
const legacyAddress = String(settings?.address || '').trim();
const locationText = province ? `${province}, ${municipality || 'Cuba'}` : '';
const addressText = addressDetail || (!province && !municipality ? legacyAddress : '');
const storeDescription = String(settings?.store_description || settings?.footer_text || settings?.welcome_text || '').trim();
const aboutStoreText = String(settings?.business_notes || settings?.footer_extra_text || '').trim();
const shippingDeliveryInfo = String(settings?.shipping_delivery_info || '').trim();
const businessTypeLabels = new Map(BUSINESS_TYPE_GROUPS.flatMap((group) => group.options.map((option) => [option.slug, option.label])));
const publicBusinessTypes = parseJsonList(settings?.business_types)
  .map((slug) => businessTypeLabels.get(slug) || slug)
  .filter(Boolean)
  .slice(0, 3);

let activeCurrencies: any[] = [];
try {
  activeCurrencies = currentStoreId ? await getCurrencies({ storeId: currentStoreId }) : [];
} catch (_) {
  activeCurrencies = [];
}
const defaultCurrency = Array.isArray(settings?.expand?.default_currency)
  ? settings.expand.default_currency[0]
  : settings?.expand?.default_currency;
const paymentCurrencies = normalizeCurrencies(activeCurrencies, defaultCurrency);

const infoLinks = [
  aboutStoreText ? { id: 'about', label: 'Sobre la tienda' } : null,
  shippingDeliveryInfo ? { id: 'shipping', label: 'Envíos y entregas' } : null,
  paymentCurrencies.length ? { id: 'payments', label: 'Métodos de pago' } : null,
  whatsappStoreHref ? { id: 'contact', label: 'Contáctanos' } : null,
].filter(Boolean);

function cleanPhone(value: any) {
  return String(value || '').replace(/[^0-9]/g, '');
}

function storeInitials(name: string) {
  return String(name || 'Tienda')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase())
    .join('') || 'T';
}

function parseJsonObject(value: any) {
  if (value && typeof value === 'object' && !Array.isArray(value)) return value;
  if (typeof value !== 'string' || !value.trim()) return {};
  try {
    const parsed = JSON.parse(value);
    return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
  } catch (_) {
    return {};
  }
}

function parseJsonList(value: any) {
  if (Array.isArray(value)) return value.filter(Boolean).map(String);
  if (typeof value !== 'string' || !value.trim()) return [];
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.filter(Boolean).map(String) : [];
  } catch (_) {
    return value.split(',').map((item) => item.trim()).filter(Boolean);
  }
}

function normalizeSocialLinks(value: any) {
  const parsed = parseJsonObject(value);
  return {
    instagram: String(parsed.instagram || '').trim(),
    facebook: String(parsed.facebook || '').trim(),
    tiktok: String(parsed.tiktok || '').trim(),
    youtube: String(parsed.youtube || '').trim(),
    whatsapp: String(parsed.whatsapp || '').trim(),
  };
}

function normalizeSocialHref(key: string, value: string) {
  const raw = String(value || '').trim();
  if (!raw) return '';
  if (key === 'whatsapp') {
    if (/^https?:\/\//i.test(raw)) return raw;
    const phone = cleanPhone(raw);
    return phone ? `https://wa.me/${phone}` : '';
  }
  if (!/^https?:\/\//i.test(raw)) return '';
  return raw;
}

function normalizeExtraLinks(source: any) {
  return [
    {
      active: source?.footer_link_1_active !== false,
      label: String(source?.footer_link_1_label || '').trim(),
      href: normalizePlainHref(source?.footer_link_1_url),
    },
    {
      active: source?.footer_link_2_active !== false,
      label: String(source?.footer_link_2_label || '').trim(),
      href: normalizePlainHref(source?.footer_link_2_url),
    },
  ].filter((item) => item.active && item.label && item.href);
}

function normalizePlainHref(value: any) {
  const raw = String(value || '').trim();
  return /^https?:\/\/\S+\.\S+/i.test(raw) ? raw : '';
}

function socialLabel(key: string) {
  return ({
    instagram: 'Instagram',
    facebook: 'Facebook',
    tiktok: 'TikTok',
    youtube: 'YouTube',
    whatsapp: 'WhatsApp',
  } as Record<string, string>)[key] || key;
}

function parseTrustItems(value: any) {
  let rawItems: any[] = [];
  if (Array.isArray(value)) {
    rawItems = value;
  } else if (typeof value === 'string' && value.trim()) {
    try {
      const parsed = JSON.parse(value);
      rawItems = Array.isArray(parsed) ? parsed : [];
    } catch (_) {
      rawItems = [];
    }
  }
  return rawItems
    .filter((item) => item && typeof item === 'object')
    .map((item) => ({
      icon: allowedIcon(item.icon),
      title: String(item.title || '').trim(),
      description: String(item.description || '').trim(),
      active: item.active !== false,
    }))
    .filter((item) => item.active && item.title)
    .slice(0, 4);
}

function allowedIcon(icon: any) {
  const value = String(icon || '').trim();
  return ['shield', 'lock', 'truck', 'headset', 'star', 'gift', 'location', 'bolt', 'heart', 'bag', 'check', 'whatsapp'].includes(value) ? value : 'check';
}

function normalizeCurrencies(currencies: any[], fallbackCurrency: any) {
  const list = (currencies || [])
    .filter((currency) => currency && currency.active !== false)
    .map(currencyView);
  if (list.length) return list;
  return fallbackCurrency ? [currencyView(fallbackCurrency)] : [];
}

function currencyView(currency: any) {
  const code = String(currency?.code || '').trim().toUpperCase();
  const name = String(currency?.name || code).trim();
  const symbol = String(currency?.symbol || '').trim();
  return {
    code,
    label: [code, name && name !== code ? name : '', symbol && symbol !== code ? `(${symbol})` : ''].filter(Boolean).join(' '),
  };
}

function iconSvg(name: string) {
  const paths: Record<string, string> = {
    shield: '<path d="M12 3 5 6v5c0 4.4 2.8 8.4 7 10 4.2-1.6 7-5.6 7-10V6l-7-3Zm0 4.4 4 1.7v2c0 2.9-1.5 5.6-4 7-2.5-1.4-4-4.1-4-7v-2l4-1.7Zm3.5 3.1-4.2 4.2-2-2 1.4-1.4.6.6 2.8-2.8 1.4 1.4Z"/>',
    lock: '<path d="M17 9V7a5 5 0 0 0-10 0v2H5v12h14V9h-2Zm-8 0V7a3 3 0 0 1 6 0v2H9Zm4 7.7V18h-2v-1.3a2 2 0 1 1 2 0Z"/>',
    truck: '<path d="M3 6h11v8h2.2l1.8 2H21v-5.2L18.2 8H16V6h3l4 5v7h-2.2a3 3 0 0 1-5.6 0H9.8a3 3 0 0 1-5.6 0H2v-4h2V8H3V6Zm3 12a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm12 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>',
    headset: '<path d="M12 3a8 8 0 0 0-8 8v4a3 3 0 0 0 3 3h2v-7H6a6 6 0 0 1 12 0h-3v7h2.2a5.2 5.2 0 0 1-4.2 2H11v2h2a7 7 0 0 0 7-7v-4a8 8 0 0 0-8-8Z"/>',
    star: '<path d="m12 2 2.8 6 6.5.8-4.8 4.5 1.2 6.4L12 16.5l-5.7 3.2 1.2-6.4-4.8-4.5 6.5-.8L12 2Z"/>',
    gift: '<path d="M20 7h-2.2A3 3 0 0 0 12 5.8 3 3 0 0 0 6.2 7H4v5h1v9h14v-9h1V7ZM9 5a1 1 0 0 1 1 1v1H9a1 1 0 0 1 0-2Zm6 0a1 1 0 0 1 0 2h-1V6a1 1 0 0 1 1-1Zm-8 7h4v7H7v-7Zm6 7v-7h4v7h-4Z"/>',
    location: '<path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z"/>',
    bolt: '<path d="M13 2 4 14h6l-1 8 10-13h-6l0-7Z"/>',
    heart: '<path d="M12 21s-8-4.7-8-11a4.8 4.8 0 0 1 8-3.6A4.8 4.8 0 0 1 20 10c0 6.3-8 11-8 11Z"/>',
    bag: '<path d="M7 8V7a5 5 0 0 1 10 0v1h3v13H4V8h3Zm2 0h6V7a3 3 0 0 0-6 0v1Z"/>',
    check: '<path d="M9.2 16.2 4.8 11.8 3.4 13.2 9.2 19 21 7.2 19.6 5.8 9.2 16.2Z"/>',
    whatsapp: '<path d="M12 2a9 9 0 0 0-7.7 13.7L3 22l6.4-1.2A9 9 0 1 0 12 2Zm0 2a7 7 0 1 1-2.1 13.7l-.4-.1-3.9.7.8-3.8-.2-.4A7 7 0 0 1 12 4Zm-3 3.8c-.2 0-.6.1-.9.5-.3.4-.8 1-.8 2.1s.8 2.2 1 2.4c.1.2 1.7 2.7 4.2 3.7 2.1.9 2.5.7 3 .7.4 0 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1-.1-.1-.3-.2-.7-.4l-1.6-.8c-.2-.1-.5-.1-.7.2l-.6.8c-.2.2-.4.2-.7.1-.4-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.6c.1-.2.2-.3.3-.5.1-.2.1-.4 0-.6L9 8.2c-.1-.3-.3-.4-.6-.4H9Z"/>',
    instagram: '<path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7Zm5 4a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm0 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm5.2-3.2a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z"/>',
    facebook: '<path d="M14 8h3V4h-3a5 5 0 0 0-5 5v3H6v4h3v6h4v-6h3l1-4h-4V9a1 1 0 0 1 1-1Z"/>',
    tiktok: '<path d="M15 3c.4 2.5 1.8 4 4 4.3V11a7 7 0 0 1-4-1.3V16a6 6 0 1 1-6-6c.4 0 .7 0 1 .1v4.1A2 2 0 1 0 11 16V3h4Z"/>',
    youtube: '<path d="M21.6 7.2a3 3 0 0 0-2.1-2.1C17.6 4.6 12 4.6 12 4.6s-5.6 0-7.5.5a3 3 0 0 0-2.1 2.1A31 31 0 0 0 2 12a31 31 0 0 0 .4 4.8 3 3 0 0 0 2.1 2.1c1.9.5 7.5.5 7.5.5s5.6 0 7.5-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 22 12a31 31 0 0 0-.4-4.8ZM10 15.2V8.8l5.5 3.2-5.5 3.2Z"/>',
  };
  return `<svg viewBox="0 0 24 24" aria-hidden="true">${paths[name] || paths.check}</svg>`;
}
---

{trustItems.length > 0 && (
  <section class="pz-trust-strip" aria-label="Beneficios de la tienda">
    <div class={`pz-trust-grid count-${trustItems.length}`}>
      {trustItems.map((item) => (
        <article class="pz-trust-item">
          <span class="pz-trust-icon" set:html={iconSvg(item.icon)} />
          <span class="pz-trust-copy">
            <strong>{item.title}</strong>
            {item.description && <small>{item.description}</small>}
          </span>
        </article>
      ))}
    </div>
  </section>
)}

<footer class="pz-public-footer" aria-label="Información de la tienda">
  <div class="pz-footer-main">
    <section class="pz-footer-store" aria-label={storeName}>
      <a class="pz-footer-logo-link" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>
        {logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : <span>{storeInitials(storeName)}</span>}
      </a>
      <div class="pz-footer-brand-copy">
        <h2>{storeName}</h2>
        {publicBusinessTypes.length > 0 && <p class="pz-footer-types">{publicBusinessTypes.join(' • ')}</p>}
      </div>
      {storeDescription && <p class="pz-footer-description">{storeDescription}</p>}
      {socialItems.length > 0 && (
        <div class="pz-footer-social" aria-label="Redes sociales">
          {socialItems.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label} title={item.label} set:html={iconSvg(item.key)} />
          ))}
        </div>
      )}
    </section>

    {infoLinks.length > 0 && (
      <section class="pz-footer-info" aria-label="Información">
        <h3>Información</h3>
        <nav>
          {infoLinks.map((item) => (
            item.id === 'contact'
              ? <a href={whatsappStoreHref} target="_blank" rel="noreferrer">{item.label}</a>
              : <button type="button" data-pz-footer-modal-open={item.id}>{item.label}</button>
          ))}
        </nav>
      </section>
    )}

    <section class="pz-footer-contact" aria-label="Contacto">
      <h3>Contacto</h3>
      {(locationText || addressText) && (
        <p class="pz-footer-contact-line pz-contact-location">
          <span class="pz-footer-contact-icon" set:html={iconSvg('location')} />
          <span class="pz-footer-contact-copy">{[locationText, addressText].filter(Boolean).join(' - ')}</span>
        </p>
      )}
      {whatsappStoreHref && <a class="pz-footer-whatsapp-btn" href={whatsappStoreHref} target="_blank" rel="noreferrer"><span set:html={iconSvg('whatsapp')} /> WhatsApp</a>}
      {extraLinks.length > 0 && (
        <div class="pz-footer-extra-links" aria-label="Enlaces adicionales">
          {extraLinks.map((item) => (
            <a class="pz-footer-extra-link" href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
          ))}
        </div>
      )}
    </section>

    {showPlatformCta && <section class="pz-footer-platform-cta" aria-label="Crear tienda en Tu Senda 84">
      <div class="pz-platform-icon" aria-hidden="true">
        <span></span>
      </div>
      <div class="pz-platform-copy">
        <h3>¿Le gustaría crear su propia tienda?</h3>
        <p>Únase a Tu Senda 84 y comience hoy mismo su tienda online.</p>
      </div>
      <a class="pz-platform-button" href={creatorStoreHref} target={creatorStoreTarget} rel="noopener noreferrer">Crear mi tienda</a>
      <div class="pz-platform-backed">
        <small>Con el respaldo de</small>
        <div class="pz-platform-brand-lockup">
          <span class="pz-tusenda-mark" aria-hidden="true">
            <img src="/brand/tusenda84-bazzar-logo.png" alt="" loading="lazy" />
          </span>
          <strong>Tu Senda 84</strong>
        </div>
      </div>
    </section>}

    {showPlatformCta && <p class="pz-footer-platform-note">Tienda pública de Tu Senda 84.</p>}
  </div>
</footer>

{aboutStoreText && (
  <div class="pz-footer-modal-overlay" data-pz-footer-modal="about" hidden>
    <section class="pz-footer-modal" role="dialog" aria-modal="true" aria-labelledby="pz-footer-about-title">
      <button class="pz-footer-modal-close" type="button" data-pz-footer-modal-close aria-label="Cerrar">×</button>
      <h2 id="pz-footer-about-title">Sobre la tienda</h2>
      <p>{aboutStoreText}</p>
    </section>
  </div>
)}

{shippingDeliveryInfo && (
  <div class="pz-footer-modal-overlay" data-pz-footer-modal="shipping" hidden>
    <section class="pz-footer-modal" role="dialog" aria-modal="true" aria-labelledby="pz-footer-shipping-title">
      <button class="pz-footer-modal-close" type="button" data-pz-footer-modal-close aria-label="Cerrar">×</button>
      <h2 id="pz-footer-shipping-title">Envíos y entregas</h2>
      <p>{shippingDeliveryInfo}</p>
    </section>
  </div>
)}

{paymentCurrencies.length > 0 && (
  <div class="pz-footer-modal-overlay" data-pz-footer-modal="payments" hidden>
    <section class="pz-footer-modal" role="dialog" aria-modal="true" aria-labelledby="pz-footer-payments-title">
      <button class="pz-footer-modal-close" type="button" data-pz-footer-modal-close aria-label="Cerrar">×</button>
      <h2 id="pz-footer-payments-title">Métodos de pago</h2>
      <p>Monedas aceptadas por esta tienda</p>
      <ul>
        {paymentCurrencies.map((currency) => <li>{currency.label}</li>)}
      </ul>
      <p>El pago se coordina directamente con la tienda al confirmar el pedido.</p>
    </section>
  </div>
)}

<script>
  (() => {
    const overlays = Array.from(document.querySelectorAll('[data-pz-footer-modal]'));
    function openFooterModal(id) {
      const overlay = overlays.find((item) => item.dataset.pzFooterModal === id);
      if (!overlay) return;
      overlay.hidden = false;
      requestAnimationFrame(() => overlay.classList.add('open'));
    }
    function closeFooterModal(overlay) {
      if (!overlay) return;
      overlay.classList.remove('open');
      setTimeout(() => { if (!overlay.classList.contains('open')) overlay.hidden = true; }, 160);
    }
    document.querySelectorAll('[data-pz-footer-modal-open]').forEach((button) => {
      button.addEventListener('click', () => openFooterModal(button.dataset.pzFooterModalOpen));
    });
    overlays.forEach((overlay) => {
      overlay.addEventListener('click', (event) => {
        if (event.target === overlay || event.target.closest('[data-pz-footer-modal-close]')) closeFooterModal(overlay);
      });
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') overlays.forEach(closeFooterModal);
    });
  })();
</script>

<style>
  .pz-trust-strip { margin: 28px 0 18px; border-radius: 8px; background: rgba(255,255,255,.96); border: 1px solid #e5edf7; box-shadow: 0 18px 45px rgba(15,23,42,.08); overflow: hidden; }
  .pz-trust-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .pz-trust-grid.count-1 { grid-template-columns: 1fr; }
  .pz-trust-grid.count-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .pz-trust-grid.count-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .pz-trust-item { min-width: 0; display: flex; align-items: center; gap: 16px; padding: 24px; border-right: 1px solid #e5edf7; }
  .pz-trust-item:last-child { border-right: 0; }
  .pz-trust-icon { width: 58px; height: 58px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; background: #eff6ff; color: #0b63f6; flex: 0 0 auto; }
  .pz-trust-icon svg { width: 34px; height: 34px; fill: currentColor; }
  .pz-trust-copy { min-width: 0; display: grid; gap: 5px; color: #0b1744; }
  .pz-trust-copy strong { font-size: 17px; line-height: 1.15; font-weight: 1000; }
  .pz-trust-copy small { color: #33446f; font-size: 14px; line-height: 1.35; font-weight: 800; }
  .pz-public-footer { margin-top: 22px; border-radius: 20px; border: 1px solid rgba(147,197,253,.18); border-top-color: rgba(191,219,254,.28); background: radial-gradient(circle at 14% 0%, rgba(59,130,246,.30), transparent 34%), radial-gradient(circle at 92% 18%, rgba(14,165,233,.16), transparent 28%), linear-gradient(135deg, #061b45 0%, #082f6f 45%, #03132f 100%); color: #fff; overflow: hidden; box-shadow: 0 28px 78px rgba(3,19,47,.28), inset 0 1px 0 rgba(255,255,255,.08); }
  .pz-footer-main { padding: clamp(30px, 5vw, 54px); display: grid; grid-template-columns: minmax(0, 1.18fr) minmax(190px, .78fr) minmax(230px, .92fr); gap: clamp(28px, 4.8vw, 72px); align-items: start; }
  .pz-footer-store { min-width: 0; display: grid; grid-template-columns: 76px minmax(0, 1fr); gap: 16px; align-items: center; }
  .pz-footer-logo-link { width: 68px; height: 68px; border-radius: 15px; background: linear-gradient(135deg, #1d7cff, #0753d8); color: #fff; display: inline-flex; align-items: center; justify-content: center; overflow: hidden; flex: 0 0 auto; text-decoration: none; font-weight: 1000; font-size: 25px; border: 1px solid rgba(255,255,255,.22); box-shadow: 0 18px 38px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.26); }
  .pz-footer-logo-link img { width: 100%; height: 100%; object-fit: contain; }
  .pz-footer-logo-link span { display: inline-flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .pz-footer-brand-copy { min-width: 0; }
  .pz-footer-brand-copy h2 { margin: 0; color: #fff; font-size: clamp(26px, 3vw, 36px); line-height: 1.03; font-weight: 1000; letter-spacing: 0; text-shadow: 0 10px 28px rgba(0,0,0,.18); }
  .pz-footer-types { margin: 7px 0 0; color: rgba(219,234,254,.82); font-size: 14px; line-height: 1.35; font-weight: 850; }
