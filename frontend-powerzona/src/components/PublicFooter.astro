---
// PZ-PUBLIC-FOOTER-V4-LINKS-FLOTANTES-ARRIBA-CTA-FINAL-20260604
import { getCurrentStore, getPublicPath } from '../lib/stores';

const { settings = {} } = Astro.props;

const storeName = settings?.store_name || settings?.stored_name || 'PowerZona';
const whatsappRaw = settings?.whatsapp_number || '';
const whatsappNumber = String(whatsappRaw).replace(/[^0-9]/g, '');

const creatorStoreWhatsappHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola me gustaria tener mi tienda.')}`
  : '';

const footerTitle = settings?.footer_title || storeName;
const footerText = settings?.footer_text || settings?.welcome_text || '';
const footerContactText = settings?.footer_contact_text || '';
const footerExtraText = settings?.footer_extra_text || settings?.reviews_text || '';
const address = settings?.address || '';
const businessHours = settings?.business_hours || '';
const servicesText = settings?.public_services_text || '';
const linkOneLabel = settings?.footer_link_1_label || '';
const linkOneUrl = settings?.footer_link_1_url || '';
const linkTwoLabel = settings?.footer_link_2_label || '';
const linkTwoUrl = settings?.footer_link_2_url || '';
const currentYear = new Date().getFullYear();
const currentStore = await getCurrentStore(Astro);
const homePath = getPublicPath('/', currentStore, Astro.url.pathname);

const hasExtraLinks = linkOneUrl || linkTwoUrl;
const hasInfoCard = businessHours || servicesText || footerContactText;
const hasMainInfo = footerText || footerContactText || footerExtraText || address || businessHours || servicesText || creatorStoreWhatsappHref || hasExtraLinks;
---

{hasMainInfo && (
  <footer class="pz-public-footer" aria-label="Información de la tienda">
    <div class="pz-footer-main">
      <div class="pz-footer-brand">
        <a class="pz-footer-logo-link" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>
          {settings?.logoImageUrl ? <img src={settings.logoImageUrl} alt={storeName} /> : <span>PZ</span>}
        </a>
        <div>
          <h2>{footerTitle}</h2>
          {footerText && <p>{footerText}</p>}
        </div>
      </div>

      {hasExtraLinks && (
        <div class="pz-footer-floating-links" aria-label="Enlaces adicionales">
          {linkOneUrl && <a href={linkOneUrl} target="_blank" rel="noreferrer">{linkOneLabel || 'Enlace 1'}</a>}
          {linkTwoUrl && <a href={linkTwoUrl} target="_blank" rel="noreferrer">{linkTwoLabel || 'Enlace 2'}</a>}
        </div>
      )}

      <div class="pz-footer-grid">
        {address && (
          <section class="pz-footer-card">
            <h3>Ubicación</h3>
            <p>{address}</p>
          </section>
        )}

        {hasInfoCard && (
          <section class="pz-footer-card">
            <h3>Información</h3>
            {footerContactText && <p>{footerContactText}</p>}
            {businessHours && <p>{businessHours}</p>}
            {servicesText && <p>{servicesText}</p>}
          </section>
        )}

        {footerExtraText && (
          <section class="pz-footer-card">
            <h3>Detalles</h3>
            <p>{footerExtraText}</p>
          </section>
        )}
      </div>

      {creatorStoreWhatsappHref && (
        <section class="pz-footer-card pz-footer-creator-card">
          <h3>Crea tu tienda</h3>
          <p>¿Le gustaría crear su propia tienda como esta? <strong>Gratis</strong>.</p>
          <a href={creatorStoreWhatsappHref} target="_blank" rel="noreferrer">Escribir por WhatsApp</a>
        </section>
      )}
    </div>
    <div class="pz-footer-bottom">
      <span>© {currentYear} {storeName}</span>
      <a href={homePath}>Inicio</a>
    </div>
  </footer>
)}

<style>
  .pz-public-footer { margin-top: 34px; border-radius: 32px 32px 0 0; background: linear-gradient(135deg, #0f172a, #111827); color: #fff; overflow: hidden; box-shadow: 0 -18px 55px rgba(15,23,42,.16); }
  .pz-footer-main { padding: clamp(22px, 5vw, 34px); display: grid; gap: 22px; }
  .pz-footer-brand { display: flex; align-items: flex-start; gap: 14px; min-width: 0; }
  .pz-footer-logo-link { width: 52px; height: 52px; border-radius: 19px; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.18); color: #fff; display: inline-flex; align-items: center; justify-content: center; overflow: hidden; flex: 0 0 auto; text-decoration: none; font-weight: 1000; box-shadow: 0 16px 34px rgba(0,0,0,.20); }
  .pz-footer-logo-link img { width: 100%; height: 100%; object-fit: cover; }
  .pz-footer-logo-link span { display: inline-flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .pz-footer-brand h2 { margin: 0; font-size: clamp(24px, 5vw, 36px); line-height: 1; font-weight: 1000; letter-spacing: -.05em; }
  .pz-footer-brand p, .pz-footer-card p, .pz-footer-more-area p { margin: 8px 0 0; color: rgba(255,255,255,.72); font-size: 14px; line-height: 1.55; font-weight: 750; white-space: pre-line; }
  .pz-footer-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .pz-footer-card { border-radius: 24px; padding: 17px; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12); min-width: 0; }
  .pz-footer-card h3 { margin: 0; font-size: 13px; font-weight: 1000; color: rgba(255,255,255,.92); text-transform: uppercase; letter-spacing: .07em; }
  .pz-footer-card strong { color: #fff; font-weight: 1000; }
  .pz-footer-card a, .pz-footer-bottom a, .pz-footer-floating-links a { color: #fff; font-weight: 1000; text-decoration: none; }
  .pz-footer-card > a { display: inline-flex; margin-top: 12px; border-radius: 999px; padding: 10px 13px; background: #fff; color: #111827; font-size: 13px; }
  .pz-footer-creator-card { order: 20; }
  .pz-footer-floating-links { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .pz-footer-floating-links a { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 9px 12px; background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.14); font-size: 13px; box-shadow: 0 12px 24px rgba(0,0,0,.12); }
  .pz-footer-bottom { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 15px clamp(22px, 5vw, 34px); background: rgba(0,0,0,.18); color: rgba(255,255,255,.70); font-size: 12px; font-weight: 900; }
  @media (max-width: 820px) { .pz-footer-grid { grid-template-columns: 1fr; } .pz-public-footer { border-radius: 28px 28px 0 0; } }
</style>
