---
---


<button id="cart-floating-btn" class="fixed bottom-6 right-6 bg-blue-600 text-white p-4 rounded-full shadow-2xl hover:bg-blue-700 transition-transform hover:scale-105 z-40 hidden flex items-center gap-2">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="9" cy="21" r="1"/>
    <circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
  </svg>

  <span id="cart-count" class="bg-white text-blue-600 font-extrabold rounded-full w-6 h-6 flex items-center justify-center text-xs">
    0
  </span>
</button>

<style>
  body.product-detail-page.product-add-floating-active #cart-floating-btn {
    bottom: calc(96px + env(safe-area-inset-bottom));
  }

  @media (max-width: 767px) {
    body.product-detail-page.product-add-floating-active #cart-floating-btn {
      bottom: calc(92px + env(safe-area-inset-bottom));
      right: 16px;
    }
  }
</style>

<div id="cart-overlay" class="fixed inset-0 bg-black/40 z-40 hidden opacity-0 transition-opacity duration-300"></div>

<div id="cart-sidebar" class="fixed top-0 right-0 w-full max-w-sm h-full bg-white shadow-2xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col">
  
  <div class="p-5 border-b border-gray-100 flex justify-between items-center bg-gray-50">
    <h2 class="text-xl font-bold text-gray-800">Tu Carrito 🛒</h2>

    <button id="close-cart-btn" class="text-gray-400 hover:text-red-500 transition-colors p-2" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div id="cart-live-alert" class="hidden mx-5 mt-4 rounded-2xl border border-blue-100 bg-blue-50 text-blue-800 p-3 text-xs font-bold"></div>

  <div id="cart-items-container" class="flex-1 overflow-y-auto p-5 space-y-4"></div>

  <div class="p-5 border-t border-gray-100 bg-gray-50">
    <div class="flex justify-between items-center mb-4">
      <span class="text-gray-600 font-medium">Total Estimado:</span>
      <span id="cart-total" class="text-2xl font-extrabold text-blue-600">$0.00 USD</span>
    </div>

    <button id="checkout-btn" class="w-full bg-green-500 text-white py-3.5 rounded-xl font-bold hover:bg-green-600 transition-colors flex justify-center items-center gap-2 shadow-md" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
      Hacer el pedido
    </button>
  </div>

</div>

<script>
  const floatingBtn = document.getElementById('cart-floating-btn');
  const cartCount = document.getElementById('cart-count');
  const cartSidebar = document.getElementById('cart-sidebar');
  const cartOverlay = document.getElementById('cart-overlay');
  const closeCartBtn = document.getElementById('close-cart-btn');
  const cartItemsContainer = document.getElementById('cart-items-container');
  const cartLiveAlert = document.getElementById('cart-live-alert');
  const cartTotal = document.getElementById('cart-total');
  const checkoutBtn = document.getElementById('checkout-btn');
  const publicPathPrefix = String(window.PZ_PUBLIC_PATH_PREFIX || '').replace(/\/$/, '');
  const checkoutPath = `${publicPathPrefix}/checkout`;
  const isCheckoutPage = window.location.pathname.replace(/\/$/, '') === checkoutPath.replace(/\/$/, '');
  const currentStoreId = String(window.PZ_CURRENT_STORE_ID || '');
  const cartStorage = window.PZCartStorage || null;
  const ONE_TO_ONE_RATE_TOLERANCE = 0.000001;
  const parseCart = (value) => {
    try {
      const parsed = JSON.parse(value || '[]');
      return Array.isArray(parsed) ? parsed : [];
    } catch (_) {
      return [];
    }
  };
  const cartStorageKey = () => cartStorage?.getCartStorageKey?.() || window.PZ_CART_STORAGE_KEY || `tusenda84_cart_${currentStoreId || 'powerzona'}`;
  const checkoutCartStorageKey = () => cartStorage?.getCheckoutStorageKey?.() || window.PZ_CHECKOUT_CART_STORAGE_KEY || `${cartStorageKey()}_checkout`;
  const itemTracksStock = (item) => item?.track_stock !== false;
  const getSelectedCurrencyCode = () => String(window.PZCurrency?.selected?.code || 'USD').toUpperCase();
  const getSelectedCurrencyObject = () => window.PZCurrency?.selected || null;
  const isSelectedCurrencyOneToOne = () => {
    const selectedCode = getSelectedCurrencyCode();
    if (selectedCode === 'USD') return true;
    const rate = Number(getSelectedCurrencyObject()?.exchange_rate);
    return Number.isFinite(rate) && Math.abs(rate - 1) < ONE_TO_ONE_RATE_TOLERANCE;
  };
  const shouldSeparateUsdOnlyTotals = () => !isSelectedCurrencyOneToOne();
  const shouldFormatItemAsOnlyUsd = (item = {}) => shouldSeparateUsdOnlyTotals() && Boolean(item.only_usd);
  const formatCartPrice = (amountUsd, item = {}) => {
    if (window.PZCurrency?.formatVisualFromUsd) return window.PZCurrency.formatVisualFromUsd(amountUsd, { onlyUsd: shouldFormatItemAsOnlyUsd(item) });
    return '$' + Number(amountUsd || 0).toFixed(2) + ' USD';
  };
  const hasMixedCurrency = (cart) => shouldSeparateUsdOnlyTotals() && cart.some((item) => Boolean(item.only_usd)) && cart.some((item) => !item.only_usd);
  const calculatePromotions = (cart) => window.PZPromotions?.calculateCartPromotions(cart, window.PZ_AUTOMATIC_PROMOTIONS || []) || null;
  let cartNoticeMessages = [];
  let cartReviewRequired = false;
  let checkoutValidationRunning = false;

  const escapeHtml = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
  const getCartValidator = () => window.PZCartLiveValidator || null;
  const isCartItemUnavailable = (item) => Boolean(getCartValidator()?.isCartItemUnavailable?.(item))
    || (!item?.is_gift && itemTracksStock(item) && !item.preorder && Number(item.stock || 0) <= 0);
  const getValidCartItems = (cart) => getCartValidator()?.getValidCartItems?.(cart) || (cart || []).filter((item) => !isCartItemUnavailable(item));
  const getUnavailableBadge = (item) => {
    const status = String(item?.cart_validation_status || '');
    const reason = String(item?.cart_validation_reason || '');
    if (status === 'variation_unavailable' && reason === 'variation_out_of_stock') return 'Variacion agotada';
    if (status === 'variation_unavailable') return 'Variacion no disponible';
    if (status === 'unavailable') return 'No disponible';
    return 'Agotado';
  };
  const getItemValidationMessages = (item) => {
    const messages = Array.isArray(item?.cart_validation_messages)
      ? item.cart_validation_messages
      : [item?.cart_validation_message].filter(Boolean);
    return [...new Set(messages.map((message) => String(message || '').trim()).filter(Boolean))];
  };
  const updateCartLiveAlert = (cart) => {
    if (!cartLiveAlert) return;
    const itemMessages = (cart || []).flatMap(getItemValidationMessages);
    const messages = [...new Set([...cartNoticeMessages, ...itemMessages].filter(Boolean))].slice(0, 5);
    cartLiveAlert.classList.toggle('hidden', messages.length === 0);
    cartLiveAlert.innerHTML = messages.length
      ? `<p>${escapeHtml(messages[0])}</p>${messages.length > 1 ? `<ul class="mt-2 space-y-1">${messages.slice(1).map((message) => `<li>${escapeHtml(message)}</li>`).join('')}</ul>` : ''}`
      : '';
  };
  const setCheckoutButtonLoading = (loading) => {
    checkoutValidationRunning = Boolean(loading);
    if (!checkoutBtn) return;
    const shouldDisable = Boolean(loading) || isCheckoutPage || !getCart().length;
    checkoutBtn.disabled = shouldDisable;
    checkoutBtn.textContent = loading ? 'Actualizando carrito...' : 'Hacer el pedido';
    checkoutBtn.classList.toggle('opacity-50', shouldDisable);
    checkoutBtn.classList.toggle('cursor-not-allowed', shouldDisable);
  };
  const runCartLiveValidation = async ({ force = false, removeUnavailable = false } = {}) => {
    const validator = getCartValidator();
    if (!validator?.applyCartValidation) return null;
    const result = await validator.applyCartValidation(getCart(), {
      force,
      removeUnavailable,
      pocketbaseUrl: window.PZ_POCKETBASE_URL,
      currentStoreId,
      saveCart,
    });
    const summary = validator.getCartValidationSummary?.(result) || null;
    if (summary?.messages?.length) {
      cartNoticeMessages = summary.messages;
    }
    if (summary?.requiresReview) {
      cartReviewRequired = true;
    }
    return { result, summary };
  };

if (isCheckoutPage) {
  floatingBtn?.classList.add('hidden');
  cartOverlay?.classList.add('hidden');
  cartSidebar?.classList.add('translate-x-full');
}
  checkoutBtn?.addEventListener('click', async () => {
    if (checkoutValidationRunning) return;
    if (!getCart().length) return;

    setCheckoutButtonLoading(true);
    let validation = null;

    try {
      validation = await runCartLiveValidation({ force: true, removeUnavailable: true });
    } catch (_) {
      cartNoticeMessages = ['No pudimos actualizar el carrito. Intenta nuevamente antes de continuar.'];
      window.dispatchEvent(new Event('cart-updated'));
      setCheckoutButtonLoading(false);
      return;
    }

    const cart = getCart();
    const validProducts = getValidCartItems(cart).filter((item) => !item.is_gift);
    const shouldReview = Boolean(cartReviewRequired || validation?.summary?.requiresReview || validation?.result?.removedCount);

    if (!validProducts.length) {
      cartNoticeMessages = ['Los productos de tu carrito ya no estan disponibles.'];
      cartReviewRequired = false;
      window.dispatchEvent(new Event('cart-updated'));
      setCheckoutButtonLoading(false);
      return;
    }

    if (shouldReview) {
      cartNoticeMessages = ['Actualizamos tu carrito. Revisa los cambios y vuelve a tocar Hacer el pedido.'];
      cartReviewRequired = false;
      window.dispatchEvent(new Event('cart-updated'));
      setCheckoutButtonLoading(false);
      return;
    }

    try {
      const payload = JSON.stringify(cart);
      localStorage.setItem(cartStorageKey(), payload);
      sessionStorage.setItem(checkoutCartStorageKey(), payload);
    } catch (error) {
    }

    window.location.href = checkoutPath;
  });

  function getCart() {
    if (cartStorage?.readCart) return cartStorage.readCart();
    return parseCart(localStorage.getItem(cartStorageKey()));
  }

  function saveCart(cart) {
    const nextCart = Array.isArray(cart)
      ? cart.map((item) => ({ ...item, store_id: item?.store_id || currentStoreId }))
      : [];
    if (cartStorage?.writeCart) cartStorage.writeCart(nextCart);
    else {
      const payload = JSON.stringify(nextCart);
      localStorage.setItem(cartStorageKey(), payload);
      if (nextCart.length) sessionStorage.setItem(checkoutCartStorageKey(), payload);
      else sessionStorage.removeItem(checkoutCartStorageKey());
    }
    window.dispatchEvent(new Event('cart-updated'));
  }

  function getItemKey(item) {
    if (item?.is_gift) return `gift::${item.gift_id || item.id}`;
    return item?.variation_id ? `${item.id}::${item.variation_id}` : (item.id || item.title);
  }

  function openCart() {
    cartOverlay.classList.remove('hidden');

    setTimeout(() => {
      cartOverlay.classList.remove('opacity-0');
    }, 10);

    cartSidebar.classList.remove('translate-x-full');
    runCartLiveValidation({ force: true, removeUnavailable: false }).catch(() => {
      cartNoticeMessages = ['No pudimos actualizar el carrito en este momento.'];
      window.dispatchEvent(new Event('cart-updated'));
    });
  }

  function closeCart() {
    cartOverlay.classList.add('opacity-0');
    cartSidebar.classList.add('translate-x-full');

    setTimeout(() => {
      cartOverlay.classList.add('hidden');
    }, 300);
  }

  floatingBtn.addEventListener('click', openCart);
  closeCartBtn.addEventListener('click', closeCart);
  cartOverlay.addEventListener('click', closeCart);

  window.addEventListener('cart-updated', () => {
    const cart = getCart();
    const validCart = getValidCartItems(cart);
    const totalItems = cart.reduce((sum, item) => sum + Number(item.quantity || 0), 0);
    const hasCartItems = cart.length > 0;
    updateCartLiveAlert(cart);

    cartCount.textContent = totalItems;

   if (isCheckoutPage) {
  floatingBtn.classList.add('hidden');
  checkoutBtn.disabled = true;
  checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
  closeCart();
} else if (hasCartItems) {
  floatingBtn.classList.remove('hidden');
  checkoutBtn.disabled = false;
  checkoutBtn.textContent = 'Hacer el pedido';
  checkoutBtn.classList.remove('opacity-50', 'cursor-not-allowed');
} else {
  floatingBtn.classList.add('hidden');
  checkoutBtn.disabled = true;
  checkoutBtn.textContent = 'Hacer el pedido';
  checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');

  closeCart();
}

    cartItemsContainer.innerHTML = '';

    const promotionTotals = calculatePromotions(validCart);
    const promotedItems = new Map((promotionTotals?.items || validCart).map((item) => [getItemKey(item), item]));
    const cartForRender = cart.map((item) => promotedItems.get(getItemKey(item)) || item);
    let totalUSD = promotionTotals?.subtotalFinalUSD || 0;
    let visualConvertibleTotalUSD = promotionTotals?.localCurrencyTotal || 0;
    let usdOnlyTotalUSD = promotionTotals?.usdOnlyTotal || 0;

    if (cart.length === 0) {
      cartItemsContainer.innerHTML = `
        <div class="flex flex-col items-center justify-center h-full text-gray-400 mt-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <p>Tu carrito está vacío.</p>
        </div>
      `;
    } else {
      cartForRender.forEach((item) => {
        const itemKey = getItemKey(item);
        const price = Number(item.price || 0);
        const quantity = Number(item.quantity || 1);
        const stock = Number(item.stock || 0);
        const isUnavailable = isCartItemUnavailable(item);
        const validationMessages = getItemValidationMessages(item);
        const unavailableBadge = isUnavailable ? getUnavailableBadge(item) : '';
        const lineTotal = isUnavailable ? 0 : Number(item.line_subtotal_final_usd ?? (price * quantity));
        const lineOriginal = isUnavailable ? 0 : Number(item.line_subtotal_original_usd ?? (price * quantity));
        const lineDiscount = Number(item.line_discount_usd || 0);
        const regularPrice = Number(item.regular_price_usd || item.original_price_usd || price || 0);
        const hasOffer = Boolean(item.is_offer) && regularPrice > price && price > 0;
        const unitSavings = hasOffer ? regularPrice - price : 0;
        const lineSavings = unitSavings * quantity;
        const hasAutomaticPromo = lineDiscount > 0 && Boolean(item.promotion_label);
        const tracksStock = itemTracksStock(item);
        const isPreorder = Boolean(item.preorder);
        const isOutOfStock = !isUnavailable && tracksStock && stock <= 0 && !isPreorder;
        const isOverStock = !isUnavailable && tracksStock && !isPreorder && !isOutOfStock && quantity > stock;
        const isGift = Boolean(item.is_gift);
        const isAtMaxStock = isUnavailable || isGift || (tracksStock && !isPreorder && !isOutOfStock && quantity >= stock);

        cartItemsContainer.innerHTML += `
          <div class="flex gap-4 border-b border-gray-100 pb-4 relative pr-8 ${isUnavailable ? 'opacity-70' : ''}">
            <img src="${item.image}" alt="${item.title}" class="w-16 h-16 object-cover rounded-lg ${isUnavailable ? 'grayscale' : ''}">

            <div class="flex-1">
              <h4 class="text-sm font-bold text-gray-800 line-clamp-2">
                ${item.title}
              </h4>

              ${item.is_gift ? `
                <p class="text-xs text-green-700 font-black mt-1">Regalo incluido</p>
              ` : item.variation_label ? `
                <p class="text-xs text-gray-500 font-bold mt-1">${item.variation_label}</p>
              ` : ''}

              ${isUnavailable ? `
                <span class="inline-flex w-fit mt-2 text-[10px] font-black bg-red-100 text-red-700 px-2 py-1 rounded-full">${escapeHtml(unavailableBadge)}</span>
              ` : ''}

              ${hasOffer ? `
                <p class="text-[11px] text-gray-400 font-black mt-1 line-through">${formatCartPrice(regularPrice, item)}</p>
                <p class="text-red-600 font-black mt-1">${formatCartPrice(price, item)}</p>
                <p class="text-[11px] text-green-700 font-black mt-1">Oferta · Ahorras ${formatCartPrice(lineSavings, item)}</p>
              ` : `
                <p class="text-blue-600 font-bold mt-1">
                  ${item.is_gift ? 'Gratis' : formatCartPrice(price, item)}
                </p>
              `}

              ${item.only_usd ? `
                <span class="inline-flex w-fit mt-1 text-[10px] font-black bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full">Solo USD</span>
              ` : ''}

              ${hasAutomaticPromo ? `
                <div class="mt-2 rounded-xl bg-emerald-50 border border-emerald-100 px-3 py-2">
                  <p class="text-[11px] text-emerald-800 font-black">Promo aplicada: ${item.promotion_label}</p>
                  <p class="text-[11px] text-emerald-700 font-black">Ahorras ${formatCartPrice(lineDiscount, item)}</p>
                </div>
              ` : ''}

              ${validationMessages.length ? `
                <div class="mt-2 rounded-xl bg-blue-50 border border-blue-100 px-3 py-2">
                  ${validationMessages.map((message) => `<p class="text-[11px] text-blue-800 font-black">${escapeHtml(message)}</p>`).join('')}
                </div>
              ` : ''}

              ${item.is_gift ? `
                <p class="text-xs text-gray-500 font-black mt-2">Disponible desde ${formatCartPrice(Number(item.min_order_usd || 0), { only_usd: false })}. Solo 1 regalo por orden.</p>
              ` : isUnavailable ? `
                <p class="text-xs text-red-600 font-black mt-2">Este producto ya no esta disponible y se quitara antes de continuar.</p>
              ` : !tracksStock ? `` : isPreorder ? `
                <p class="text-xs text-blue-700 font-black mt-2">Preorden disponible. Se coordina por WhatsApp.</p>
              ` : isOutOfStock ? `
                <p class="text-xs text-red-600 font-black mt-2">Agotado. Elimina este producto para poder hacer el pedido.</p>
              ` : isOverStock ? `
                <p class="text-xs text-orange-600 font-black mt-2">Cantidad mayor al stock disponible (${stock}).</p>
              ` : ''}

              <div class="flex items-center justify-between mt-3">
                <div class="flex items-center border border-gray-200 rounded-xl overflow-hidden">
                  <button
                    type="button"
                    data-key="${itemKey}"
                    ${isUnavailable ? 'disabled' : ''}
                    class="decrease-item-btn px-3 py-1.5 font-bold ${
                      isUnavailable
                        ? 'text-gray-400 bg-gray-100 cursor-not-allowed opacity-60'
                        : 'text-gray-700 hover:bg-gray-100'
                    }"
                  >
                    −
                  </button>

                  <span class="px-3 py-1.5 text-sm font-bold text-gray-800 bg-gray-50">
                    ${quantity}
                  </span>

                  <button
                    type="button"
                    data-key="${itemKey}"
                    ${(isUnavailable || isAtMaxStock || isOutOfStock) ? 'disabled' : ''}
                    class="increase-item-btn px-3 py-1.5 font-bold ${
                      (isUnavailable || isAtMaxStock || isOutOfStock)
                        ? 'text-gray-400 bg-gray-100 cursor-not-allowed opacity-60'
                        : 'text-gray-700 hover:bg-gray-100'
                    }"
                  >
                    +
                  </button>
                </div>

                <span class="text-xs font-bold text-gray-600">
                  ${isUnavailable ? 'No suma al total' : item.is_gift ? 'Gratis' : (hasAutomaticPromo ? `${formatCartPrice(lineTotal, item)} <span class="text-gray-400 line-through ml-1">${formatCartPrice(lineOriginal, item)}</span>` : formatCartPrice(lineTotal, item))}
                </span>
              </div>

              ${isAtMaxStock && !isOutOfStock && !isUnavailable ? `
                <p class="text-xs text-orange-600 font-semibold mt-2">
                  Stock máximo alcanzado (${stock} disponibles)
                </p>
              ` : ''}
            </div>

            <button
              type="button"
              data-key="${itemKey}"
              class="delete-item-btn absolute top-0 right-0 text-gray-300 hover:text-red-500 transition-colors p-1"
              title="Eliminar producto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6h18"></path>
                <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        `;
      });
    }

    if (hasMixedCurrency(validCart)) {
      cartTotal.textContent = `${formatCartPrice(visualConvertibleTotalUSD, { only_usd: false })} + ${formatCartPrice(usdOnlyTotalUSD, { only_usd: true })}`;
    } else if (usdOnlyTotalUSD > 0 && visualConvertibleTotalUSD <= 0) {
      cartTotal.textContent = formatCartPrice(usdOnlyTotalUSD, { only_usd: true });
    } else {
      cartTotal.textContent = formatCartPrice(totalUSD, { only_usd: false });
    }

    cartItemsContainer.querySelectorAll('.increase-item-btn').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        const key = event.currentTarget.dataset.key;
        const currentCart = getCart();

        const updatedCart = currentCart.map((item) => {
          if (getItemKey(item) === key) {
            const stock = Number(item.stock || 0);
            const quantity = Number(item.quantity || 1);
            const tracksStock = itemTracksStock(item);
            const isPreorder = Boolean(item.preorder);

            if (isCartItemUnavailable(item) || item.is_gift || (tracksStock && !isPreorder && (stock <= 0 || quantity >= stock))) {
              return item;
            }

            return {
              ...item,
              quantity: quantity + 1,
            };
          }

          return item;
        });

        saveCart(updatedCart);
      });
    });

    cartItemsContainer.querySelectorAll('.decrease-item-btn').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        const key = event.currentTarget.dataset.key;
        const currentCart = getCart();

        const updatedCart = currentCart
          .map((item) => {
            if (getItemKey(item) === key) {
              if (isCartItemUnavailable(item)) return item;
              const quantity = Number(item.quantity || 1);

              return {
                ...item,
                quantity: quantity - 1,
              };
            }

            return item;
          })
          .filter((item) => Number(item.quantity || 0) > 0);

        saveCart(updatedCart);
      });
    });

    cartItemsContainer.querySelectorAll('.delete-item-btn').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        const key = event.currentTarget.dataset.key;
        const currentCart = getCart();
        const updatedCart = currentCart.filter((item) => getItemKey(item) !== key);

        saveCart(updatedCart);
      });
    });
  });

  window.addEventListener('pz-currency-changed', () => window.dispatchEvent(new Event('cart-updated')));
  window.addEventListener('pz-promotions-updated', () => window.dispatchEvent(new Event('cart-updated')));
