    </nav>
    <div class="drawer-admin-action">
      <a class="drawer-link drawer-admin-link" href="/admin">Ir al panel de administración</a>
    </div>
  </aside>

  <section class="public-hero">
    <div class="public-hero-cover">{coverImageUrl && <img src={coverImageUrl} alt={`Portada de ${storeName}`} />}</div>
    <div class="public-hero-content">
      <h1 class="public-hero-title">{storeName}</h1>
      <p class="public-hero-text">{welcomeText}</p>

    </div>
  </section>

  <div class="public-hero-actions" aria-label="Acciones después de la portada">
    <a class="hero-btn" href={whatsappStoreHref} target="_blank" rel="noreferrer">WhatsApp</a>
    <a class="hero-btn secondary" href="#categorias">Ver categorías</a>
  </div>

  <PromoBar settings={settings} />

  {(address || businessHours || servicesText || reviewsText) && (
    <section class="public-info-grid">
      {servicesText && <article id="servicios" class="public-info-card"><h2>Servicios</h2><p>{servicesText}</p></article>}
      {businessHours && <article id="horarios" class="public-info-card"><h2>Horarios</h2><p>{businessHours}</p></article>}
      {address && <article class="public-info-card"><h2>Dirección</h2><p>{address}</p></article>}
      {reviewsText && <article id="resena" class="public-info-card"><h2>Reseña</h2><p>{reviewsText}</p></article>}
      <article id="moneda" class="public-info-card"><h2>Moneda</h2><p>Puedes elegir la moneda visual. El cliente verá la moneda elegida; el envío muestra USD y equivalente cuando aplique.</p></article>
    </section>
  )}

  {promoVisualItems.length > 0 && (
    <div class="mb-8">
      <div class="section-head"><div><h2 class="section-title">Promociones</h2><p class="section-subtitle">Accesos visuales y ofertas del negocio.</p></div></div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {promoVisualItems.map((item) => (
          <article class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            {item.imageUrl && <img src={item.imageUrl} alt={item.title} class="w-full h-44 object-cover" />}
            <div class="p-5">
              <h3 class="text-lg font-extrabold text-gray-900">{item.title}</h3>
              {item.description && <p class="text-sm text-gray-500 mt-2 leading-relaxed">{item.description}</p>}
              <a href={visualItemHref(item)} target={item.action_type === 'url' || item.action_type === 'archivo' || item.action_type === 'whatsapp' ? '_blank' : undefined} rel="noreferrer" class="inline-flex mt-4 rounded-2xl bg-gray-900 text-white px-4 py-3 text-sm font-extrabold">
                {visualButtonText(item)}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  )}

  {quickAccessItems.length > 0 && (
    <div class="mb-8">
      <div class="section-head"><div><h2 class="section-title">Accesos rápidos</h2><p class="section-subtitle">Entradas directas a zonas importantes.</p></div></div>
      <div class="flex gap-3 overflow-x-auto pb-2">
        {quickAccessItems.map((item) => (
          <a href={visualItemHref(item)} target={item.action_type === 'url' || item.action_type === 'archivo' || item.action_type === 'whatsapp' ? '_blank' : undefined} rel="noreferrer" class="min-w-[170px] bg-white rounded-2xl shadow-sm border border-gray-100 p-4 block">
            {item.imageUrl ? <img src={item.imageUrl} alt={item.title} class="w-full h-24 object-cover rounded-xl mb-3" /> : <div class="w-full h-24 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center text-2xl mb-3">⚡</div>}
            <p class="font-extrabold text-gray-900 text-sm">{item.title}</p>
            {item.description && <p class="text-xs text-gray-500 mt-1 line-clamp-2">{item.description}</p>}
          </a>
        ))}
      </div>
    </div>
  )}

  {featuredProducts.length > 0 && (
    <section id="destacados" class="mb-8 scroll-mt-24">
      <div class="section-head">
        <div>
          <h2 class="section-title">Productos destacados</h2>
        </div>
      </div>
      <div class="featured-strip" aria-label="Carrusel de productos destacados">
        {featuredProducts.map((product) => (
          <a href={`/producto/${product.slug}`} class="block">
            <ProductCard view="compact" title={product.name} price={String(getProductOfferView(product).price)} regularPrice={String(getProductOfferView(product).regularPrice)} isOffer={getProductOfferView(product).isOffer} image={product.imageUrls?.[0] ?? 'https://placehold.co/500x500?text=PowerZona'} stock={product.stock} allowPreorder={product.allow_preorder} trackStock={product.track_stock !== false} hasVariations={Boolean(product.has_variations)} onlyUsd={Boolean(product.only_usd)} promoText={getProductAutomaticPromotionText(product, automaticPromotions)} />
          </a>
        ))}
      </div>
    </section>
  )}


  {giftsPublicActive && gifts.length > 0 && (
    <section id="regalos" class="mb-8 scroll-mt-24" aria-label={giftsPublicTitle}>
      <a href="/regalos" class="public-gift-banner-link" aria-label={`Abrir ${giftsPublicTitle}`}>
        <div class="public-gift-copy">
          <span class="public-gift-kicker">Especial para tu compra</span>
          <div class="public-gift-copy-top">
            <div class="public-gift-copy-main">
              <h2 class="public-gift-title">{giftsPublicTitle}</h2>
              <p class="public-gift-text">Descubre los regalos disponibles y elige uno cuando tu pedido califique.</p>
            </div>
            <span class="public-gift-cta">Ver regalos <span aria-hidden="true">›</span></span>
          </div>
          <div class="public-gift-meta">
            <span class="public-gift-pill">{gifts.length} regalos</span>
            <span class="public-gift-pill">1 por orden</span>
          </div>
        </div>
        <div class="public-gift-banner">
          {giftsPublicImageUrl ? <img src={giftsPublicImageUrl} alt={giftsPublicTitle} loading="lazy" /> : <div class="public-gift-banner-fallback">🎁</div>}
        </div>
      </a>
    </section>
  )}

  {categories.length > 0 && (
    <section id="categorias" class="mb-8 scroll-mt-24">
      <div class="section-head">
        <div>
          <h2 class="section-title">Categorías</h2>
        </div>
      </div>
      <div class="public-category-grid">
        {categories.map((category) => {
          const categoryProducts = productsByCategoryTotal(category.id);
          return (
            <a href={`/categoria/${category.slug}`} class="public-category-link" aria-label={`Abrir categoría ${category.name}`}>
              <h3 class="public-category-title-outside">{category.name}</h3>
              <div class="public-category-card">
                {category.imageUrl ? <img src={category.imageUrl} alt={category.name} /> : <div class="public-category-fallback">PZ</div>}
                <span class="public-category-go">›</span>
              </div>
              <div class="public-category-meta">
                <span class="public-category-pill">{productCountLabel(categoryProducts.length)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {homepageProducts.length > 0 && (
    <section class="mb-8">
      <div class="section-head">
        <div>
          <h2 class="section-title">Productos</h2>
          <p class="section-subtitle">Productos publicados directamente en portada.</p>
        </div>
      </div>
      <div class="homepage-products-grid">
        {homepageProducts.map((product) => (
          <a href={`/producto/${product.slug}`} class="block">
            <ProductCard view="compact" title={product.name} price={String(getProductOfferView(product).price)} regularPrice={String(getProductOfferView(product).regularPrice)} isOffer={getProductOfferView(product).isOffer} image={product.imageUrls?.[0] ?? 'https://placehold.co/500x500?text=PowerZona'} stock={product.stock} allowPreorder={product.allow_preorder} trackStock={product.track_stock !== false} hasVariations={Boolean(product.has_variations)} onlyUsd={Boolean(product.only_usd)} promoText={getProductAutomaticPromotionText(product, automaticPromotions)} />
          </a>
        ))}
      </div>
    </section>
  )}

  <PublicFooter settings={settings} />

  <script>
    const openPublicMenuBtn = document.getElementById('public-menu-open');
    const closePublicMenuBtn = document.getElementById('public-menu-close');
    const publicDrawer = document.getElementById('public-drawer');
    const publicOverlay = document.getElementById('public-drawer-overlay');
    function openPublicMenu() {
      document.body.classList.add('public-menu-open');
      publicDrawer?.setAttribute('aria-hidden', 'false');
      openPublicMenuBtn?.setAttribute('aria-expanded', 'true');
      if (publicOverlay) publicOverlay.hidden = false;
    }
    function closePublicMenu() {
      document.body.classList.remove('public-menu-open');
      publicDrawer?.setAttribute('aria-hidden', 'true');
      openPublicMenuBtn?.setAttribute('aria-expanded', 'false');
      setTimeout(() => { if (!document.body.classList.contains('public-menu-open') && publicOverlay) publicOverlay.hidden = true; }, 220);
    }
    openPublicMenuBtn?.addEventListener('click', openPublicMenu);
    closePublicMenuBtn?.addEventListener('click', closePublicMenu);
    publicOverlay?.addEventListener('click', closePublicMenu);
    publicDrawer?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closePublicMenu));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closePublicMenu(); });

    function getGiftCart() {
      try { return JSON.parse(localStorage.getItem('powerzona_cart') || '[]'); } catch (_) { return []; }
    }
    function saveGiftCart(cart) {
      const payload = JSON.stringify(cart);
      localStorage.setItem('powerzona_cart', payload);
      if (cart.length) sessionStorage.setItem('powerzona_checkout_cart', payload);
      else sessionStorage.removeItem('powerzona_checkout_cart');
      window.dispatchEvent(new Event('cart-updated'));
    }
    function getGiftCartSubtotal(cart = getGiftCart()) {
      return cart.filter((item) => !item.is_gift).reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 1), 0);
    }
    function showGiftInfo(message) {
      const alert = document.getElementById('gift-info-alert');
      if (!alert) return;
      alert.textContent = message;
      alert.style.display = message ? 'block' : 'none';
      if (message) alert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function syncGiftButtons() {
      const subtotal = getGiftCartSubtotal();
      document.querySelectorAll('[data-gift-card]').forEach((card) => {
        const min = Number(card.dataset.giftMin || 0);
        const stock = Number(card.dataset.giftStock || 0);
        const btn = card.querySelector('[data-gift-button]');
        if (!btn) return;
        const canAdd = subtotal >= min && stock > 0;
        btn.disabled = !canAdd;
        btn.textContent = stock <= 0 ? 'Agotado' : canAdd ? 'Agregar regalo' : `Disponible desde $${min.toFixed(2)} USD`;
      });
    }
    function addGiftFromCard(card) {
      const cart = getGiftCart();
      const min = Number(card.dataset.giftMin || 0);
      const subtotal = getGiftCartSubtotal(cart);
      if (subtotal < min) {
        showGiftInfo(`Este regalo estará disponible cuando tu carrito llegue a $${min.toFixed(2)} USD.`);
        return;
      }
      const existingGift = cart.find((item) => item.is_gift);
      if (existingGift && existingGift.gift_id !== card.dataset.giftId) {
        const replace = window.confirm('Ya tienes un regalo seleccionado. ¿Quieres reemplazarlo por este?');
        if (!replace) return;
      }
      const withoutGifts = cart.filter((item) => !item.is_gift);
      withoutGifts.push({
        id: `gift-${card.dataset.giftId}`,
        gift_id: card.dataset.giftId,
        title: card.dataset.giftName || 'Regalo',
        image: card.dataset.giftImage || 'https://placehold.co/500x500?text=Regalo',
        price: 0,
        quantity: 1,
        stock: Number(card.dataset.giftStock || 0),
        min_order_usd: min,
        is_gift: true,
        track_stock: true,
      });
      saveGiftCart(withoutGifts);
      showGiftInfo('Regalo agregado al carrito. Solo puedes llevar 1 regalo por orden.');
    }
    document.querySelectorAll('[data-gift-button]').forEach((button) => {
      button.addEventListener('click', () => {
        const card = button.closest('[data-gift-card]');
        if (card) addGiftFromCard(card);
      });
    });
    window.addEventListener('cart-updated', syncGiftButtons);
    syncGiftButtons();

  </script>
</Layout>
