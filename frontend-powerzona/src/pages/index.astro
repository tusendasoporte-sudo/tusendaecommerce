---
import Layout from '../layouts/Layout.astro';
import { getFeaturedStores } from '../lib/stores';
import { getSettings } from '../lib/api';

const featuredStores = await getFeaturedStores();
const visibleStores = await Promise.all(featuredStores.map(async (store) => {
  const settings = await getSettings({ storeId: store.id }).catch(() => null);
  return {
    ...store,
    bazarImageUrl: store.bazaarImageUrl || settings?.logoImageUrl || settings?.coverImageUrl || store.logoUrl || store.bannerUrl || '',
    description: String(settings?.store_description || '').trim(),
  };
}));

function storeInitials(name: string) {
  return String(name || 'TS')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase())
    .join('') || 'TS';
}

function storeHref(store: any) {
  return `/t/${encodeURIComponent(String(store.slug || '').trim().toLowerCase())}`;
}
---

<Layout
  isBazar={true}
  seo={{
    title: 'Tu Senda 84',
    description: 'Tu Senda 84',
    image: '/brand/tusenda84-bazzar-logo.webp',
    canonical: '/',
    type: 'website',
    siteName: 'Tu Senda 84',
  }}
>
  <style>
    .bazar-shell { display: grid; gap: 28px; color: #111827; }
    .bazar-hero { position: relative; overflow: hidden; border-radius: 30px; border: 1px solid rgba(226,232,240,.95); background: #0f172a; box-shadow: 0 24px 70px rgba(15,23,42,.14); }
    .bazar-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 12%, rgba(34,197,94,.26), transparent 30%), radial-gradient(circle at 85% 18%, rgba(14,165,233,.22), transparent 28%), linear-gradient(135deg,#0f172a,#172554 52%,#164e63); }
    .bazar-hero-content { position: relative; z-index: 1; display: grid; gap: 18px; padding: clamp(26px, 6vw, 54px); min-height: 320px; align-content: center; color: #fff; }
    .bazar-kicker { width: max-content; max-width: 100%; border-radius: 999px; padding: 8px 12px; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.22); color: rgba(255,255,255,.9); font-size: 12px; font-weight: 900; }
    .bazar-title { margin: 0; font-size: clamp(40px, 9vw, 76px); line-height: .92; font-weight: 1000; letter-spacing: 0; }
    .bazar-copy { margin: 0; max-width: 640px; color: rgba(255,255,255,.84); font-size: clamp(16px, 2.2vw, 19px); line-height: 1.55; font-weight: 750; }
    .bazar-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 4px; }
    .bazar-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 18px; padding: 13px 17px; background: #22c55e; color: #052e16; font-size: 14px; font-weight: 1000; text-decoration: none; box-shadow: 0 18px 42px rgba(34,197,94,.2); }
    .bazar-btn.secondary { background: rgba(255,255,255,.96); color: #111827; box-shadow: 0 14px 34px rgba(15,23,42,.12); }
    .bazar-section-head { display: flex; align-items: end; justify-content: space-between; gap: 16px; }
    .bazar-section-title { margin: 0; font-size: clamp(25px, 4vw, 36px); line-height: 1; font-weight: 1000; letter-spacing: 0; color: #111827; }
    .bazar-section-text { margin: 7px 0 0; color: #64748b; font-size: 14px; line-height: 1.45; font-weight: 800; }
    .store-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; }
    .store-card { overflow: hidden; border-radius: 8px; border: 1px solid #e5e7eb; background: #fff; color: inherit; text-decoration: none; box-shadow: 0 16px 40px rgba(15,23,42,.07); transition: transform .18s ease, box-shadow .18s ease; }
    .store-card:hover { transform: translateY(-2px); box-shadow: 0 22px 52px rgba(15,23,42,.11); }
    .store-banner { position: relative; min-height: 150px; aspect-ratio: 16 / 8; background: linear-gradient(135deg,#f1f5f9,#dbeafe); display: grid; place-items: center; overflow: hidden; }
    .store-banner img { width: 100%; height: 100%; object-fit: cover; }
    .store-fallback { width: 72px; height: 72px; border-radius: 24px; display: grid; place-items: center; background: #111827; color: #fff; font-size: 23px; font-weight: 1000; box-shadow: 0 16px 40px rgba(15,23,42,.18); }
    .store-featured { position: absolute; top: 12px; left: 12px; border-radius: 999px; padding: 7px 10px; background: rgba(255,255,255,.94); border: 1px solid rgba(226,232,240,.95); color: #166534; font-size: 11px; font-weight: 1000; }
    .store-body { display: grid; gap: 12px; padding: 18px; }
    .store-meta { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .store-name { margin: 0; min-width: 0; color: #111827; font-size: 21px; line-height: 1.05; font-weight: 1000; letter-spacing: 0; }
    .store-status { flex: 0 0 auto; border-radius: 999px; padding: 7px 10px; background: #ecfdf5; border: 1px solid #bbf7d0; color: #166534; font-size: 11px; font-weight: 1000; }
    .store-description { margin: 0; color: #64748b; font-size: 14px; line-height: 1.45; font-weight: 750; }
    .store-cta { display: inline-flex; align-items: center; justify-content: center; width: 100%; border-radius: 8px; padding: 13px 14px; background: #111827; color: #fff; font-size: 14px; font-weight: 1000; }
    .bazar-coming { display: grid; gap: 8px; border-radius: 8px; border: 1px dashed #cbd5e1; background: #f8fafc; padding: clamp(20px, 4vw, 30px); }
    .bazar-coming h2 { margin: 0; color: #111827; font-size: 22px; font-weight: 1000; letter-spacing: 0; }
    .bazar-coming p { margin: 0; color: #64748b; font-size: 14px; line-height: 1.5; font-weight: 800; }
    .empty-stores { border-radius: 8px; border: 1px solid #e5e7eb; background: #fff; padding: 22px; color: #64748b; font-size: 14px; font-weight: 800; }

    @media (max-width: 640px) {
      .bazar-hero { border-radius: 24px; }
      .bazar-hero-content { min-height: 300px; }
      .bazar-actions { display: grid; grid-template-columns: 1fr; }
      .bazar-btn { width: 100%; }
      .bazar-section-head { display: grid; }
    }
  </style>

  <main class="bazar-shell">
    <section class="bazar-hero" aria-label="Tu Senda 84">
      <div class="bazar-hero-content">
        <span class="bazar-kicker">Bazar principal</span>
        <h1 class="bazar-title">Tu Senda 84</h1>
        <p class="bazar-copy">Explora tiendas, ofertas y negocios disponibles en Tu Senda 84.</p>
        <div class="bazar-actions">
          <a class="bazar-btn" href="/t/powerzona">Entrar a PowerZona</a>
          <a class="bazar-btn secondary" href="#tiendas">Ver tiendas destacadas</a>
        </div>
      </div>
    </section>

    <section id="tiendas" class="bazar-stores" aria-label="Tiendas destacadas">
      <div class="bazar-section-head">
        <div>
          <h2 class="bazar-section-title">Tiendas destacadas</h2>
          <p class="bazar-section-text">Negocios disponibles para comprar y explorar desde un solo lugar.</p>
        </div>
      </div>

      {visibleStores.length > 0 ? (
        <div class="store-grid">
          {visibleStores.map((store) => (
            <a class="store-card" href={storeHref(store)} aria-label={`Entrar a ${store.name}`}>
              <div class="store-banner">
                {store.bazarImageUrl ? <img src={store.bazarImageUrl} alt={store.name} loading="lazy" /> : <div class="store-fallback">{storeInitials(store.name)}</div>}
                {store.featured === true && <span class="store-featured">Destacada</span>}
              </div>
              <div class="store-body">
                <div class="store-meta">
                  <h3 class="store-name">{store.name || 'Tienda'}</h3>
                  <span class="store-status">Abierta</span>
                </div>
                {store.description && <p class="store-description">{store.description}</p>}
                <span class="store-cta">Ver tienda</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-stores">Próximamente estarán disponibles las primeras tiendas.</div>
      )}
    </section>

    <section class="bazar-coming" aria-label="Próximamente">
      <h2>Próximamente más tiendas, promociones y negocios.</h2>
      <p>Tu Senda 84 seguirá creciendo con nuevas opciones para descubrir comercios disponibles.</p>
    </section>
  </main>
</Layout>
