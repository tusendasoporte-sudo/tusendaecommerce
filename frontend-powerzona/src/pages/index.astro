// PZ-PUBLIC-HOME-V8-MENU-MONEDA-ACTIVA-20260604
// PowerZona Ajustes Visuales V23 - nombres de categorías fuera y encima de la tarjeta
// PZ-INDEX-V28-CATEGORIAS-IMAGEN-16X9-20260605
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import PublicFooter from '../components/PublicFooter.astro';
import PromoBar from '../components/PromoBar.astro';
import { getSettings, getCategories, getSubcategories, getProducts, getFeaturedProducts, getStoreVisualItems, getPublicGifts, getAutomaticPromotions, getProductAutomaticPromotionText } from '../lib/api';

const settings = await getSettings();
const categories = await getCategories();
const subcategories = await getSubcategories();
const products = await getProducts();
const featuredProducts = await getFeaturedProducts();
const visualItems = await getStoreVisualItems();
const gifts = await getPublicGifts();
const automaticPromotions = await getAutomaticPromotions();

// Regla pública:
// - La portada no abre categorías en la misma página.
// - Categoría y subcategoría abren en página propia.
// - Productos destacados usan vista más compacta que las páginas de categoría.
// - Productos sin categoría se mantienen en portada.
const homepageProducts = products.filter((product) => !product.category && product.featured !== true);
const promoVisualItems = visualItems.filter((item) => item.type === 'promo_visual');
const quickAccessItems = visualItems.filter((item) => item.type === 'acceso_rapido');

const storeName = settings?.store_name || settings?.stored_name || 'PowerZona';
const welcomeText = settings?.welcome_text || 'Descubre nuestras mejores ofertas y productos destacados.';
const address = settings?.address || '';
const businessHours = settings?.business_hours || '';
const servicesText = settings?.public_services_text || '';
const reviewsText = settings?.reviews_text || '';
const logoImageUrl = settings?.logoImageUrl || '';
const coverImageUrl = settings?.coverImageUrl || '';
const giftsPublicActive = settings?.gifts_public_active !== false;
const giftsPublicTitle = settings?.gifts_public_title || 'Regalos';
const giftsPublicImageUrl = settings?.giftsPublicImageUrl || '';

function cleanWhatsappNumber(value: string | undefined) {
  return String(value || '').replace(/[^0-9]/g, '');
}

function subcategoriesByCategory(categoryId: string) {
  return subcategories.filter((subcategory) => subcategory.category === categoryId);
}

function productCountLabel(count: number) {
  return `${count} ${count === 1 ? 'producto' : 'productos'}`;
}

function productsByCategoryTotal(categoryId: string) {
  const childSubcategoryIds = new Set(subcategoriesByCategory(categoryId).map((subcategory) => subcategory.id));
  const categoryProducts = products.filter((product) => product.category === categoryId || childSubcategoryIds.has(product.subcategory));
  return Array.from(new Map(categoryProducts.map((product) => [product.id, product])).values());
}

const whatsappNumber = cleanWhatsappNumber(settings?.whatsapp_number);
const whatsappStoreHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`Hola ${storeName}, quiero información.`)}`
  : '#';

function visualItemHref(item: any) {
  const actionType = item.action_type || 'whatsapp';
  if (actionType === 'url' && item.target_url) return item.target_url;
  if (actionType === 'archivo' && item.attachmentUrl) return item.attachmentUrl;
  if (actionType === 'categoria' && item.expand?.category?.slug) return `/categoria/${item.expand.category.slug}`;
  if (actionType === 'whatsapp') {
    const text = encodeURIComponent(item.whatsapp_message || `Hola ${storeName}, quiero información sobre ${item.title || 'esta promo'}.`);
    return whatsappNumber ? `https://wa.me/${whatsappNumber}?text=${text}` : '#';
  }
  return item.target_url || '#';
}

function visualButtonText(item: any) {
  if (item.button_text) return item.button_text;
  if (item.action_type === 'archivo') return 'Ver archivo';
  if (item.action_type === 'url') return 'Abrir enlace';
  if (item.action_type === 'categoria') return 'Ver categoría';
  return 'Contactar por WhatsApp';
}
function getProductOfferView(product: any) {
  const activePrice = Number(product?.base_price_usd || 0);
  const regularPrice = Number(product?.regular_price_usd || activePrice);
  const isOffer = Boolean(product?.is_offer) && activePrice > 0 && regularPrice > activePrice;
  return {
    price: activePrice,
    regularPrice: isOffer ? regularPrice : activePrice,
    isOffer,
  };
}

