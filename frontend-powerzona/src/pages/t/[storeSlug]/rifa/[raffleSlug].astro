---
import RafflePublicPage from '../../../../components/public-store/RafflePublicPage.astro';
import { getSettings } from '../../../../lib/api';
import { StoreResolutionError, getCurrentStore } from '../../../../lib/stores';
import { getOccupiedRaffleNumbers, getVisibleRaffleBySlug } from '../../../../lib/raffles';

let currentStore;

try {
  currentStore = await getCurrentStore(Astro);
} catch (error) {
  if (error instanceof StoreResolutionError) {
    return Astro.redirect('/');
  }

  throw error;
}

const raffleSlug = String(Astro.params.raffleSlug || '').trim();
const settings = await getSettings({ storeId: currentStore.id }).catch(() => null);
const raffle = await getVisibleRaffleBySlug(currentStore.id, raffleSlug);

const occupiedNumbers = raffle ? await getOccupiedRaffleNumbers(raffle.id) : [];
const canonicalPath = `/t/${encodeURIComponent(currentStore.slug)}/rifa/${encodeURIComponent(raffle?.slug || raffleSlug)}`;
---

<RafflePublicPage
  store={currentStore}
  settings={settings}
  raffle={raffle}
  occupiedNumbers={occupiedNumbers}
  canonicalPath={canonicalPath}
/>
