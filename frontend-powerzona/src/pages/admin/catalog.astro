    <script define:vars={{ pocketbaseUrl, currentStoreId, adminCatalogPath, adminProductsPath, adminAuthToken }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_CATALOG_PATH = String(adminCatalogPath || '/admin/catalog');
      const ADMIN_PRODUCTS_PATH = String(adminProductsPath || '/admin/products');
      const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      const adminView = document.getElementById('admin-view');
      const logoutBtn = document.getElementById('logout-btn');
      const adminSubtitle = document.getElementById('admin-subtitle') || { textContent: '' };
      const catalogSearch = document.getElementById('catalog-search');
      const catalogStatusFilter = document.getElementById('catalog-status-filter');
      const categoryCreateMainBtn = document.getElementById('category-create-main-btn');
      const statCategoriesTotal = document.getElementById('stat-categories-total');
      const statCategoriesActive = document.getElementById('stat-categories-active');
      const statCategoriesChildren = document.getElementById('stat-categories-children');
      const statProductsAssigned = document.getElementById('stat-products-assigned');

      const categoryForm = document.getElementById('category-form');
      const categoryName = document.getElementById('category-name');
      const categoryDescription = document.getElementById('category-description');
      const categoryImage = document.getElementById('category-image');
      const categoryActive = document.getElementById('category-active');
      const categorySubmit = document.getElementById('category-submit');
      const categoryAlert = document.getElementById('category-alert');
      const categoryCreateCard = document.getElementById('category-create-card');
      const categoryCreateToggle = document.getElementById('category-create-toggle');
      const categoryCreateClose = document.querySelector('.category-create-close');

      const subcategoryForm = document.getElementById('subcategory-form');
      const subcategoryCategory = document.getElementById('subcategory-category');
      const subcategoryName = document.getElementById('subcategory-name');
      const subcategoryImage = document.getElementById('subcategory-image');
      const subcategoryActive = document.getElementById('subcategory-active');
      const subcategoryAlert = document.getElementById('subcategory-alert');
      const subcategoryCreateCard = document.getElementById('subcategory-create-card');
      const subcategoryCreateToggle = document.getElementById('subcategory-create-toggle');

      const categoriesList = document.getElementById('categories-list');
      const subcategoriesList = document.getElementById('subcategories-list');
      const categoriesCount = document.getElementById('categories-count');
      const subcategoriesCount = document.getElementById('subcategories-count');
      const catalogContentView = document.getElementById('catalog-content-view');
      const contentViewHeading = document.getElementById('content-view-heading');
      const contentViewBody = document.getElementById('content-view-body');
      const contentViewBack = document.getElementById('content-view-back');
      const contentViewParentBack = document.getElementById('content-view-parent-back');

      let categories = [];
      let subcategories = [];
      let products = [];
      let contentNavigation = { type: 'general', categoryId: '', subcategoryId: '', parentCategoryId: '' };
      let categoryCreateSubmitting = false;

      const sidebar = document.querySelector('[data-admin-sidebar-root]');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarOverlay = document.getElementById('sidebar-overlay');

      function openSidebar() {
        document.body.classList.add('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'false');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'true');
        if (sidebarOverlay) sidebarOverlay.hidden = false;
      }

      function closeSidebar() {
        document.body.classList.remove('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'true');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'false');
        setTimeout(() => {
          if (!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true;
        }, 220);
      }

      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeSidebar();
      });
      sidebar?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSidebar));
      function slugify(value) {
        return String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      function escapeHtml(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function normalizeName(value) {
        return String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim()
          .replace(/\s+/g, ' ');
      }

      async function optimizeCatalogImageFile(file) {
        if (!file || !file.type?.startsWith('image/')) return file;
        let objectUrl = '';
        try {
          const image = await new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve(img);
            img.onerror = reject;
            objectUrl = URL.createObjectURL(file);
            img.src = objectUrl;
          });

          const targetWidth = 1200;
          const targetHeight = 675;
          const sourceWidth = image.naturalWidth || image.width;
          const sourceHeight = image.naturalHeight || image.height;
          const scale = Math.min(targetWidth / sourceWidth, targetHeight / sourceHeight, 1);
          const drawWidth = Math.max(1, Math.round(sourceWidth * scale));
          const drawHeight = Math.max(1, Math.round(sourceHeight * scale));
          const dx = Math.round((targetWidth - drawWidth) / 2);
          const dy = Math.round((targetHeight - drawHeight) / 2);

          const canvas = document.createElement('canvas');
          canvas.width = targetWidth;
          canvas.height = targetHeight;
          const ctx = canvas.getContext('2d');
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          ctx.fillStyle = '#f8fbff';
          ctx.fillRect(0, 0, targetWidth, targetHeight);
          ctx.drawImage(image, 0, 0, sourceWidth, sourceHeight, dx, dy, drawWidth, drawHeight);

          const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/webp', 0.82));
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          if (!blob) return file;
          const safeName = String(file.name || 'categoria')
            .replace(/\.[^.]+$/, '')
            .replace(/[^a-z0-9_-]+/gi, '_')
            .toLowerCase();
          return new File([blob], `${safeName}_categoria_1200x675.webp`, { type: 'image/webp', lastModified: Date.now() });
        } catch (error) {
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          return file;
        }
      }

      function recordImageUrl(collection, record) {
        if (!record?.image) return '';
        return `${POCKETBASE_URL}/api/files/${collection}/${record.id}/${record.image}`;
      }

      function imageMarkup(collection, record, label) {
        const url = recordImageUrl(collection, record);
        const thumbStyle = 'width:56px !important;height:56px !important;max-width:56px !important;max-height:56px !important;min-width:56px !important;min-height:56px !important;flex:0 0 56px !important;object-fit:contain !important;display:block;border-radius:14px;';
        if (!url) return `<span class="row-thumb placeholder" style="${thumbStyle}" aria-label="Sin imagen">+</span>`;
        return `<img class="row-thumb" style="${thumbStyle}" src="${escapeHtml(url)}" alt="${escapeHtml(label)}" loading="lazy" />`;
      }

      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }
      function productImageUrl(product) {
        const images = parseProductImageOrder(product);
        const firstImage = images[0];
        if (!product?.id || !firstImage || !POCKETBASE_URL) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }

      function productImageMarkup(product) {
        const name = product?.name || 'Producto';
        const url = productImageUrl(product);
        const thumbStyle = 'width:56px !important;height:56px !important;max-width:56px !important;max-height:56px !important;min-width:56px !important;min-height:56px !important;flex:0 0 56px !important;object-fit:contain !important;display:block;border-radius:14px;';
        if (!url) return `<span class="row-thumb placeholder" style="${thumbStyle}" aria-label="Sin imagen">P</span>`;
        return `<img class="row-thumb" style="${thumbStyle}" src="${escapeHtml(url)}" alt="${escapeHtml(name)}" loading="lazy" />`;
      }

      function formatUsd(value) {
        const amount = Number(value || 0);
        return `${amount.toFixed(2)} USD`;
      }

      function productHasRealSubcategory(product) {
        return Boolean(product?.subcategory && subcategories.some((item) => item.id === product.subcategory));
      }

      function getDirectProductsForCategory(categoryId) {
        return products.filter((product) => product.category === categoryId && !productHasRealSubcategory(product));
      }

      function getAllProductsForCategory(categoryId) {
        return products.filter((product) => product.category === categoryId);
      }

      function getProductsForSubcategory(subcategoryId) {
        return products.filter((product) => product.subcategory === subcategoryId);
      }

      function productStatusLabel(product) {
        return product?.active ? 'Visible' : 'Oculto';
      }

      function renderContentStats(stats) {
        return `
          <div class="content-stats-grid">
            ${stats.map((stat) => `
              <div class="content-stat">
                <strong>${escapeHtml(stat.value)}</strong>
                <span>${escapeHtml(stat.label)}</span>
              </div>
            `).join('')}
          </div>
        `;
      }

      function renderProductCards(productItems) {
        if (!productItems.length) {
          return '<div class="content-empty">No hay productos en esta parte todavía.</div>';
        }

        return productItems.map((product) => {
          const parentSubcategory = subcategories.find((item) => item.id === product.subcategory);
          const metaParts = [
            `Stock: ${Number(product.stock || 0)}`,
            productStatusLabel(product),
            parentSubcategory ? `Subcategoría: ${parentSubcategory.name}` : 'Producto directo'
          ];
          return `
            <article class="content-product-card" data-product-id="${product.id}">
              ${productImageMarkup(product)}
              <div style="min-width:0;">
                <p class="content-item-title">${escapeHtml(product.name || 'Producto sin nombre')}</p>
                <p class="content-item-meta">${escapeHtml(metaParts.join(' · '))}</p>
              </div>
              <div class="content-product-actions">
                <span class="content-price-pill">${escapeHtml(formatUsd(product.base_price_usd))}</span>
                <button class="mini-btn js-product-edit-soon" type="button">Editar</button>
              </div>
            </article>
          `;
        }).join('');
      }

      function renderSubcategoryCards(subcategoryItems) {
        if (!subcategoryItems.length) {
          return '<div class="content-empty">Esta categoría todavía no tiene subcategorías.</div>';
        }

        return subcategoryItems.map((subcategory) => {
          const count = getProductsForSubcategory(subcategory.id).length;
          return `
            <article class="content-subcategory-card js-open-subcategory-content" data-subcategory-id="${subcategory.id}">
              ${imageMarkup('subcategories', subcategory, subcategory.name || 'Subcategoría')}
              <div style="min-width:0;">
                <p class="content-item-title">${escapeHtml(subcategory.name)}</p>
                <p class="content-item-meta">${count} productos · ${subcategory.active ? 'Visible propia' : 'Oculta propia'}</p>
              </div>
              <button class="mini-btn" type="button">Ver productos ›</button>
            </article>
          `;
        }).join('');
      }

      function openContentView() {
        adminView?.classList.add('content-mode');
        catalogContentView?.classList.add('open');
        setTimeout(() => catalogContentView?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 40);
      }

      function closeContentView() {
        contentNavigation = { type: 'general', categoryId: '', subcategoryId: '', parentCategoryId: '' };
        adminView?.classList.remove('content-mode');
        catalogContentView?.classList.remove('open');
        if (contentViewParentBack) {
          contentViewParentBack.classList.add('hidden');
          contentViewParentBack.textContent = '← Volver al anterior';
        }
        if (contentViewHeading) contentViewHeading.innerHTML = '';
        if (contentViewBody) contentViewBody.innerHTML = '';
      }

      function updateContentBackButton(parentCategoryId = '') {
        if (!contentViewParentBack) return;
        const parent = parentCategoryId ? getCategory(parentCategoryId) : null;
        contentViewParentBack.classList.toggle('hidden', !parent);
        contentViewParentBack.textContent = parent ? `← Volver a ${parent.name}` : '← Volver al anterior';
      }

      function showCategoryContent(categoryId) {
        const category = getCategory(categoryId);
        if (!category) return;
        contentNavigation = { type: 'category', categoryId: category.id, subcategoryId: '', parentCategoryId: '' };
        updateContentBackButton('');
        const childSubcategories = sortedByCatalogOrder(subcategories.filter((item) => item.category === category.id));
        const directProducts = getDirectProductsForCategory(category.id);
        const allCategoryProducts = getAllProductsForCategory(category.id);

        contentViewHeading.innerHTML = `
          ${imageMarkup('categories', category, category.name || 'Categoría')}
          <div style="min-width:0;">
            <p class="content-view-title">${escapeHtml(category.name)}</p>
            <p class="content-view-subtitle">Contenido de categoría · ${category.active ? 'Visible en tienda' : 'Oculta en tienda'}</p>
          </div>
        `;

        contentViewBody.innerHTML = `
          ${renderContentStats([
            { value: String(childSubcategories.length), label: 'Subcategorías' },
            { value: String(directProducts.length), label: 'Productos directos' },
            { value: String(allCategoryProducts.length), label: 'Productos totales' },
          ])}

          <section class="content-section">
            <div class="content-section-head">
              <h3 class="content-section-title">Subcategorías dentro de esta categoría</h3>
              <p class="content-section-note">Toca una subcategoría para ver sus productos.</p>
            </div>
            <div class="content-mini-grid">${renderSubcategoryCards(childSubcategories)}</div>
          </section>

          <section class="content-section">
            <div class="content-section-head">
              <div>
                <h3 class="content-section-title">Productos directos de la categoría</h3>
                <p class="content-section-note">Productos que no dependen de una subcategoría.</p>
              </div>
              <button class="mini-btn primary js-product-create-soon" type="button">+ Nuevo producto</button>
            </div>
            <div class="content-mini-grid">${renderProductCards(directProducts)}</div>
          </section>
        `;
        openContentView();
      }

      function showSubcategoryContent(subcategoryId) {
        const subcategory = subcategories.find((item) => item.id === subcategoryId);
        if (!subcategory) return;
        const parent = getCategory(subcategory.category);
        contentNavigation = { type: 'subcategory', categoryId: parent?.id || '', subcategoryId: subcategory.id, parentCategoryId: parent?.id || '' };
        updateContentBackButton(parent?.id || '');
        const productItems = getProductsForSubcategory(subcategory.id);
        const publicVisible = parent?.active === true && subcategory.active === true;

        contentViewHeading.innerHTML = `
          ${imageMarkup('subcategories', subcategory, subcategory.name || 'Subcategoría')}
          <div style="min-width:0;">
            <p class="content-view-title">${escapeHtml(subcategory.name)}</p>
            <p class="content-view-subtitle">${escapeHtml(parent?.name || 'Sin categoría padre')} · ${publicVisible ? 'Visible en tienda' : 'Oculta públicamente'}</p>
          </div>
        `;

        contentViewBody.innerHTML = `
          ${renderContentStats([
            { value: String(productItems.length), label: 'Productos' },
            { value: String(productItems.filter((item) => item.active).length), label: 'Activos' },
            { value: String(productItems.filter((item) => !item.active).length), label: 'Ocultos' },
          ])}

          <section class="content-section">
            <div class="content-section-head">
              <div>
                <h3 class="content-section-title">Productos dentro de esta subcategoría</h3>
                <p class="content-section-note">Administra los productos asociados a esta subcategoría.</p>
              </div>
              <button class="mini-btn primary js-product-create-soon" type="button">+ Nuevo producto</button>
            </div>
            <div class="content-mini-grid">${renderProductCards(productItems)}</div>
          </section>
        `;
        openContentView();
      }

      function nextOrder(items) {
        if (!items.length) return 1;
        return Math.max(...items.map((item) => Number(item.order || 0))) + 1;
      }

      function categoryNameExists(name, exceptId = '') {
        const normalized = normalizeName(name);
        return categories.some((category) => category.id !== exceptId && normalizeName(category.name) === normalized);
      }

      function subcategoryNameExists(name, categoryId, exceptId = '') {
        const normalized = normalizeName(name);
        return subcategories.some((subcategory) =>
          subcategory.id !== exceptId &&
          subcategory.category === categoryId &&
          normalizeName(subcategory.name) === normalized
        );
      }

      async function patchRecord(collection, id, changes) {
        return apiRequest(`/api/collections/${collection}/records/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(changes),
        });
      }

      function setCreatePanel(card, toggle, isOpen) {
        card?.classList.toggle('open', isOpen);
        toggle?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        const title = toggle?.querySelector('.create-toggle-title');
        const subtitle = toggle?.querySelector('.create-toggle-subtitle');
        const icon = toggle?.querySelector('.create-toggle-icon');
        if (title && toggle === categoryCreateToggle) title.textContent = isOpen ? 'Cerrar nueva categoría' : 'Nueva categoría';
        if (title && toggle === subcategoryCreateToggle) title.textContent = isOpen ? 'Cerrar nueva subcategoría' : 'Nueva subcategoría';
        if (subtitle) subtitle.textContent = isOpen ? 'Toca para cerrar este formulario.' : 'Toca para abrir el formulario completo.';
        if (icon) icon.textContent = isOpen ? '−' : '＋';
      }

      function toggleCreatePanel(type) {
        const isCategory = type === 'category';
        const card = isCategory ? categoryCreateCard : subcategoryCreateCard;
        const toggle = isCategory ? categoryCreateToggle : subcategoryCreateToggle;
        const otherCard = isCategory ? subcategoryCreateCard : categoryCreateCard;
        const otherToggle = isCategory ? subcategoryCreateToggle : categoryCreateToggle;
        const willOpen = !card?.classList.contains('open');
        setCreatePanel(otherCard, otherToggle, false);
        setCreatePanel(card, toggle, willOpen);
        if (willOpen) setTimeout(() => (isCategory ? categoryName : subcategoryCategory)?.focus(), 60);
      }

      function isCategoryCreatePanelOpen() {
        return categoryCreateCard?.classList.contains('open') === true;
      }

      function openCategoryCreatePanel() {
        if (!isCategoryCreatePanelOpen()) toggleCreatePanel('category');
        categoryCreateCard?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => categoryName?.focus(), 180);
      }

      function closeCategoryCreatePanel() {
        if (!isCategoryCreatePanelOpen()) return;
        setCreatePanel(categoryCreateCard, categoryCreateToggle, false);
        setAlert(categoryAlert, '');
      }

      function setAlert(element, message, type = 'info') {
        element.textContent = message;
        element.className = `alert alert-${type}`;
        element.classList.toggle('hidden', !message);
      }
      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function showAdmin() { adminView?.classList.remove('hidden'); }

      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) {
          const error = new Error(result?.message || 'Error de comunicacion con la plataforma.');
          error.status = response.status;
          error.data = result;
          throw error;
        }
        return result;
      }

      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${params}${separator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }

      async function countRecords(collection, filter = '') {
        const query = new URLSearchParams();
        query.set('page', '1');
        query.set('perPage', '1');
        query.set('filter', withStoreFilterExpression(filter));
        const result = await apiRequest(`/api/collections/${collection}/records?${query.toString()}`);
        return Number(result?.totalItems || 0);
      }

      function withStoreFilter(params = '') {
        const query = new URLSearchParams(params || '');
        const existing = query.get('filter');
        if (existing) query.set('filter', `(${existing}) && ${STORE_FILTER}`);
        else query.set('filter', STORE_FILTER);
        return query.toString();
      }

      function isCurrentStoreRecord(record) {
        const value = record?.store;
        return Array.isArray(value) ? value.includes(CURRENT_STORE_ID) : String(value || '') === CURRENT_STORE_ID;
      }

      function pbFilterValue(value) {
        return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
      }

      function withStoreFilterExpression(filter = '') {
        return filter ? `(${filter}) && ${STORE_FILTER}` : STORE_FILTER;
      }

      function getCategory(id) {
        return categories.find((category) => category.id === id) || null;
      }

      function openCategoryEditor(categoryId) {
        const row = categoriesList?.querySelector(`[data-category-id="${categoryId}"]`);
        row?.classList.add('editing');
      }

      function getProductCountForCategory(categoryId) {
        const childSubcategoryIds = new Set(
          subcategories
            .filter((subcategory) => subcategory.category === categoryId)
            .map((subcategory) => subcategory.id)
        );

        const productIds = new Set();

        products.forEach((product) => {
          const belongsDirectlyToCategory = product.category === categoryId;
          const belongsToChildSubcategory = product.subcategory && childSubcategoryIds.has(product.subcategory);

          if (belongsDirectlyToCategory || belongsToChildSubcategory) {
            productIds.add(product.id);
          }
        });

        return productIds.size;
      }

      function getProductCountForSubcategory(subcategoryId) {
        return products.filter((product) => product.subcategory === subcategoryId).length;
      }

      function renderInlineSubcategoryCards(category) {
