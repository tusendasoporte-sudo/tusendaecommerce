---
import { refreshAuthFromCookie } from '../../lib/auth';
import { getPublicStorePath, getStoreAdminPath } from '../../lib/adminRoutes';
import { requireCurrentStoreForAdmin } from '../../lib/storeContext';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreId = adminContext.storeId;
const adminAuthToken = authPb.authStore.token;
const currentStoreSlug = adminContext.store.slug || '';
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminCatalogPath = getStoreAdminPath(currentStoreSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const adminPromosPath = getStoreAdminPath(currentStoreSlug, 'promos');
const adminOrganizationPath = getStoreAdminPath(currentStoreSlug, 'organization');
const publicStorePath = getPublicStorePath(currentStoreSlug);
---
<!-- PZ-AJUSTES-GENERALES-PUBLICOS-MENU-PUBLICO-V5-20260603
  Cambio: se eliminó de forma general la opción/texto "Tienda pública" del sidebar admin.
-->
<!-- PZ-CATALOG-ADMIN-CATEGORIA-PAGINA-DEDICADA-V1-20260603
  Bloque: Categorías admin visual
  Cambio: Nueva categoría queda encima del listado y la edición de categoría abre en página dedicada /admin/catalog/category/[id].
-->
<!-- PZ-CATALOG-JERARQUIA-CATEGORIA-CONTENIDO-V17-20260531
  Bloque: Gestión de catálogo - conexión con página de productos separada
  Cambio: El módulo Productos del sidebar y los botones Nuevo producto/Editar producto ahora llevan a /admin/products.
-->
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de catálogo | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --green: #16a34a;
        --blue: #2563eb;
        --red: #dc2626;
        --orange: #f97316;
        --purple: #7c3aed;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.16), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, 0.10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }

      a { color: inherit; text-decoration: none; }
      button, input, select { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .65; }

      .hidden { display: none !important; }
      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; display: block; }
      .sidebar-overlay {
        position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .36);
        opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(2px);
      }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar {
        position: fixed; top: 18px; left: 18px; bottom: 18px; z-index: 90; width: min(286px, calc(100vw - 36px));
        border-radius: 30px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        color: #0f172a; border: 1px solid rgba(226, 232, 240, .95); box-shadow: 0 28px 80px rgba(15, 23, 42, .22);
        overflow: hidden; transform: translateX(calc(-100% - 28px)); transition: transform .24s ease;
      }
      body.sidebar-open .sidebar { transform: translateX(0); }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; background: #0f172a; color: #fff; box-shadow: 0 14px 30px rgba(15, 23, 42, .18); font-weight: 1000; }
      .brand-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; }
      .brand-subtitle { margin: 2px 0 0; color: #64748b; font-size: 11px; font-weight: 850; }
      .sidebar-label { margin: 18px 9px 9px; color: #64748b; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .nav-list { display: grid; gap: 8px; }
      .nav-item { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: 18px; color: #334155; font-size: 13px; font-weight: 950; border: 1px solid transparent; }
      .nav-item:hover { background: #f1f5f9; border-color: #e2e8f0; color: #0f172a; }
      .nav-item.active { background: #0f172a; border-color: #0f172a; color: #fff; box-shadow: 0 12px 26px rgba(15,23,42,.16); }
      .nav-icon { width: 34px; height: 34px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; background: #f8fafc; color: #0f172a; border: 1px solid #e2e8f0; flex: 0 0 auto; }
      .nav-icon svg { width: 18px; height: 18px; display: block; fill: currentColor; }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.20); }
      .sidebar-footer { margin-top: auto; padding: 14px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .sidebar-footer strong { display: block; font-size: 12px; margin-bottom: 5px; color: #0f172a; }
      .sidebar-footer span { display: block; color: #475569; font-size: 11px; line-height: 1.45; font-weight: 750; }
      .sidebar-close {
        margin-left: auto; width: 36px; height: 36px; border-radius: 14px; border: 1px solid #e2e8f0;
        background: #fff; color: #0f172a; font-weight: 1000; box-shadow: 0 8px 18px rgba(15,23,42,.05);
      }
      .menu-btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 10px; border-radius: 18px; padding: 12px 15px;
        background: #0f172a; color: #fff; border: 1px solid #0f172a; box-shadow: 0 12px 26px rgba(15,23,42,.16); font-weight: 1000;
      }
      .main-wrap { min-width: 0; padding: 2px 0 28px; }
      .topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; flex-wrap: wrap; }
      .back-link, .action-btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 10px;
        border-radius: 18px; padding: 12px 15px; background: rgba(255,255,255,.92);
        border: 1px solid rgba(226, 232, 240, 0.95); box-shadow: 0 12px 26px rgba(15,23,42,.07); font-weight: 950;
      }
      .action-btn.dark { background: #0f172a; color: #fff; }
      .action-btn.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .page-title { font-size: clamp(25px, 3vw, 40px); font-weight: 1000; letter-spacing: -0.045em; line-height: 1.05; margin: 0; }
      .page-title span { color: #334155; font-weight: 800; }
      .page-subtitle { margin: 9px 0 0; font-size: 15px; color: var(--muted); line-height: 1.55; max-width: 760px; }
      .hero-card, .panel-card, .list-card {
        background: rgba(255, 255, 255, 0.92); border: 1px solid rgba(226, 232, 240, 0.96);
        border-radius: 30px; box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08); backdrop-filter: blur(10px);
      }
      .hero-card { padding: 26px; margin-bottom: 18px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 18px; align-items: center; position: relative; overflow: hidden; }
      .hero-card::after { content: ''; position: absolute; right: -80px; top: -90px; width: 230px; height: 230px; background: radial-gradient(circle, rgba(37,99,235,.16), transparent 66%); pointer-events: none; }
      .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; position: relative; z-index: 1; }
      .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 8px 12px; background: #dcfce7; color: #166534; font-size: 13px; font-weight: 1000; }
      .grid { display: grid; grid-template-columns: minmax(315px, .78fr) minmax(0, 1.22fr); gap: 18px; align-items: start; }
      #catalog-grid { grid-template-columns: 1fr; }
      #catalog-tools-panel { display: none !important; }
      #catalog-main-panel { width: 100%; }
      .catalog-create-on-top { margin-bottom: 0; }
      .catalog-open-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 0; border-radius: 999px; padding: 10px 14px; background: #0f172a; color: #fff; font-weight: 1000; box-shadow: 0 12px 24px rgba(15,23,42,.16); }
      .catalog-open-btn:hover { transform: translateY(-1px); }
      .panel-card { padding: 22px; }
      .create-accordion-card { padding: 0; overflow: hidden; }
      .create-toggle-btn {
        width: 100%; border: 0; background: transparent; color: var(--text); padding: 18px 20px;
        display: flex; align-items: center; justify-content: space-between; gap: 14px; text-align: left;
      }
      .create-toggle-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
      .create-toggle-title { display: block; font-size: 18px; font-weight: 1000; letter-spacing: -.025em; }
      .create-toggle-subtitle { display: block; margin-top: 3px; color: var(--muted); font-size: 12px; line-height: 1.35; font-weight: 800; }
      .create-toggle-icon {
        width: 38px; height: 38px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center;
        background: #eff6ff; color: #1d4ed8; flex: 0 0 auto; font-weight: 1000;
      }
      .create-toggle-arrow {
        width: 34px; height: 34px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center;
        background: #f8fafc; border: 1px solid var(--border); color: #334155; font-weight: 1000; flex: 0 0 auto; transition: transform .18s ease;
      }
      .create-accordion-card.open .create-toggle-arrow { transform: rotate(180deg); }
      .create-panel { display: none; padding: 0 20px 20px; border-top: 1px solid var(--border); }
      .create-accordion-card.open .create-panel { display: block; }
      .create-panel .panel-text { margin-top: 15px; }
      .panel-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -.025em; display: flex; align-items: center; gap: 10px; }
      .title-icon { width: 36px; height: 36px; border-radius: 15px; display: inline-flex; align-items: center; justify-content: center; background: #eff6ff; color: #1d4ed8; }
      .panel-text { margin: 8px 0 18px; color: var(--muted); line-height: 1.55; font-size: 14px; }
      .form-grid { display: grid; gap: 12px; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .04em; }
      .field input, .field select {
        width: 100%; border: 1px solid var(--border); border-radius: 16px; background: #fff; color: var(--text);
        padding: 12px 13px; outline: none; font-weight: 800; box-shadow: inset 0 1px 0 rgba(15,23,42,.02);
      }
      .field input[type="file"] { padding: 10px; background: #f8fafc; }
      .image-help { margin: 2px 0 0; color: #64748b; font-size: 11px; line-height: 1.4; font-weight: 800; }
      .field input:focus, .field select:focus { border-color: #93c5fd; box-shadow: 0 0 0 4px rgba(37, 99, 235, .12); }
      .form-row { display: grid; grid-template-columns: 1fr 120px; gap: 12px; }
      .form-row.simple { grid-template-columns: 1fr; }
      .checkline { display: flex; align-items: center; gap: 10px; font-weight: 900; color: #334155; }
      .checkline input { width: 18px; height: 18px; accent-color: #16a34a; }
      .submit-btn { border: 0; border-radius: 18px; padding: 13px 16px; background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; font-weight: 1000; box-shadow: 0 14px 28px rgba(15,23,42,.20); }
      .submit-btn:hover { transform: translateY(-1px); }
      .alert { margin-top: 12px; border-radius: 16px; padding: 11px 12px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
      .section-stack { display: grid; gap: 18px; }
      .list-card { overflow: visible; position: relative; z-index: 1; }
      .catalog-categories-card { z-index: 40; margin-bottom: 34px; }
      .catalog-categories-card.menu-open-card { z-index: 9990; }
      .catalog-subcategories-card.menu-open-card { z-index: 9990; }
      .catalog-subcategories-card { z-index: 5; }
      .section-stack { overflow: visible; }
      .list-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 20px 22px; border-bottom: 1px solid var(--border); flex-wrap: wrap; background: linear-gradient(180deg, rgba(248,250,252,.86), rgba(255,255,255,.6)); }
      .list-title { margin: 0; font-size: 18px; font-weight: 1000; letter-spacing: -.02em; display: flex; align-items: center; gap: 9px; }
      .list-subtitle { margin: 5px 0 0; color: var(--muted); font-size: 13px; font-weight: 750; }
      .list-body { display: grid; gap: 0; overflow: visible; position: relative; }
      .row { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(190px, .75fr) minmax(260px, auto); gap: 14px; align-items: center; padding: 16px 22px; border-bottom: 1px solid #eef2f7; transition: background .18s ease, transform .18s ease; }
      .row:hover { background: #fbfdff; }
      .row:last-child { border-bottom: 0; }
      .row.subcategory-row { grid-template-columns: minmax(0, 1.05fr) minmax(160px, .75fr) minmax(160px, .75fr) minmax(270px, auto); }
      .row-main { display: flex; align-items: center; gap: 12px; min-width: 0; }
      .row-thumb { width: 56px !important; height: 56px !important; max-width: 56px !important; min-width: 56px !important; max-height: 56px !important; min-height: 56px !important; flex: 0 0 56px !important; border-radius: 14px; object-fit: cover !important; display: block; background: #f1f5f9; border: 1px solid #e2e8f0; box-shadow: 0 8px 18px rgba(15, 23, 42, .08); }
      .row-main .row-thumb, .list-body img.row-thumb { width: 56px !important; height: 56px !important; max-width: 56px !important; max-height: 56px !important; }
      .row-thumb.placeholder { display: inline-flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 22px; font-weight: 900; }
      .row-title { margin: 0; font-size: 15px; font-weight: 950; }
      .row-meta { margin: 4px 0 0; color: var(--muted); font-size: 12px; font-weight: 750; word-break: break-word; }
      .small-input, .small-select { border: 1px solid var(--border); border-radius: 14px; background: #fff; padding: 10px 11px; font-weight: 850; width: 100%; min-width: 0; box-shadow: 0 8px 18px rgba(15,23,42,.035); }
      .status-pill { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 8px 10px; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .035em; border: 1px solid transparent; white-space: nowrap; }
      .status-visible { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .status-hidden { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .status-parent { background: #ffedd5; color: #9a3412; border-color: #fed7aa; }
      .row-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap; }
      .catalog-item-card {
        display: grid;
        gap: 14px;
        margin: 14px 16px;
        padding: 16px;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background:
          linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 16px 34px rgba(15, 23, 42, .075);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        overflow: visible;
        z-index: 1;
      }
      .catalog-item-card:hover {
        transform: translateY(-1px);
        border-color: #cbd5e1;
        box-shadow: 0 20px 42px rgba(15, 23, 42, .10);
      }
      .catalog-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        padding-bottom: 12px;
        border-bottom: 1px solid #eef2f7;
      }
      .catalog-card-info {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }
      .catalog-card-text { min-width: 0; }
      .catalog-card-title {
        margin: 0;
        font-size: 16px;
        font-weight: 1000;
        letter-spacing: -.02em;
        color: #0f172a;
      }
      .catalog-card-meta {
        margin: 5px 0 0;
        color: #64748b;
        font-size: 12px;
        font-weight: 850;
        line-height: 1.45;
      }
      .catalog-card-editor {
        display: grid;
        gap: 14px;
        padding: 15px;
        border-radius: 22px;
        border: 1px solid #e2e8f0;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.9), 0 14px 30px rgba(15,23,42,.055);
      }
      .catalog-card-editor .premium-field {
        background: #ffffff;
        border-color: #dbe3ee;
      }
      .catalog-card-editor .premium-actions {
        margin-top: 0;
        padding-top: 14px;
        border-top: 1px solid #e8edf5;
      }
      .catalog-edit-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        align-items: end;
      }
      .catalog-edit-grid.one-column { grid-template-columns: 1fr; }
      .premium-field {
        display: grid;
        gap: 7px;
        padding: 12px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
      }
      .premium-field label {
        color: #475569;
        font-size: 10px;
        font-weight: 1000;
        text-transform: uppercase;
        letter-spacing: .08em;
      }
      .premium-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding-top: 2px;
      }
      .premium-actions-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      .mini-btn.order-btn { background: #f8fafc; color: #334155; border-color: #e2e8f0; }
      @media (max-width: 760px) {
        .catalog-card-top, .premium-actions { align-items: flex-start; flex-direction: column; }
        .catalog-edit-grid { grid-template-columns: 1fr; }
      }

      .catalog-item-card.row, .catalog-item-card.subcategory-row {
        grid-template-columns: 1fr;
        align-items: stretch;
      }
      .catalog-card-top {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 14px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.75);
      }
      .catalog-card-title { display: flex; align-items: center; gap: 8px; }
      .premium-field {
        box-shadow: inset 0 1px 0 rgba(255,255,255,.85), 0 10px 22px rgba(15,23,42,.035);
      }
      .premium-field .small-input, .premium-field .small-select {
        border-radius: 16px;
        background: #fff;
        border-color: #dbe3ee;
      }
      .premium-actions {
        border-top: 1px solid #eef2f7;
        margin-top: 2px;
        padding-top: 14px;
      }
      .premium-actions-group {
        padding: 7px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 18px;
      }
      .premium-actions-group .mini-btn { box-shadow: none; }

      .mini-btn { border: 1px solid var(--border); background: #fff; color: #0f172a; border-radius: 14px; padding: 9px 11px; font-size: 12px; font-weight: 1000; box-shadow: 0 8px 18px rgba(15,23,42,.05); }
      .mini-btn:hover:not(:disabled) { transform: translateY(-1px); }
      .mini-btn.primary { background: #0f172a; color: #fff; border-color: #0f172a; }
      .mini-btn.hide { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .mini-btn.show { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .empty-state { padding: 22px; color: var(--muted); font-weight: 850; text-align: center; }
      .login-card { width: min(480px, 100%); margin: 55px auto; }
      .rule-box { margin-top: 18px; padding: 18px; border-radius: 22px; background: #f8fafc; border: 1px solid var(--border); }
      .rule-box h3 { margin: 0 0 10px; font-size: 15px; font-weight: 950; }
      .rule-box ul { margin: 0; padding-left: 18px; color: #475569; font-size: 13px; font-weight: 800; line-height: 1.65; }



      /* Jerarquía premium compacta: miniatura · nombre · ojo · ordenar · menú */
      .catalog-hierarchy-row {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto auto auto;
        gap: 12px;
        align-items: center;
        margin: 12px 16px;
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 14px 30px rgba(15, 23, 42, .07);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        overflow: visible;
        z-index: 1;
      }
      .catalog-hierarchy-row:hover {
        transform: translateY(-1px);
        border-color: #cbd5e1;
        box-shadow: 0 18px 38px rgba(15, 23, 42, .095);
      }
      .catalog-hierarchy-row.menu-open {
        z-index: 10000;
      }
      .catalog-row-main {
        cursor: pointer;
