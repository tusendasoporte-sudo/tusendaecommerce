                </div>
                <div class="premium-field">
                  <label>Estado</label>
                  <label class="checkline"><input class="js-inline-subcategory-new-active" type="checkbox" checked /> Visible en tienda</label>
                </div>
              </div>
              <div class="premium-actions">
                <div class="premium-actions-group">
                  <button class="mini-btn js-inline-subcategory-new-cancel" type="button">Cerrar</button>
                </div>
                <div class="premium-actions-group">
                  <button class="mini-btn primary js-inline-subcategory-create" type="button">Crear en ${escapeHtml(category.name || 'esta categoría')}</button>
                </div>
              </div>
              <div class="alert alert-info hidden inline-subcategory-alert"></div>
            </div>

            <div class="category-subcategories-list">
              ${renderInlineSubcategoryCards(category)}
            </div>

            <div class="category-content-divider">
              <div class="category-subcategories-head" style="margin-bottom:10px;">
                <div>
                  <h3 class="category-subcategories-title">Productos directos</h3>
                  <p class="category-subcategories-note">Productos publicados en esta categoría sin subcategoría.</p>
                </div>
                <button class="mini-btn primary js-product-create-soon" type="button">+ Nuevo producto</button>
              </div>
              <div class="category-subcategories-list">
                ${renderInlineProductCards(category)}
              </div>
            </div>
          </div>
        `;
      }

      async function createInlineSubcategory(panel) {
        const categoryId = panel?.dataset?.inlineCategoryId;
        const category = getCategory(categoryId);
        const nameInput = panel?.querySelector('.js-inline-subcategory-new-name');
        const imageInput = panel?.querySelector('.js-inline-subcategory-new-image');
        const activeInput = panel?.querySelector('.js-inline-subcategory-new-active');
        const alertBox = panel?.querySelector('.inline-subcategory-alert');
        const name = nameInput?.value.trim() || '';

        if (!category || !isCurrentStoreRecord(category)) {
          setAlert(alertBox, 'No se encontró la categoría padre.', 'error');
          return;
        }
        if (!name) {
          setAlert(alertBox, 'Escribe el nombre de la subcategoría.', 'error');
          return;
        }
        if (subcategoryNameExists(name, category.id)) {
          setAlert(alertBox, `Ya existe una subcategoría llamada "${name}" dentro de esta categoría.`, 'error');
          return;
        }

        setAlert(alertBox, 'Creando subcategoría...', 'info');
        const siblings = subcategories.filter((item) => item.category === category.id);
        const formData = new FormData();
        formData.append('category', category.id);
        formData.append('name', name);
        formData.append('description', categoryDescription?.value?.trim() || '');
        formData.append('slug', slugify(name));
        formData.append('active', activeInput?.checked ? 'true' : 'false');
        formData.append('order', String(nextOrder(siblings)));
        formData.append('store', CURRENT_STORE_ID);
        if (imageInput?.files?.[0]) formData.append('image', await optimizeCatalogImageFile(imageInput.files[0]));

        await apiRequest('/api/collections/subcategories/records', {
          method: 'POST',
          body: formData,
        });
        await loadCatalog();
        openCategoryEditor(category.id);
      }

      function renderCategoryOptions() {
        if (!categories.length) {
          subcategoryCategory.innerHTML = '<option value="">Primero crea una categoría</option>';
          subcategoryCategory.disabled = true;
          return;
        }
        subcategoryCategory.disabled = false;
        subcategoryCategory.innerHTML = categories
          .map((category) => `<option value="${category.id}">${escapeHtml(category.name)}${category.active ? '' : ' · Oculta'}</option>`)
          .join('');
      }

      function renderCategories() {
        categoriesCount.textContent = `${categories.length} categorías · ${categories.filter((item) => item.active).length} visibles · ${categories.filter((item) => !item.active).length} ocultas`;
        if (!categories.length) {
          categoriesList.innerHTML = '<div class="empty-state">Todavía no hay categorías creadas.</div>';
          return;
        }

        categoriesList.innerHTML = categories.map((category, index) => {
          const productCount = getProductCountForCategory(category.id);
          const children = subcategories.filter((sub) => sub.category === category.id).length;
          const statusClass = category.active ? '' : 'hidden-state';
          const statusText = category.active ? 'Visible' : 'Oculta';
          const toggleText = category.active ? 'Desactivar' : 'Activar';
          const featuredText = category.featured_on_home === true ? 'Quitar destacado' : 'Destacar categoria';
          return `
            <article class="catalog-hierarchy-row" data-category-id="${category.id}">
              <div class="catalog-row-main">
                ${imageMarkup('categories', category, category.name || 'Categoría')}
                <div class="catalog-card-text">
                  <p class="catalog-row-title">${escapeHtml(category.name)}</p>
                  <p class="catalog-row-meta">${children} subcategorías · ${productCount} productos directos</p>
                </div>
              </div>

              <button class="visibility-btn ${statusClass} js-category-toggle" type="button" title="Cambiar visibilidad">👁 ${statusText}</button>

              <button class="visibility-btn js-category-featured" type="button" title="Destacar en portada">${escapeHtml(category.featured_on_home === true ? 'Destacada' : 'Destacar')}</button>

              <div class="catalog-order-actions" aria-label="Ordenar categoría">
                <button class="catalog-icon-btn js-category-up" type="button" ${index === 0 ? 'disabled' : ''} title="Subir">↑</button>
                <button class="catalog-icon-btn js-category-down" type="button" ${index === categories.length - 1 ? 'disabled' : ''} title="Bajar">↓</button>
              </div>

              <div class="catalog-menu-wrap">
                <button class="catalog-icon-btn js-menu-toggle" type="button" title="Más opciones">⋮</button>
                <div class="catalog-menu">
                  <button class="js-category-edit" type="button"><span>Editar</span><strong>✎</strong></button>
                  <button class="js-category-view" type="button"><span>Ver contenido</span><strong>›</strong></button>
                  <button class="js-category-toggle" type="button"><span>${toggleText}</span><strong>👁</strong></button>
                  <button class="danger js-category-delete-soon" type="button"><span>Borrar completa</span><strong>!</strong></button>
                </div>
              </div>

            </article>
          `;
        }).join('');
      }

      function renderSubcategories() {
        subcategoriesCount.textContent = `${subcategories.length} subcategorías · ${subcategories.filter((item) => item.active).length} visibles propias · ${subcategories.filter((item) => !item.active).length} ocultas propias`;
        if (!subcategories.length) {
          subcategoriesList.innerHTML = '<div class="empty-state">Todavía no hay subcategorías creadas.</div>';
          return;
        }

        subcategoriesList.innerHTML = subcategories.map((subcategory) => {
          const parent = getCategory(subcategory.category);
          const siblings = subcategories.filter((item) => item.category === subcategory.category);
          const siblingIndex = siblings.findIndex((item) => item.id === subcategory.id);
          const parentIsVisible = parent?.active === true;
          const isPublicVisible = parentIsVisible && subcategory.active === true;
          const statusClass = isPublicVisible ? '' : (parentIsVisible ? 'hidden-state' : 'parent-hidden-state');
          const statusText = isPublicVisible ? 'Visible' : (parentIsVisible ? 'Oculta' : 'Oculta por categoría');
          const toggleText = subcategory.active ? 'Desactivar' : 'Activar';
          const productCount = getProductCountForSubcategory(subcategory.id);
          return `
            <article class="catalog-hierarchy-row" data-subcategory-id="${subcategory.id}">
              <div class="catalog-row-main">
                ${imageMarkup('subcategories', subcategory, subcategory.name || 'Subcategoría')}
                <div class="catalog-card-text">
                  <p class="catalog-row-title">${escapeHtml(subcategory.name)}</p>
                  <p class="catalog-row-meta">${escapeHtml(parent?.name || 'Sin categoría')} · ${productCount} productos</p>
                </div>
              </div>

              <button class="visibility-btn ${statusClass} js-subcategory-toggle" type="button" title="Cambiar visibilidad">👁 ${statusText}</button>

              <div class="catalog-order-actions" aria-label="Ordenar subcategoría">
                <button class="catalog-icon-btn js-subcategory-up" type="button" ${siblingIndex <= 0 ? 'disabled' : ''} title="Subir">↑</button>
                <button class="catalog-icon-btn js-subcategory-down" type="button" ${siblingIndex === siblings.length - 1 ? 'disabled' : ''} title="Bajar">↓</button>
              </div>

              <div class="catalog-menu-wrap">
                <button class="catalog-icon-btn js-menu-toggle" type="button" title="Más opciones">⋮</button>
                <div class="catalog-menu">
                  <button class="js-subcategory-edit" type="button"><span>Editar</span><strong>✎</strong></button>
                  <button class="js-subcategory-view" type="button"><span>Ver contenido</span><strong>›</strong></button>
                  <button class="js-subcategory-toggle" type="button"><span>${toggleText}</span><strong>👁</strong></button>
                  <button class="danger js-subcategory-delete-soon" type="button"><span>Borrar y mover productos</span><strong>!</strong></button>
                </div>
              </div>

              <div class="catalog-inline-editor">
                <div class="catalog-card-editor">
                  <div class="catalog-edit-grid">
                    <div class="premium-field">
                      <label>Categoría padre</label>
                      <select class="small-select js-subcategory-category">
                        ${categories.map((category) => `<option value="${category.id}" ${category.id === subcategory.category ? 'selected' : ''}>${escapeHtml(category.name)}${category.active ? '' : ' · Oculta'}</option>`).join('')}
                      </select>
                    </div>
                    <div class="premium-field">
                      <label>Nombre de la subcategoría</label>
                      <input class="small-input js-subcategory-name" value="${escapeHtml(subcategory.name)}" />
                    </div>
                    <div class="premium-field">
                      <label>Cambiar foto</label>
                      <input class="small-input js-subcategory-image" type="file" accept="image/*" />
                      <p class="image-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                    </div>
                  </div>

                  <div class="premium-actions">
                    <div class="premium-actions-group">
                      <button class="mini-btn js-subcategory-cancel-edit" type="button">Cerrar edición</button>
                    </div>
                    <div class="premium-actions-group">
                      <button class="mini-btn primary js-subcategory-save" type="button">Guardar cambios</button>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          `;
        }).join('');
      }

      function renderAll() {
        categories.sort((a, b) => Number(a.order || 0) - Number(b.order || 0) || String(a.name || '').localeCompare(String(b.name || '')));
        subcategories.sort((a, b) => {
          const parentA = getCategory(a.category)?.name || '';
          const parentB = getCategory(b.category)?.name || '';
          return parentA.localeCompare(parentB) || Number(a.order || 0) - Number(b.order || 0) || String(a.name || '').localeCompare(String(b.name || ''));
        });
        renderCategoryOptions();
        renderCategories();
        renderSubcategories();
        adminSubtitle.textContent = `Categorías actualizadas. Abre una categoría para gestionarla en su propia página.`;
      }

      async function loadCatalog() {
        if (refreshBtn) refreshBtn.disabled = true;
        categoriesList.innerHTML = '<div class="empty-state">Cargando categorías...</div>';
        subcategoriesList.innerHTML = '<div class="empty-state">Cargando subcategorías...</div>';
        try {
          const [categoryRecords, subcategoryRecords, productRecords] = await Promise.all([
            loadAllRecords('categories', withStoreFilter('sort=order,name')),
            loadAllRecords('subcategories', withStoreFilter('sort=order,name')),
            loadAllRecords('products', withStoreFilter('sort=name')),
          ]);
          categories = categoryRecords;
          subcategories = subcategoryRecords;
          products = productRecords;
          renderAll();
          closeContentView();
        } catch (error) {
          console.error(error);
          categoriesList.innerHTML = '<div class="empty-state">No se pudieron cargar las categorías. Revisa tu sesión admin.</div>';
          subcategoriesList.innerHTML = '<div class="empty-state">No se pudieron cargar las subcategorías. Revisa tu sesión admin.</div>';
        } finally {
          if (refreshBtn) refreshBtn.disabled = false;
        }
      }

      async function createCategory(event) {
        event.preventDefault();
        const name = categoryName.value.trim();
        if (!name) {
          setAlert(categoryAlert, 'Escribe el nombre de la categoría.', 'error');
          return;
        }
        if (categoryNameExists(name)) {
          setAlert(categoryAlert, `Ya existe una categoría llamada "${name}".`, 'error');
          return;
        }

        setAlert(categoryAlert, 'Creando categoría...', 'info');
        const formData = new FormData();
        formData.append('name', name);
        formData.append('slug', slugify(name));
        formData.append('active', categoryActive.checked ? 'true' : 'false');
        formData.append('order', String(nextOrder(categories)));
        formData.append('store', CURRENT_STORE_ID);
        if (categoryImage.files?.[0]) formData.append('image', await optimizeCatalogImageFile(categoryImage.files[0]));

        try {
          const createdCategory = await apiRequest('/api/collections/categories/records', {
            method: 'POST',
            body: formData,
          });
          categoryForm.reset();
          categoryActive.checked = true;
          setAlert(categoryAlert, 'Categoría creada correctamente. Abriendo su página...', 'success');
          window.location.href = `${ADMIN_CATALOG_PATH}/category/${createdCategory.id}`;
        } catch (error) {
          console.error(error);
          setAlert(categoryAlert, error.message || 'No se pudo crear la categoría.', 'error');
        }
      }

      async function createSubcategory(event) {
        event.preventDefault();
        const name = subcategoryName.value.trim();
        const categoryId = subcategoryCategory.value;
        if (!categoryId) {
          setAlert(subcategoryAlert, 'Selecciona una categoría padre.', 'error');
          return;
        }
        if (!name) {
          setAlert(subcategoryAlert, 'Escribe el nombre de la subcategoría.', 'error');
          return;
        }
        if (subcategoryNameExists(name, categoryId)) {
          setAlert(subcategoryAlert, `Ya existe una subcategoría llamada "${name}" dentro de esta categoría.`, 'error');
          return;
        }

        if (!categories.some((category) => category.id === categoryId && isCurrentStoreRecord(category))) {
          setAlert(subcategoryAlert, 'La categoria seleccionada no pertenece a esta tienda.', 'error');
          return;
        }

        setAlert(subcategoryAlert, 'Creando subcategoría...', 'info');
        const siblings = subcategories.filter((item) => item.category === categoryId);
        const formData = new FormData();
        formData.append('category', categoryId);
        formData.append('name', name);
        formData.append('slug', slugify(name));
        formData.append('active', subcategoryActive.checked ? 'true' : 'false');
        formData.append('order', String(nextOrder(siblings)));
        formData.append('store', CURRENT_STORE_ID);
        if (subcategoryImage.files?.[0]) formData.append('image', await optimizeCatalogImageFile(subcategoryImage.files[0]));

        try {
          await apiRequest('/api/collections/subcategories/records', {
            method: 'POST',
            body: formData,
          });
          subcategoryForm.reset();
          subcategoryActive.checked = true;
          renderCategoryOptions();
          setAlert(subcategoryAlert, 'Subcategoría creada correctamente.', 'success');
          await loadCatalog();
        } catch (error) {
          console.error(error);
          setAlert(subcategoryAlert, error.message || 'No se pudo crear la subcategoría.', 'error');
        }
      }

      async function updateCategory(row, changes) {
        const id = row.dataset.categoryId;
        const imageFile = row.querySelector('.js-category-image')?.files?.[0];
        if (imageFile) {
          const formData = new FormData();
          Object.entries(changes).forEach(([key, value]) => formData.append(key, String(value)));
          formData.append('image', await optimizeCatalogImageFile(imageFile));
          await apiRequest(`/api/collections/categories/records/${id}`, {
            method: 'PATCH',
            body: formData,
          });
        } else {
          await apiRequest(`/api/collections/categories/records/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(changes),
          });
        }
        await loadCatalog();
      }

      async function toggleCategoryFeatured(category) {
        if (!category || !category.id) return;
        const nextFeatured = category.featured_on_home !== true;
        const featuredCategories = categories.filter((item) => item.featured_on_home === true && item.id !== category.id);
        if (nextFeatured && featuredCategories.length >= 2) {
          alert('Solo puedes destacar hasta 2 categorias.');
          return;
        }

        await apiRequest(`/api/collections/categories/records/${category.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            featured_on_home: nextFeatured,
            featured_order: nextFeatured ? (featuredCategories.length + 1) * 10 : 0,
            store: CURRENT_STORE_ID,
          }),
        });
        await loadCatalog();
      }

      async function updateSubcategory(row, changes) {
        const id = row.dataset.subcategoryId;
        const imageFile = row.querySelector('.js-subcategory-image')?.files?.[0];
        if (imageFile) {
          const formData = new FormData();
          Object.entries(changes).forEach(([key, value]) => formData.append(key, String(value)));
          formData.append('image', await optimizeCatalogImageFile(imageFile));
          await apiRequest(`/api/collections/subcategories/records/${id}`, {
            method: 'PATCH',
            body: formData,
          });
        } else {
          await apiRequest(`/api/collections/subcategories/records/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(changes),
          });
        }
        await loadCatalog();
      }

      function sortedByCatalogOrder(items) {
        return [...items].sort((a, b) => Number(a.order || 0) - Number(b.order || 0) || String(a.name || '').localeCompare(String(b.name || '')));
      }

      async function saveSequentialOrder(collection, orderedItems) {
        await Promise.all(orderedItems.map((item, index) => {
          const order = (index + 1) * 10;
          return patchRecord(collection, item.id, { order });
        }));
      }

      async function moveCategory(categoryId, direction) {
        const ordered = sortedByCatalogOrder(categories);
        const index = ordered.findIndex((item) => item.id === categoryId);
        const targetIndex = index + direction;
        if (index < 0 || targetIndex < 0 || targetIndex >= ordered.length) return;

        const [current] = ordered.splice(index, 1);
        ordered.splice(targetIndex, 0, current);
        await saveSequentialOrder('categories', ordered);
        await loadCatalog();
      }

      async function moveSubcategory(subcategoryId, direction) {
        const current = subcategories.find((item) => item.id === subcategoryId);
        if (!current) return;

        const siblings = sortedByCatalogOrder(subcategories.filter((item) => item.category === current.category));
        const index = siblings.findIndex((item) => item.id === subcategoryId);
        const targetIndex = index + direction;
        if (index < 0 || targetIndex < 0 || targetIndex >= siblings.length) return;

        const [moving] = siblings.splice(index, 1);
        siblings.splice(targetIndex, 0, moving);
        await saveSequentialOrder('subcategories', siblings);
        await loadCatalog();
      }



      function closeCatalogMenus(exceptWrap = null) {
        document.querySelectorAll('.catalog-menu-wrap.open').forEach((wrap) => {
          if (wrap !== exceptWrap) {
            wrap.classList.remove('open');
            wrap.closest('.catalog-hierarchy-row')?.classList.remove('menu-open');
            wrap.closest('.list-card')?.classList.remove('menu-open-card');
            wrap.querySelector('.catalog-menu')?.classList.remove('drop-up');
          }
        });
      }

      function openCatalogMenu(wrap) {
        if (!wrap) return;
        const wasOpen = wrap.classList.contains('open');
        closeCatalogMenus(wrap);
        if (wasOpen) {
          wrap.classList.remove('open');
          wrap.closest('.catalog-hierarchy-row')?.classList.remove('menu-open');
          wrap.closest('.list-card')?.classList.remove('menu-open-card');
          wrap.querySelector('.catalog-menu')?.classList.remove('drop-up');
          return;
        }

        const menu = wrap.querySelector('.catalog-menu');
        wrap.classList.add('open');
        wrap.closest('.catalog-hierarchy-row')?.classList.add('menu-open');
        wrap.closest('.list-card')?.classList.add('menu-open-card');
        menu?.classList.remove('drop-up');

        requestAnimationFrame(() => {
          if (!menu) return;
          const menuRect = menu.getBoundingClientRect();
          const buttonRect = wrap.getBoundingClientRect();
          const spaceBelow = window.innerHeight - buttonRect.bottom;
          const spaceAbove = buttonRect.top;
          if (spaceBelow < menuRect.height + 18 && spaceAbove > menuRect.height + 18) {
            menu.classList.add('drop-up');
          }
        });
      }

      document.addEventListener('click', (event) => {
        if (!event.target.closest('.catalog-menu-wrap')) closeCatalogMenus();
      });
      logoutBtn?.addEventListener('click', () => {
        document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax';
        window.location.assign('/login');
      });

      function productCreateUrl(categoryId = '', subcategoryId = '') {
        const params = new URLSearchParams();
        params.set('new', '1');
        if (categoryId) params.set('category', categoryId);
        if (subcategoryId) params.set('subcategory', subcategoryId);
        return `${ADMIN_PRODUCTS_PATH}?${params.toString()}`;
      }
      function productEditUrl(productId = '') {
        const params = new URLSearchParams();
        if (productId) params.set('product', productId);
        return `${ADMIN_PRODUCTS_PATH}?${params.toString()}`;
      }
      refreshBtn?.addEventListener('click', loadCatalog);
      contentViewParentBack?.addEventListener('click', () => {
        if (contentNavigation?.parentCategoryId) {
          showCategoryContent(contentNavigation.parentCategoryId);
        }
      });
      contentViewBack?.addEventListener('click', closeContentView);
      contentViewBody?.addEventListener('click', (event) => {
        const subcategoryCard = event.target.closest('.js-open-subcategory-content');
        if (subcategoryCard?.dataset?.subcategoryId) {
          showSubcategoryContent(subcategoryCard.dataset.subcategoryId);
          return;
        }
        const productCreateButton = event.target.closest('.js-product-create-soon');
        if (productCreateButton) {
          window.location.href = productCreateUrl(contentNavigation?.categoryId || '', contentNavigation?.subcategoryId || '');
          return;
        }
        const productEditButton = event.target.closest('.js-product-edit-soon');
        if (productEditButton) {
          const productCard = productEditButton.closest('[data-product-id]');
          window.location.href = productEditUrl(productCard?.dataset?.productId || '');
        }
      });
      categoryCreateToggle?.addEventListener('click', () => toggleCreatePanel('category'));
      subcategoryCreateToggle?.addEventListener('click', () => toggleCreatePanel('subcategory'));
      categoryForm.addEventListener('submit', createCategory);
      subcategoryForm.addEventListener('submit', createSubcategory);

      categoriesList.addEventListener('click', async (event) => {
        const inlineSubcategoryMain = event.target.closest('.category-child-main');
        if (inlineSubcategoryMain) {
          const childRow = inlineSubcategoryMain.closest('[data-subcategory-id]');
          if (childRow) {
            closeCatalogMenus();
            const wasEditing = childRow.classList.contains('editing');
            childRow.classList.toggle('editing', !wasEditing);
            if (!wasEditing) childRow.querySelector('.js-subcategory-name')?.focus();
          }
          return;
        }

        const inlineButton = event.target.closest('button');
        if (inlineButton) {
          const inlinePanel = inlineButton.closest('.category-subcategories-panel');
          const inlineRow = inlineButton.closest('.category-child-row');
          if (inlinePanel || inlineRow) {
            inlineButton.disabled = true;
            try {
              if (inlineButton.classList.contains('js-menu-toggle')) {
                openCatalogMenu(inlineButton.closest('.catalog-menu-wrap'));
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-new-toggle')) {
                inlinePanel.classList.toggle('creating');
                inlinePanel.querySelector('.js-inline-subcategory-new-name')?.focus();
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-new-cancel')) {
                inlinePanel.classList.remove('creating');
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-create')) {
                await createInlineSubcategory(inlinePanel);
                return;
              }
              if (inlineButton.classList.contains('js-product-create-soon')) {
                const inlineCategoryId = inlinePanel?.dataset?.inlineCategoryId || '';
                const inlineSubcategoryId = inlineRow?.dataset?.subcategoryId || '';
                window.location.href = productCreateUrl(inlineCategoryId || (inlineSubcategoryId ? subcategories.find((item) => item.id === inlineSubcategoryId)?.category : ''), inlineSubcategoryId);
                return;
              }
              if (inlineButton.classList.contains('js-product-edit-soon')) {
                const productRow = inlineButton.closest('[data-product-id]');
                window.location.href = productEditUrl(productRow?.dataset?.productId || '');
                return;
              }

              const subcategory = inlineRow ? subcategories.find((item) => item.id === inlineRow.dataset.subcategoryId) : null;
              if (!subcategory) return;

              if (inlineButton.classList.contains('js-inline-subcategory-up')) {
                await moveSubcategory(subcategory.id, -1);
                openCategoryEditor(subcategory.category);
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-down')) {
                await moveSubcategory(subcategory.id, 1);
                openCategoryEditor(subcategory.category);
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-edit')) {
                closeCatalogMenus();
                inlineRow.classList.add('editing');
                inlineRow.querySelector('.js-subcategory-name')?.focus();
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-cancel-edit')) {
                inlineRow.classList.remove('editing');
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-view')) {
                closeCatalogMenus();
                showSubcategoryContent(subcategory.id);
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-delete-soon')) {
                closeCatalogMenus();
                alert('Siguiente paso: aquí pondremos el borrado seguro de subcategoría, moviendo sus productos a la categoría padre.');
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-toggle')) {
                await updateSubcategory(inlineRow, { active: !subcategory.active });
                openCategoryEditor(subcategory.category);
                return;
              }
              if (inlineButton.classList.contains('js-inline-subcategory-save')) {
                const name = inlineRow.querySelector('.js-subcategory-name').value.trim();
                const category = inlineRow.querySelector('.js-subcategory-category').value;
                if (!name) {
                  alert('El nombre de la subcategoría no puede estar vacío.');
                  return;
                }
                if (subcategoryNameExists(name, category, subcategory.id)) {
                  alert(`Ya existe una subcategoría llamada "${name}" dentro de esta categoría.`);
                  return;
                }
                await updateSubcategory(inlineRow, { category, name, slug: slugify(name) });
                openCategoryEditor(category);
                return;
              }
            } catch (error) {
              console.error(error);
              alert(error.message || 'No se pudo actualizar la subcategoría.');
            } finally {
              inlineButton.disabled = false;
            }
            return;
          }
        }
        const mainClick = event.target.closest('.catalog-row-main');
        if (mainClick) {
          const row = mainClick.closest('[data-category-id]');
          if (row?.dataset?.categoryId) {
            closeCatalogMenus();
            window.location.href = `${ADMIN_CATALOG_PATH}/category/${row.dataset.categoryId}`;
          }
          return;
        }

        const button = event.target.closest('button');
        if (!button) return;
        const row = button.closest('[data-category-id]');
        if (!row) return;
        const category = categories.find((item) => item.id === row.dataset.categoryId);
        if (!category) return;

        button.disabled = true;
        try {
          if (button.classList.contains('js-category-up')) {
            await moveCategory(category.id, -1);
            return;
          }
          if (button.classList.contains('js-category-down')) {
            await moveCategory(category.id, 1);
            return;
          }
          if (button.classList.contains('js-menu-toggle')) {
            openCatalogMenu(button.closest('.catalog-menu-wrap'));
            return;
          }
          if (button.classList.contains('js-category-edit')) {
            closeCatalogMenus();
            window.location.href = `${ADMIN_CATALOG_PATH}/category/${category.id}`;
            return;
          }
          if (button.classList.contains('js-category-cancel-edit')) {
            row.classList.remove('editing');
            return;
          }
          if (button.classList.contains('js-category-view')) {
            closeCatalogMenus();
            showCategoryContent(category.id);
            return;
          }
          if (button.classList.contains('js-category-featured')) {
            closeCatalogMenus();
            await toggleCategoryFeatured(category);
            return;
          }
          if (button.classList.contains('js-category-delete-soon')) {
            closeCatalogMenus();
            alert('Siguiente paso: aquí pondremos el borrado seguro con confirmación fuerte. No lo activo todavía para evitar borrar contenido por error.');
            return;
          }
          if (button.classList.contains('js-category-toggle')) {
            await updateCategory(row, { active: !category.active });
            return;
          }
          if (button.classList.contains('js-category-save')) {
            const name = row.querySelector('.js-category-name').value.trim();
            if (!name) {
              alert('El nombre de la categoría no puede estar vacío.');
              return;
            }
            if (categoryNameExists(name, category.id)) {
              alert(`Ya existe una categoría llamada "${name}".`);
              return;
            }
            await updateCategory(row, { name, slug: slugify(name) });
          }
        } catch (error) {
          console.error(error);
          alert(error.message || 'No se pudo actualizar la categoría.');
        } finally {
          button.disabled = false;
        }
      });

      subcategoriesList.addEventListener('click', async (event) => {
        const mainClick = event.target.closest('.catalog-row-main');
        if (mainClick) {
          const row = mainClick.closest('[data-subcategory-id]');
          if (row) {
            closeCatalogMenus();
            const wasEditing = row.classList.contains('editing');
            row.classList.toggle('editing', !wasEditing);
            if (!wasEditing) row.querySelector('.js-subcategory-name')?.focus();
          }
          return;
        }

        const button = event.target.closest('button');
        if (!button) return;
        const row = button.closest('[data-subcategory-id]');
        if (!row) return;
        const subcategory = subcategories.find((item) => item.id === row.dataset.subcategoryId);
        if (!subcategory) return;

        button.disabled = true;
        try {
          if (button.classList.contains('js-subcategory-up')) {
            await moveSubcategory(subcategory.id, -1);
            return;
          }
          if (button.classList.contains('js-subcategory-down')) {
            await moveSubcategory(subcategory.id, 1);
            return;
          }
          if (button.classList.contains('js-menu-toggle')) {
            openCatalogMenu(button.closest('.catalog-menu-wrap'));
            return;
          }
          if (button.classList.contains('js-subcategory-edit')) {
            closeCatalogMenus();
            row.classList.add('editing');
            row.querySelector('.js-subcategory-name')?.focus();
            return;
          }
          if (button.classList.contains('js-subcategory-cancel-edit')) {
            row.classList.remove('editing');
            return;
          }
          if (button.classList.contains('js-subcategory-view')) {
            closeCatalogMenus();
            showSubcategoryContent(subcategory.id);
            return;
          }
          if (button.classList.contains('js-subcategory-delete-soon')) {
            closeCatalogMenus();
            alert('Siguiente paso: aquí pondremos el borrado seguro de subcategoría, moviendo sus productos a la categoría padre.');
            return;
          }
          if (button.classList.contains('js-subcategory-toggle')) {
            await updateSubcategory(row, { active: !subcategory.active });
            return;
          }
          if (button.classList.contains('js-subcategory-save')) {
            const name = row.querySelector('.js-subcategory-name').value.trim();
            const category = row.querySelector('.js-subcategory-category').value;
            if (!name) {
              alert('El nombre de la subcategoría no puede estar vacío.');
              return;
            }
            if (!category) {
              alert('Selecciona una categoría padre.');
              return;
            }
            if (subcategoryNameExists(name, category, subcategory.id)) {
              alert(`Ya existe una subcategoría llamada "${name}" dentro de esta categoría.`);
              return;
            }
            const siblings = subcategories.filter((item) => item.category === category && item.id !== subcategory.id);
            const changes = { category, name, slug: slugify(name) };
            if (category !== subcategory.category) {
              changes.order = nextOrder(siblings);
            }
            await updateSubcategory(row, changes);
          }
        } catch (error) {
          console.error(error);
          alert(error.message || 'No se pudo actualizar la subcategoría.');
        } finally {
          button.disabled = false;
        }
      });
      showAdmin();
      if (POCKETBASE_URL && getAdminToken()) {
        loadCatalog();
      } else {
        setAlert(categoryAlert, 'No se pudo validar la sesion administrativa.', 'error');
      }
    </script>
  </body>
</html>
