                  <button class="js-inline-subcategory-view" type="button"><span>Ver contenido</span><strong>›</strong></button>
                  <button class="js-inline-subcategory-toggle" type="button"><span>${toggleText}</span><strong>👁</strong></button>
                  <button class="danger js-inline-subcategory-delete-soon" type="button"><span>Borrar y mover productos</span><strong>!</strong></button>
                </div>
              </div>

              <div class="category-child-editor">
