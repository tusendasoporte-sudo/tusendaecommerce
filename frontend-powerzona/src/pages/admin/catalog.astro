              return;
            }
            const siblings = subcategories.filter((item) => item.category === category && item.id !== subcategory.id);
            const changes = { category, name, slug: slugify(name) };
            if (category !== subcategory.category) {
              changes.order = nextOrder(siblings);
            }
            await updateSubcategory(row, changes);
          }
        } catch (error) {
          console.error(error);
          showAdminToast(error.message || 'No se pudo actualizar la subcategoría.', 'error');
        } finally {
          button.disabled = false;
        }
      });
      showAdmin();
      if (POCKETBASE_URL && getAdminToken()) {
        loadCatalog();
      } else {
        setAlert(categoryAlert, 'No se pudo validar la sesion administrativa.', 'error');
      }
    </script>
  </body>
</html>
