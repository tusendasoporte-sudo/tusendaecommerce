        subcategoryCategory.disabled = false;
        subcategoryCategory.innerHTML = categories
          .map((category) => `<option value="${category.id}">${escapeHtml(category.name)}${category.active ? '' : ' · Oculta'}</option>`)
          .join('');
      }

      function renderCatalogStats() {
        const totalProductsAssigned = products.filter((item) => item.category || item.subcategory).length;
        if (statCategoriesTotal) statCategoriesTotal.textContent = String(categories.length);
        if (statCategoriesActive) statCategoriesActive.textContent = String(categories.filter((item) => item.active).length);
        if (statCategoriesChildren) {
          statCategoriesChildren.textContent = String(categories.filter((category) => subcategories.some((sub) => sub.category === category.id)).length);
        }
        if (statProductsAssigned) statProductsAssigned.textContent = String(totalProductsAssigned);
      }

      function getFilteredCategories() {
        const searchTerm = normalizeName(catalogSearch?.value || '');
        const status = catalogStatusFilter?.value || 'all';
        return sortedByCatalogOrder(categories)
          .filter((category) => {
            const haystack = normalizeName(`${category.name || ''} ${category.slug || ''} ${category.description || ''}`);
            const matchesSearch = !searchTerm || haystack.includes(searchTerm);
            const matchesStatus = status === 'all' || (status === 'active' ? category.active : !category.active);
            return matchesSearch && matchesStatus;
          });
      }

