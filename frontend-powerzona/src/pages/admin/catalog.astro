                      <select class="small-select js-subcategory-category">
                        ${categories.map((category) => `<option value="${category.id}" ${category.id === subcategory.category ? 'selected' : ''}>${escapeHtml(category.name)}${category.active ? '' : ' · Oculta'}</option>`).join('')}
