          const receiptUrl = buildReceiptUrl(orderWithReceipt);
          if (!receiptUrl) throw new Error('No se pudo generar el enlace del resumen de la orden.');
          window.open(receiptUrl, '_blank', 'noopener,noreferrer');
        } catch (error) {
          console.error(error);
          setDetailAlert(error?.message || 'No se pudo abrir el resumen de la orden.', 'error');
        }
      }

      async function markDelivered() {
        if (!selectedOrder) return;
        if (normalizeStatus(selectedOrder.status) !== 'confirmed') {
          setDetailAlert('Para marcar una orden como Entregada, primero debe estar Confirmada.', 'error');
          return;
        }
        detailStatus.value = 'delivered';
        await saveSelectedOrder({ status: 'delivered' });
      }

      async function deleteOrderPermanentlyNoStock(orderId) {
        if (!orderId) return;
        const filter = encodeURIComponent(`order = "${orderId}"`);
        const itemsResult = await apiRequest(`/api/collections/order_items/records?filter=${filter}&perPage=200`);
        const items = itemsResult.items || [];
        for (const item of items) {
          await apiRequest(`/api/collections/order_items/records/${item.id}`, { method: 'DELETE' });
        }
        await apiRequest(`/api/collections/orders/records/${orderId}`, { method: 'DELETE' });
      }

      async function deleteOrderFromList(orderId, { restoreStock = false } = {}) {
        const order = orders.find((item) => item.id === orderId);
        if (!order) throw new Error('No se encontró la orden seleccionada.');
        let restoreSnapshots = [];
        let deleteCompleted = false;
        try {
          if (restoreStock) restoreSnapshots = await restoreInventoryForOrder(orderId);
          await deleteOrderPermanentlyNoStock(orderId);
          deleteCompleted = true;
          orders = orders.filter((item) => item.id !== orderId);
          delete orderItemsByOrder[orderId];
          if (selectedOrder?.id === orderId) clearDetail();
          renderStats();
          renderOrders();
          if (restoreStock) {
            try { await refreshInventoryAfterMovement(); } catch (refreshError) { console.error(refreshError); }
          }
          setOrdersAdminAlert(restoreStock ? 'Orden borrada correctamente. Inventario devuelto.' : 'Orden borrada correctamente.', 'success');
        } catch (error) {
          if (restoreStock && restoreSnapshots.length && !deleteCompleted) await revertInventorySnapshots(restoreSnapshots);
          setOrdersAdminAlert(restoreStock ? 'No se pudo devolver el inventario o borrar la orden.' : 'No se pudo borrar la orden.', 'error');
          throw error;
        }
      }

      function requestDeleteOrderFromList(orderId) {
        const order = orders.find((item) => item.id === orderId);
        if (!order) {
          setOrdersAdminAlert('No se encontró la orden seleccionada.', 'error');
          return;
        }
        const status = normalizeStatus(order.status);
        if (['pending', 'cancelled', 'delivered'].includes(status)) {
          openOrderDeleteConfirm({
            title: 'Borrar pedido',
            message: '¿Seguro que deseas borrar esta orden? Esta acción no afecta el inventario.',
            confirmText: 'Sí, borrar pedido',
            action: async () => deleteOrderFromList(orderId, { restoreStock: false }),
          });
          return;
        }
        if (status === 'confirmed') {
          openOrderDeleteConfirm({
            title: 'Borrar orden confirmada',
            message: 'Esta orden está confirmada y pudo haber descontado inventario. ¿Deseas devolver los productos al inventario antes de borrar la orden?',
            confirmText: 'Devolver inventario y borrar',
            action: async () => deleteOrderFromList(orderId, { restoreStock: true }),
            secondaryText: 'Borrar sin devolver',
            secondaryAction: async () => deleteOrderFromList(orderId, { restoreStock: false }),
          });
          return;
        }
        setOrdersAdminAlert('Este estado no está preparado para borrado rápido. Abre el pedido y revisa su estado.', 'error');
      }

      async function deleteCancelledOrderFromSummary() {
        if (!selectedOrder) return;
        if (normalizeStatus(selectedOrder.status) !== 'cancelled') {
          setDetailAlert('Solo puedes eliminar desde el resumen cuando la orden está Cancelada.', 'error');
          updateCancelledDeleteButtonState();
          return;
        }
        openOrderDeleteConfirm({
          title: 'Eliminar pedido',
          message: 'Esta acción eliminará la orden y sus productos relacionados. No modifica el inventario.',
          confirmText: 'Sí, borrar pedido',
          action: async () => {
            deleteCancelledOrderBtn.disabled = true;
            deleteCancelledOrderBtn.textContent = 'Eliminando...';
            setDetailAlert('Eliminando orden cancelada...', 'info');
            setOrdersAdminAlert('');
            try {
              const deletedId = selectedOrder.id;
              await deleteOrderPermanentlyNoStock(deletedId);
              orders = orders.filter((order) => order.id !== deletedId);
              clearDetail();
              renderStats();
              renderOrders();
              renderCleanupOrdersList();
              setOrdersAdminAlert('Orden eliminada correctamente. El inventario no fue modificado.', 'success');
            } catch (error) {
              setDetailAlert('No se pudo eliminar la orden. Revisa las reglas administrativas de borrado.', 'error');
              throw error;
            } finally {
              deleteCancelledOrderBtn.disabled = false;
              deleteCancelledOrderBtn.textContent = 'Eliminar pedido';
            }
          },
        });
      }

      async function deleteSelectedOrderFromDetailPage() {
        if (!selectedOrder || !IS_ORDER_DETAIL_PAGE) return;
        openOrderDeleteConfirm({
          title: 'Eliminar pedido',
          message: 'Esta acción elimina la orden y no modifica el inventario. Úsalo solo para limpieza administrativa o después de exportar tus órdenes.',
          confirmText: 'Sí, eliminar',
          action: async () => {
            floatingDeleteOrderBtn.disabled = true;
            floatingDeleteOrderBtn.textContent = 'Eliminando...';
            setDetailAlert('Eliminando pedido...', 'info');
            try {
              await deleteOrderPermanentlyNoStock(selectedOrder.id);
              window.location.assign(ADMIN_ORDERS_PATH);
            } catch (error) {
              floatingDeleteOrderBtn.disabled = false;
              floatingDeleteOrderBtn.textContent = 'Eliminar pedido';
              setDetailAlert('No se pudo eliminar la orden. Revisa las reglas administrativas de borrado.', 'error');
              throw error;
            }
          },
        });
      }

      function openCleanupOrdersPanel() {
        cleanupSelectionMode = true;
        cleanupOrdersPanel?.classList.remove('hidden');
        if (cleanupOrdersOpenBtn) {
          cleanupOrdersOpenBtn.className = cleanupOrdersOpenBtnOriginalClass;
          cleanupOrdersOpenBtn.classList.add('active');
          cleanupOrdersOpenBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none"><path d="M7 7h10l-.8 13H7.8L7 7Z" fill="#FEE2E2" stroke="#DC2626" stroke-width="2"/><path d="M9 7V5h6v2M10 11v5M14 11v5" stroke="#991B1B" stroke-width="2" stroke-linecap="round"/></svg>Modo borrar activo';
        }
        updateCleanupSelectionUI();
        renderOrders();
      }

      function closeCleanupOrdersPanel() {
        cleanupSelectionMode = false;
        cleanupSelectedOrderIds = new Set();
        cleanupOrdersPanel?.classList.add('hidden');
        if (cleanupOrdersOpenBtn) {
          cleanupOrdersOpenBtn.className = cleanupOrdersOpenBtnOriginalClass;
          cleanupOrdersOpenBtn.innerHTML = cleanupOrdersOpenBtnOriginalHtml;
          cleanupOrdersOpenBtn.disabled = false;
        }
        updateCleanupSelectionUI();
        renderOrders();
      }

      function renderCleanupOrdersList() {
        updateCleanupSelectionUI();
      }

      function getCleanupSelectableOrders() {
        return getFilteredOrders();
      }

      function getCleanupSelectedOrderIds() {
        return Array.from(cleanupSelectedOrderIds).filter((id) => orders.some((order) => order.id === id));
      }

      function updateCleanupSelectionUI() {
        cleanupSelectedOrderIds = new Set(getCleanupSelectedOrderIds());
        const selectedCount = cleanupSelectedOrderIds.size;
        const selectableCount = getCleanupSelectableOrders().length;
        if (cleanupSelectedCount) cleanupSelectedCount.textContent = `${selectedCount} seleccionada${selectedCount === 1 ? '' : 's'}`;
        if (cleanupDeleteSelectedBtn) cleanupDeleteSelectedBtn.disabled = selectedCount === 0;
        if (cleanupSelectAllBtn) cleanupSelectAllBtn.disabled = selectableCount === 0;
      }

      function toggleCleanupOrderSelection(orderId, isSelected) {
        if (!orderId) return;
        if (isSelected) cleanupSelectedOrderIds.add(orderId);
        else cleanupSelectedOrderIds.delete(orderId);
        updateCleanupSelectionUI();
      }

      function selectAllCleanupOrders() {
        getCleanupSelectableOrders().forEach((order) => cleanupSelectedOrderIds.add(order.id));
        renderOrders();
      }

      async function deleteSelectedCleanupOrders() {
        const ids = getCleanupSelectedOrderIds();
        if (!ids.length) {
          setOrdersAdminAlert('Selecciona al menos una orden para borrar.', 'error');
          return;
        }
        openOrderDeleteConfirm({
          title: 'Borrar órdenes seleccionadas',
          message: 'Esta acción eliminará las órdenes seleccionadas y sus productos relacionados. No modifica el inventario.',
          confirmText: 'Sí, borrar seleccionadas',
          action: async () => {
            cleanupDeleteSelectedBtn.disabled = true;
            cleanupDeleteSelectedBtn.textContent = 'Borrando...';
            setOrdersAdminAlert('');
            try {
              for (const id of ids) {
                await deleteOrderPermanentlyNoStock(id);
              }
              orders = orders.filter((order) => !ids.includes(order.id));
              ids.forEach((id) => cleanupSelectedOrderIds.delete(id));
              if (selectedOrder && ids.includes(selectedOrder.id)) clearDetail();
              renderStats();
              renderOrders();
              updateCleanupSelectionUI();
              setOrdersAdminAlert('Órdenes borradas correctamente. El inventario no fue modificado.', 'success');
            } catch (error) {
              setOrdersAdminAlert('No se pudieron borrar todas las órdenes. Revisa las reglas administrativas de borrado.', 'error');
              throw error;
            } finally {
              cleanupDeleteSelectedBtn.disabled = false;
              cleanupDeleteSelectedBtn.textContent = 'Borrar seleccionadas';
              updateCleanupSelectionUI();
            }
          },
        });
      }
      const refreshOrdersView = () => {
        loadStoreSettings();
        loadOrders();
      };
      refreshBtn.addEventListener('click', refreshOrdersView);
      refreshMobileBtn?.addEventListener('click', refreshOrdersView);
      ordersListRefreshBtn?.addEventListener('click', refreshOrdersView);
      searchInput.addEventListener('input', () => { currentOrdersPage = 1; renderOrders(); });
      statusFilter.addEventListener('change', () => { currentOrdersPage = 1; renderOrders(); });
      deliveryFilter.addEventListener('change', () => { currentOrdersPage = 1; renderOrders(); });
      saveOrderBtn.addEventListener('click', () => saveSelectedOrder());
      toggleEditOrderBtn?.addEventListener('click', () => setEditOrderPanel(editOrderPanel?.classList.contains('hidden')));
      closeEditOrderBtn?.addEventListener('click', () => setEditOrderPanel(false));
      editDeliveryMethod?.addEventListener('change', () => {
        updateDeliveryEditorVisibility();
        scheduleOrderAutoSave();
      });
      editShippingMunicipality?.addEventListener('change', () => {
        renderShippingZoneOptions('');
        updateDeliveryEditorVisibility();
      });
      editShippingZone?.addEventListener('change', () => {
        updateShippingCostPreview();
        updateDeliveryLivePreview();
        scheduleOrderAutoSave();
      });
      editCustomerName?.addEventListener('input', scheduleOrderAutoSave);
      editCustomerPhone?.addEventListener('input', scheduleOrderAutoSave);
      editCustomerAddress?.addEventListener('input', scheduleOrderAutoSave);
      detailNotes?.addEventListener('input', scheduleOrderAutoSave);
      toggleAddProductBtn?.addEventListener('click', () => setAddProductPanel(addProductPanel?.classList.contains('hidden')));
      closeAddProductBtn?.addEventListener('click', () => setAddProductPanel(false));
      addProductBtn.addEventListener('click', addProductToOrder);
      addProductSearch.addEventListener('input', renderProductSearchResults);
      addProductVariationSelect.addEventListener('change', handleAddVariationChange);
      addProductQuantity.addEventListener('input', updateAddProductQuantityLimit);
      addProductQuantity.addEventListener('change', updateAddProductQuantityLimit);
      copyOrderBtn.addEventListener('click', copyOrderSummary);
      whatsappOrderBtn.addEventListener('click', openWhatsAppOrder);
      printOrderBtn.addEventListener('click', printSelectedOrder);
      markDeliveredBtn.addEventListener('click', markDelivered);
      requestReviewBtn?.addEventListener('click', openReviewWhatsApp);
      deleteCancelledOrderBtn?.addEventListener('click', deleteCancelledOrderFromSummary);
      floatingDeleteOrderBtn?.addEventListener('click', deleteSelectedOrderFromDetailPage);
      closeDetailBtn.addEventListener('click', () => {
        if (IS_ORDER_DETAIL_PAGE) window.location.assign(ADMIN_ORDERS_PATH);
        else clearDetail();
      });
      cleanupOrdersCloseBtn?.addEventListener('click', closeCleanupOrdersPanel);
      cleanupSelectAllBtn?.addEventListener('click', selectAllCleanupOrders);
      cleanupDeleteSelectedBtn?.addEventListener('click', deleteSelectedCleanupOrders);
      orderDeleteConfirmCancel?.addEventListener('click', closeOrderDeleteConfirm);
      orderDeleteConfirmSubmit?.addEventListener('click', confirmPendingOrderDelete);
      orderDeleteConfirmSecondary?.addEventListener('click', confirmPendingOrderDeleteSecondary);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !orderDeleteConfirmModal?.classList.contains('hidden')) closeOrderDeleteConfirm();
      });

      if (!POCKETBASE_URL) {
        showAdmin();
        ordersList.innerHTML = '<div class="empty-state">Falta PUBLIC_POCKETBASE_URL en el archivo .env del frontend.</div>';
      } else if (getAdminToken()) {
        showAdmin();
        loadProductCatalog();
        loadShippingZones();
        loadStoreSettings();
        loadOrders();
      } else {
        showAdmin();
        ordersList.innerHTML = '<div class="empty-state">No se pudo validar la sesion administrativa.</div>';
      }
    </script>
  </body>
</html>
