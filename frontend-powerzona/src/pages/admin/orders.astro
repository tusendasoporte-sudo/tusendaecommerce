    <script define:vars={{ pocketbaseUrl, adminAuthToken, currentStoreId, adminOrdersPath, initialOrderId, isOrderDetailPage, publicStorePath }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_ORDERS_PATH = String(adminOrdersPath || '/admin/orders');
      const INITIAL_ORDER_ID = String(initialOrderId || '');
      const IS_ORDER_DETAIL_PAGE = Boolean(isOrderDetailPage);
      const PUBLIC_STORE_PATH = String(publicStorePath || '').replace(/\/$/, '');
      const adminView = document.getElementById('admin-view');
      const refreshBtn = document.getElementById('refresh-btn');
      const refreshMobileBtn = document.getElementById('refresh-mobile-btn');
      const cleanupOrdersOpenBtn = document.getElementById('cleanup-orders-open-btn');
      const cleanupOrdersPanel = document.getElementById('cleanup-orders-panel');
      const cleanupOrdersCloseBtn = document.getElementById('cleanup-orders-close-btn');
      const cleanupOrdersList = document.getElementById('cleanup-orders-list');
      const cleanupSelectedCount = document.getElementById('cleanup-selected-count');
      const cleanupSelectAllBtn = document.getElementById('cleanup-select-all-btn');
      const cleanupDeleteSelectedBtn = document.getElementById('cleanup-delete-selected-btn');
      const ordersAdminAlert = document.getElementById('orders-admin-alert');
      const orderDeleteConfirmModal = document.getElementById('order-delete-confirm-modal');
      const orderDeleteConfirmTitle = document.getElementById('order-delete-confirm-title');
      const orderDeleteConfirmMessage = document.getElementById('order-delete-confirm-message');
      const orderDeleteConfirmAlert = document.getElementById('order-delete-confirm-alert');
      const orderDeleteConfirmCancel = document.getElementById('order-delete-confirm-cancel');
      const orderDeleteConfirmSecondary = document.getElementById('order-delete-confirm-secondary');
      const orderDeleteConfirmSubmit = document.getElementById('order-delete-confirm-submit');
      const searchInput = document.getElementById('search-input');
      const statusFilter = document.getElementById('status-filter');
      const deliveryFilter = document.getElementById('delivery-filter');
      const ordersList = document.getElementById('orders-list');
      const ordersListRefreshBtn = document.getElementById('orders-list-refresh-btn');
      const ordersPagination = document.getElementById('orders-pagination');
      const ORDERS_PER_PAGE = 10;
      let currentOrdersPage = 1;
      let cleanupSelectionMode = false;
      let cleanupSelectedOrderIds = new Set();
      const adminSubtitle = document.getElementById('admin-subtitle');
      const orderDetailEmpty = document.getElementById('order-detail-empty');
      const orderDetail = document.getElementById('order-detail');
      const detailActionsArea = document.getElementById('detail-actions-area');
      const detailOrderNumber = document.getElementById('detail-order-number');
      const detailCreated = document.getElementById('detail-created');
      const detailStatusBadge = document.getElementById('detail-status-badge');
      const detailCustomer = document.getElementById('detail-customer');
      const detailPhone = document.getElementById('detail-phone');
      const detailDelivery = document.getElementById('detail-delivery');
      const detailTotal = document.getElementById('detail-total');
      const detailAddressBox = document.getElementById('detail-address-box');
      const detailAddress = document.getElementById('detail-address');
      const detailItems = document.getElementById('detail-items');
      const detailCoupon = document.getElementById('detail-coupon');
      const toggleAddProductBtn = document.getElementById('toggle-add-product-btn');
      const addProductPanel = document.getElementById('add-product-panel');
      const closeAddProductBtn = document.getElementById('close-add-product-btn');
      const addProductSearch = document.getElementById('add-product-search');
      const addProductSelectedId = document.getElementById('add-product-selected-id');
      const addProductResults = document.getElementById('add-product-results');
      const addProductPreview = document.getElementById('add-product-preview');
      const addProductVariationWrap = document.getElementById('add-product-variation-wrap');
      const addProductVariationSelect = document.getElementById('add-product-variation-select');
      const addProductQuantity = document.getElementById('add-product-quantity');
      const addProductPrice = document.getElementById('add-product-price');
      const addProductBtn = document.getElementById('add-product-btn');
      const toggleEditOrderBtn = document.getElementById('toggle-edit-order-btn');
      const editOrderPanel = document.getElementById('edit-order-panel');
      const closeEditOrderBtn = document.getElementById('close-edit-order-btn');
      const detailStatus = document.getElementById('detail-status');
      const detailNotes = document.getElementById('detail-notes');
      const editCustomerName = document.getElementById('edit-customer-name');
      const editCustomerPhone = document.getElementById('edit-customer-phone');
      const editCustomerAddressWrap = document.getElementById('edit-customer-address-wrap');
      const editCustomerAddress = document.getElementById('edit-customer-address');
      const editDeliveryMethod = document.getElementById('edit-delivery-method');
      const editShippingMunicipalityWrap = document.getElementById('edit-shipping-municipality-wrap');
      const editShippingMunicipality = document.getElementById('edit-shipping-municipality');
      const editShippingZoneWrap = document.getElementById('edit-shipping-zone-wrap');
      const editShippingZone = document.getElementById('edit-shipping-zone');
      const editShippingCostWrap = document.getElementById('edit-shipping-cost-wrap');
      const editShippingCost = document.getElementById('edit-shipping-cost');
      const saveOrderBtn = document.getElementById('save-order-btn');
      const detailAlert = document.getElementById('detail-alert');
      const copyOrderBtn = document.getElementById('copy-order-btn');
      const whatsappOrderBtn = document.getElementById('whatsapp-order-btn');
      const printOrderBtn = document.getElementById('print-order-btn');
      const markDeliveredBtn = document.getElementById('mark-delivered-btn');
      const requestReviewBtn = document.getElementById('request-review-btn');
      const deleteCancelledOrderBtn = document.getElementById('delete-cancelled-order-btn');
      const floatingDeleteOrderBtn = document.getElementById('floating-delete-order-btn');
      const closeDetailBtn = document.getElementById('close-detail-btn');
      const statTotal = document.getElementById('stat-total');
      const statPending = document.getElementById('stat-pending');
      const statConfirmed = document.getElementById('stat-confirmed');
      const statCancelled = document.getElementById('stat-cancelled');
      const statDelivered = document.getElementById('stat-delivered');

      let orders = [];
      let selectedOrder = null;
      let selectedItems = [];
      let orderItemsByOrder = {};
      let productCatalog = [];
      let productVariations = [];
      let shippingZones = [];
      let selectedAddProduct = null;
      const itemSaveTimers = new Map();
      let orderAutoSaveTimer = null;
      let orderAutoSaveRunning = false;
      let orderAutoSavePending = false;
      let pendingOrderDeleteAction = null;
      let pendingOrderDeleteSecondaryAction = null;
      let storeSettingsRecord = null;
      const cleanupOrdersOpenBtnOriginalHtml = cleanupOrdersOpenBtn ? cleanupOrdersOpenBtn.innerHTML : '';
      const cleanupOrdersOpenBtnOriginalClass = cleanupOrdersOpenBtn ? cleanupOrdersOpenBtn.className : '';

      const statusLabels = { pending: 'Pendiente', confirmed: 'Confirmada', delivered: 'Entregada', cancelled: 'Cancelada' };
      const statusAliases = {
        pending: 'pending', pendiente: 'pending',
        confirmed: 'confirmed', confirmada: 'confirmed', confirmado: 'confirmed',
        preparing: 'pending', preparando: 'pending',
        delivered: 'delivered', entregada: 'delivered', entregado: 'delivered',
        cancelled: 'cancelled', canceled: 'cancelled', cancelada: 'cancelled', cancelado: 'cancelled'
      };
      const deliveryLabels = { delivery: 'Envío', pickup: 'Recogida', coordinate: 'Coordinar' };

      const DEFAULT_REVIEW_WHATSAPP_MESSAGE = 'Hola {cliente}, gracias por comprar en {tienda}. Nos ayudas dejando tu rese\u00f1a de la orden {numero_orden} aqu\u00ed: {link_rese\u00f1a}';

      function escapePocketBaseFilterValue(value) {
        return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
      }

      function withStoreFilter(params = '', fieldName = 'store') {
        const query = new URLSearchParams(params || '');
        if (!CURRENT_STORE_ID) return query.toString();
        const storeFilter = `${fieldName}="${escapePocketBaseFilterValue(CURRENT_STORE_ID)}"`;
        const existing = query.get('filter');
        query.set('filter', existing ? `(${existing}) && ${storeFilter}` : storeFilter);
        return query.toString();
      }

      function hasValue(value) {
        return value !== null && value !== undefined && String(value).trim() !== '';
      }

      function getOrderDetailPath(orderId) {
        return `${ADMIN_ORDERS_PATH.replace(/\/$/, '')}/${encodeURIComponent(orderId || '')}`;
      }

      function escapeHtml(value) {
        return String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      }

      function formatUSD(value) { return '$' + Number(value || 0).toFixed(2) + ' USD'; }

      function getOrderCurrencyCode(order) {
        return String(order?.expand?.currency?.code || order?.currency_code || 'USD').toUpperCase();
      }

      function formatVisualAmount(value, currencyCode) {
        const code = String(currencyCode || 'USD').toUpperCase();
        const numeric = Number(value || 0);
        if (code === 'USD') return formatUSD(numeric);
        const decimals = Math.abs(numeric % 1) > 0.001 ? 2 : 0;
        return `${numeric.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals })} ${code}`;
      }

      function convertOrderUsdToSelected(order, usdValue) {
        const code = getOrderCurrencyCode(order);
        if (code === 'USD') return Number(usdValue || 0);
        const rate = Number(order?.exchange_rate_used || order?.expand?.currency?.exchange_rate || 1);
        return Number(usdValue || 0) * (Number.isFinite(rate) && rate > 0 ? rate : 1);
      }

      function getOrderVisualBreakdown(order, items = null) {
        const code = getOrderCurrencyCode(order);
        const list = Array.isArray(items) ? items : (orderItemsByOrder[order?.id] || []);
        const subtotalUSD = Number(order?.subtotal ?? Math.max(0, Number(order?.total || 0) - Number(order?.shipping || 0)));
        let usdOnlyUSD = Number(order?.usd_only_total || 0);
        if (!usdOnlyUSD && list.length) {
          usdOnlyUSD = list.reduce((sum, item) => Boolean(item.only_usd) ? sum + Number(item.line_total_usd || 0) : sum, 0);
        }
        let convertibleUSD = Math.max(0, subtotalUSD - usdOnlyUSD);
        if (list.length) {
          const fromItems = list.reduce((sum, item) => !Boolean(item.only_usd) ? sum + Number(item.line_total_usd || 0) : sum, 0);
          if (fromItems > 0 || usdOnlyUSD > 0) convertibleUSD = fromItems;
        }

        const selectedProductTotal = code === 'USD' ? convertibleUSD : Number(order?.local_currency_total || convertOrderUsdToSelected(order, convertibleUSD));
        const shippingUSD = Number(order?.shipping || 0);
        const shippingSelected = code === 'USD' ? shippingUSD : Number(order?.shipping_cup || convertOrderUsdToSelected(order, shippingUSD));

        return { code, subtotalUSD, convertibleUSD, usdOnlyUSD, selectedProductTotal, shippingUSD, shippingSelected, totalInternalUSD: subtotalUSD + shippingUSD };
      }

      function getOrderVisualSummaryLines(order, items = null) {
        const data = getOrderVisualBreakdown(order, items);
        const lines = [];
        if (data.code !== 'USD' && data.convertibleUSD > 0) lines.push(`Productos ${data.code}: ${formatVisualAmount(data.selectedProductTotal, data.code)}`);
        if (data.usdOnlyUSD > 0) lines.push(`Productos USD: ${formatUSD(data.usdOnlyUSD)}`);
        if (data.code === 'USD' && data.usdOnlyUSD <= 0) lines.push(`Productos USD: ${formatUSD(data.subtotalUSD)}`);
        if (!lines.length) lines.push(`Productos ${data.code}: ${formatVisualAmount(data.selectedProductTotal || data.subtotalUSD, data.code)}`);
        lines.push(`Envío: ${data.shippingUSD > 0 ? (data.code !== 'USD' ? `${formatUSD(data.shippingUSD)} / ${formatVisualAmount(data.shippingSelected, data.code)}` : formatUSD(data.shippingUSD)) : 'Sin costo / pendiente'}`);
        return lines;
      }

      function renderOrderAdminSummary(order, items = null, compact = false) {
        const data = getOrderVisualBreakdown(order, items);
        const visibleLines = getOrderVisualSummaryLines(order, items);
        const visibleHtml = visibleLines.map((line) => `<div>${escapeHtml(line)}</div>`).join('');
        if (compact) return visibleHtml;
        return `${visibleHtml}<div style="margin-top:6px;color:#64748b;font-size:11px;font-weight:850;line-height:1.25;">Interno USD: productos ${formatUSD(data.subtotalUSD)} + envío ${formatUSD(data.shippingUSD)} = ${formatUSD(data.totalInternalUSD)}</div>`;
      }
      function getOrderCouponInfo(order) {
        if (!order) return null;
        const code = String(order.coupon_code || order.manual_coupon_code || order.applied_coupon_code || order.selected_coupon_code || '').trim();
        const couponId = String(order.coupon_id || order.manual_coupon || '').trim();
        const productDiscount = Number(order.coupon_discount_usd || order.coupon_discount_amount_usd || 0);
        const shippingDiscount = Number(order.shipping_discount_usd || 0);
        const totalDiscount = Math.max(0, productDiscount + shippingDiscount);
        const summary = String(order.coupon_summary || order.discount_summary || order.final_discount_label || '').trim();
        if (!code && !couponId && totalDiscount <= 0 && !summary) return null;
        return { code, couponId, productDiscount, shippingDiscount, totalDiscount, summary };
      }

      function renderOrderCouponBadge(order) {
        const coupon = getOrderCouponInfo(order);
        if (!coupon) return '';
        const discountText = coupon.totalDiscount > 0 ? ` -${formatUSD(coupon.totalDiscount)}` : '';
        return `<span style="display:inline-flex !important; align-items:center !important; gap:6px !important; padding:8px 10px !important; border-radius:999px !important; background:#ecfdf5 !important; border:1px solid #bbf7d0 !important; color:#166534 !important; font-size:12px !important; line-height:1 !important; font-weight:1000 !important; box-shadow:0 8px 16px rgba(22,163,74,.08),inset 0 1px 0 rgba(255,255,255,.95) !important;">Cupon${coupon.code ? `: ${escapeHtml(coupon.code)}` : ''}${escapeHtml(discountText)}</span>`;
      }

      function renderOrderCouponCard(order) {
        const coupon = getOrderCouponInfo(order);
        if (!coupon) return '';
        const detailLines = [];
        if (coupon.code) detailLines.push(['Codigo', coupon.code]);
        if (coupon.totalDiscount > 0) detailLines.push(['Descuento', `-${formatUSD(coupon.totalDiscount)}`]);
        if (coupon.shippingDiscount > 0) detailLines.push(['Envio descontado', `-${formatUSD(coupon.shippingDiscount)}`]);
        detailLines.push(['Tipo', 'Cupon manual']);
        if (coupon.summary && coupon.summary.toLowerCase() !== coupon.code.toLowerCase()) detailLines.push(['Detalle', coupon.summary]);

        return `
          <section class="coupon-summary-card" style="margin:16px 0 18px;padding:15px;border-radius:20px;background:linear-gradient(145deg,#ecfdf5 0%,#ffffff 72%);border:1px solid rgba(187,247,208,.95);box-shadow:0 14px 30px rgba(15,23,42,.07),inset 0 1px 0 rgba(255,255,255,.95);">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:10px;">
              <h3 class="section-title" style="margin:0;font-size:15px;">Cupon aplicado</h3>
              <span style="display:inline-flex;align-items:center;padding:6px 9px;border-radius:999px;background:#dcfce7;color:#166534;border:1px solid #bbf7d0;font-size:10px;font-weight:1000;text-transform:uppercase;letter-spacing:.06em;">Manual</span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;">
              ${detailLines.map(([label, value]) => `
                <div style="min-width:0;padding:10px 11px;border-radius:15px;background:rgba(255,255,255,.86);border:1px solid rgba(226,232,240,.9);">
                  <div style="font-size:10px;font-weight:1000;text-transform:uppercase;letter-spacing:.07em;color:#64748b;margin-bottom:4px;">${escapeHtml(label)}</div>
                  <div style="font-size:13px;font-weight:950;color:#0f172a;line-height:1.3;word-break:break-word;">${escapeHtml(value)}</div>
                </div>
              `).join('')}
            </div>
          </section>`;
      }

      function renderDetailCoupon(order) {
        if (!detailCoupon) return;
        const html = renderOrderCouponCard(order);
        detailCoupon.innerHTML = html;
        detailCoupon.classList.toggle('hidden', !html);
      }

      function formatDate(value) {
        if (!value) return 'Sin fecha';
        return new Intl.DateTimeFormat('es-US', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(value));
      }
      function formatDateOnly(value) {
        if (!value) return 'Sin fecha';
        return new Intl.DateTimeFormat('es-US', {
          day: 'numeric',
          month: 'short',
          year: 'numeric',
        }).format(new Date(value));
      }
      function formatDateGroup(value) {
        if (!value) return 'Sin fecha';
        return new Intl.DateTimeFormat('es-US', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(value));
      }
      function getOrderFinalTotal(order) {
        const total = Number(order?.total_usd ?? order?.total ?? 0);
        if (Number.isFinite(total) && total > 0) return formatUSD(total);
        const items = orderItemsByOrder[order?.id] || [];
        const subtotal = items.reduce((sum, item) => sum + Number(item.line_total_usd || 0), 0);
        const shipping = Number(order?.shipping_usd || order?.shipping || 0);
        return formatUSD(subtotal + shipping);
      }
      function getDateKey(value) {
        if (!value) return 'sin-fecha';
        const date = new Date(value);
        return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
      }
      function pluralizePedidos(count) { return count === 1 ? '1 pedido' : `${count} pedidos`; }
      function normalizeStatus(status) {
        const key = String(status || 'pending').trim().toLowerCase();
        return statusAliases[key] || key || 'pending';
      }
      function getStatusLabel(status) {
        const normalized = normalizeStatus(status);
        return statusLabels[normalized] || status || 'Pendiente';
      }
      function getStatusClass(status) { return `badge status-${normalizeStatus(status)}`; }

      function getStatusInlineStyle(status) {
        const normalized = normalizeStatus(status);
        const base = 'display:inline-flex;align-items:center;justify-content:center;min-width:84px;padding:5px 10px;border-radius:999px;font-size:10px;line-height:1;font-weight:1000;text-transform:uppercase;letter-spacing:.035em;border:1px solid;';
        const styles = {
          pending: 'background:#fef3c7;color:#92400e;border-color:#f59e0b;box-shadow:0 6px 14px rgba(245,158,11,.18);',
          confirmed: 'background:#dcfce7;color:#14532d;border-color:#22c55e;box-shadow:0 6px 14px rgba(22,163,74,.16);',
          preparing: 'background:#ede9fe;color:#5b21b6;border-color:#8b5cf6;',
          delivered: 'background:#dbeafe;color:#1e40af;border-color:#3b82f6;',
          cancelled: 'background:#fee2e2;color:#991b1b;border-color:#ef4444;'
        };
        return base + (styles[normalized] || styles.pending);
      }
      function setDetailAlert(message, type = 'info') { detailAlert.textContent = message; detailAlert.className = `alert alert-${type}`; detailAlert.classList.toggle('hidden', !message); }
      function setOrdersAdminAlert(message = '', type = 'info') {
        if (!ordersAdminAlert) return;
        ordersAdminAlert.textContent = message;
        ordersAdminAlert.className = `alert alert-${type} orders-admin-alert`;
        ordersAdminAlert.classList.toggle('hidden', !message);
      }
      function setOrderConfirmAlert(message = '', type = 'error') {
        if (!orderDeleteConfirmAlert) return;
        orderDeleteConfirmAlert.textContent = message;
        orderDeleteConfirmAlert.className = `alert alert-${type} order-confirm-alert`;
        orderDeleteConfirmAlert.classList.toggle('hidden', !message);
      }
      function closeOrderDeleteConfirm() {
        pendingOrderDeleteAction = null;
        pendingOrderDeleteSecondaryAction = null;
        setOrderConfirmAlert('');
        orderDeleteConfirmModal?.classList.add('hidden');
        orderDeleteConfirmModal?.setAttribute('aria-hidden', 'true');
        if (orderDeleteConfirmSubmit) {
          orderDeleteConfirmSubmit.disabled = false;
          orderDeleteConfirmSubmit.textContent = 'Sí, borrar pedido';
        }
        if (orderDeleteConfirmSecondary) {
          orderDeleteConfirmSecondary.disabled = false;
          orderDeleteConfirmSecondary.textContent = 'Borrar sin devolver';
          orderDeleteConfirmSecondary.classList.add('hidden');
        }
        if (orderDeleteConfirmCancel) orderDeleteConfirmCancel.disabled = false;
      }
      function openOrderDeleteConfirm({ title, message, confirmText, action, secondaryText = '', secondaryAction = null }) {
        pendingOrderDeleteAction = action;
        pendingOrderDeleteSecondaryAction = secondaryAction;
        setOrderConfirmAlert('');
        if (orderDeleteConfirmTitle) orderDeleteConfirmTitle.textContent = title;
        if (orderDeleteConfirmMessage) orderDeleteConfirmMessage.textContent = message;
        if (orderDeleteConfirmSubmit) {
          orderDeleteConfirmSubmit.disabled = false;
          orderDeleteConfirmSubmit.textContent = confirmText;
        }
        if (orderDeleteConfirmSecondary) {
          orderDeleteConfirmSecondary.disabled = false;
          orderDeleteConfirmSecondary.textContent = secondaryText || 'Borrar sin devolver';
          orderDeleteConfirmSecondary.classList.toggle('hidden', !secondaryAction);
        }
        if (orderDeleteConfirmCancel) orderDeleteConfirmCancel.disabled = false;
        orderDeleteConfirmModal?.classList.remove('hidden');
        orderDeleteConfirmModal?.setAttribute('aria-hidden', 'false');
        orderDeleteConfirmSubmit?.focus();
      }
      async function runPendingOrderDelete(action, button, loadingText) {
        if (!action) return;
        if (orderDeleteConfirmSubmit) {
          orderDeleteConfirmSubmit.disabled = true;
        }
        if (orderDeleteConfirmSecondary) orderDeleteConfirmSecondary.disabled = true;
        if (button) button.textContent = loadingText;
        if (orderDeleteConfirmCancel) orderDeleteConfirmCancel.disabled = true;
        setOrderConfirmAlert('');
        try {
          await action();
          closeOrderDeleteConfirm();
        } catch (error) {
          console.error(error);
          setOrderConfirmAlert(error?.message || 'No se pudo completar el borrado.', 'error');
          if (orderDeleteConfirmSubmit) {
            orderDeleteConfirmSubmit.disabled = false;
            orderDeleteConfirmSubmit.textContent = orderDeleteConfirmTitle?.textContent?.includes('seleccionadas') ? 'Sí, borrar seleccionadas' : 'Sí, borrar pedido';
          }
          if (orderDeleteConfirmSecondary) {
            orderDeleteConfirmSecondary.disabled = false;
            orderDeleteConfirmSecondary.textContent = 'Borrar sin devolver';
          }
          if (orderDeleteConfirmCancel) orderDeleteConfirmCancel.disabled = false;
        }
      }
      async function confirmPendingOrderDelete() {
        await runPendingOrderDelete(pendingOrderDeleteAction, orderDeleteConfirmSubmit, 'Borrando...');
      }
      async function confirmPendingOrderDeleteSecondary() {
        await runPendingOrderDelete(pendingOrderDeleteSecondaryAction, orderDeleteConfirmSecondary, 'Borrando...');
      }
      function showAdmin() { adminView.classList.remove('hidden'); }
      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function clearAdminToken() { document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax'; }

      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(result?.message || 'Error de comunicacion con la plataforma.');
        return result;
      }

      async function loadStoreSettings() {
        try {
          const result = await apiRequest(`/api/collections/settings/records?${withStoreFilter('filter=active=true&sort=-updated&perPage=1')}`);
          storeSettingsRecord = result.items?.[0] || null;
        } catch (error) {
          console.error('No se pudieron cargar los ajustes de reseñas.', error);
          storeSettingsRecord = null;
        } finally {
          updateReviewRequestButtonState();
        }
      }

      async function loadOrders() {
        ordersList.innerHTML = '<div class="empty-state">Cargando órdenes...</div>';
        refreshBtn.disabled = true;
        try {
          const result = await apiRequest(`/api/collections/orders/records?${withStoreFilter('sort=-created&expand=shipping_zone,currency&perPage=200')}`);
          orders = result.items || [];
          await loadOrderItemSummaries();
          adminSubtitle.textContent = `${orders.length} órdenes encontradas. Última actualización: ${formatDate(new Date().toISOString())}.`;
          renderStats();
          renderOrders();
          if (INITIAL_ORDER_ID && !selectedOrder) {
            await selectOrder(INITIAL_ORDER_ID);
            if (!selectedOrder) {
              orderDetailEmpty.classList.remove('hidden');
              orderDetail.classList.add('hidden');
              floatingDeleteOrderBtn?.classList.add('hidden');
              orderDetailEmpty.textContent = 'No tienes acceso a este pedido.';
            }
          }
          if (selectedOrder && !orders.some((order) => order.id === selectedOrder.id)) clearDetail();
        } catch (error) {
          console.error(error);
          ordersList.innerHTML = '<div class="empty-state">No se pudieron cargar las órdenes. Revisa tu sesion admin o las reglas administrativas.</div>';
        } finally {
          refreshBtn.disabled = false;
        }
      }


      async function loadOrderItemSummaries() {
        orderItemsByOrder = {};
        if (!orders.length) return;
        try {
          const orderIds = orders.map((order) => order.id).filter(Boolean);
          if (!orderIds.length) return;
          const filter = encodeURIComponent(orderIds.map((id) => `order = "${id}"`).join(' || '));
          const result = await apiRequest(`/api/collections/order_items/records?filter=${filter}&sort=created&expand=product,variation,gift&perPage=500`);
          (result.items || []).forEach((item) => {
            const orderId = item.order;
            if (!orderId) return;
            if (!orderItemsByOrder[orderId]) orderItemsByOrder[orderId] = [];
            orderItemsByOrder[orderId].push(item);
          });
        } catch (error) {
          console.error('No se pudieron cargar los productos para el resumen de órdenes.', error);
          orderItemsByOrder = {};
        }
      }

      function getVariationLabelFromRecord(variation) {
        return [variation?.variation_type, variation?.value].filter(Boolean).join(': ') || variation?.name || '';
      }

      function getItemVariationDisplay(item) {
        return item?.variation_label || item?.variation_name || getVariationLabelFromRecord(item?.expand?.variation) || '';
      }

      function getItemDisplayName(item) {
        const productName = item?.product_name || item?.expand?.gift?.name || item?.expand?.product?.name || (item?.is_gift ? 'Regalo' : 'Producto');
        if (item?.is_gift) return `🎁 ${productName}`;
        const variationName = getItemVariationDisplay(item);
        return variationName ? `${productName} — ${variationName}` : productName;
      }

      function getOrderItemsSummary(order) {
        const items = orderItemsByOrder[order.id] || [];
        if (!items.length) return '';
        return items.slice(0, 3).map((item) => {
          const quantity = Number(item.quantity || 1);
          return `${quantity}× ${getItemDisplayName(item)}`;
        }).join(' · ') + (items.length > 3 ? ` · +${items.length - 3} más` : '');
      }

      async function loadProductCatalog() {
        try {
          const [productsResult, variationsResult] = await Promise.all([
            apiRequest(`/api/collections/products/records?${withStoreFilter('sort=name&perPage=500')}`),
            apiRequest(`/api/collections/product_variations/records?${withStoreFilter('sort=variation_type,value&perPage=500', 'product.store')}`),
          ]);
          productCatalog = productsResult.items || [];
          productVariations = variationsResult.items || [];
          resetAddProductForm();
        } catch (error) {
          console.error(error);
          productCatalog = [];
          productVariations = [];
          resetAddProductForm('No se pudieron cargar los productos. Revisa las reglas de products y product_variations.');
        }
      }

      async function loadShippingZones() {
        try {
          const result = await apiRequest(`/api/collections/shipping_zones/records?${withStoreFilter('sort=municipality,zone&perPage=500')}`);
          shippingZones = result.items || [];
          renderShippingMunicipalities();
        } catch (error) {
          console.error(error);
          shippingZones = [];
          renderShippingMunicipalities();
        }
      }

      function getShippingZoneById(zoneId) {
        if (!zoneId) return null;
        return shippingZones.find((zone) => zone.id === zoneId) || null;
      }

      function renderShippingMunicipalities(selectedMunicipality = '') {
        if (!editShippingMunicipality) return;
        const municipalities = [...new Set(shippingZones.map((zone) => zone.municipality).filter(Boolean))].sort((a, b) => a.localeCompare(b));
        editShippingMunicipality.innerHTML = '<option value="">Selecciona municipio</option>' + municipalities.map((municipality) => `<option value="${escapeHtml(municipality)}">${escapeHtml(municipality)}</option>`).join('');
        if (selectedMunicipality && municipalities.includes(selectedMunicipality)) {
          editShippingMunicipality.value = selectedMunicipality;
        }
      }

      function renderShippingZoneOptions(selectedZoneId = '') {
        if (!editShippingZone || !editShippingMunicipality) return;
        const municipality = editShippingMunicipality.value;
        const zones = shippingZones.filter((zone) => zone.municipality === municipality);
        editShippingZone.innerHTML = '<option value="">Selecciona zona</option>' + zones.map((zone) => {
          const label = [zone.zone, formatUSD(zone.price_usd || 0)].filter(Boolean).join(' - ');
          return `<option value="${escapeHtml(zone.id)}">${escapeHtml(label)}</option>`;
        }).join('');
        if (selectedZoneId && zones.some((zone) => zone.id === selectedZoneId)) {
          editShippingZone.value = selectedZoneId;
        }
        updateShippingCostPreview();
      }

      function updateShippingCostPreview() {
        if (!editShippingCost) return;
        const zone = getShippingZoneById(editShippingZone?.value) || selectedOrder?.expand?.shipping_zone || getShippingZoneById(selectedOrder?.shipping_zone);
        const method = editDeliveryMethod?.value || selectedOrder?.delivery_method || 'delivery';
        editShippingCost.value = method === 'delivery' ? formatUSD(zone?.price_usd || selectedOrder?.shipping || selectedOrder?.shipping_usd || 0) : formatUSD(0);
      }

      function getSelectedShippingZoneForEditor() {
        return getShippingZoneById(editShippingZone?.value) || selectedOrder?.expand?.shipping_zone || getShippingZoneById(selectedOrder?.shipping_zone) || null;
      }

      function getEditorSubtotal() {
        return selectedItems.reduce((sum, item) => sum + Number(item.line_total_usd || 0), 0);
      }

      function updateDeliveryLivePreview() {
        if (!selectedOrder) return;
        const method = editDeliveryMethod?.value || selectedOrder.delivery_method || 'delivery';
        const isDelivery = method === 'delivery';
        const zone = getSelectedShippingZoneForEditor();
        const zoneLabel = isDelivery && zone ? `${[zone.municipality, zone.zone].filter(Boolean).join(' / ')} - ${formatUSD(zone.price_usd || 0)}` : '';
        const deliveryText = [deliveryLabels[method] || method || 'Sin método', zoneLabel].filter(Boolean).join(' · ');
        if (detailDelivery) detailDelivery.textContent = deliveryText;
        if (detailAddressBox) detailAddressBox.classList.toggle('hidden', !isDelivery);
        if (detailAddress) detailAddress.textContent = isDelivery ? (editCustomerAddress?.value || selectedOrder.customer_address || 'Sin dirección / no aplica') : 'No aplica';
        if (detailTotal) {
          const subtotal = getEditorSubtotal() || Number(selectedOrder.total || 0) - getOrderShippingAmount(selectedOrder);
          const shipping = isDelivery ? Number(zone?.price_usd || selectedOrder.shipping || selectedOrder.shipping_usd || 0) : 0;
          detailTotal.textContent = formatUSD(Math.max(0, subtotal) + shipping);
        }
      }

      function updateDeliveryEditorVisibility() {
        const method = editDeliveryMethod?.value || 'delivery';
        const isDelivery = method === 'delivery';

        editCustomerAddressWrap?.classList.toggle('hidden', !isDelivery);
        editShippingMunicipalityWrap?.classList.toggle('hidden', !isDelivery);
        editShippingZoneWrap?.classList.toggle('hidden', !isDelivery);
        editShippingCostWrap?.classList.toggle('hidden', !isDelivery);

        updateShippingCostPreview();
        updateDeliveryLivePreview();
      }

      function getOrderEditorPayloadForAutoSave() {
        if (!selectedOrder) return null;
        const nextDeliveryMethod = editDeliveryMethod?.value || selectedOrder.delivery_method || 'delivery';
        const nextShippingZone = nextDeliveryMethod === 'delivery' ? getSelectedShippingZoneForEditor() : null;
        const subtotal = selectedItems.reduce((sum, item) => sum + Number(item.line_total_usd || 0), 0);
        const fallbackSubtotal = Math.max(0, Number(selectedOrder.total || 0) - getOrderShippingAmount(selectedOrder));
        const orderSubtotal = subtotal || fallbackSubtotal;
        const nextShippingAmount = nextDeliveryMethod === 'delivery' ? Number(nextShippingZone?.price_usd || selectedOrder.shipping || selectedOrder.shipping_usd || 0) : 0;
        const nextTotal = orderSubtotal + nextShippingAmount;
        const payload = {
          customer_name: editCustomerName?.value.trim() || '',
          customer_phone: editCustomerPhone?.value.trim() || '',
          customer_address: editCustomerAddress?.value.trim() || '',
          delivery_method: nextDeliveryMethod,
          shipping: nextShippingAmount,
          shipping_usd: nextShippingAmount,
          total: nextTotal,
          total_usd: nextTotal,
          notes: detailNotes?.value.trim() || '',
        };

        if (nextDeliveryMethod === 'delivery' && nextShippingZone?.id) {
          payload.shipping_zone = nextShippingZone.id;
        }

        return payload;
      }

      function updateOrderEditorPreviewBeforeAutoSave() {
        if (!selectedOrder) return;
        if (detailCustomer) detailCustomer.textContent = editCustomerName?.value.trim() || 'Sin nombre';
        if (detailPhone) detailPhone.textContent = editCustomerPhone?.value.trim() || 'Sin teléfono';
        updateDeliveryEditorVisibility();
      }

      function scheduleOrderAutoSave() {
        if (!selectedOrder || isOrderEditingLocked()) return;
        updateOrderEditorPreviewBeforeAutoSave();
        clearTimeout(orderAutoSaveTimer);
        orderAutoSaveTimer = setTimeout(() => autoSaveOrderEditorFields(), 650);
      }

      async function autoSaveOrderEditorFields() {
        if (!selectedOrder || isOrderEditingLocked()) return;
        const payload = getOrderEditorPayloadForAutoSave();
        if (!payload) return;

        if (orderAutoSaveRunning) {
          orderAutoSavePending = true;
          return;
        }

        orderAutoSaveRunning = true;
        orderAutoSavePending = false;
        setDetailAlert('Guardando cambios automáticos...', 'info');

        try {
          const updatedOrder = await apiRequest(`/api/collections/orders/records/${selectedOrder.id}?expand=shipping_zone,currency`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
          selectedOrder = updatedOrder;
          detailStatusBadge.className = getStatusClass(selectedOrder.status);
          detailStatusBadge.textContent = getStatusLabel(selectedOrder.status);
          detailCustomer.textContent = selectedOrder.customer_name || 'Sin nombre';
          detailPhone.textContent = selectedOrder.customer_phone || 'Sin teléfono';
          updateShippingCostPreview();
          updateDeliveryLivePreview();
          renderStats();
          renderOrders();
          setDetailAlert('Cambios guardados automáticamente.', 'success');
        } catch (error) {
          console.error(error);
          setDetailAlert('No se pudieron guardar automáticamente los datos de la orden. Revisa tu sesion admin o las reglas administrativas.', 'error');
        } finally {
          orderAutoSaveRunning = false;
          if (orderAutoSavePending) {
            orderAutoSavePending = false;
            scheduleOrderAutoSave();
          }
        }
      }

      function getVariationsForProduct(productId) {
        return productVariations.filter((variation) => variation.product === productId);
      }

      function getVariationLabel(variation) {
        return [variation.variation_type, variation.value].filter(Boolean).join(': ') || 'Variación';
      }

      function getVariationUnitPrice(product, variation) {
        return Number(product?.base_price_usd || 0) + Number(variation?.extra_price || 0);
      }

      function getStockValue(record) {
        if (!record) return null;
        const candidates = [record.stock, record.quantity, record.inventory, record.stock_available];
        const value = candidates.find((candidate) => candidate !== undefined && candidate !== null && candidate !== '');
        if (value === undefined) return null;
        const numeric = Number(value);
        return Number.isFinite(numeric) ? Math.max(0, numeric) : null;
      }

      // Regla segura: track_stock=false significa que el producto se puede vender sin validar ni descontar inventario.
      function productTracksStock(product) {
        return product?.track_stock !== false;
      }

      function getItemProduct(item) {
        return item?.expand?.product || productCatalog.find((product) => product.id === item?.product) || null;
      }

      function getItemVariation(item) {
        return item?.expand?.variation || productVariations.find((variation) => variation.id === item?.variation) || null;
      }

      function orderHasStockDeducted(order = selectedOrder) {
        return Boolean(order?.stock_deducted || order?.inventory_deducted);
      }

      function isOrderEditingLocked() {
        const status = normalizeStatus(selectedOrder?.status);
        return Boolean(selectedOrder && ['confirmed', 'delivered', 'cancelled'].includes(status));
      }

      function isProductEditingLocked() {
        return isOrderEditingLocked();
      }

      function getProductStockKey(productId, variationId = '') {
        if (variationId) return `variation:${variationId}`;
        if (productId) return `product:${productId}`;
        return '';
      }

      function getItemStockKey(item) {
        if (!item) return '';
        return getProductStockKey(item.product, item.variation || '');
      }

      function getUsedQuantityForStockKey(stockKey, excludeItemId = '') {
        if (!stockKey) return 0;
        return selectedItems.reduce((sum, item) => {
          if (excludeItemId && item.id === excludeItemId) return sum;
          return getItemStockKey(item) === stockKey ? sum + Number(item.quantity || 0) : sum;
        }, 0);
      }

      function getMaxQuantityForExistingItem(item) {
        const stockInfo = getItemStockInfo(item);
        if (!stockInfo?.tracksStock) return null;
        if (!Number.isFinite(stockInfo.stock) || stockInfo.stock === null) return null;
        const usedByOtherLines = getUsedQuantityForStockKey(getItemStockKey(item), item.id);
        return Math.max(0, Number(stockInfo.stock || 0) - usedByOtherLines);
      }

      function getAvailableStockForProductSelection(product, variation = null) {
        if (!product || !productTracksStock(product)) return null;
        const stockSource = variation || product;
        const baseStock = getStockValue(stockSource);
        if (!Number.isFinite(baseStock) || baseStock === null) return null;
        const stockKey = getProductStockKey(product.id, variation?.id || '');
        const usedInThisOrder = getUsedQuantityForStockKey(stockKey);
        return Math.max(0, Number(baseStock || 0) - usedInThisOrder);
      }

      function findExistingItemForSelection(productId, variationId = '') {
        const stockKey = getProductStockKey(productId, variationId);
        return selectedItems.find((item) => getItemStockKey(item) === stockKey) || null;
      }

      function getItemStockInfo(item) {
        const product = getItemProduct(item);
        if (!productTracksStock(product)) {
          return {
            stock: null,
            label: 'Sin stock descontable',
            source: 'none',
            tracksStock: false,
          };
        }

        const variation = getItemVariation(item);
        if (variation) {
          return {
            stock: getStockValue(variation),
            label: `Stock de variación: ${Number(getStockValue(variation) || 0)}`,
            source: 'variation',
            tracksStock: true,
          };
        }

        return {
          stock: getStockValue(product),
          label: `Stock del producto: ${Number(getStockValue(product) || 0)}`,
          source: 'product',
          tracksStock: true,
        };
      }

      function clampQuantityToStock(input, maxStock, statusEl = null) {
        if (!input) return 1;
        let quantity = Math.max(1, Math.floor(Number(input.value || 1)));
        if (Number.isFinite(maxStock) && maxStock !== null) {
          if (maxStock <= 0) {
            quantity = 1;
            input.value = '1';
            if (statusEl) statusEl.textContent = 'Este producto no tiene stock disponible.';
            return quantity;
          }
          if (quantity > maxStock) {
            quantity = maxStock;
            input.value = String(maxStock);
            if (statusEl) statusEl.textContent = `No puedes superar el stock disponible (${maxStock}).`;
          }
        }
        input.value = String(quantity);
        return quantity;
      }

      function getAddProductCurrentStock() {
        if (!selectedAddProduct) return null;
        const variations = getVariationsForProduct(selectedAddProduct.id);
        const variation = productVariations.find((item) => item.id === addProductVariationSelect.value);
        if (variations.length && variation) return getAvailableStockForProductSelection(selectedAddProduct, variation);
        if (!variations.length) return getAvailableStockForProductSelection(selectedAddProduct, null);
        return null;
      }

      function updateAddProductQuantityLimit() {
        if (!addProductQuantity) return;
        const availableStock = getAddProductCurrentStock();
        if (Number.isFinite(availableStock) && availableStock !== null) {
          addProductQuantity.max = String(availableStock);
          if (availableStock <= 0) {
            addProductQuantity.value = '1';
            if (addProductPreview && selectedAddProduct) {
              addProductPreview.textContent = 'Este producto ya no tiene unidades disponibles para agregar en esta orden.';
            }
            return;
          }
          if (Number(addProductQuantity.value || 1) > availableStock) {
            addProductQuantity.value = String(availableStock);
          }
        } else {
          addProductQuantity.removeAttribute('max');
        }
      }

      function resetAddProductForm(message = '') {
        selectedAddProduct = null;
        if (addProductSearch) addProductSearch.value = '';
        if (addProductSelectedId) addProductSelectedId.value = '';
        if (addProductPrice) addProductPrice.value = '0.00';
        if (addProductQuantity) addProductQuantity.value = '1';
        if (addProductVariationWrap) addProductVariationWrap.classList.add('hidden');
        if (addProductVariationSelect) addProductVariationSelect.innerHTML = '<option value="">Selecciona una variación</option>';
        if (addProductResults) {
          addProductResults.innerHTML = '';
          addProductResults.classList.add('hidden');
        }
        if (addProductPreview) {
          addProductPreview.textContent = message || 'Selecciona un producto para cargar precio, stock y variaciones.';
        }
      }

      function renderProductSearchResults() {
        if (!addProductResults || !addProductSearch) return;
        const query = addProductSearch.value.trim().toLowerCase();
        selectedAddProduct = null;
        addProductSelectedId.value = '';

        if (!query) {
          addProductResults.innerHTML = '';
          addProductResults.classList.add('hidden');
          if (addProductPreview) addProductPreview.textContent = 'Escribe el nombre del producto para buscarlo.';
          return;
        }

        const matches = productCatalog
          .filter((product) => String(product.name || '').toLowerCase().includes(query))
          .slice(0, 10);

        if (!matches.length) {
          addProductResults.innerHTML = '<div class="item-row" style="grid-template-columns:1fr;"><div class="item-sub">No se encontraron productos con ese nombre.</div></div>';
          addProductResults.classList.remove('hidden');
          return;
        }

        addProductResults.innerHTML = matches.map((product) => {
          const variationsCount = getVariationsForProduct(product.id).length;
          return `
            <button class="item-row add-product-result" type="button" data-product-id="${escapeHtml(product.id)}" style="width:100%; grid-template-columns:1fr auto; text-align:left; border:1px solid #e2e8f0; background:#fff;">
              <div>
                <div class="item-name">${escapeHtml(product.name)}</div>
                <div class="item-sub">${productTracksStock(product) ? `Stock: ${Number(product.stock || 0)} · Disponible sin duplicar: ${variationsCount ? 'elige variación' : Number(getAvailableStockForProductSelection(product, null) || 0)}` : 'Sin stock descontable'} · ${variationsCount ? `${variationsCount} variaciones` : 'Sin variaciones'}</div>
              </div>
              <div class="item-price">${formatUSD(product.base_price_usd)}</div>
            </button>`;
        }).join('');
        addProductResults.classList.remove('hidden');

        addProductResults.querySelectorAll('.add-product-result').forEach((button) => {
          button.addEventListener('click', () => selectAddProduct(button.dataset.productId));
        });
      }

      function selectAddProduct(productId) {
        const product = productCatalog.find((item) => item.id === productId);
        if (!product) return;

        selectedAddProduct = product;
        addProductSelectedId.value = product.id;
        addProductSearch.value = product.name;
        addProductResults.innerHTML = '';
        addProductResults.classList.add('hidden');
        addProductQuantity.value = '1';

        const variations = getVariationsForProduct(product.id);
        if (variations.length) {
          addProductVariationWrap.classList.remove('hidden');
          addProductVariationSelect.innerHTML = '<option value="">Selecciona una variación</option>' + variations.map((variation) => `
            <option value="${escapeHtml(variation.id)}">${escapeHtml(getVariationLabel(variation))} · ${productTracksStock(product) ? `Stock: ${Number(variation.stock || 0)}` : 'Sin stock descontable'} · ${formatUSD(getVariationUnitPrice(product, variation))}</option>
          `).join('');
          addProductPrice.value = Number(product.base_price_usd || 0).toFixed(2);
          addProductQuantity.removeAttribute('max');
          addProductPreview.textContent = `Producto seleccionado: ${product.name}. Selecciona una variación para cargar precio y stock.`;
        } else {
          addProductVariationWrap.classList.add('hidden');
          addProductVariationSelect.innerHTML = '<option value="">Sin variaciones</option>';
          addProductPrice.value = Number(product.base_price_usd || 0).toFixed(2);
          updateAddProductQuantityLimit();
          const availableStock = getAvailableStockForProductSelection(product, null);
          addProductPreview.textContent = productTracksStock(product)
            ? `Producto seleccionado: ${product.name}. Disponible para agregar: ${Number(availableStock || 0)} de ${Number(getStockValue(product) || 0)} en stock.`
            : `Producto seleccionado: ${product.name}. Este producto no descuenta inventario; puedes agregar la cantidad necesaria.`;
        }
      }

      function handleAddVariationChange() {
        if (!selectedAddProduct) return;
        const variation = productVariations.find((item) => item.id === addProductVariationSelect.value);
        if (!variation) {
          addProductPrice.value = Number(selectedAddProduct.base_price_usd || 0).toFixed(2);
          addProductPreview.textContent = `Producto seleccionado: ${selectedAddProduct.name}. Selecciona una variación para cargar precio y stock.`;
          return;
        }
        addProductPrice.value = getVariationUnitPrice(selectedAddProduct, variation).toFixed(2);
        updateAddProductQuantityLimit();
        const availableStock = getAvailableStockForProductSelection(selectedAddProduct, variation);
        addProductPreview.textContent = productTracksStock(selectedAddProduct)
          ? `Variación seleccionada: ${getVariationLabel(variation)}. Disponible para agregar: ${Number(availableStock || 0)} de ${Number(getStockValue(variation) || 0)} en stock.`
          : `Variación seleccionada: ${getVariationLabel(variation)}. Este producto no descuenta inventario; puedes agregar la cantidad necesaria.`;
      }

      function renderStats() {
        statTotal.textContent = String(orders.length);
        statPending.textContent = String(orders.filter((order) => normalizeStatus(order.status) === 'pending').length);
        statConfirmed.textContent = String(orders.filter((order) => normalizeStatus(order.status) === 'confirmed').length);
        statCancelled.textContent = String(orders.filter((order) => normalizeStatus(order.status) === 'cancelled').length);
        statDelivered.textContent = String(orders.filter((order) => normalizeStatus(order.status) === 'delivered').length);
        updateCleanupSelectionUI();
      }

      function getShippingZoneLabel(order) {
        const zone = order.expand?.shipping_zone;
        if (!zone) return '';
        const zoneName = [zone.municipality, zone.zone].filter(Boolean).join(' / ');
        return zoneName ? `${zoneName} - ${formatUSD(zone.price_usd || order.shipping || 0)}` : '';
      }

      function getFilteredOrders() {
        const search = searchInput.value.trim().toLowerCase();
        const status = statusFilter.value;
        const delivery = deliveryFilter.value;
        return orders.filter((order) => {
          const matchesStatus = status === 'all' || normalizeStatus(order.status) === status;
          const matchesDelivery = delivery === 'all' || order.delivery_method === delivery;
          const haystack = [order.order_number, order.customer_name, order.customer_phone, order.customer_address, getShippingZoneLabel(order)].join(' ').toLowerCase();
          const matchesSearch = !search || haystack.includes(search);
          return matchesStatus && matchesDelivery && matchesSearch;
        });
      }

      function getOrderAccent(status) {
        const normalized = normalizeStatus(status);
        if (normalized === 'confirmed') return 'linear-gradient(180deg,#22c55e,#16a34a)';
        if (normalized === 'delivered') return 'linear-gradient(180deg,#3b82f6,#2563eb)';
        if (normalized === 'cancelled') return 'linear-gradient(180deg,#ef4444,#dc2626)';
        return 'linear-gradient(180deg,#f59e0b,#f97316)';
      }

      function renderOrders() {
        const filteredOrders = getFilteredOrders();
        const totalPages = Math.max(1, Math.ceil(filteredOrders.length / ORDERS_PER_PAGE));
        if (currentOrdersPage > totalPages) currentOrdersPage = totalPages;
        if (currentOrdersPage < 1) currentOrdersPage = 1;

        if (!filteredOrders.length) {
          ordersList.innerHTML = '<div class="empty-state">No hay pedidos con esos filtros.</div>';
          if (ordersPagination) {
            ordersPagination.classList.add('hidden');
            ordersPagination.innerHTML = '';
          }
          updateCleanupSelectionUI();
          return;
        }

        const startIndex = (currentOrdersPage - 1) * ORDERS_PER_PAGE;
        const pageOrders = filteredOrders.slice(startIndex, startIndex + ORDERS_PER_PAGE);
        const headerMarkup = `
          <div class="orders-table-head" aria-hidden="true">
            <span>Pedido</span>
            <span>Cliente</span>
            <span>Fecha</span>
            <span>Total</span>
            <span>Entrega</span>
            <span>Estado</span>
            <span>Acciones</span>
          </div>`;
        const rowsMarkup = pageOrders.map((order) => {
          const isActive = selectedOrder?.id === order.id;
          const checked = cleanupSelectedOrderIds.has(order.id) ? 'checked' : '';
          const deliveryMethod = String(order.delivery_method || '').trim();
          const deliveryClass = ['delivery', 'pickup', 'coordinate'].includes(deliveryMethod) ? deliveryMethod : 'coordinate';
          const statusClass = normalizeStatus(order.status);
          const itemsSummary = getOrderItemsSummary(order);
          const deleteIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10l-.8 13H7.8L7 7Zm2-3h6l1 2h4v2H4V6h4l1-2Zm1 7h2v6h-2v-6Zm4 0h2v6h-2v-6Z"/></svg>';
          const rowMarkup = `
            <article class="order-table-row ${isActive ? 'active' : ''}" data-order-id="${escapeHtml(order.id)}">
              <div class="order-cell order-main">
                <span class="order-number">${escapeHtml(order.order_number || '')}</span>
                ${itemsSummary ? `<span class="order-items-summary">${escapeHtml(itemsSummary)}</span>` : '<span class="order-items-summary">Sin resumen de productos</span>'}
              </div>
              <div class="order-cell order-customer">
                <span class="order-customer-name">${escapeHtml(order.customer_name || 'Cliente sin nombre')}</span>
                <span class="order-subtext">${escapeHtml(order.customer_phone || 'Sin telefono')}</span>
              </div>
              <div class="order-cell order-date-cell">${formatDateOnly(order.created)}</div>
              <div class="order-cell center order-total-cell"><span class="order-total-simple">${getOrderFinalTotal(order)}</span></div>
              <div class="order-cell center order-delivery-cell"><span class="order-chip ${deliveryClass}">${escapeHtml(deliveryLabels[deliveryMethod] || deliveryMethod || 'Coordinar')}</span></div>
              <div class="order-cell center order-status-cell"><span class="order-status-chip status-${escapeHtml(statusClass)}">${escapeHtml(getStatusLabel(order.status))}</span></div>
              <div class="order-row-actions">
                <button class="order-open-btn js-open-order" type="button" data-order-open="${escapeHtml(order.id)}">Abrir</button>
                <button class="order-delete-btn js-delete-order" type="button" data-order-delete="${escapeHtml(order.id)}" aria-label="Borrar pedido">${deleteIcon}</button>
              </div>
            </article>`;

          if (!cleanupSelectionMode) return rowMarkup;
          return `
            <div class="order-select-row">
              <input class="cleanup-order-checkbox order-select-box" type="checkbox" value="${escapeHtml(order.id)}" ${checked} aria-label="Seleccionar orden ${escapeHtml(order.order_number || '')}" />
              ${rowMarkup}
            </div>`;
        }).join('');

        ordersList.innerHTML = `${headerMarkup}${rowsMarkup}`;
        renderOrdersPagination(filteredOrders.length, totalPages, startIndex, pageOrders.length);

        document.querySelectorAll('[data-order-id]').forEach((row) => {
          row.addEventListener('click', () => {
            const orderId = row.dataset.orderId;
            if (cleanupSelectionMode) {
              const selectRow = row.closest('.order-select-row');
              const checkbox = selectRow?.querySelector('.cleanup-order-checkbox');
              if (checkbox) {
                checkbox.checked = !checkbox.checked;
                toggleCleanupOrderSelection(checkbox.value, checkbox.checked);
              }
              return;
            }
            if (!orderId) return;
            window.location.assign(getOrderDetailPath(orderId));
          });
        });

        document.querySelectorAll('.js-open-order').forEach((button) => {
          button.addEventListener('click', (event) => {
            event.stopPropagation();
            const orderId = button.dataset.orderOpen;
            if (!orderId || cleanupSelectionMode) return;
            window.location.assign(getOrderDetailPath(orderId));
          });
        });

        document.querySelectorAll('.js-delete-order').forEach((button) => {
          button.addEventListener('click', (event) => {
            event.stopPropagation();
            requestDeleteOrderFromList(button.dataset.orderDelete);
          });
        });

        document.querySelectorAll('.cleanup-order-checkbox').forEach((checkbox) => {
          checkbox.addEventListener('click', (event) => event.stopPropagation());
          checkbox.addEventListener('change', () => toggleCleanupOrderSelection(checkbox.value, checkbox.checked));
        });
        updateCleanupSelectionUI();
      }

      function renderOrdersPagination(totalOrders, totalPages, startIndex, pageCount) {
        if (!ordersPagination) return;
        if (!totalOrders) {
          ordersPagination.classList.add('hidden');
          ordersPagination.innerHTML = '';
          return;
        }

        ordersPagination.classList.remove('hidden');
        const from = startIndex + 1;
        const to = startIndex + pageCount;
        const totalLabel = totalOrders === 1 ? '1 pedido' : `${totalOrders} pedidos`;
        const windowSize = 5;
        const firstPage = Math.max(1, Math.min(currentOrdersPage - 2, totalPages - windowSize + 1));
        const lastPage = Math.min(totalPages, firstPage + windowSize - 1);
        const pageButtons = Array.from({ length: lastPage - firstPage + 1 }, (_, index) => {
          const page = firstPage + index;
          return `<button class="page-btn ${page === currentOrdersPage ? 'active' : ''}" type="button" data-orders-page="${page}">${page}</button>`;
        }).join('');

        ordersPagination.innerHTML = `
          <div class="pagination-info">Mostrando ${from}&ndash;${to} de ${totalLabel} · 10 por página</div>
          <div class="pagination-actions">
            <button class="page-btn" type="button" data-orders-page="prev" ${currentOrdersPage === 1 ? 'disabled' : ''}>Anterior</button>
            ${pageButtons}
            <button class="page-btn" type="button" data-orders-page="next" ${currentOrdersPage === totalPages ? 'disabled' : ''}>Siguiente</button>
          </div>`;

        ordersPagination.querySelectorAll('[data-orders-page]').forEach((button) => {
          button.addEventListener('click', () => {
            const target = button.dataset.ordersPage;
            if (target === 'prev') currentOrdersPage -= 1;
            else if (target === 'next') currentOrdersPage += 1;
            else currentOrdersPage = Number(target || 1);
            renderOrders();
          });
        });
      }

      function clearDetail() {
        selectedOrder = null;
        selectedItems = [];
        orderDetailEmpty.classList.remove('hidden');
        orderDetail.classList.add('hidden');
        floatingDeleteOrderBtn?.classList.add('hidden');
        detailActionsArea?.classList.add('hidden');
        renderDetailCoupon(null);
        updateReviewRequestButtonState();
        setAddProductPanel(false);
        setEditOrderPanel(false);
        renderOrders();
      }

      async function selectOrder(orderId) {
        selectedOrder = orders.find((order) => order.id === orderId) || null;
        selectedItems = [];
        renderOrders();
        if (!selectedOrder) return;
        orderDetailEmpty.classList.add('hidden');
        orderDetail.classList.remove('hidden');
        detailActionsArea?.classList.remove('hidden');
        setDetailAlert('Cargando productos de la orden...', 'info');
        fillDetail(selectedOrder);
        detailItems.innerHTML = '<div class="item-row"><div class="item-sub">Cargando productos...</div></div>';
        try {
          const filter = encodeURIComponent(`order = "${selectedOrder.id}"`);
          const result = await apiRequest(`/api/collections/order_items/records?filter=${filter}&sort=created&expand=product,variation,gift&perPage=100`);
          selectedItems = result.items || [];
          orderItemsByOrder[selectedOrder.id] = selectedItems;
          renderItems();
          if (selectedOrder) detailTotal.innerHTML = renderOrderAdminSummary(selectedOrder, selectedItems);
          setDetailAlert('', 'info');
        } catch (error) {
          console.error(error);
          detailItems.innerHTML = '<div class="item-row"><div class="item-sub">No se pudieron cargar los productos.</div></div>';
          setDetailAlert('No se pudieron cargar los productos de la orden.', 'error');
        }
      }

      function fillDetail(order) {
        const isDeliveryOrder = order.delivery_method === 'delivery';
        const deliveryText = [deliveryLabels[order.delivery_method] || order.delivery_method || 'Sin método', isDeliveryOrder ? getShippingZoneLabel(order) : ''].filter(Boolean).join(' · ');
        detailOrderNumber.textContent = order.order_number;
        detailCreated.textContent = formatDate(order.created);
        detailStatusBadge.className = getStatusClass(order.status);
        detailStatusBadge.textContent = getStatusLabel(order.status);
        detailCustomer.textContent = order.customer_name || 'Sin nombre';
        detailPhone.textContent = order.customer_phone || 'Sin teléfono';
        detailDelivery.textContent = deliveryText;
        detailTotal.innerHTML = renderOrderAdminSummary(order, selectedItems);
        renderDetailCoupon(order);
        if (detailAddressBox) detailAddressBox.classList.toggle('hidden', !isDeliveryOrder);
        detailAddress.textContent = isDeliveryOrder ? (order.customer_address || 'Sin dirección / no aplica') : 'No aplica';
        detailStatus.value = normalizeStatus(order.status);
        detailNotes.value = order.notes || '';
        editCustomerName.value = order.customer_name || '';
        editCustomerPhone.value = order.customer_phone || '';
        editCustomerAddress.value = order.customer_address || '';
        editDeliveryMethod.value = order.delivery_method || 'delivery';

        const currentZone = order.expand?.shipping_zone || getShippingZoneById(order.shipping_zone);
        const currentMunicipality = currentZone?.municipality || '';
        renderShippingMunicipalities(currentMunicipality);
        renderShippingZoneOptions(order.shipping_zone || currentZone?.id || '');
        updateDeliveryEditorVisibility();

        setEditOrderPanel(false);
        updateStatusControlsState();
        updateProductEditorLockState();
        updateCustomerEditorLockState();
        updateWhatsAppButtonState();
      }

      function setAddProductPanel(open) {
        if (!addProductPanel || !toggleAddProductBtn) return;
        const locked = isProductEditingLocked();
        if (locked) {
          addProductPanel.classList.add('hidden');
          toggleAddProductBtn.disabled = true;
          toggleAddProductBtn.textContent = 'Edición bloqueada';
          return;
        }
        addProductPanel.classList.toggle('hidden', !open);
        toggleAddProductBtn.disabled = false;
        toggleAddProductBtn.textContent = open ? 'Cerrar agregar producto' : '+ Agregar producto';
        if (!open) resetAddProductForm();
      }

      function setEditOrderPanel(open) {
        if (!editOrderPanel || !toggleEditOrderBtn) return;
        const locked = isOrderEditingLocked();
        if (locked) {
          editOrderPanel.classList.add('hidden');
          toggleEditOrderBtn.disabled = true;
          toggleEditOrderBtn.textContent = 'Datos bloqueados';
          return;
        }
        editOrderPanel.classList.toggle('hidden', !open);
        toggleEditOrderBtn.disabled = false;
        toggleEditOrderBtn.textContent = open ? 'Cerrar edición' : '✏️ Editar Datos del Cliente';
      }

      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }

      function getProductImageUrlFromItem(item) {
        const product = item?.expand?.product || productCatalog.find((entry) => entry.id === item?.product);
        const images = parseProductImageOrder(product);
        const firstImage = images[0];
        if (!product?.id || !firstImage || !POCKETBASE_URL) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }

      function getProductInitial(name = '') {
        const cleanName = String(name || 'P').trim();
        return escapeHtml(cleanName.charAt(0).toUpperCase() || 'P');
      }

      function getStockBadgeClass(stockInfo) {
        const stock = Number(stockInfo?.stock);
        if (!Number.isFinite(stock)) return '';
        if (stock <= 0) return 'danger';
        if (stock <= 3) return 'warning';
        return 'success';
      }

      function updateProductEditorLockState() {
        const locked = isProductEditingLocked();
        [addProductSearch, addProductVariationSelect, addProductQuantity, addProductPrice, addProductBtn].forEach((element) => {
          if (element) element.disabled = locked;
        });
        if (toggleAddProductBtn) {
          toggleAddProductBtn.disabled = locked;
          toggleAddProductBtn.textContent = locked ? 'Edición bloqueada' : (addProductPanel?.classList.contains('hidden') ? '+ Agregar producto' : 'Cerrar agregar producto');
        }
        if (locked && addProductPanel) addProductPanel.classList.add('hidden');
        if (locked && addProductPreview) {
          addProductPreview.textContent = 'Esta orden está cerrada para edición. Para cambiar productos, primero vuelve la orden a Pendiente si aplica.';
        }
      }

      function updateCustomerEditorLockState() {
        const locked = isOrderEditingLocked();
        [editCustomerName, editCustomerPhone, editCustomerAddress, editDeliveryMethod, editShippingMunicipality, editShippingZone, detailNotes].forEach((element) => {
          if (element) element.disabled = locked;
        });
        if (toggleEditOrderBtn) {
          toggleEditOrderBtn.disabled = locked;
          toggleEditOrderBtn.textContent = locked ? 'Datos bloqueados' : (editOrderPanel?.classList.contains('hidden') ? '✏️ Editar Datos del Cliente' : 'Cerrar edición');
        }
        if (locked && editOrderPanel) editOrderPanel.classList.add('hidden');
      }

      function getReviewRequestDelayHours() {
        const hours = Number(storeSettingsRecord?.review_request_delay_hours);
        return Number.isFinite(hours) && hours >= 0 ? hours : 24;
      }

      function getDeliveredAtDate(order) {
        if (!hasValue(order?.delivered_at)) return null;
        const deliveredAt = new Date(order.delivered_at);
        return Number.isNaN(deliveredAt.getTime()) ? null : deliveredAt;
      }

      function isReviewDelayReady(order) {
        const deliveredAt = getDeliveredAtDate(order);
        if (!deliveredAt) return false;
        const delayMs = getReviewRequestDelayHours() * 60 * 60 * 1000;
        return Date.now() - deliveredAt.getTime() >= delayMs;
      }

      function updateReviewRequestButtonState() {
        if (!requestReviewBtn) return;
        requestReviewBtn.classList.remove('hidden');
        requestReviewBtn.disabled = true;
        requestReviewBtn.textContent = 'Pedir reseña';
        if (!selectedOrder) return;

        const currentStatus = normalizeStatus(selectedOrder.status);
        if (currentStatus !== 'delivered') {
          requestReviewBtn.textContent = 'Pedir reseña';
          return;
        }
        if (hasValue(selectedOrder.review_completed_at)) {
          requestReviewBtn.textContent = 'Reseña recibida';
          return;
        }
        if (hasValue(selectedOrder.review_skipped_at)) {
          requestReviewBtn.textContent = 'Reseña ignorada';
          return;
        }
        if (!getDeliveredAtDate(selectedOrder)) {
          requestReviewBtn.textContent = 'Falta fecha de entrega';
          return;
        }
        if (!hasValue(selectedOrder.review_requested_at) && !isReviewDelayReady(selectedOrder)) {
          requestReviewBtn.textContent = 'Reseña disponible luego';
          return;
        }

        requestReviewBtn.disabled = false;
        requestReviewBtn.textContent = hasValue(selectedOrder.review_requested_at) ? 'Reenviar reseña' : 'Pedir reseña';
      }

      function updateStatusControlsState() {
        if (!selectedOrder || !detailStatus) return;
        const currentStatus = normalizeStatus(selectedOrder.status);
        const deliveredOption = detailStatus.querySelector('option[value="delivered"]');
        if (deliveredOption) {
          deliveredOption.disabled = !['confirmed', 'delivered'].includes(currentStatus);
        }
        if (markDeliveredBtn) {
          markDeliveredBtn.disabled = currentStatus !== 'confirmed';
          markDeliveredBtn.textContent = currentStatus === 'delivered' ? 'Orden entregada' : 'Marcar entregada';
        }
        updateReviewRequestButtonState();
        updateCancelledDeleteButtonState();
      }

      function updateCancelledDeleteButtonState() {
        const canDeleteFromSummary = selectedOrder && normalizeStatus(selectedOrder.status) === 'cancelled';
        if (deleteCancelledOrderBtn) deleteCancelledOrderBtn.classList.toggle('hidden', !canDeleteFromSummary);
        if (floatingDeleteOrderBtn) {
          const showFloatingDelete = Boolean(IS_ORDER_DETAIL_PAGE && selectedOrder && !canDeleteFromSummary);
          floatingDeleteOrderBtn.classList.toggle('hidden', !showFloatingDelete);
        }
      }

      function getItemUnitPrice(item) {
        const quantity = Math.max(1, Number(item.quantity || 1));
        return Number(item.unit_price_usd || item.unit_price_selected_currency || (Number(item.line_total_usd || 0) / quantity) || 0);
      }

      function getOrderShippingAmount(order) {
        if (!order || order.delivery_method !== 'delivery') return 0;
        return Number(order.shipping || order.shipping_usd || order.expand?.shipping_zone?.price_usd || 0);
      }


      async function ensureSelectedItemsLoaded() {
        if (!selectedOrder) return [];
        if (selectedItems.length) return selectedItems;
        const filter = encodeURIComponent(`order = "${selectedOrder.id}"`);
        const result = await apiRequest(`/api/collections/order_items/records?filter=${filter}&sort=created&expand=product,variation,gift&perPage=100`);
        selectedItems = result.items || [];
        return selectedItems;
      }

      function getInventoryGroups(items = selectedItems) {
        const groups = new Map();
        items.forEach((item) => {
          const quantity = Math.max(0, Math.floor(Number(item.quantity || 0)));
          if (!quantity) return;
          if (item.is_gift) {
            if (!item.gift) return;
            const key = `gift:${item.gift}`;
            const existing = groups.get(key) || { key, type: 'gift', id: item.gift, giftId: item.gift, productName: item.product_name || item.expand?.gift?.name || 'Regalo', variationName: '', quantity: 0 };
            existing.quantity += quantity;
            groups.set(key, existing);
            return;
          }
          if (!item.product) return;
          const product = getItemProduct(item);
          if (!productTracksStock(product)) return;
          const variationId = item.variation || '';
          const key = variationId ? `variation:${variationId}` : `product:${item.product}`;
          const existing = groups.get(key) || {
            key,
            type: variationId ? 'variation' : 'product',
            id: variationId || item.product,
            productId: item.product,
            variationId,
            productName: item.product_name || 'Producto',
            variationName: item.variation_name || '',
            quantity: 0,
          };
          existing.quantity += quantity;
          groups.set(key, existing);
        });
        return Array.from(groups.values());
      }

      async function getInventoryRecord(group) {
        const collection = group.type === 'gift' ? 'gifts' : (group.type === 'variation' ? 'product_variations' : 'products');
        return await apiRequest(`/api/collections/${collection}/records/${group.id}`);
      }

      async function patchInventoryStock(group, newStock) {
        const collection = group.type === 'gift' ? 'gifts' : (group.type === 'variation' ? 'product_variations' : 'products');
        return await apiRequest(`/api/collections/${collection}/records/${group.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ stock: Math.max(0, Number(newStock || 0)) }),
        });
      }

      async function deductInventoryForSelectedOrder() {
        if (!selectedOrder) return;
        const items = await ensureSelectedItemsLoaded();
        const groups = getInventoryGroups(items);
        if (!groups.length) return;

        const snapshots = [];
        for (const group of groups) {
          const record = await getInventoryRecord(group);
          const currentStock = Number(record.stock || 0);
          const label = group.variationName ? `${group.productName} (${group.variationName})` : group.productName;
          if (currentStock < group.quantity) {
            throw new Error(`Stock insuficiente para ${label}. Disponible: ${currentStock}. Necesario: ${group.quantity}.`);
          }
          snapshots.push({ group, currentStock });
        }

        const changed = [];
        try {
          for (const snapshot of snapshots) {
            await patchInventoryStock(snapshot.group, snapshot.currentStock - snapshot.group.quantity);
            changed.push(snapshot);
          }
        } catch (error) {
          for (const snapshot of changed.reverse()) {
            try { await patchInventoryStock(snapshot.group, snapshot.currentStock); } catch (rollbackError) { console.error(rollbackError); }
          }
          throw new Error('No se pudo descontar inventario completo. Se intentó revertir cualquier cambio parcial.');
        }
      }

      async function restoreInventoryForSelectedOrder() {
        if (!selectedOrder) return;
        const items = await ensureSelectedItemsLoaded();
        const groups = getInventoryGroups(items);
        for (const group of groups) {
          const record = await getInventoryRecord(group);
          await patchInventoryStock(group, Number(record.stock || 0) + Number(group.quantity || 0));
        }
      }

      async function getOrderItemsForOrder(orderId) {
        if (!orderId) return [];
        const filter = encodeURIComponent(`order = "${orderId}"`);
        const result = await apiRequest(`/api/collections/order_items/records?filter=${filter}&sort=created&expand=product,variation,gift&perPage=200`);
        return result.items || [];
      }

      async function revertInventorySnapshots(snapshots = []) {
        for (const snapshot of snapshots.slice().reverse()) {
          try {
            await patchInventoryStock(snapshot.group, snapshot.currentStock);
          } catch (error) {
            console.error(error);
          }
        }
      }

      async function restoreInventoryForOrder(orderId) {
        const items = await getOrderItemsForOrder(orderId);
        const groups = getInventoryGroups(items);
        if (!groups.length) return [];

        const snapshots = [];
        for (const group of groups) {
          const record = await getInventoryRecord(group);
          snapshots.push({ group, currentStock: Number(record.stock || 0) });
        }

        const changed = [];
        try {
          for (const snapshot of snapshots) {
            await patchInventoryStock(snapshot.group, snapshot.currentStock + Number(snapshot.group.quantity || 0));
            changed.push(snapshot);
          }
        } catch (error) {
          await revertInventorySnapshots(changed);
          throw new Error('No se pudo devolver el inventario. Se intentó revertir cualquier cambio parcial.');
        }
        return changed;
      }

