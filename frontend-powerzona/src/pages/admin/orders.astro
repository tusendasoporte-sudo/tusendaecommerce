---
import { getPublicStorePath, getStoreAdminPath } from '../../lib/adminRoutes';
import { refreshAuthFromCookie } from '../../lib/auth';
import { requireCurrentStoreForAdmin } from '../../lib/storeContext';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const adminAuthToken = authPb.authStore.token;
const currentStoreId = adminContext.storeId;
const currentStoreSlug = adminContext.store.slug || '';
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminCatalogPath = getStoreAdminPath(currentStoreSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const adminPromosPath = getStoreAdminPath(currentStoreSlug, 'promos');
const adminOrganizationPath = getStoreAdminPath(currentStoreSlug, 'organization');
const publicStorePath = getPublicStorePath(currentStoreSlug);
const currentStoreName = adminContext.store.name || adminContext.store.title || currentStoreSlug || 'Tienda';
const masterSupportWhatsapp = String(import.meta.env.PUBLIC_MASTER_SUPPORT_WHATSAPP || '').replace(/[^0-9]/g, '');
const masterSupportEmail = String(import.meta.env.PUBLIC_MASTER_SUPPORT_EMAIL || '').trim();
const supportMessage = `Hola soporte de Tu Senda 84, necesito ayuda con el panel de pedidos de la tienda ${currentStoreName} (${currentStoreSlug || 'sin-slug'}).`;
const masterSupportHref = masterSupportWhatsapp
  ? `https://wa.me/${masterSupportWhatsapp}?text=${encodeURIComponent(supportMessage)}`
  : (masterSupportEmail ? `mailto:${masterSupportEmail}?subject=${encodeURIComponent('Soporte Pedidos Tu Senda 84')}&body=${encodeURIComponent(supportMessage)}` : '');
const masterSupportLabel = masterSupportHref ? 'Contactar a soporte' : 'Soporte Tu Senda 84';
const initialOrderId = String(Astro.params.id || '').trim();
const isOrderDetailPage = Boolean(initialOrderId);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pedidos | PowerZona Admin</title>
    <!-- PowerZona Orders V29 muestra variaciones en tarjetas y productos de orden - 20260602 -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --blue: #2563eb;
        --green: #16a34a;
        --orange: #f97316;
        --purple: #7c3aed;
        --red: #dc2626;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        --shadow-3d: 0 24px 52px rgba(15, 23, 42, 0.10), 0 8px 18px rgba(15, 23, 42, 0.06), inset 0 1px 0 rgba(255,255,255,0.92);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.15), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, 0.10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }
      button, input, select, textarea { font: inherit; }
      button { cursor: pointer; }
      a { color: inherit; text-decoration: none; }
      .hidden { display: none !important; }
      .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
      .login-card { width: min(100%, 460px); background: rgba(255,255,255,0.96); border: 1px solid rgba(226,232,240,0.9); border-radius: 32px; box-shadow: 0 30px 90px rgba(15,23,42,0.18); padding: 30px; }
      .brand-chip { display: inline-flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: 13px; font-weight: 950; }
      .login-title { font-size: 34px; font-weight: 950; letter-spacing: -0.04em; margin: 18px 0 8px; }
      .login-subtitle { color: var(--muted); line-height: 1.55; margin: 0 0 24px; }
      label { display: block; font-size: 13px; font-weight: 900; color: #334155; margin-bottom: 8px; }
      input, select, textarea { width: 100%; border: 1px solid var(--border); border-radius: 16px; background: #f8fafc; padding: 13px 14px; outline: none; }
      textarea { min-height: 112px; resize: vertical; }
      input:focus, select:focus, textarea:focus { border-color: rgba(37,99,235,0.45); box-shadow: 0 0 0 4px rgba(37,99,235,0.12); }
      .btn { border: 0; border-radius: 16px; padding: 12px 18px; font-weight: 950; transition: transform .18s ease, opacity .18s ease, box-shadow .18s ease; }
      .btn:hover { transform: translateY(-1px); }
      .btn:disabled { opacity: .55; cursor: not-allowed; transform: none; }
      .btn-primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; box-shadow: 0 14px 32px rgba(37,99,235,0.24); }
      .btn-secondary { background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); color: #0f172a; border: 1px solid #e2e8f0; box-shadow: var(--shadow); }
      .btn-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
      .alert { border-radius: 16px; padding: 12px 14px; font-size: 13px; font-weight: 850; }
      .alert-error { background: #fee2e2; color: #991b1b; }
      .alert-success { background: #dcfce7; color: #166534; }
      .alert-info { background: #dbeafe; color: #1e40af; }
      .app-shell:not(.pz-admin-content) { width: min(1480px, 100%); margin: 0 auto; padding: 24px; }
      .orders-main { min-width: 0; padding: 2px 0 96px; }
      .icon-btn, .menu-btn, .notification-btn, .primary-blue-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        border-radius: 16px;
        border: 1px solid rgba(226, 232, 240, .95);
        background: rgba(255, 255, 255, .92);
        color: #0f172a;
        box-shadow: 0 12px 26px rgba(15, 23, 42, .07);
        font-weight: 950;
      }
      .icon-btn, .menu-btn { width: 46px; height: 46px; padding: 0; box-shadow: none; }
      .icon-btn svg, .menu-btn svg, .notification-btn svg, .primary-blue-btn svg { width: 18px; height: 18px; fill: currentColor; }
      .primary-blue-btn {
        min-height: 48px;
        padding: 12px 18px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff;
        border-color: rgba(37, 99, 235, .88);
        box-shadow: 0 14px 28px rgba(37, 99, 235, .22);
      }
      .notification-btn { width: 48px; height: 48px; position: relative; }
      .notification-btn::after { content: ''; position: absolute; top: 12px; right: 12px; width: 7px; height: 7px; border-radius: 999px; background: #f97316; box-shadow: 0 0 0 3px #fff; }
      .topbar {
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(226, 232, 240, .96);
        border-radius: 30px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        padding: 26px 28px;
        margin-bottom: 18px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: center;
      }
      .topbar-left, .topbar-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .topbar-right { justify-content: flex-end; }
      .hero-eyebrow { margin: 0 0 8px; color: #2563eb; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .page-title { margin: 0; font-size: clamp(30px, 3.3vw, 46px); font-weight: 1000; letter-spacing: -.045em; line-height: 1.03; }
      .page-subtitle { margin: 9px 0 0; color: var(--muted); font-size: 15px; line-height: 1.55; max-width: 790px; font-weight: 700; }
      .action-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; border-radius: 18px; padding: 12px 15px; background: linear-gradient(180deg,#fff 0%,#f8fafc 100%); border: 1px solid rgba(226,232,240,.9); box-shadow: var(--shadow); font-weight: 950; color: #0f172a; transition: transform .18s ease, box-shadow .18s ease; }
      .action-btn:hover { transform: translateY(-2px); box-shadow: 0 22px 42px rgba(15,23,42,.12), 0 8px 16px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.95); }
      .action-btn svg { width: 18px; height: 18px; }
      .card {
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(226, 232, 240, .96);
        border-radius: 30px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }
      .stats-grid { display: grid; grid-template-columns: repeat(5, minmax(145px, 1fr)); gap: 18px; margin-bottom: 18px; }
      .stat-card { min-height: 112px; display: grid; align-content: center; gap: 8px; border-radius: 26px; padding: 18px 20px; box-shadow: 0 12px 28px rgba(15, 23, 42, .06); }
      .stat-label { margin: 0; color: #475569; font-size: 13px; font-weight: 950; }
      .stat-value { margin: 0; color: #0f172a; font-size: 28px; font-weight: 1000; letter-spacing: -.04em; }
      .toolbar { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(170px, .5fr) minmax(170px, .5fr); gap: 18px; align-items: end; padding: 22px; margin-bottom: 18px; }
      .toolbar input,
      .toolbar select {
        background: #fff;
        font-weight: 800;
        box-shadow: inset 0 1px 0 rgba(15, 23, 42, .02);
      }
      .cleanup-panel { padding: 18px; margin-bottom: 18px; }
      .cleanup-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-bottom: 14px; }
      .cleanup-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -0.03em; }
      .cleanup-warning { margin: 8px 0 0; color: #7f1d1d; background: #fef2f2; border: 1px solid #fecaca; border-radius: 18px; padding: 12px 14px; font-size: 13px; line-height: 1.45; font-weight: 850; }
      .cleanup-list { display: flex; flex-direction: column; gap: 10px; max-height: 390px; overflow: auto; padding: 4px; }
      .cleanup-row { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid rgba(226,232,240,.95); border-radius: 18px; background: #fff; }
      .cleanup-row input { width: 18px; height: 18px; padding: 0; }
      .cleanup-main { min-width: 0; }
      .cleanup-main strong { display: block; font-size: 14px; font-weight: 1000; color: #0f172a; }
      .cleanup-main span { display: block; margin-top: 3px; font-size: 12px; color: #64748b; font-weight: 800; }
      .cleanup-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; margin-top: 14px; }
      .admin-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(420px, .95fr); gap: 18px; align-items: start; }
      .orders-list { overflow: hidden; border-radius: 30px; box-shadow: var(--shadow); }
      .orders-list #orders-list { display: flex; flex-direction: column; gap: 18px; padding: 14px; }
      .order-row { display: flex; align-items: center; justify-content: space-between; gap: 18px; width: 100%; min-height: 96px; padding: 17px 20px; border: 1px solid rgba(226,232,240,.92); border-radius: 22px; background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%); text-align: left; transition: background .16s ease, transform .16s ease, box-shadow .16s ease, border-color .16s ease; box-shadow: 0 12px 26px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.92); }
      .order-row > div:first-child { min-width: 0; flex: 1 1 auto; }
      .order-row:hover { transform: translateY(-2px); border-color: rgba(37,99,235,.22); box-shadow: 0 20px 38px rgba(15,23,42,.10), inset 0 1px 0 rgba(255,255,255,.95); }
      .order-row.active { background: linear-gradient(145deg, rgba(239,246,255,.98), rgba(255,255,255,.98)); border-color: rgba(37,99,235,.36); box-shadow: 0 22px 42px rgba(37,99,235,.12), inset 4px 0 0 #2563eb; }
      .order-row h3 { margin: 0 0 7px; font-size: 17px; font-weight: 950; letter-spacing: -0.02em; }
      .order-meta { display: flex; flex-wrap: wrap; gap: 8px; font-size: 13px; color: var(--muted); }
      .order-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0; min-width: 175px; flex: 0 0 auto; }
      .total-text { margin-top: 8px; font-size: 20px; font-weight: 1000; color: #0f172a; text-align: right; letter-spacing: -0.02em; line-height: 1.1; }
      .badge { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 8px 14px; font-size: 14px; font-weight: 1000; white-space: nowrap; letter-spacing: .02em; border: 1px solid transparent; box-shadow: inset 0 1px 0 rgba(255,255,255,.68); }
      .order-status-big { min-width: 76px; padding: 4px 9px; font-size: 9px; font-weight: 1000; text-transform: uppercase; letter-spacing: .035em; box-shadow: 0 6px 14px rgba(15,23,42,.07), inset 0 1px 0 rgba(255,255,255,.72); }
      .status-pending { background: linear-gradient(135deg, #fef3c7, #fde68a); color: #78350f; border-color: #f59e0b; box-shadow: 0 8px 18px rgba(245,158,11,.18), inset 0 1px 0 rgba(255,255,255,.75); }
      .status-confirmed { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: #14532d; border-color: #22c55e; box-shadow: 0 8px 18px rgba(22,163,74,.18), inset 0 1px 0 rgba(255,255,255,.75); }
      .status-preparing { background: #ede9fe; color: #5b21b6; border-color: #ddd6fe; }
      .status-delivered { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }
      .status-cancelled { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .detail-panel { padding: 20px; position: sticky; top: 18px; }
      .detail-title { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
      .detail-title-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
      .close-detail-btn { width: 38px; height: 38px; border-radius: 14px; border: 1px solid #e2e8f0; background: linear-gradient(180deg,#fff 0%,#f8fafc 100%); color: #64748b; font-size: 18px; font-weight: 950; box-shadow: 0 10px 22px rgba(15,23,42,.08); }
      .close-detail-btn:hover { color: #0f172a; transform: translateY(-1px); }
      .detail-title h2 { margin: 0; font-size: 24px; letter-spacing: -0.035em; }
      .info-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin: 16px 0; }
      .form-grid { display: grid; gap: 14px; }
      .form-grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .info-box { background: rgba(248,250,252,.9); border: 1px solid rgba(148,163,184,.14); border-radius: 18px; padding: 12px; }
      .info-label { font-size: 11px; font-weight: 950; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; margin-bottom: 4px; }
      .info-value { font-weight: 850; color: #0f172a; word-break: break-word; }
      .items-box { border: 1px solid rgba(148,163,184,.18); border-radius: 20px; overflow: visible; margin: 16px 0; padding: 12px; background: rgba(255,255,255,.82); box-shadow: inset 0 1px 0 rgba(255,255,255,.8); }
      .item-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 18px; padding: 18px 20px; border: 1px solid #eff4fa; border-radius: 17px; width: 100%; box-sizing: border-box; background: rgba(255,255,255,.72); }
      .item-row + .item-row { margin-top: 10px; }
      .item-main { min-width: 0; padding-left: 6px; }
      .item-name { font-weight: 950; color: #0f172a; line-height: 1.35; word-break: break-word; }
      .item-sub { font-size: 13px; color: var(--muted); margin-top: 6px; line-height: 1.35; }
      .item-price { font-weight: 1000; color: #0f172a; white-space: nowrap; padding: 6px 0 6px 14px; text-align: right; }
      .order-product-list { display: flex; flex-direction: column; gap: 12px; }
      .order-product-card { display: grid; grid-template-columns: 74px minmax(0, 1fr); gap: 14px; align-items: start; padding: 14px; border: 1px solid rgba(226,232,240,.92); border-radius: 22px; background: linear-gradient(145deg,#ffffff 0%,#f8fafc 100%); box-shadow: 0 14px 30px rgba(15,23,42,.07), inset 0 1px 0 rgba(255,255,255,.95); }
      .order-product-img { width: 74px; height: 74px; border-radius: 20px; object-fit: cover; background: linear-gradient(135deg,#e2e8f0,#f8fafc); border: 1px solid rgba(226,232,240,.95); box-shadow: 0 10px 18px rgba(15,23,42,.08); }
      .order-product-placeholder { width: 74px; height: 74px; border-radius: 20px; display: grid; place-items: center; background: linear-gradient(135deg,#eff6ff,#f8fafc); color: #2563eb; font-size: 24px; font-weight: 1000; border: 1px solid rgba(191,219,254,.9); }
      .order-product-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
      .order-product-title { font-size: 15px; font-weight: 1000; color: #0f172a; line-height: 1.25; word-break: break-word; }
      .order-product-total { color: #0f172a; font-size: 16px; font-weight: 1000; white-space: nowrap; text-align: right; }
      .order-product-meta { display: flex; flex-wrap: wrap; gap: 7px; margin: 8px 0 12px; }
      .product-pill { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 6px 9px; background: #f1f5f9; color: #334155; border: 1px solid #e2e8f0; font-size: 11px; font-weight: 950; }
      .product-pill.success { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .product-pill.warning { background: #fef3c7; color: #92400e; border-color: #fde68a; }
      .product-pill.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .product-edit-grid { display: grid; grid-template-columns: minmax(0, 1fr) 130px 130px; gap: 10px; align-items: end; }
      .product-edit-grid label { font-size: 10px; margin-bottom: 5px; }
      .product-edit-grid input { border-radius: 14px; padding: 10px 11px; background: #ffffff; }
      .product-card-actions { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 10px; align-items: center; margin-top: 10px; }
      .add-product-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 22px; }
      .add-product-header .section-title { margin: 0; }
      .add-product-panel { margin-top: 14px; padding: 14px; border: 1px solid rgba(226,232,240,.92); border-radius: 22px; background: linear-gradient(145deg,#ffffff 0%,#f8fafc 100%); box-shadow: 0 12px 26px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.95); }
      .add-product-actions { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 10px; align-items: center; }
      .empty-state { padding: 36px 18px; text-align: center; color: var(--muted); font-weight: 800; }
      .section-title { margin: 22px 0 10px; font-size: 16px; font-weight: 950; }
      .quick-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin-top: 16px; }
      .quick-actions .btn { padding: 11px 12px; }
      .danger-zone { margin-top: 16px; padding: 14px; border: 1px solid #fecaca; background: rgba(254,226,226,.48); border-radius: 20px; }
      .danger-zone p { margin: 0 0 10px; color: #991b1b; font-size: 13px; font-weight: 800; line-height: 1.45; }
      @media (max-width: 1300px) { .stats-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
      @media (max-width: 1100px) { .toolbar, .admin-grid { grid-template-columns: 1fr; } .detail-panel { position: static; } }
      @media (max-width: 720px) { .topbar { flex-direction: column; } .toolbar, .info-grid, .form-grid.two, .quick-actions, .product-edit-grid, .add-product-actions { grid-template-columns: 1fr; } .order-row { flex-direction: column; align-items: stretch; } .order-right { align-items: flex-start; min-width: 0; } .order-status-big { min-width: 0; width: fit-content; } .total-text { text-align: left; } .item-row { grid-template-columns: 1fr; gap: 10px; padding: 18px; } .item-main { padding-left: 4px; } .item-price { text-align: left; padding-left: 4px; } .order-product-card { grid-template-columns: 58px minmax(0,1fr); padding: 12px; } .order-product-img, .order-product-placeholder { width: 58px; height: 58px; border-radius: 16px; } .order-product-head { flex-direction: column; } .order-product-total { text-align: left; } }

      .cleanup-selection-bar { padding: 14px 16px; margin-bottom: 18px; display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; border: 1px solid rgba(248,113,113,.28); background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(254,242,242,.92)); }
      .cleanup-selection-copy { min-width: 240px; }
      .cleanup-selection-title { margin: 0; font-size: 16px; font-weight: 1000; color: #7f1d1d; letter-spacing: -0.02em; }
      .cleanup-selection-warning { margin: 5px 0 0; color: #991b1b; font-size: 12px; line-height: 1.35; font-weight: 850; }
      .cleanup-selection-count { display: inline-flex; align-items: center; justify-content: center; min-height: 34px; padding: 7px 11px; border-radius: 999px; background: #fff; border: 1px solid #fecaca; color: #991b1b; font-size: 12px; font-weight: 1000; }
      .cleanup-selection-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .order-select-row { display: grid; grid-template-columns: 34px minmax(0, 1fr); align-items: center; gap: 12px; }
      .order-select-box { width: 24px !important; height: 24px !important; padding: 0 !important; margin: 0 !important; accent-color: #dc2626; cursor: pointer; }
      .order-select-row .order-row { min-width: 0; }
      .orders-admin-alert { margin: 0 0 18px; }
      .order-confirm-modal { position: fixed; inset: 0; z-index: 120; display: flex; align-items: center; justify-content: center; padding: 18px; background: rgba(15,23,42,.42); backdrop-filter: blur(4px); }
