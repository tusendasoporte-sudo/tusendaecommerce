      async function reloadSelectedItems() {
        if (!selectedOrder) return;
        const filter = encodeURIComponent(`order = "${selectedOrder.id}"`);
        const result = await apiRequest(`/api/collections/order_items/records?filter=${filter}&sort=created&expand=product,variation,gift&perPage=100`);
        selectedItems = result.items || [];
        if (selectedOrder?.id) orderItemsByOrder[selectedOrder.id] = selectedItems;
        renderItems();
        renderOrders();
      }

      function getEditedItemsTotalFromForm() {
        let total = 0;
        selectedItems.forEach((item) => {
          const row = detailItems.querySelector(`[data-item-id="${item.id}"]`);
          if (!row) return;
          const quantityInput = row.querySelector('.edit-item-quantity');
          const maxStock = quantityInput?.dataset.maxStock ? Number(quantityInput.dataset.maxStock) : null;
          const quantity = clampQuantityToStock(quantityInput, maxStock);
          const unitPrice = Math.max(0, Number(row.querySelector('.edit-item-unit-price')?.value || 0));
          total += quantity * unitPrice;
        });
        return total;
      }

      async function updateOrderTotal(productsTotal = null) {
        if (!selectedOrder) return null;
        const subtotal = productsTotal === null ? selectedItems.reduce((sum, item) => sum + Number(item.line_total_usd || 0), 0) : Number(productsTotal || 0);
        const shipping = getOrderShippingAmount(selectedOrder);
        const newTotal = subtotal + shipping;
        const updatedOrder = await apiRequest(`/api/collections/orders/records/${selectedOrder.id}?expand=shipping_zone,currency`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            total: newTotal,
            total_usd: newTotal,
          }),
        });
        selectedOrder = updatedOrder;
        orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
        fillDetail(updatedOrder);
        renderStats();
        renderOrders();
        return updatedOrder;
      }

      function updateItemRowPreview(row) {
        if (!row) return;
        const quantityInput = row.querySelector('.edit-item-quantity');
        const maxStock = quantityInput?.dataset.maxStock ? Number(quantityInput.dataset.maxStock) : null;
        const status = row.querySelector('.item-save-status');
        const quantity = clampQuantityToStock(quantityInput, maxStock, status);
        const unitPrice = Math.max(0, Number(row.querySelector('.edit-item-unit-price')?.value || 0));
        const totalEl = row.querySelector('.item-live-total');
        if (totalEl) totalEl.textContent = formatUSD(quantity * unitPrice);
      }

      function bindQuantityButtons() {
        detailItems.querySelectorAll('.item-qty-minus, .item-qty-plus').forEach((button) => {
          button.addEventListener('click', () => {
            if (isProductEditingLocked()) return;

            const row = button.closest('.order-product-card');
            if (!row) return;

            const quantityInput = row.querySelector('.edit-item-quantity');
            if (!quantityInput) return;

            const currentValue = Math.max(1, Number(quantityInput.value || 1));
            const maxStock = quantityInput.dataset.maxStock ? Number(quantityInput.dataset.maxStock) : null;
            let nextValue = currentValue;

            if (button.classList.contains('item-qty-minus')) {
              nextValue = Math.max(1, currentValue - 1);
            }

            if (button.classList.contains('item-qty-plus')) {
              nextValue = Number.isFinite(maxStock) && maxStock > 0
                ? Math.min(maxStock, currentValue + 1)
                : currentValue + 1;
            }

            if (nextValue === currentValue) return;

            quantityInput.value = String(nextValue);
            quantityInput.dispatchEvent(new Event('input', { bubbles: true }));
            quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
          });
        });
      }

      function bindItemAutoSave() {
        detailItems.querySelectorAll('[data-item-id]').forEach((row) => {
          const itemId = row.dataset.itemId;
          row.querySelectorAll('.edit-item-name, .edit-item-quantity, .edit-item-unit-price').forEach((input) => {
            input.addEventListener('input', () => {
              updateItemRowPreview(row);
              const status = row.querySelector('.item-save-status');
              if (status) status.textContent = 'Guardando cambios...';
              clearTimeout(itemSaveTimers.get(itemId));
              itemSaveTimers.set(itemId, setTimeout(() => saveSingleOrderItem(itemId), 650));
            });
            input.addEventListener('change', () => {
              updateItemRowPreview(row);
              clearTimeout(itemSaveTimers.get(itemId));
              saveSingleOrderItem(itemId);
            });
          });
        });
      }

      async function saveSingleOrderItem(itemId) {
        if (!selectedOrder || !itemId) return;
        if (isProductEditingLocked()) {
          setDetailAlert('Esta orden ya descontó inventario. La edición de productos está bloqueada por seguridad.', 'error');
          return;
        }
        const row = detailItems.querySelector(`[data-item-id="${itemId}"]`);
        const item = selectedItems.find((entry) => entry.id === itemId);
        if (!row || !item) return;

        const status = row.querySelector('.item-save-status');
        try {
          const productName = row.querySelector('.edit-item-name')?.value.trim() || item.product_name || 'Producto';
          const quantityInput = row.querySelector('.edit-item-quantity');
          const maxStock = quantityInput?.dataset.maxStock ? Number(quantityInput.dataset.maxStock) : null;
          const quantity = clampQuantityToStock(quantityInput, maxStock, status);
          if (Number.isFinite(maxStock) && maxStock !== null && maxStock <= 0) {
            if (status) status.textContent = 'No se guardó: sin stock disponible.';
            setDetailAlert('No puedes guardar una cantidad mayor al stock disponible.', 'error');
            return;
          }
          const unitPriceUSD = Math.max(0, Number(row.querySelector('.edit-item-unit-price')?.value || 0));
          const lineTotalUSD = quantity * unitPriceUSD;
          const unitProfitUSD = Number(item.unit_profit_usd || 0);

          const updatedItem = await apiRequest(`/api/collections/order_items/records/${itemId}?expand=product,variation,gift`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              product_name: productName,
              quantity,
              unit_price_usd: unitPriceUSD,
              unit_price_selected_currency: unitPriceUSD,
              line_total_usd: lineTotalUSD,
              line_total_selected_currency: lineTotalUSD,
              line_profit_usd: unitProfitUSD * quantity,
            }),
          });

          selectedItems = selectedItems.map((entry) => entry.id === itemId ? updatedItem : entry);
          if (selectedOrder?.id) orderItemsByOrder[selectedOrder.id] = selectedItems;
          await updateOrderTotal(getEditedItemsTotalFromForm());
          renderOrders();
          if (status) status.textContent = 'Guardado automático';
        } catch (error) {
          console.error(error);
          if (status) status.textContent = 'No se pudo guardar';
          setDetailAlert('No se pudo guardar el producto automáticamente. Revisa reglas update en order_items.', 'error');
        }
      }

      async function saveOrderProducts() {
        if (!selectedOrder) return;
        for (const item of selectedItems) await saveSingleOrderItem(item.id);
      }

      async function addProductToOrder() {
        if (!selectedOrder) return;
        if (isProductEditingLocked()) {
          setDetailAlert('Esta orden ya descontó inventario. Para modificar productos, primero revierte/cambia el estado según el flujo seguro.', 'error');
          return;
        }

        const productId = addProductSelectedId.value;
        const product = selectedAddProduct || productCatalog.find((item) => item.id === productId);
        if (!product) {
          setDetailAlert('Busca y selecciona un producto del catálogo antes de agregarlo.', 'error');
          return;
        }

        const productVariationsForSelected = getVariationsForProduct(product.id);
        const variation = productVariations.find((item) => item.id === addProductVariationSelect.value);
        if (productVariationsForSelected.length && !variation) {
          setDetailAlert('Este producto tiene variaciones. Selecciona una variación antes de agregarlo.', 'error');
          return;
        }

        addProductBtn.disabled = true;
        setDetailAlert('Agregando producto a la orden...', 'info');

        try {
          const availableStock = getAvailableStockForProductSelection(product, variation || null);
          let quantity = Math.max(1, Math.floor(Number(addProductQuantity.value || 1)));
          if (Number.isFinite(availableStock) && availableStock !== null) {
            if (availableStock <= 0) {
              setDetailAlert('No puedes agregar este producto porque ya no queda stock disponible para esta orden.', 'error');
              return;
            }
            if (quantity > availableStock) {
              addProductQuantity.value = String(availableStock);
              setDetailAlert(`No puedes agregar más de ${availableStock} unidad(es). Esa es la disponibilidad real después de contar lo que ya está en esta orden.`, 'error');
              return;
            }
          }

          const unitPriceUSD = Math.max(0, Number(addProductPrice.value || product.base_price_usd || 0));
          const unitCostUSD = Number(variation?.cost_usd ?? product.cost_usd ?? 0);
          const unitProfitUSD = unitPriceUSD - unitCostUSD;
          const variationName = variation ? getVariationLabel(variation) : '';
          const existingItem = findExistingItemForSelection(product.id, variation?.id || '');

          if (existingItem) {
            const newQuantity = Number(existingItem.quantity || 0) + quantity;
            const lineTotalUSD = newQuantity * unitPriceUSD;
            const updatedItem = await apiRequest(`/api/collections/order_items/records/${existingItem.id}?expand=product,variation,gift`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                product_name: existingItem.product_name || product.name,
                product_ref: existingItem.product_ref || product.id,
                variation_name: existingItem.variation_name || variationName,
                variation_label: existingItem.variation_label || variationName,
                variation_ref: existingItem.variation_ref || variation?.internal_ref || variation?.id || '',
                quantity: newQuantity,
                unit_price_usd: unitPriceUSD,
                unit_price_selected_currency: unitPriceUSD,
                variation_price_usd: unitPriceUSD,
                line_total_usd: lineTotalUSD,
                line_total_selected_currency: lineTotalUSD,
                unit_profit_usd: unitProfitUSD,
                line_profit_usd: unitProfitUSD * newQuantity,
              }),
            });
            selectedItems = selectedItems.map((item) => item.id === existingItem.id ? updatedItem : item);
            setAddProductPanel(false);
            await reloadSelectedItems();
            await updateOrderTotal();
            setDetailAlert('Este producto ya existía en la orden. Se sumó la cantidad a la línea existente.', 'success');
            return;
          }

          const lineTotalUSD = quantity * unitPriceUSD;
          const payload = {
            order: selectedOrder.id,
            product: product.id,
            product_ref: product.id,
            product_name: product.name,
            variation_name: variationName,
            variation_label: variationName,
            variation_ref: variation?.internal_ref || variation?.id || '',
            quantity,
            unit_price_usd: unitPriceUSD,
            unit_price_selected_currency: unitPriceUSD,
            variation_price_usd: unitPriceUSD,
            line_total_usd: lineTotalUSD,
            line_total_selected_currency: lineTotalUSD,
            unit_profit_usd: unitProfitUSD,
            line_profit_usd: unitProfitUSD * quantity,
            only_usd: Boolean(product.only_usd),
          };

          if (variation) payload.variation = variation.id;

          await apiRequest('/api/collections/order_items/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          setAddProductPanel(false);
          await reloadSelectedItems();
          await updateOrderTotal();
          setDetailAlert('Producto agregado y total de la orden actualizado.', 'success');
        } catch (error) {
          console.error(error);
          setDetailAlert('No se pudo agregar el producto. Revisa reglas create/update en order_items y que product_variations tenga acceso de lectura.', 'error');
        } finally {
          addProductBtn.disabled = false;
        }
      }

      async function deleteOrderItem(itemId) {
        if (!selectedOrder || !itemId) return;
        if (isProductEditingLocked()) {
          setDetailAlert('Esta orden ya descontó inventario. No puedes borrar productos sin revertir primero el inventario.', 'error');
          return;
        }
        const item = selectedItems.find((entry) => entry.id === itemId);
        const confirmation = window.confirm(`¿Seguro que quieres borrar ${item?.product_name || 'este producto'} de la orden?`);
        if (!confirmation) return;

        setDetailAlert('Borrando producto de la orden...', 'info');
        try {
          await apiRequest(`/api/collections/order_items/records/${itemId}`, { method: 'DELETE' });
          await reloadSelectedItems();
          await updateOrderTotal();
          setDetailAlert('Producto borrado y total de la orden actualizado.', 'success');
        } catch (error) {
          console.error(error);
          setDetailAlert('No se pudo borrar el producto. Revisa las reglas de delete en order_items.', 'error');
        }
      }

      async function saveSelectedOrder(extraPayload = {}) {
        if (!selectedOrder) return;
        saveOrderBtn.disabled = true;
        const previousOrder = selectedOrder;
        const previousStatus = normalizeStatus(previousOrder.status);
        const nextStatus = normalizeStatus(extraPayload.status || detailStatus.value);
        if (nextStatus === 'delivered' && !['confirmed', 'delivered'].includes(previousStatus)) {
          detailStatus.value = previousStatus;
          setDetailAlert('Para marcar una orden como Entregada, primero debe estar Confirmada.', 'error');
          saveOrderBtn.disabled = false;
          return;
        }
        const hadStockDeducted = orderHasStockDeducted(previousOrder);
        const shouldDeductInventory = nextStatus === 'confirmed' && !hadStockDeducted;
        const shouldRestoreInventory = hadStockDeducted && ['pending', 'cancelled'].includes(nextStatus);

        if (shouldDeductInventory) {
          setDetailAlert('Confirmando orden y descontando inventario...', 'info');
        } else if (shouldRestoreInventory) {
          setDetailAlert(nextStatus === 'cancelled' ? 'Cancelando orden y restaurando inventario...' : 'Volviendo la orden a pendiente y restaurando inventario...', 'info');
        } else {
          setDetailAlert('Guardando cambios...', 'info');
        }

        try {
          if (shouldDeductInventory) await deductInventoryForSelectedOrder();
          if (shouldRestoreInventory) await restoreInventoryForSelectedOrder();

          const nextDeliveryMethod = editDeliveryMethod.value;
          const nextShippingZone = nextDeliveryMethod === 'delivery' ? getSelectedShippingZoneForEditor() : null;
          const subtotal = selectedItems.reduce((sum, item) => sum + Number(item.line_total_usd || 0), 0);
          const nextShippingAmount = nextDeliveryMethod === 'delivery' ? Number(nextShippingZone?.price_usd || selectedOrder.shipping || selectedOrder.shipping_usd || 0) : 0;
          const nextTotal = subtotal + nextShippingAmount;

          const payload = {
            customer_name: editCustomerName.value.trim(),
            customer_phone: editCustomerPhone.value.trim(),
            customer_address: editCustomerAddress.value.trim(),
            delivery_method: nextDeliveryMethod,
            shipping: nextShippingAmount,
            shipping_usd: nextShippingAmount,
            total: nextTotal,
            total_usd: nextTotal,
            status: nextStatus,
            notes: detailNotes.value.trim(),
            ...extraPayload,
          };

          if (nextStatus === 'delivered' && !hasValue(previousOrder.delivered_at) && !hasValue(payload.delivered_at)) {
            payload.delivered_at = new Date().toISOString();
          }

          if (nextDeliveryMethod === 'delivery' && nextShippingZone?.id) {
            payload.shipping_zone = nextShippingZone.id;
          }

          if (shouldDeductInventory) payload.stock_deducted = true;
          if (shouldRestoreInventory) payload.stock_deducted = false;

          const updatedOrder = await apiRequest(`/api/collections/orders/records/${selectedOrder.id}?expand=shipping_zone,currency`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
          selectedOrder = updatedOrder;
          fillDetail(updatedOrder);
          renderStats();
          renderOrders();

          if (shouldDeductInventory || shouldRestoreInventory) await refreshInventoryAfterMovement();

          if (shouldDeductInventory) {
            setDetailAlert('Orden confirmada correctamente. El inventario fue descontado y la edición de productos quedó bloqueada por seguridad.', 'success');
          } else if (shouldRestoreInventory) {
            setDetailAlert(nextStatus === 'cancelled' ? 'Orden cancelada correctamente. El inventario fue restaurado y la orden quedó liberada.' : 'Orden devuelta a pendiente correctamente. El inventario fue restaurado y la edición quedó liberada.', 'success');
          } else {
            setDetailAlert('Orden actualizada correctamente.', 'success');
          }
        } catch (error) {
          console.error(error);
          if (shouldDeductInventory || shouldRestoreInventory) {
            detailStatus.value = previousStatus;
            setDetailAlert(error?.message || 'No se pudo completar el movimiento de inventario. La orden no fue actualizada.', 'error');
          } else {
            setDetailAlert('No se pudo actualizar la orden. Revisa tu sesion admin o las reglas administrativas.', 'error');
          }
        } finally {
          saveOrderBtn.disabled = false;
        }
      }

      function buildOrderSummary() {
        if (!selectedOrder) return '';
        const lines = [];
        lines.push(`Hola PowerZona, quiero revisar este pedido:`);
        lines.push('');
        lines.push(`Orden: ${selectedOrder.order_number}`);
        lines.push(`Cliente: ${selectedOrder.customer_name || ''}`);
        lines.push(`Teléfono: ${selectedOrder.customer_phone || ''}`);
        lines.push(`Entrega: ${deliveryLabels[selectedOrder.delivery_method] || selectedOrder.delivery_method || ''}`);
        const zoneLabel = selectedOrder.delivery_method === 'delivery' ? getShippingZoneLabel(selectedOrder) : '';
        if (zoneLabel) lines.push(`Zona: ${zoneLabel}`);
        if (selectedOrder.delivery_method === 'delivery' && selectedOrder.customer_address) lines.push(`Dirección: ${selectedOrder.customer_address}`);
        lines.push('');
        lines.push('Productos:');
        if (selectedItems.length) {
          selectedItems.forEach((item, index) => {
            lines.push(`${index + 1}. ${getItemDisplayName(item)}`);
            lines.push(`   Cantidad: ${Number(item.quantity || 0)}`);
            lines.push(`   Total: ${formatUSD(item.line_total_usd)}`);
          });
        } else {
          lines.push('Sin productos cargados.');
        }
        lines.push('');
        lines.push('Resumen cliente:');
        getOrderVisualSummaryLines(selectedOrder, selectedItems).forEach((line) => lines.push(line));
        const internal = getOrderVisualBreakdown(selectedOrder, selectedItems);
        lines.push(`Interno USD: productos ${formatUSD(internal.subtotalUSD)} + envío ${formatUSD(internal.shippingUSD)} = ${formatUSD(internal.totalInternalUSD)}`);
        lines.push(`Estado: ${getStatusLabel(selectedOrder.status)}`);
        if (selectedOrder.notes) lines.push(`Notas: ${selectedOrder.notes}`);
        return lines.join('\n');
      }

      async function copyOrderSummary() {
        const summary = buildOrderSummary();
        if (!summary) return;
        try {
          await navigator.clipboard.writeText(summary);
          setDetailAlert('Resumen copiado correctamente.', 'success');
        } catch (error) {
          console.error(error);
          setDetailAlert('No se pudo copiar automáticamente. Puedes seleccionar el texto desde WhatsApp o imprimir.', 'error');
        }
      }

