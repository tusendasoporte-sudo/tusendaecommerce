      function openWhatsAppOrder() {
        if (!selectedOrder) return;
        const phone = String(selectedOrder.customer_phone || '').replace(/\D/g, '');
        const message = buildCustomerContactMessage();
        const url = phone ? `https://wa.me/${phone}?text=${encodeURIComponent(message)}` : `https://wa.me/?text=${encodeURIComponent(message)}`;
        window.open(url, '_blank', 'noopener,noreferrer');
      }

      function buildReceiptToken() {
        const characters = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        const cryptoValues = new Uint32Array(24);
        if (window.crypto?.getRandomValues) {
          window.crypto.getRandomValues(cryptoValues);
          return Array.from(cryptoValues, (value) => characters[value % characters.length]).join('');
        }
        let token = '';
        for (let i = 0; i < 24; i++) token += characters[Math.floor(Math.random() * characters.length)];
        return token;
      }

      function buildReceiptUrl(order) {
        if (!order?.order_number || !order?.receipt_token) return '';
        return `${window.location.origin}/orden/${encodeURIComponent(order.order_number)}/${encodeURIComponent(order.receipt_token)}`;
      }

      async function ensureSelectedOrderReceiptToken() {
        if (!selectedOrder) return null;
        if (selectedOrder.receipt_token) return selectedOrder;
        const receiptToken = buildReceiptToken();
        const updatedOrder = await apiRequest(`/api/collections/orders/records/${selectedOrder.id}?expand=shipping_zone,currency`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ receipt_token: receiptToken }),
        });
        selectedOrder = updatedOrder;
        orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
        return updatedOrder;
      }

      function buildReviewToken() {
        const characters = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        const cryptoValues = new Uint32Array(28);
        if (window.crypto?.getRandomValues) {
          window.crypto.getRandomValues(cryptoValues);
          return Array.from(cryptoValues, (value) => characters[value % characters.length]).join('');
        }
        let token = '';
        for (let i = 0; i < 28; i++) token += characters[Math.floor(Math.random() * characters.length)];
        return token;
      }

      function buildReviewUrl(order) {
        if (!order?.review_token || !PUBLIC_STORE_PATH) return '';
        return `${window.location.origin}${PUBLIC_STORE_PATH}/review/order/${encodeURIComponent(order.review_token)}`;
      }

      async function ensureSelectedOrderReviewToken() {
        if (!selectedOrder) return null;
        if (selectedOrder.review_token) return selectedOrder;
        const reviewToken = buildReviewToken();
        const updatedOrder = await apiRequest(`/api/collections/orders/records/${selectedOrder.id}?expand=shipping_zone,currency`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ review_token: reviewToken }),
        });
        selectedOrder = updatedOrder;
        orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
        return updatedOrder;
      }

      function getReviewStoreName() {
        return storeSettingsRecord?.store_name
          || storeSettingsRecord?.business_name
          || storeSettingsRecord?.name
          || storeSettingsRecord?.title
          || 'tu tienda';
      }

      function buildReviewWhatsappMessage(order, reviewUrl) {
        const template = String(storeSettingsRecord?.review_whatsapp_message || DEFAULT_REVIEW_WHATSAPP_MESSAGE);
        return template
          .replace(/\{cliente\}/g, order?.customer_name || 'cliente')
          .replace(/\{tienda\}/g, getReviewStoreName())
          .replace(/\{numero_orden\}/g, order?.order_number || '')
          .replace(/\{link_rese\u00f1a\}/g, reviewUrl)
          .replace(/\{link_resena\}/g, reviewUrl);
      }

      async function openReviewWhatsApp() {
        if (!selectedOrder) return;
        const currentStatus = normalizeStatus(selectedOrder.status);
        if (currentStatus !== 'delivered') {
          setDetailAlert('Solo puedes pedir reseña cuando la orden está Entregada.', 'error');
          updateReviewRequestButtonState();
          return;
        }
        if (hasValue(selectedOrder.review_completed_at)) {
          setDetailAlert('Esta orden ya tiene reseña recibida.', 'info');
          updateReviewRequestButtonState();
          return;
        }
        if (hasValue(selectedOrder.review_skipped_at)) {
          setDetailAlert('Esta orden fue marcada como reseña ignorada.', 'info');
          updateReviewRequestButtonState();
          return;
        }
        if (!getDeliveredAtDate(selectedOrder)) {
          setDetailAlert('Esta orden no tiene fecha de entrega registrada.', 'error');
          updateReviewRequestButtonState();
          return;
        }
        if (!hasValue(selectedOrder.review_requested_at) && !isReviewDelayReady(selectedOrder)) {
          setDetailAlert(`La reseña estará disponible luego de ${getReviewRequestDelayHours()} horas desde la entrega.`, 'info');
          updateReviewRequestButtonState();
          return;
        }

        const originalLabel = requestReviewBtn?.textContent || 'Pedir reseña';
        if (requestReviewBtn) {
          requestReviewBtn.disabled = true;
          requestReviewBtn.textContent = 'Preparando reseña...';
        }

        try {
          const orderWithToken = await ensureSelectedOrderReviewToken();
          const reviewUrl = buildReviewUrl(orderWithToken);
          if (!reviewUrl) throw new Error('No se pudo generar el enlace público de reseña.');
          const message = buildReviewWhatsappMessage(orderWithToken, reviewUrl);
          const phone = String(orderWithToken.customer_phone || '').replace(/\D/g, '');
          const whatsappUrl = phone ? `https://wa.me/${phone}?text=${encodeURIComponent(message)}` : `https://wa.me/?text=${encodeURIComponent(message)}`;
          window.open(whatsappUrl, '_blank', 'noopener,noreferrer');

          const updatedOrder = await apiRequest(`/api/collections/orders/records/${orderWithToken.id}?expand=shipping_zone,currency`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              review_requested_at: new Date().toISOString(),
              review_request_count: Number(orderWithToken.review_request_count || 0) + 1,
            }),
          });
          selectedOrder = updatedOrder;
          orders = orders.map((order) => order.id === updatedOrder.id ? updatedOrder : order);
          fillDetail(updatedOrder);
          renderOrders();
          setDetailAlert(hasValue(orderWithToken.review_requested_at) ? 'Solicitud de reseña reenviada por WhatsApp.' : 'Solicitud de reseña preparada por WhatsApp.', 'success');
        } catch (error) {
          console.error(error);
          setDetailAlert(error?.message || 'No se pudo preparar la solicitud de reseña.', 'error');
          if (requestReviewBtn) requestReviewBtn.textContent = originalLabel;
        } finally {
          updateReviewRequestButtonState();
        }
      }

      async function printSelectedOrder() {
