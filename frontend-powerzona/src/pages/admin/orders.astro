        if (!whatsappOrderBtn || !selectedOrder) return;
        const status = normalizeStatus(selectedOrder.status);
        const labels = {
          pending: '🟢 Contactar cliente',
          confirmed: '🟢 Notificar confirmación',
          delivered: '🟢 Notificar entrega',
