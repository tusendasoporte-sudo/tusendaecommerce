          lines.push('');
          lines.push('Necesitamos confirmar algunos detalles antes de continuar con tu orden.');
          lines.push('');
          lines.push(`Total actual: ${formatUSD(selectedOrder.total)}`);
          lines.push(`Estado actual: ${getStatusLabel(selectedOrder.status)}`);
