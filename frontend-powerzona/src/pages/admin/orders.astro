          lines.push(`Hola ${customerName}, te escribo de PowerZona sobre tu orden ${orderNumber}.`.replace(/\s+/g, ' ').trim());
          lines.push('');
          lines.push('La orden fue cancelada. Si deseas hacer algún cambio o crear una nueva, podemos coordinarlo por aquí.');
        } else {
