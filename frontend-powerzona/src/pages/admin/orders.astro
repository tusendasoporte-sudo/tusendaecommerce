      function buildCustomerContactMessage() {
        if (!selectedOrder) return '';
        const status = normalizeStatus(selectedOrder.status);
        const customerName = selectedOrder.customer_name || 'cliente';
        const orderNumber = selectedOrder.order_number || 'tu orden';
        const lines = [];

        if (status === 'confirmed') {
          lines.push(`Hola ${customerName}, tu orden ${orderNumber} fue confirmada ✅`.replace(/\s+/g, ' ').trim());
          lines.push('');
          lines.push(`Total confirmado: ${formatUSD(selectedOrder.total)}`);
          lines.push('Ya estamos gestionando tu pedido. Te avisaremos cualquier detalle por esta vía.');
        } else if (status === 'delivered') {
