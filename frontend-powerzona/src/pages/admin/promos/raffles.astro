---
import { refreshAuthFromCookie } from '../../../lib/auth';
import { getPublicStorePath } from '../../../lib/adminRoutes';
import { requireCurrentStoreForAdmin } from '../../../lib/storeContext';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import AdminSectionHeader from '../../../components/admin/AdminSectionHeader.astro';
import AdminIcon from '../../../components/admin/AdminIcon.astro';
import '../../../styles/global.css';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreId = adminContext.storeId;
const adminAuthToken = authPb.authStore.token;
const currentStoreSlug = adminContext.store.slug || '';
const currentStoreName = adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona';
const publicStorePath = getPublicStorePath(currentStoreSlug);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rifas | PowerZona</title>
    <link rel="icon" href="/favicon.ico?v=2" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --green: #16a34a;
        --blue: #2563eb;
        --red: #dc2626;
        --orange: #f97316;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }
      a { color: inherit; text-decoration: none; }
      button, input, select, textarea { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .65; }
      .hidden { display: none !important; }

      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; display: block; }
      .main-wrap { min-width: 0; padding: 2px 0 28px; }
      .raffle-admin-grid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(380px, .9fr); gap: 18px; align-items: start; }
      .raffle-admin-panel,
      .raffle-admin-card {
        background: rgba(255,255,255,.95);
        border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }
      .raffle-admin-panel { padding: 20px; display: grid; gap: 16px; }
      .raffle-admin-summary { margin-bottom: 18px; }
      .raffle-summary-card {
        display: grid;
        grid-template-columns: minmax(220px, .9fr) minmax(260px, 1fr);
        gap: 16px;
        align-items: start;
        padding: 20px 22px;
        border-radius: 24px;
        background: linear-gradient(135deg, #ffffff 0%, #f8fbff 58%, #eff6ff 100%);
        border: 1px solid rgba(191, 219, 254, .86);
        box-shadow: var(--shadow);
      }
      .raffle-summary-head h2 { margin: 0; color: #0f172a; font-size: 20px; font-weight: 1000; letter-spacing: 0; }
      .raffle-summary-head p { margin: 6px 0 0; color: #64748b; font-size: 13px; line-height: 1.45; font-weight: 800; }
      .raffle-summary-metrics { display: grid; border: 1px solid rgba(226,232,240,.96); border-radius: 16px; background: rgba(255,255,255,.82); overflow: hidden; }
      .raffle-summary-row { min-height: 42px; display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 10px 14px; }
      .raffle-summary-row + .raffle-summary-row { border-top: 1px solid rgba(226,232,240,.9); }
      .raffle-summary-label { color: #64748b; font-size: 13px; font-weight: 950; letter-spacing: 0; }
      .raffle-summary-value { color: #0f172a; font-size: 18px; font-weight: 1000; line-height: 1; letter-spacing: 0; }
      .raffle-panel-head { display: flex; justify-content: space-between; gap: 14px; align-items: flex-start; }
      .raffle-panel-head h2 { margin: 0; color: #0f172a; font-size: 22px; font-weight: 1000; letter-spacing: 0; }
      .raffle-panel-head p { margin: 6px 0 0; color: #64748b; font-size: 13px; line-height: 1.45; font-weight: 800; }
      .raffle-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; }
      .raffle-btn {
        min-height: 42px;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #0f172a;
        padding: 10px 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 1000;
        box-shadow: 0 10px 22px rgba(15,23,42,.06);
      }
      .raffle-btn.primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; border-color: #1d4ed8; box-shadow: 0 14px 26px rgba(37,99,235,.20); }
      .raffle-btn.success { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .raffle-btn.warning { background: #fff7ed; color: #9a3412; border-color: #fed7aa; }
      .raffle-btn.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .raffle-btn svg { width: 18px; height: 18px; fill: currentColor; }
      .raffle-icon-btn {
        width: 42px;
        height: 42px;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        background: #fff;
        color: #0f172a;
        display: inline-grid;
        place-items: center;
        font-size: 22px;
        font-weight: 1000;
        box-shadow: 0 10px 22px rgba(15,23,42,.06);
      }
      .raffle-modal {
        position: fixed;
        inset: 0;
        z-index: 80;
        display: grid;
        place-items: center;
        padding: 28px;
        background: rgba(15, 23, 42, .46);
        backdrop-filter: blur(4px);
      }
      .raffle-modal-card {
        width: min(900px, 100%);
        max-height: min(88vh, 920px);
        overflow: auto;
        border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .28);
      }
      .raffle-date-card {
        width: min(520px, 100%);
        overflow: hidden;
        border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .28);
      }
      .raffle-date-body { display: grid; gap: 12px; padding: 18px 20px; }
      .raffle-date-actions { justify-content: flex-end; padding: 0 20px 20px; }
      .raffle-modal-head {
        position: sticky;
        top: 0;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: flex-start;
        padding: 20px 20px 14px;
        border-bottom: 1px solid #e2e8f0;
        background: rgba(255,255,255,.96);
        backdrop-filter: blur(10px);
      }
      .raffle-modal-head h2 { margin: 0; color: #0f172a; font-size: 22px; font-weight: 1000; letter-spacing: 0; }
      .raffle-form { display: grid; gap: 14px; }
      .raffle-form.hidden { display: none !important; }
      .raffle-form > .raffle-form-grid,
      .raffle-form > .alert,
      .raffle-form > .raffle-actions { margin-left: 20px; margin-right: 20px; }
      .raffle-form > .raffle-actions {
        position: sticky;
        bottom: 0;
        z-index: 2;
        margin: 0;
        padding: 14px 20px 20px;
        border-top: 1px solid #e2e8f0;
        background: rgba(255,255,255,.96);
        backdrop-filter: blur(10px);
      }
      .raffle-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      .raffle-form-grid .full { grid-column: 1 / -1; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: 0; }
      .field input, .field select, .field textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: #fff;
        color: var(--text);
        padding: 12px 13px;
        outline: none;
        font-weight: 800;
        box-shadow: inset 0 1px 0 rgba(15,23,42,.02);
      }
      .field textarea { min-height: 92px; resize: vertical; line-height: 1.45; }
      .field input:focus, .field select:focus, .field textarea:focus { border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37,99,235,.10); }
      .field input[readonly] { background: #f8fafc; color: #334155; }
      .form-help { margin: 0; color: #64748b; font-size: 12px; font-weight: 750; line-height: 1.45; }
      .winner-message-field { gap: 10px; }
      .winner-message-toggle {
        width: 100%;
        min-height: 78px;
        border: 1px solid #bfdbfe;
        border-radius: 18px;
        background: linear-gradient(135deg, #ffffff 0%, #f8fbff 56%, #eff6ff 100%);
        color: #0f172a;
        padding: 14px 16px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto auto;
        align-items: center;
        gap: 12px;
        text-align: left;
        box-shadow: 0 14px 30px rgba(37, 99, 235, .09);
        transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
      }
      .winner-message-toggle:hover {
        border-color: #93c5fd;
        box-shadow: 0 18px 34px rgba(37, 99, 235, .13);
        transform: translateY(-1px);
      }
      .winner-message-toggle:focus-visible {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37,99,235,.12), 0 18px 34px rgba(37, 99, 235, .13);
      }
      .winner-message-toggle-copy { display: grid; gap: 4px; min-width: 0; }
      .winner-message-title { color: #0f172a; font-size: 15px; font-weight: 1000; line-height: 1.18; }
      .winner-message-description { color: #64748b; font-size: 12px; font-weight: 800; line-height: 1.35; }
      .winner-message-badge,
      .winner-message-toggle-label {
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        border-radius: 999px;
        padding: 7px 10px;
        font-size: 12px;
        font-weight: 1000;
      }
      .winner-message-badge {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
      }
      .winner-message-toggle-label {
        background: #dbeafe;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
      }
      .winner-message-chevron {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: inline-grid;
        place-items: center;
        background: #ffffff;
        color: #2563eb;
        border: 1px solid #dbeafe;
        box-shadow: 0 8px 18px rgba(37, 99, 235, .08);
      }
      .winner-message-chevron svg {
        width: 18px;
        height: 18px;
        fill: none;
        stroke: currentColor;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        transition: transform .18s ease;
      }
      .winner-message-field.is-open .winner-message-chevron svg {
        transform: rotate(180deg);
      }
      .winner-message-panel {
        display: grid;
        gap: 8px;
        padding: 14px;
        border: 1px solid #dbeafe;
        border-radius: 16px;
        background: #ffffff;
      }
      .winner-message-panel[hidden] { display: none; }
      .winner-message-panel textarea {
        min-height: 118px;
      }
      .switch-row { display: inline-flex; align-items: center; gap: 9px; color: #334155; font-size: 13px; font-weight: 900; }
      .switch-row input { width: 18px; height: 18px; accent-color: #2563eb; }
      .segmented-control { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
      .segmented-control label { min-height: 46px; display: flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #dbeafe; border-radius: 14px; background: #fff; color: #1e3a8a; font-size: 13px; font-weight: 950; text-transform: none; }
      .segmented-control input { width: 16px; height: 16px; accent-color: #2563eb; }
      .segmented-control label.is-disabled {
        background: #f8fafc;
        border-color: #e2e8f0;
        color: #64748b;
        opacity: .68;
        cursor: not-allowed;
        box-shadow: none;
      }
      .segmented-control label.is-disabled input {
        cursor: not-allowed;
      }
      .prize-display-limit-note {
        margin-top: 2px;
        color: #1e40af;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 12px;
        padding: 9px 11px;
      }
      .prize-editor-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
      .prize-editor-head h3 { margin: 0; color: #0f172a; font-size: 17px; font-weight: 1000; letter-spacing: 0; }
      .prize-editor-list { display: grid; gap: 10px; }
      .prize-editor-card {
        display: grid;
        grid-template-columns: 112px minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
        padding: 12px;
        border: 1px solid #dbeafe;
        border-radius: 18px;
        background: #f8fbff;
      }
      .prize-photo-box { display: grid; gap: 8px; }
      .prize-photo-preview { width: 100%; aspect-ratio: 1; border-radius: 14px; border: 1px solid #dbeafe; background: #eff6ff; display: grid; place-items: center; overflow: hidden; color: #1d4ed8; font-size: 12px; font-weight: 1000; text-align: center; }
      .prize-photo-preview img { width: 100%; height: 100%; object-fit: cover; }
      .prize-photo-box input { padding: 8px; font-size: 11px; border-radius: 12px; }
      .prize-image-help { font-size: 11px; }
      .prize-fields { display: grid; gap: 9px; }
      .prize-fields input,
      .prize-fields textarea { width: 100%; }
      .prize-fields textarea { min-height: 68px; }
      .prize-remove-btn { width: 40px; height: 40px; border-radius: 12px; border: 1px solid #fecaca; background: #fee2e2; color: #991b1b; font-size: 20px; font-weight: 1000; line-height: 1; }
      .alert { position: relative; border-radius: 14px; padding: 11px 42px 11px 12px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
      .alert-close { position: absolute; top: 7px; right: 8px; width: 28px; height: 28px; border: 0; border-radius: 8px; background: rgba(255,255,255,.72); color: currentColor; font-weight: 1000; }
      .raffle-list { display: grid; gap: 12px; overflow: visible; }
      .raffle-row {
        position: relative;
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        align-items: stretch;
        padding: 16px;
        border: 1px solid #dbeafe;
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 14px 32px rgba(15, 23, 42, .055);
        cursor: pointer;
        overflow: visible;
        transition: border-color .18s ease, background .18s ease, box-shadow .18s ease, transform .18s ease;
      }
      .raffle-row:hover { border-color: #bfdbfe; box-shadow: 0 18px 38px rgba(15, 23, 42, .08); transform: translateY(-1px); }
      .raffle-row.is-selected { border-color: #2563eb; background: #eff6ff; box-shadow: 0 20px 44px rgba(37, 99, 235, .16); }
      .raffle-row.is-menu-open { z-index: 30; }
      .raffle-row.is-menu-open .raffle-menu { z-index: 1000; }
      .raffle-row-main { display: grid; grid-template-columns: 58px minmax(0, 1fr) auto; gap: 13px; align-items: start; min-width: 0; overflow: visible; }
      .raffle-thumb { width: 58px; height: 58px; border-radius: 17px; background: linear-gradient(135deg, #dbeafe, #dcfce7); display: grid; place-items: center; color: #1d4ed8; font-weight: 1000; font-size: 18px; overflow: hidden; border: 1px solid #dbeafe; }
      .raffle-thumb img { width: 100%; height: 100%; object-fit: cover; }
      .raffle-row-copy { min-width: 0; }
      .raffle-row-slot { margin: 0 0 3px; color: #2563eb; font-size: 12px; font-weight: 1000; text-transform: uppercase; letter-spacing: .01em; }
      .raffle-row-title { margin: 0; color: #0f172a; font-size: 17px; font-weight: 1000; line-height: 1.16; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .raffle-row-meta { margin: 8px 0 0; color: #64748b; font-size: 13px; line-height: 1.35; font-weight: 850; }
      .raffle-row-access { display: inline-flex; align-items: center; gap: 7px; }
      .raffle-row-access::before { content: ""; width: 8px; height: 8px; flex: 0 0 8px; border-radius: 999px; background: #94a3b8; box-shadow: 0 0 0 3px rgba(148, 163, 184, .14); }
      .raffle-row-access.is-enabled::before { background: #22c55e; box-shadow: 0 0 0 3px rgba(34, 197, 94, .12); }
      .raffle-row-access.is-disabled::before { background: #94a3b8; box-shadow: 0 0 0 3px rgba(148, 163, 184, .16); }
      .raffle-row-head-actions { display: grid; gap: 8px; justify-items: end; align-content: start; min-width: 118px; }
      .raffle-select-pill { min-height: 36px; border: 1px solid #bfdbfe; border-radius: 999px; background: #fff; color: #2563eb; padding: 8px 14px; font-size: 12px; font-weight: 1000; white-space: nowrap; box-shadow: 0 10px 22px rgba(15, 23, 42, .06); }
      .raffle-select-pill.is-selected { border-color: #2563eb; background: #2563eb; color: #fff; box-shadow: 0 14px 28px rgba(37, 99, 235, .24); }
      .raffle-participant-pill { min-height: 34px; border: 1px solid #dbeafe; border-radius: 999px; background: #eff6ff; color: #1d4ed8; padding: 7px 12px; font-size: 12px; font-weight: 1000; white-space: nowrap; box-shadow: 0 8px 18px rgba(37, 99, 235, .08); }
      .raffle-row-actions { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr) 54px; gap: 10px; align-items: center; overflow: visible; }
      .raffle-row-actions .raffle-btn { width: 100%; min-height: 46px; border-radius: 15px; justify-content: center; }
      .raffle-status-pill { display: inline-flex; align-items: center; min-height: 28px; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 1000; background: #f1f5f9; color: #64748b; }
      .raffle-status-pill.draft { background: #f1f5f9; color: #475569; }
      .raffle-status-pill.scheduled { background: #e0f2fe; color: #075985; }
      .raffle-status-pill.active { background: #dcfce7; color: #166534; }
      .raffle-status-pill.selection_closed { background: #fff7ed; color: #9a3412; }
      .raffle-status-pill.result_pending { background: #fef3c7; color: #92400e; }
      .raffle-status-pill.winner_published { background: #dbeafe; color: #1d4ed8; }
      .raffle-status-pill.no_winner_published { background: #eef2ff; color: #4338ca; }
      .raffle-status-pill.finalized { background: #e2e8f0; color: #334155; }
      .raffle-menu { position: relative; width: 54px; min-width: 54px; overflow: visible; z-index: 5; }
      .raffle-menu-button { width: 54px; min-height: 46px; border: 1px solid #e2e8f0; border-radius: 15px; background: #fff; color: #0f172a; display: grid; place-items: center; font-size: 24px; font-weight: 1000; line-height: 1; box-shadow: 0 10px 22px rgba(15, 23, 42, .06); }
      .raffle-menu-button:hover,
      .raffle-menu-button[aria-expanded="true"] { border-color: #bfdbfe; background: #eff6ff; color: #1d4ed8; }
      .raffle-menu-panel { position: absolute; right: 0; top: calc(100% + 10px); z-index: 999; width: min(280px, calc(100vw - 42px)); min-width: 230px; padding: 8px; border-radius: 18px; border: 1px solid #e2e8f0; background: #fff; box-shadow: 0 24px 58px rgba(15, 23, 42, .22); display: grid; gap: 4px; }
      .raffle-menu-panel[hidden] { display: none; }
      .raffle-menu-panel::before { content: ""; position: absolute; top: -7px; right: 20px; width: 14px; height: 14px; transform: rotate(45deg); border-left: 1px solid #e2e8f0; border-top: 1px solid #e2e8f0; background: #fff; }
      .raffle-menu-panel button { position: relative; z-index: 1; width: 100%; min-height: 46px; border: 0; border-radius: 13px; background: #fff; color: #0f172a; display: grid; grid-template-columns: 28px minmax(0, 1fr); align-items: center; gap: 10px; text-align: left; padding: 10px 12px; font-size: 14px; font-weight: 900; }
      .raffle-menu-panel button + button { border-top: 1px solid #eef2f7; }
      .raffle-menu-panel button:hover { background: #eff6ff; color: #1d4ed8; }
      .raffle-menu-panel button.danger { color: #991b1b; }
      .raffle-menu-panel button.danger:hover { background: #fff1f2; color: #991b1b; }
      .raffle-menu-icon { width: 28px; height: 28px; border-radius: 10px; display: grid; place-items: center; color: currentColor; font-size: 17px; }
      .raffle-menu-icon svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 2.25; stroke-linecap: round; stroke-linejoin: round; }
      .raffle-control-card { display: grid; gap: 10px; padding: 14px; border-radius: 18px; border: 1px solid #dbeafe; background: #f8fbff; }
      .raffle-control-card h3 { margin: 0; color: #0f172a; font-size: 16px; font-weight: 1000; }
      .raffle-control-actions { display: flex; flex-wrap: wrap; gap: 8px; }
      .empty-state { border: 1px dashed #cbd5e1; border-radius: 18px; background: #f8fafc; color: #64748b; padding: 20px; font-size: 14px; font-weight: 850; text-align: center; }
      .entry-toolbar { display: grid; gap: 10px; }
      .result-box.result-checker {
        display: grid;
        gap: 14px;
        padding: 16px;
        border-radius: 22px;
        border: 1px solid rgba(191, 219, 254, 0.88);
        background:
          radial-gradient(circle at 92% 12%, rgba(7, 91, 234, 0.08), transparent 30%),
          linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        box-shadow: 0 20px 44px rgba(15, 23, 42, 0.08);
      }
      .result-checker-intro {
        display: grid;
        gap: 9px;
      }
      .result-checker-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
      }
      .result-checker-eyebrow {
        width: fit-content;
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 0 10px;
        border-radius: 999px;
        color: #075bea;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        font-size: 11px;
        font-weight: 1000;
        text-transform: uppercase;
      }
      .result-draw-date-pill {
        min-width: 172px;
        display: grid;
        gap: 4px;
        justify-items: start;
        padding: 11px 13px;
        border-radius: 16px;
        border: 1px solid #dbeafe;
        background: #eff6ff;
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.06);
      }
      .result-draw-date-pill span {
        color: #075bea;
        font-size: 10px;
        font-weight: 1000;
        text-transform: uppercase;
        letter-spacing: 0;
      }
      .result-draw-date-pill strong {
        color: #0f172a;
        font-size: 12px;
        line-height: 1.25;
        font-weight: 1000;
      }
      .result-draw-date-pill.is-scheduled {
        border-color: #bfdbfe;
        background: linear-gradient(180deg, #eff6ff, #ffffff);
      }
      .result-draw-date-pill.is-due {
        border-color: #fecaca;
        background: linear-gradient(180deg, #fef2f2, #ffffff);
        box-shadow: 0 14px 32px rgba(220, 38, 38, 0.10);
      }
      .result-draw-date-pill.is-due span {
        color: #dc2626;
      }
      .result-draw-date-pill.is-published {
        border-color: #bbf7d0;
        background: linear-gradient(180deg, #f0fdf4, #ffffff);
      }
      .result-draw-date-pill.is-published span {
        color: #16a34a;
      }
      .result-draw-date-pill.is-muted {
        border-color: #e2e8f0;
        background: #f8fafc;
      }
      .result-draw-date-pill.is-muted span {
        color: #64748b;
      }
      .result-box.result-checker h3 {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        line-height: 1.15;
        font-weight: 1000;
      }
      .result-start-check-btn {
        width: fit-content;
        max-width: 100%;
        min-width: 210px;
        margin-top: 4px;
        white-space: normal;
        text-align: left;
      }
      .result-start-check-btn span {
        overflow-wrap: anywhere;
      }
      .result-start-check-btn:disabled,
      .result-start-check-btn.is-disabled {
        cursor: not-allowed;
        opacity: .64;
        color: #64748b;
        background: #f1f5f9;
        border-color: #e2e8f0;
        box-shadow: none;
      }
      .result-checker-disabled-help {
        margin: 0;
        color: #64748b;
        font-size: 12px;
        font-weight: 850;
        line-height: 1.45;
      }
      .result-checker-disabled-help.is-due {
        color: #dc2626;
      }
      .result-check-panel {
        display: grid;
        gap: 10px;
        padding: 14px;
        border-radius: 18px;
        border: 1px solid rgba(219, 231, 255, 0.95);
        background: rgba(248, 251, 255, 0.94);
      }
      .result-number-field > span {
        color: #334155;
        font-size: 12px;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: 0;
      }
      .result-number-row {
        display: grid;
        grid-template-columns: 96px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
      }
      .result-number-row input {
        width: 100%;
        min-height: 48px;
        border-radius: 14px;
        border: 1px solid #dbeafe;
        background: #ffffff;
        color: #0f172a;
        font-size: 22px;
        font-weight: 1000;
        text-align: center;
        outline: none;
      }
      .result-number-row input:focus {
        border-color: #60a5fa;
        box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.16);
      }
      .result-reset-check-btn {
        justify-self: start;
        border: 0;
        background: transparent;
        color: #075bea;
        font-size: 13px;
        font-weight: 950;
        cursor: pointer;
        padding: 0;
      }
      .result-check-preview {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 12px;
        align-items: start;
        padding: 14px;
        border-radius: 18px;
      }
      .result-check-preview.is-winner {
        border: 1px solid rgba(134, 239, 172, 0.95);
        background:
          radial-gradient(circle at 92% 14%, rgba(34, 197, 94, 0.14), transparent 28%),
          linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
      }
      .result-check-preview.is-no-winner {
        border: 1px solid rgba(253, 186, 116, 0.9);
        background:
          radial-gradient(circle at 92% 14%, rgba(249, 115, 22, 0.12), transparent 28%),
          linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
      }
      .result-check-icon {
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        color: #ffffff;
        font-size: 22px;
        font-weight: 1000;
      }
      .result-check-preview.is-winner .result-check-icon {
        background: #16a34a;
        box-shadow: 0 14px 28px rgba(22, 163, 74, 0.2);
      }
      .result-check-preview.is-no-winner .result-check-icon {
        background: #f97316;
        box-shadow: 0 14px 28px rgba(249, 115, 22, 0.18);
      }
      .result-check-copy {
        min-width: 0;
        display: grid;
        gap: 8px;
      }
      .result-check-copy h4 {
        margin: 0;
        color: #0f172a;
        font-size: 16px;
        font-weight: 1000;
      }
      .result-check-copy p {
        margin: 0;
        color: #334155;
        font-size: 13px;
        line-height: 1.45;
        font-weight: 850;
      }
      .result-check-copy strong {
        color: #075bea;
        font-weight: 1000;
      }
      .result-check-copy dl {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 12px;
        margin: 4px 0 0;
      }
      .result-check-copy dl div {
        min-width: 0;
        display: grid;
        gap: 2px;
      }
      .result-check-copy dt {
        color: #64748b;
        font-size: 11px;
        font-weight: 950;
        text-transform: uppercase;
      }
      .result-check-copy dd {
        min-width: 0;
        margin: 0;
        color: #0f172a;
        font-size: 13px;
        font-weight: 950;
        overflow-wrap: anywhere;
      }
      .result-check-note {
        color: #9a3412 !important;
      }
      .result-publish-actions {
        display: grid;
        gap: 8px;
      }
      .result-publish-actions .raffle-btn {
        min-height: 48px;
      }
      .result-box .hidden,
      .result-check-panel.hidden,
      .result-check-preview.hidden,
      .result-publish-actions.hidden,
      .result-reset-check-btn.hidden,
      #publish-winner-btn.hidden,
      #publish-no-winner-btn.hidden {
        display: none !important;
      }
      .winner-contact-box { display: grid; gap: 9px; padding: 12px; border: 1px solid #bfdbfe; border-radius: 14px; background: #eff6ff; }
      .winner-contact-box p { margin: 0; color: #1e3a8a; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .winner-contact-actions { display: flex; flex-wrap: wrap; gap: 8px; }
      .winner-detail-list { display: grid; gap: 8px; margin: 0; padding: 0; }
      .winner-detail-list div { display: grid; grid-template-columns: 150px minmax(0, 1fr); gap: 10px; align-items: start; }
      .winner-detail-list dt { color: #64748b; font-size: 12px; font-weight: 950; text-transform: uppercase; }
      .winner-detail-list dd { margin: 0; color: #0f172a; font-size: 14px; font-weight: 900; overflow-wrap: anywhere; }
      .entry-list { display: grid; gap: 9px; max-height: 520px; overflow: auto; padding-right: 3px; }
      .entry-row { display: grid; grid-template-columns: 58px minmax(0, 1fr) auto; gap: 10px; align-items: center; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; padding: 10px; }
      .entry-number { width: 48px; height: 48px; display: grid; place-items: center; border-radius: 14px; background: #eff6ff; color: #1d4ed8; font-size: 20px; font-weight: 1000; }
      .entry-title { margin: 0; color: #0f172a; font-size: 14px; font-weight: 1000; }
      .entry-meta { margin: 4px 0 0; color: #64748b; font-size: 12px; font-weight: 800; overflow-wrap: anywhere; }
      .entry-section-title { margin: 10px 0 0; color: #334155; font-size: 12px; font-weight: 1000; text-transform: uppercase; letter-spacing: 0; }
      .entry-status-badge { display: inline-flex; align-items: center; min-height: 28px; padding: 6px 9px; border-radius: 999px; background: #f1f5f9; color: #475569; font-size: 12px; font-weight: 1000; }
      .entry-status-badge.allowed { background: #dcfce7; color: #166534; }
      .image-strip { display: flex; flex-wrap: wrap; gap: 8px; }
      .image-strip img { width: 64px; height: 48px; object-fit: cover; border-radius: 10px; border: 1px solid #e2e8f0; background: #f8fafc; }

      @media (max-width: 1023px) {
        .app-shell { padding-top: 76px; padding-bottom: 104px; }
      }

      @media (max-width: 900px) {
        .raffle-admin-grid,
        .raffle-form-grid {
          grid-template-columns: 1fr;
        }
        .result-number-row {
          grid-template-columns: 1fr;
        }
        .result-start-check-btn {
          width: 100%;
          min-width: 0;
        }
        .result-check-preview {
          grid-template-columns: 1fr;
        }
        .result-check-icon {
          width: 42px;
          height: 42px;
        }
        .result-check-copy dl {
          grid-template-columns: 1fr;
        }
        .raffle-summary-card,
        .prize-editor-card {
          grid-template-columns: 1fr;
        }
        .raffle-summary-metrics {
          grid-template-columns: 1fr;
        }
        .raffle-panel-head,
        .entry-row {
          grid-template-columns: 1fr;
          align-items: stretch;
        }
        .raffle-row-main {
          grid-template-columns: 58px minmax(0, 1fr) auto;
        }
        .raffle-row-head-actions {
          grid-column: auto;
          justify-content: end;
        }
        .prize-remove-btn { width: 100%; }
      }

      @media (max-width: 720px) {
        .result-checker-head {
          display: grid;
        }
        .result-draw-date-pill {
          width: 100%;
          min-width: 0;
        }
      }

      @media (max-width: 560px) {
        .raffle-modal {
          align-items: end;
          padding: 0;
        }
        .raffle-modal-card {
          width: 100%;
          max-height: 94vh;
          border-radius: 22px 22px 0 0;
        }
        .raffle-form > .raffle-form-grid,
        .raffle-form > .alert,
        .raffle-form > .raffle-actions {
          margin-left: 14px;
          margin-right: 14px;
        }
        .raffle-form > .raffle-actions {
          margin: 0;
          padding: 12px 14px 16px;
        }
        .raffle-summary-metrics,
        .segmented-control {
          grid-template-columns: 1fr;
        }
        .winner-message-toggle {
          min-height: 86px;
          grid-template-columns: minmax(0, 1fr) auto;
          padding: 13px;
        }
        .winner-message-badge,
        .winner-message-toggle-label {
          justify-self: start;
        }
        .winner-message-chevron {
          grid-column: 2;
          grid-row: 1 / span 3;
        }
        .winner-message-panel {
          padding: 12px;
        }
        .winner-message-panel textarea {
          min-height: 104px;
        }
        .app-shell {
          padding-left: 12px;
          padding-right: 12px;
        }
        .raffle-admin-panel {
          padding: 14px;
          border-radius: 18px;
        }
        .raffle-summary-card {
          padding: 14px;
          border-radius: 18px;
        }
        .raffle-list { gap: 12px; }
        .raffle-row { padding: 14px; border-radius: 20px; }
        .raffle-row-main {
          grid-template-columns: 54px minmax(0, 1fr) auto;
          gap: 11px;
        }
        .raffle-thumb {
          width: 54px;
          height: 54px;
          border-radius: 16px;
          font-size: 17px;
        }
        .raffle-row-title { font-size: 16px; }
        .raffle-row-head-actions { min-width: 104px; gap: 7px; }
        .raffle-select-pill { min-height: 32px; padding: 7px 11px; font-size: 11px; }
        .raffle-participant-pill { min-height: 31px; padding: 6px 10px; font-size: 11px; }
        .raffle-row-actions {
          grid-template-columns: minmax(0, 1fr) minmax(0, .9fr) 52px;
          gap: 8px;
        }
        .raffle-row-actions .raffle-btn,
        .raffle-menu-button { min-height: 42px; border-radius: 14px; font-size: 12px; }
        .raffle-menu { width: 52px; min-width: 52px; }
        .raffle-menu-button { width: 52px; }
        .raffle-menu-panel {
          right: 0;
          top: calc(100% + 10px);
          width: min(270px, calc(100vw - 34px));
        }
      }
    </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell pz-admin-content">
      <AdminSidebar
        storeId={currentStoreId}
        pocketbaseUrl={pocketbaseUrl}
        authToken={adminAuthToken}
        storeSlug={currentStoreSlug}
        storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'}
        activeSection="marketing"
        mobileTitle="Rifas"
        mobileActionLabel="Actualizar"
        mobileActionTarget="#raffle-new-btn"
      />

      <main class="main-wrap pz-admin-content-inner">
        <AdminSectionHeader
          kicker="Marketing / Rifas"
          title="Rifas"
          description="Administra hasta 3 rifas reutilizables para tu grupo de WhatsApp."
          titleId="raffle-admin-title"
          bellId="admin-raffles-bell"
        >
          <button id="raffle-new-btn" class="admin-primary-action admin-header-primary-action" type="button" slot="action">
            <span aria-hidden="true">↻</span>
            <span>Actualizar</span>
          </button>
        </AdminSectionHeader>

        <section class="raffle-admin-summary" aria-label="Resumen de rifas">
          <article class="raffle-summary-card">
            <div class="raffle-summary-head">
              <h2>Resumen de rifas</h2>
              <p>Actividad general de las rifas de esta tienda.</p>
            </div>
            <div class="raffle-summary-metrics">
              <div class="raffle-summary-row">
                <span class="raffle-summary-label">Rifas creadas</span>
                <strong id="raffle-summary-total" class="raffle-summary-value">0</strong>
              </div>
              <div class="raffle-summary-row">
                <span class="raffle-summary-label">Rifas activas</span>
                <strong id="raffle-summary-active" class="raffle-summary-value">0</strong>
              </div>
              <div class="raffle-summary-row">
                <span class="raffle-summary-label">Participantes</span>
                <strong id="raffle-summary-entries" class="raffle-summary-value">0</strong>
              </div>
            </div>
          </article>
        </section>

        <section class="raffle-admin-grid">
          <div class="raffle-admin-panel">
            <div class="raffle-panel-head">
              <div>
                <h2>Rifas de la tienda</h2>
                <p>Administra hasta 3 rifas reutilizables para tu grupo de WhatsApp. Cada espacio conserva un enlace fijo.</p>
              </div>
            </div>

            <div id="raffle-alert" class="alert alert-info hidden"></div>

            <div id="raffle-modal" class="raffle-modal hidden" aria-hidden="true">
              <div class="raffle-modal-card" role="dialog" aria-modal="true" aria-labelledby="raffle-modal-title">
                <form id="raffle-form" class="raffle-form">
                  <div class="raffle-modal-head">
                    <div>
                      <p id="raffle-modal-kicker" class="raffle-row-slot">Rifa</p>
                      <h2 id="raffle-modal-title">Administrar rifa</h2>
                    </div>
                    <button id="raffle-modal-close-btn" class="raffle-icon-btn pz-admin-icon-btn" type="button" aria-label="Cerrar">
                      <AdminIcon name="close" class="pz-admin-action-icon" />
                    </button>
                  </div>
                  <input id="raffle-id" type="hidden" />
              <div class="raffle-form-grid">
                <div class="field full">
                  <label for="raffle-title">Título</label>
                  <input id="raffle-title" type="text" maxlength="140" required />
                </div>
                <div class="field">
                  <label for="raffle-access-code">Código del grupo</label>
                  <input id="raffle-access-code" type="text" maxlength="80" autocomplete="off" required />
                  <p class="form-help">Este código será solicitado a los clientes del grupo para participar.</p>
                </div>
                <div class="field">
                  <label for="raffle-starts">Inicio</label>
                  <input id="raffle-starts" type="datetime-local" />
                </div>
                <div class="field">
                  <label for="raffle-closes">Cierre de selección</label>
                  <input id="raffle-closes" type="datetime-local" />
                </div>
                <div class="field">
                  <label for="raffle-draw">Sorteo</label>
                  <input id="raffle-draw" type="datetime-local" />
                </div>
                <div class="field full">
                  <label>Acceso a la rifa</label>
                  <label class="switch-row"><input id="raffle-link-enabled" type="checkbox" checked /> Activar link de la rifa</label>
                  <p class="form-help">Permite que las personas con el enlace directo puedan entrar.</p>
                  <label class="switch-row"><input id="raffle-show-in-store" type="checkbox" /> Mostrar rifa en la tienda pública</label>
                  <p class="form-help">Muestra un acceso a esta rifa dentro de la tienda. Si está apagado, solo se podrá entrar por link directo.</p>
                </div>
                <div class="field full">
                  <label for="raffle-description">Descripción</label>
                  <textarea id="raffle-description"></textarea>
                </div>
                <div class="field full">
                  <label for="raffle-conditions">Condiciones adicionales</label>
                  <textarea id="raffle-conditions"></textarea>
                </div>
                <div class="field full winner-message-field" id="raffle-winner-message-field">
                  <button
                    id="raffle-winner-message-toggle"
                    class="winner-message-toggle"
                    type="button"
                    aria-expanded="false"
                    aria-controls="raffle-winner-message-panel"
                  >
                    <span class="winner-message-toggle-copy">
                      <span class="winner-message-title">Mensaje para ganador</span>
                      <span class="winner-message-description">Personaliza el mensaje que recibirá el ganador.</span>
                    </span>
                    <span id="raffle-winner-message-badge" class="winner-message-badge hidden">Configurado</span>
                    <span id="raffle-winner-message-toggle-label" class="winner-message-toggle-label">Editar mensaje</span>
                    <span class="winner-message-chevron" aria-hidden="true">
                      <svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"></path></svg>
                    </span>
                  </button>
                  <div id="raffle-winner-message-panel" class="winner-message-panel" hidden>
                    <label for="raffle-winner-message">Mensaje para ganador</label>
                    <textarea id="raffle-winner-message" maxlength="1800"></textarea>
                    <p class="form-help">Variables: &#123;nombre_cliente&#125;, &#123;telefono_cliente&#125;, &#123;numero_ganador&#125;, &#123;nombre_rifa&#125;, &#123;nombre_tienda&#125;, &#123;premios&#125;, &#123;link_rifa&#125;</p>
                  </div>
                </div>
                <div class="field full">
                  <div class="prize-editor-head">
                    <div>
                      <h3>Regalos / Premios de la rifa</h3>
                      <p class="form-help">Cada regalo puede tener foto, nombre y una descripción corta.</p>
                    </div>
                    <button id="raffle-add-prize-btn" class="raffle-btn pz-admin-action-btn" type="button">
                      <AdminIcon name="plus" class="pz-admin-action-icon" />
                      <span>Agregar regalo</span>
                    </button>
                  </div>
                  <div id="raffle-prizes-list" class="prize-editor-list"></div>
                </div>
                <div class="field full">
                  <label>Presentación de premios</label>
                  <div class="segmented-control" role="radiogroup" aria-label="Presentación de premios">
                    <label id="raffle-prizes-display-fixed-label"><input id="raffle-prizes-display-fixed" type="radio" name="raffle-prizes-display" value="fixed" checked /> Fijo</label>
                    <label><input id="raffle-prizes-display-carousel" type="radio" name="raffle-prizes-display" value="carousel" /> Carrusel</label>
                  </div>
                  <p class="form-help">Si agregas más de 3 regalos, se recomienda carrusel para mantener una vista cómoda.</p>
                  <p id="raffle-prizes-display-limit-note" class="form-help prize-display-limit-note hidden">Con más de 3 premios, la presentación debe ser carrusel para mantener una vista cómoda.</p>
                </div>
                <div id="raffle-control-card" class="raffle-control-card full hidden">
                  <h3>Estado actual de la rifa</h3>
                  <div><span id="raffle-current-status" class="raffle-status-pill draft">Nueva rifa</span></div>
                  <p class="form-help">Acciones de control</p>
                  <div class="raffle-control-actions">
                    <button class="raffle-btn pz-admin-action-btn js-form-control-action" type="button" data-action="close_selection">Cerrar selección</button>
                    <button class="raffle-btn pz-admin-action-btn js-form-control-action" type="button" data-action="open_selection">Abrir selección</button>
