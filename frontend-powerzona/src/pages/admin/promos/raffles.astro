        const winnerMessageToggleLabel = document.getElementById('raffle-winner-message-toggle-label');
        const fields = {
          id: document.getElementById('raffle-id'),
          title: document.getElementById('raffle-title'),
          accessCode: document.getElementById('raffle-access-code'),
          starts: document.getElementById('raffle-starts'),
          closes: document.getElementById('raffle-closes'),
          draw: document.getElementById('raffle-draw'),
          linkEnabled: document.getElementById('raffle-link-enabled'),
          showInStore: document.getElementById('raffle-show-in-store'),
          description: document.getElementById('raffle-description'),
          conditions: document.getElementById('raffle-conditions'),
          winnerMessage: document.getElementById('raffle-winner-message'),
          prizesList: document.getElementById('raffle-prizes-list'),
          addPrize: document.getElementById('raffle-add-prize-btn'),
          prizeDisplayFixed: document.getElementById('raffle-prizes-display-fixed'),
          prizeDisplayFixedLabel: document.getElementById('raffle-prizes-display-fixed-label'),
          prizeDisplayCarousel: document.getElementById('raffle-prizes-display-carousel'),
          prizeDisplayLimitNote: document.getElementById('raffle-prizes-display-limit-note'),
          total: document.getElementById('raffle-summary-total'),
          active: document.getElementById('raffle-summary-active'),
          entries: document.getElementById('raffle-summary-entries'),
        };
        let raffles = [];
        let allEntries = [];
        let entries = [];
        let selectedRaffleId = '';
        let prizeState = [];
        let formSnapshot = '';
        let pendingDateResolve = null;
        let pendingWinner = null;
        let resultCheck = null;
        const alertTimers = new WeakMap();
        const RAFFLE_PRIZE_ALLOWED_IMAGE_TYPES = new Set(['image/jpeg', 'image/png', 'image/webp']);
        const RAFFLE_PRIZE_IMAGE_MAX_SIZE = 900;
        const RAFFLE_PRIZE_WEBP_QUALITY = 0.86;
        const optimizedPrizeFiles = new WeakMap();
        const pendingPrizeOptimizations = new WeakMap();
        const prizePreviewUrls = new WeakMap();
        const prizePreviewRows = new Set();

        function openSidebar() {
          document.body.classList.add('sidebar-open');
          sidebar?.setAttribute('aria-hidden', 'false');
          if (sidebarOverlay) sidebarOverlay.hidden = false;
          sidebarOpenBtn?.setAttribute('aria-expanded', 'true');
        }

        function closeSidebar() {
          document.body.classList.remove('sidebar-open');
          sidebar?.setAttribute('aria-hidden', 'true');
          sidebarOpenBtn?.setAttribute('aria-expanded', 'false');
          window.setTimeout(() => {
            if (!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true;
          }, 220);
        }

        function show(box, message = '', type = 'info') {
          if (!box) return;
          const previousTimer = alertTimers.get(box);
          if (previousTimer) window.clearTimeout(previousTimer);
          if (!message) {
            box.className = 'alert alert-info hidden';
            box.innerHTML = '';
            return;
          }
          box.className = `alert alert-${type}`;
          box.innerHTML = `<span>${escapeHtml(message)}</span>${type === 'error' ? '<button class="alert-close" type="button" aria-label="Cerrar">×</button>' : ''}`;
          box.querySelector('.alert-close')?.addEventListener('click', () => show(box, ''));
          const timeout = type === 'success' ? 4000 : type === 'error' ? 8000 : 5000;
          const timer = window.setTimeout(() => show(box, ''), timeout);
          alertTimers.set(box, timer);
        }

        function escapeHtml(value) {
          return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[char]));
        }

        function slugify(value) {
          return String(value || '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '')
            .replace(/-{2,}/g, '-')
            .slice(0, 90);
        }

        function rafflePrizeImageTypeError() {
          return 'Solo se aceptan imagenes JPG, PNG o WebP para premios de rifa.';
        }

        function isAllowedRafflePrizeImageType(file) {
          return file instanceof File && RAFFLE_PRIZE_ALLOWED_IMAGE_TYPES.has(String(file.type || '').toLowerCase());
        }

        function cleanRafflePrizeWebpName(name) {
          const cleanBaseName = String(name || '').replace(/\.[^.]+$/, '');
          return `${slugify(cleanBaseName) || 'premio-rifa'}.webp`;
        }

        function canvasToWebpBlob(canvas) {
          return new Promise((resolve, reject) => {
            canvas.toBlob((blob) => {
              if (!blob || blob.size <= 0 || blob.type !== 'image/webp') {
                reject(new Error('No se pudo crear el WebP del premio.'));
                return;
              }
              resolve(blob);
            }, 'image/webp', RAFFLE_PRIZE_WEBP_QUALITY);
          });
        }

        async function decodeRafflePrizeImage(file) {
          if (typeof window.createImageBitmap === 'function') {
            const bitmap = await window.createImageBitmap(file);
            return {
              source: bitmap,
              width: bitmap.width,
              height: bitmap.height,
              close: () => bitmap.close?.(),
            };
          }

          return new Promise((resolve, reject) => {
            const url = URL.createObjectURL(file);
            const image = new Image();
            image.onload = () => {
              URL.revokeObjectURL(url);
              resolve({
                source: image,
                width: image.naturalWidth || image.width,
                height: image.naturalHeight || image.height,
                close: () => {},
              });
            };
            image.onerror = () => {
              URL.revokeObjectURL(url);
              reject(new Error('No se pudo leer la imagen del premio.'));
            };
            image.src = url;
          });
        }

        async function optimizeRafflePrizeImageFile(file) {
          if (!(file instanceof File) || file.size <= 0) {
            throw new Error('Selecciona una imagen valida para el premio.');
          }
          if (!isAllowedRafflePrizeImageType(file)) {
            throw new Error(rafflePrizeImageTypeError());
          }

          let decoded = null;
          try {
            decoded = await decodeRafflePrizeImage(file);
            const width = Number(decoded.width || 0);
            const height = Number(decoded.height || 0);
            if (!width || !height) throw new Error('La imagen del premio no tiene dimensiones validas.');

            const scale = Math.min(1, RAFFLE_PRIZE_IMAGE_MAX_SIZE / width, RAFFLE_PRIZE_IMAGE_MAX_SIZE / height);
            const targetWidth = Math.max(1, Math.round(width * scale));
            const targetHeight = Math.max(1, Math.round(height * scale));
            const canvas = document.createElement('canvas');
            canvas.width = targetWidth;
            canvas.height = targetHeight;
            const context = canvas.getContext('2d');
            if (!context) throw new Error('No se pudo preparar la imagen del premio.');

            context.drawImage(decoded.source, 0, 0, targetWidth, targetHeight);
            const blob = await canvasToWebpBlob(canvas);
            return new File([blob], cleanRafflePrizeWebpName(file.name), {
              type: 'image/webp',
              lastModified: Date.now(),
            });
          } catch (_) {
            throw new Error('No se pudo optimizar la imagen del premio. Usa un JPG, PNG o WebP valido.');
          } finally {
            decoded?.close?.();
          }
        }

        function revokePrizePreviewUrl(row) {
          const url = prizePreviewUrls.get(row);
          if (url) URL.revokeObjectURL(url);
          prizePreviewUrls.delete(row);
          prizePreviewRows.delete(row);
        }

        function clearPrizePreviewUrls() {
          Array.from(prizePreviewRows).forEach((row) => revokePrizePreviewUrl(row));
        }

        function clearPrizeRowUpload(row, clearInput = false) {
          if (!row) return;
          optimizedPrizeFiles.delete(row);
          pendingPrizeOptimizations.delete(row);
          revokePrizePreviewUrl(row);
          if (clearInput) {
            const input = row.querySelector('.js-prize-file');
            if (input) input.value = '';
          }
        }

        function restoreRafflePrizePreview(row) {
          const preview = row?.querySelector('.js-prize-preview');
          if (!preview) return;
          const image = row.dataset.image || '';
          if (image && fields.id?.value) {
            preview.innerHTML = `<img src="${escapeHtml(fileUrl({ id: fields.id.value }, image))}" alt="">`;
            return;
          }
          const index = Math.max(0, currentPrizeRows().indexOf(row)) + 1;
          preview.innerHTML = `<span>Foto<br>Premio ${index}</span>`;
        }

        function setRafflePrizePreview(row, file) {
          const preview = row?.querySelector('.js-prize-preview');
          if (!preview || !(file instanceof File)) return;
          revokePrizePreviewUrl(row);
          const url = URL.createObjectURL(file);
          prizePreviewUrls.set(row, url);
          prizePreviewRows.add(row);
          preview.innerHTML = `<img src="${url}" alt="">`;
        }

        function getPrizeUploadFile(row) {
          if (!row) return null;
          return optimizedPrizeFiles.get(row) || row.querySelector('.js-prize-file')?.files?.[0] || null;
        }

        function getPrizeUploadSignature(row) {
          const file = getPrizeUploadFile(row);
          return file ? `${row.dataset.prizeId || ''}:${file.name}:${file.size}` : '';
        }

        async function getOptimizedPrizeFileForRow(row) {
          if (!row) return null;
          const pending = pendingPrizeOptimizations.get(row);
          if (pending) return pending;

          const optimized = optimizedPrizeFiles.get(row);
          if (optimized) return optimized;

          const file = row.querySelector('.js-prize-file')?.files?.[0];
          if (!file) return null;

          const optimization = optimizeRafflePrizeImageFile(file);
          pendingPrizeOptimizations.set(row, optimization);
          try {
            const nextFile = await optimization;
            optimizedPrizeFiles.set(row, nextFile);
            return nextFile;
          } finally {
            if (pendingPrizeOptimizations.get(row) === optimization) pendingPrizeOptimizations.delete(row);
          }
        }

        async function handleRafflePrizeFileChange(input) {
          const row = input?.closest('[data-prize-id]');
          if (!row) return;
          clearPrizeRowUpload(row);

          const file = input.files?.[0];
          if (!file) return;

          if (!isAllowedRafflePrizeImageType(file)) {
            input.value = '';
            restoreRafflePrizePreview(row);
            show(formAlert, rafflePrizeImageTypeError(), 'error');
            return;
          }

          const optimization = optimizeRafflePrizeImageFile(file);
          pendingPrizeOptimizations.set(row, optimization);
          try {
            const optimizedFile = await optimization;
            if (pendingPrizeOptimizations.get(row) !== optimization) return;
            optimizedPrizeFiles.set(row, optimizedFile);
            setRafflePrizePreview(row, optimizedFile);
            show(formAlert, '');
          } catch (error) {
            if (pendingPrizeOptimizations.get(row) !== optimization) return;
            optimizedPrizeFiles.delete(row);
            input.value = '';
            restoreRafflePrizePreview(row);
            show(formAlert, error?.message || 'No se pudo optimizar la imagen del premio.', 'error');
          } finally {
            if (pendingPrizeOptimizations.get(row) === optimization) pendingPrizeOptimizations.delete(row);
          }
        }

        function parseJsonArray(value) {
          if (Array.isArray(value)) return value;
          if (typeof value !== 'string' || !value.trim()) return [];
          try {
            const parsed = JSON.parse(value);
            return Array.isArray(parsed) ? parsed : [];
          } catch (_) {
            return [];
          }
        }

        function isLinkEnabled(raffle) {
          if (!raffle) return false;
          if (typeof raffle.link_enabled === 'boolean') return raffle.link_enabled;
          return raffle.visible !== false;
        }

        function addHours(value, hours) {
          const date = new Date(value || '');
          if (Number.isNaN(date.getTime())) return null;
          return new Date(date.getTime() + hours * 60 * 60 * 1000);
        }

        function calculatedStatus(raffle) {
          if (!raffle) return 'archived';
          if (raffle.is_configured !== true) return 'draft';
          const now = Date.now();
          const status = String(raffle.status || 'active');
          if (status === 'archived' || status === 'finalized') return status;

          const finalizedAt = raffle.finalized_at ? new Date(raffle.finalized_at) : null;
          if (finalizedAt && !Number.isNaN(finalizedAt.getTime()) && finalizedAt.getTime() <= now) return 'finalized';

          if (status === 'winner_published' || status === 'no_winner_published') {
            const autoFinal = addHours(raffle.result_published_at, 24);
            return autoFinal && autoFinal.getTime() <= now ? 'finalized' : status;
          }

          const drawAt = raffle.draw_at ? new Date(raffle.draw_at) : null;
          if (drawAt && !Number.isNaN(drawAt.getTime()) && drawAt.getTime() <= now) return 'result_pending';

          if (raffle.selection_manually_closed === true) return 'selection_closed';

          const closesAt = raffle.closes_at ? new Date(raffle.closes_at) : null;
          if (closesAt && !Number.isNaN(closesAt.getTime()) && closesAt.getTime() <= now) return 'selection_closed';

          if (status === 'selection_closed' || status === 'result_pending') return status;
          const startsAt = raffle.starts_at ? new Date(raffle.starts_at) : null;
          if (startsAt && !Number.isNaN(startsAt.getTime()) && startsAt.getTime() > now) return 'scheduled';
          return 'active';
        }

        function setPrizeDisplayMode(mode) {
          const value = mode === 'carousel' ? 'carousel' : 'fixed';
          const input = value === 'carousel' ? fields.prizeDisplayCarousel : fields.prizeDisplayFixed;
          if (input) input.checked = true;
        }

        function shouldForcePrizeCarousel() {
          return currentPrizeRows().length > PRIZE_FIXED_LIMIT;
        }

        function updatePrizeDisplayModeAvailability() {
          const forceCarousel = shouldForcePrizeCarousel();
          if (forceCarousel) setPrizeDisplayMode('carousel');
          if (fields.prizeDisplayFixed) fields.prizeDisplayFixed.disabled = forceCarousel;
          fields.prizeDisplayFixedLabel?.classList.toggle('is-disabled', forceCarousel);
          fields.prizeDisplayFixedLabel?.setAttribute('aria-disabled', forceCarousel ? 'true' : 'false');
          fields.prizeDisplayLimitNote?.classList.toggle('hidden', !forceCarousel);
        }

        function getPrizeDisplayMode() {
          if (shouldForcePrizeCarousel()) return 'carousel';
          return document.querySelector('input[name="raffle-prizes-display"]:checked')?.value || 'fixed';
        }

        function makePrizeId() {
          return `premio-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
        }

        function normalizePrizeItem(item, index, raffle = null) {
          const prize = item && typeof item === 'object' ? item : {};
          return {
            id: slugify(prize.id || `premio-${index + 1}`) || `premio-${index + 1}`,
            name: String(prize.name || '').trim().slice(0, 80),
            description: String(prize.description || '').trim().slice(0, 180),
            image: String(prize.image || '').trim(),
            raffleId: raffle?.id || '',
          };
        }

        function prizesFromRaffle(raffle) {
          const structured = parseJsonArray(raffle?.prizes_json)
            .map((item, index) => normalizePrizeItem(item, index, raffle))
            .filter((prize) => prize.name || prize.description || prize.image);

          if (structured.length) return structured;

          const images = Array.isArray(raffle?.images) ? raffle.images : (raffle?.images ? [raffle.images] : []);
          return images.map((image, index) => ({
            id: `legacy-${index + 1}`,
            name: `Premio ${index + 1}`,
            description: raffle?.description || '',
            image,
            raffleId: raffle?.id || '',
          }));
        }

        function currentPrizeRows() {
          return Array.from(fields.prizesList?.querySelectorAll('[data-prize-id]') || []);
        }

        function readPrizeRows() {
          return currentPrizeRows().map((row) => ({
            id: row.dataset.prizeId || makePrizeId(),
            name: row.querySelector('.js-prize-name')?.value?.trim() || '',
            description: row.querySelector('.js-prize-description')?.value?.trim() || '',
            image: row.dataset.image || '',
            uploadKey: row.dataset.prizeId || '',
          })).filter((prize) => {
            const row = fields.prizesList?.querySelector(`[data-prize-id="${CSS.escape(prize.id)}"]`);
            const file = getPrizeUploadFile(row);
            return prize.name || prize.description || prize.image || file;
          });
        }

        function prizeEditorRowHtml(prize, index) {
          const image = prize.image && prize.raffleId ? fileUrl({ id: prize.raffleId }, prize.image) : '';
          const preview = image
            ? `<img src="${escapeHtml(image)}" alt="">`
            : `<span>Foto<br>Premio ${index + 1}</span>`;

          return `
            <article class="prize-editor-card" data-prize-id="${escapeHtml(prize.id)}" data-image="${escapeHtml(prize.image || '')}">
              <div class="prize-photo-box">
                <div class="prize-photo-preview js-prize-preview">${preview}</div>
                <input class="js-prize-file" type="file" accept="image/jpeg,image/png,image/webp" />
                <p class="form-help prize-image-help">JPG, PNG o WebP. Se optimiza automaticamente a WebP 900 x 900 px.</p>
              </div>
              <div class="prize-fields">
                <input class="js-prize-name" type="text" maxlength="80" placeholder="Nombre del regalo" value="${escapeHtml(prize.name || '')}" />
                <textarea class="js-prize-description" maxlength="180" placeholder="Descripción corta">${escapeHtml(prize.description || '')}</textarea>
              </div>
              <button class="prize-remove-btn js-prize-remove" type="button" aria-label="Borrar regalo">&times;</button>
            </article>
          `;
        }

        function renderPrizeEditor() {
          if (!fields.prizesList) return;
          clearPrizePreviewUrls();
          if (!prizeState.length) {
            fields.prizesList.innerHTML = '<div class="empty-state">Agrega al menos un regalo para mostrarlo en la página pública.</div>';
            updatePrizeDisplayModeAvailability();
            return;
          }

          fields.prizesList.innerHTML = prizeState.map(prizeEditorRowHtml).join('');
          updatePrizeDisplayModeAvailability();
        }

        function normalizeNumber(value) {
          const digits = String(value || '').replace(/\D/g, '').slice(0, 2);
          return digits.length === 1 ? `0${digits}` : digits;
        }

        function toDatetimeLocal(value) {
          if (!value) return '';
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return '';
          const offset = date.getTimezoneOffset() * 60000;
          return new Date(date.getTime() - offset).toISOString().slice(0, 16);
        }

        function dateLabel(value) {
          if (!value) return 'Sin fecha';
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return 'Sin fecha';
          return new Intl.DateTimeFormat('es', { dateStyle: 'medium', timeStyle: 'short' }).format(date);
        }

        function parseDate(value) {
          const date = new Date(value || '');
          return Number.isNaN(date.getTime()) ? null : date;
        }

        function getSelectedRaffle() {
          return raffles.find((item) => item.id === selectedRaffleId) || null;
        }

        function raffleHasPublishedResult(raffle) {
          const status = String(raffle?.status || '');
          return status === 'winner_published'
            || status === 'no_winner_published'
            || status === 'finalized'
            || Boolean(raffle?.winner_number)
            || Boolean(raffle?.no_winner_number)
            || Boolean(raffle?.result_published_at);
        }

        function isDrawDateReached(raffle) {
          const drawDate = parseDate(raffle?.draw_at);
          return Boolean(drawDate && drawDate.getTime() <= Date.now());
        }

        function getResultCheckAvailability(raffle) {
          if (!raffle) {
            return {
              enabled: false,
              state: 'no_raffle',
              label: 'Selecciona una rifa',
              help: 'Selecciona una rifa para chequear el resultado.',
            };
          }

          if (raffle.is_configured !== true) {
            return {
              enabled: false,
              state: 'not_configured',
              label: 'Configura la rifa',
              help: 'Configura la rifa antes de chequear el resultado.',
            };
          }

          if (raffleHasPublishedResult(raffle)) {
            return {
              enabled: false,
              state: 'published',
              label: 'Resultado publicado',
              help: 'Esta rifa ya tiene resultado publicado.',
            };
          }

          const drawDate = parseDate(raffle.draw_at);
          if (!drawDate) {
            return {
              enabled: false,
              state: 'missing_draw_date',
              label: 'Sin fecha de sorteo',
              help: 'Agrega una fecha de sorteo para poder chequear el resultado.',
            };
          }

          if (drawDate.getTime() > Date.now()) {
            const formattedDate = dateLabel(drawDate);
            return {
              enabled: false,
              state: 'scheduled',
              label: `Disponible el ${formattedDate}`,
              help: `Podrás chequear el resultado el ${formattedDate}.`,
            };
          }

          return {
            enabled: true,
            state: 'due',
            label: 'Chequear resultado',
            help: 'La fecha del sorteo ya llegó. Puedes chequear el número sorteado.',
          };
        }

        function slotLabel(raffle) {
          const number = Number(raffle?.slot_number || String(raffle?.slug || '').replace('rifa-', ''));
          return Number.isInteger(number) && number >= 1 && number <= 3 ? `Rifa ${number}` : 'Rifa';
        }

        function displayTitle(raffle) {
          return raffle?.is_configured === true && String(raffle?.title || '').trim()
            ? String(raffle.title).trim()
            : 'Nueva rifa';
        }

        function activeEntryCount(raffleId) {
          return allEntries.filter((entry) => entry.raffle === raffleId && entry.status === 'active').length;
        }

        function participantLabel(count) {
          return `${count} ${count === 1 ? 'participante' : 'participantes'}`;
        }

        function activeEntryForNumber(number) {
          const normalized = normalizeNumber(number);
          return entries.find((entry) => entry.status === 'active' && normalizeNumber(entry.chosen_number) === normalized) || null;
        }

        function renderResultDrawDate(raffle, availability = getResultCheckAvailability(raffle)) {
          if (!resultDrawDatePill || !resultDrawDateStatus || !resultDrawDateLabel) return;
          const drawDate = parseDate(raffle?.draw_at);
          let pillClass = 'is-muted';
          let statusText = 'Sin fecha';
          let labelText = 'Fecha no configurada';

          if (drawDate) {
            labelText = dateLabel(drawDate);
            if (availability.state === 'published') {
              pillClass = 'is-published';
              statusText = 'Publicado';
            } else if (drawDate.getTime() <= Date.now()) {
              pillClass = 'is-due';
              statusText = 'Resultado pendiente';
            } else {
              pillClass = 'is-scheduled';
              statusText = 'Programado';
            }
          } else if (raffle && raffle.is_configured !== true) {
            statusText = 'Sin configurar';
            labelText = 'Configura la rifa';
          }

          resultDrawDatePill.classList.remove('is-muted', 'is-scheduled', 'is-due', 'is-published');
          resultDrawDatePill.classList.add(pillClass);
          resultDrawDateStatus.textContent = statusText;
          resultDrawDateLabel.textContent = labelText;
        }

        function renderResultCheckButton(availability) {
          if (resultStartCheckBtn) {
            const isPublished = availability.state === 'published';
            resultStartCheckBtn.classList.toggle('hidden', isPublished);
            resultStartCheckBtn.disabled = !availability.enabled;
            resultStartCheckBtn.classList.toggle('is-disabled', !availability.enabled);
            resultStartCheckBtn.setAttribute('aria-disabled', availability.enabled ? 'false' : 'true');
          }
          if (resultStartCheckLabel) {
            resultStartCheckLabel.textContent = availability.enabled ? 'Chequear resultado' : availability.label;
          }
          if (resultCheckerDisabledHelp) {
            resultCheckerDisabledHelp.textContent = availability.help;
            resultCheckerDisabledHelp.classList.toggle('hidden', availability.state === 'published');
            resultCheckerDisabledHelp.classList.toggle('is-due', availability.state === 'due');
          }
          resultCheckerGuides.forEach((item) => item.classList.toggle('hidden', availability.state === 'published'));
        }

        function resultAvailabilityMessage(availability, forPublish = false) {
          if (forPublish && availability.state === 'scheduled') {
            return 'El resultado estará disponible en la fecha del sorteo.';
          }
          return availability.help || 'No se puede chequear el resultado en este momento.';
        }

        function clearResultCheck(keepPanelOpen = true) {
          resultCheck = null;
          resultStartCheckBtn?.classList.remove('hidden');
          if (resultCheckPreview) {
            resultCheckPreview.className = 'result-check-preview hidden';
            resultCheckPreview.innerHTML = '';
          }
          resultPublishActions?.classList.add('hidden');
          publishWinnerBtn?.classList.add('hidden');
          publishNoWinnerBtn?.classList.add('hidden');
          resultResetCheckBtn?.classList.add('hidden');
          resultCheckerIntro?.classList.remove('hidden');
          if (!keepPanelOpen) {
            resultCheckPanel?.classList.add('hidden');
            resultBox?.setAttribute('data-result-check-state', 'idle');
            if (resultNumber) resultNumber.value = '';
            return;
          }
          resultBox?.setAttribute('data-result-check-state', 'checking');
        }

        function openResultCheckPanel() {
          const raffle = getSelectedRaffle();
          const availability = getResultCheckAvailability(raffle);
          if (!availability.enabled) {
            renderResultChecker(raffle);
            show(entriesAlert, resultAvailabilityMessage(availability), 'error');
            return;
          }
          clearResultCheck(true);
          resultCheckPanel?.classList.remove('hidden');
          resultResetCheckBtn?.classList.add('hidden');
          resultBox?.setAttribute('data-result-check-state', 'checking');
          window.setTimeout(() => resultNumber?.focus(), 0);
        }

        function renderResultCheckWinner(number, entry) {
          if (!resultCheckPreview) return;
          resultCheckPreview.className = 'result-check-preview is-winner';
          resultCheckPreview.innerHTML = `
            <div class="result-check-icon">✓</div>
            <div class="result-check-copy">
              <h4>Ganador encontrado</h4>
              <p>El número <strong>${escapeHtml(number)}</strong> pertenece a un participante activo.</p>
              <dl>
                <div><dt>Número reservado</dt><dd>${escapeHtml(number)}</dd></div>
                <div><dt>Teléfono</dt><dd>${escapeHtml(entry?.phone || '--')}</dd></div>
                <div><dt>Comprobante</dt><dd>${escapeHtml(entry?.receipt_code || '--')}</dd></div>
                <div><dt>Fecha de reserva</dt><dd>${escapeHtml(dateLabel(entry?.created) || '--')}</dd></div>
              </dl>
            </div>
          `;
          resultPublishActions?.classList.remove('hidden');
          publishWinnerBtn?.classList.remove('hidden');
          publishNoWinnerBtn?.classList.add('hidden');
          resultResetCheckBtn?.classList.remove('hidden');
          resultBox?.setAttribute('data-result-check-state', 'winner');
        }

        function renderResultCheckNoWinner(number) {
          if (!resultCheckPreview) return;
          resultCheckPreview.className = 'result-check-preview is-no-winner';
          resultCheckPreview.innerHTML = `
            <div class="result-check-icon">!</div>
            <div class="result-check-copy">
              <h4>No hay ganador para este número</h4>
              <p>El número <strong>${escapeHtml(number)}</strong> no pertenece a ningún participante activo.</p>
              <p class="result-check-note">Puedes publicar el resultado sin ganador si ese fue el número sorteado.</p>
            </div>
          `;
          resultPublishActions?.classList.remove('hidden');
          publishWinnerBtn?.classList.add('hidden');
          publishNoWinnerBtn?.classList.remove('hidden');
          resultResetCheckBtn?.classList.remove('hidden');
          resultBox?.setAttribute('data-result-check-state', 'no-winner');
        }

        function renderPublishedResult(raffle) {
          resultCheck = null;
          resultCheckerIntro?.classList.remove('hidden');
          resultCheckPanel?.classList.add('hidden');
          resultPublishActions?.classList.add('hidden');
          publishWinnerBtn?.classList.add('hidden');
          publishNoWinnerBtn?.classList.add('hidden');
          resultResetCheckBtn?.classList.add('hidden');
          resultBox?.setAttribute('data-result-check-state', 'published');
          if (!resultCheckPreview) return;

          const status = String(raffle?.status || '');
          const winnerNumber = normalizeNumber(raffle?.winner_number || '');
          const noWinnerNumber = normalizeNumber(raffle?.no_winner_number || '');
          const hasWinner = status === 'winner_published' || Boolean(winnerNumber);
          const number = hasWinner ? winnerNumber : noWinnerNumber;
          resultCheckPreview.className = hasWinner ? 'result-check-preview is-winner' : 'result-check-preview is-no-winner';
          resultCheckPreview.innerHTML = `
            <div class="result-check-icon">${hasWinner ? '✓' : '!'}</div>
            <div class="result-check-copy">
              <h4>${hasWinner ? 'Resultado publicado' : 'Resultado publicado sin ganador'}</h4>
              <p>${hasWinner ? 'Número ganador' : 'Número sorteado'}: <strong>${escapeHtml(number || '--')}</strong></p>
            </div>
          `;
        }

        function renderResultChecker(raffle) {
          if (!resultBox) return;
          const availability = getResultCheckAvailability(raffle);
          renderResultDrawDate(raffle, availability);
          const configured = raffle?.is_configured === true;
          if (!raffle || !configured) {
            clearResultCheck(false);
            renderResultCheckButton(availability);
            return;
          }
          if (availability.state === 'published') {
            renderResultCheckButton(availability);
            renderPublishedResult(raffle);
            return;
          }
          clearResultCheck(false);
          renderResultCheckButton(availability);
        }

        function resultNumberFromInput() {
          const raw = String(resultNumber?.value || '').trim();
          if (!/^\d{1,2}$/.test(raw)) return '';
          return normalizeNumber(raw);
        }

        function checkResultNumber() {
          const raffle = getSelectedRaffle();
          const availability = getResultCheckAvailability(raffle);
          if (!availability.enabled) {
            renderResultChecker(raffle);
            show(entriesAlert, resultAvailabilityMessage(availability), 'error');
            return;
          }

          const number = resultNumberFromInput();
          if (!/^\d{2}$/.test(number)) {
            show(entriesAlert, 'Escribe un número entre 00 y 99.', 'error');
            return;
          }
          if (resultNumber) resultNumber.value = number;
          const entry = activeEntryForNumber(number);
          if (entry) {
            resultCheck = { number, entry, outcome: 'winner' };
            renderResultCheckWinner(number, entry);
            return;
          }
          resultCheck = { number, entry: null, outcome: 'no_winner' };
          renderResultCheckNoWinner(number);
        }

        function prizeSummary(raffle) {
          const names = prizesFromRaffle(raffle)
            .map((prize) => prize.name || prize.description)
            .filter(Boolean)
            .slice(0, 6);
          return names.length ? names.join(', ') : 'Premio de la rifa';
        }

        function winnerTemplate(raffle) {
          const text = String(raffle?.winner_message || '').trim();
          return text || DEFAULT_WINNER_MESSAGE;
        }

        function winnerMessage(raffle, entry, number) {
          const phone = String(entry?.phone || '').trim();
          const replacements = {
            nombre_cliente: phone || 'cliente',
            telefono_cliente: phone,
            numero_ganador: number || raffle?.winner_number || '--',
            nombre_rifa: displayTitle(raffle),
            nombre_tienda: CURRENT_STORE_NAME,
            premios: prizeSummary(raffle),
            link_rifa: `${window.location.origin}${publicRaffleHref(raffle)}`,
          };
          return winnerTemplate(raffle).replace(/\{([a-z_]+)\}/g, (_, key) => (
            Object.prototype.hasOwnProperty.call(replacements, key) ? replacements[key] : `{${key}}`
          ));
        }

        function winnerWhatsappHref(entry, message) {
          const phone = String(entry?.phone || '').replace(/\D/g, '');
          if (!/^53\d{8}$/.test(phone)) return '';
          return `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
        }

        function winnerContactData() {
          const raffle = raffles.find((item) => item.id === selectedRaffleId);
          const number = String(raffle?.winner_number || '').trim();
          if (!raffle || !number) return null;
          const entry = activeEntryForNumber(number);
          if (!entry) return null;
          const message = winnerMessage(raffle, entry, number);
          return { raffle, entry, number, message, href: winnerWhatsappHref(entry, message) };
        }

        function renderWinnerContact() {
          const data = winnerContactData();
          winnerContactBox?.classList.toggle('hidden', !data);
          if (!data) return;
          if (winnerContactText) {
            winnerContactText.textContent = `Ganador publicado: numero ${data.number}. Telefono: ${data.entry.phone || '--'}.`;
          }
          if (winnerWhatsappBtn) winnerWhatsappBtn.disabled = !data.href;
          if (!data.href) {
            show(entriesAlert, 'El telefono del ganador no parece valido para WhatsApp. Revisa el numero antes de contactar.', 'error');
          }
        }

        function openWinnerWhatsapp(data) {
          if (!data?.href) {
            show(entriesAlert, 'El telefono del ganador no parece valido para WhatsApp. Revisa el numero antes de contactar.', 'error');
            return false;
          }
          const opened = window.open(data.href, '_blank', 'noopener');
          if (!opened) {
            show(entriesAlert, 'Ganador publicado. Puedes contactar al cliente por WhatsApp.', 'info');
            return false;
          }
          return true;
        }

        function currentFormSignature() {
          if (!form) return '';
          return JSON.stringify({
            id: fields.id.value,
            title: fields.title.value,
            accessCode: fields.accessCode.value,
            starts: fields.starts.value,
            closes: fields.closes.value,
            draw: fields.draw.value,
            linkEnabled: fields.linkEnabled.checked,
            showInStore: fields.showInStore.checked,
            description: fields.description.value,
            conditions: fields.conditions.value,
            winnerMessage: fields.winnerMessage.value,
            displayMode: getPrizeDisplayMode(),
            prizes: readPrizeRows().map(({ id, name, description, image }) => ({ id, name, description, image })),
            files: currentPrizeRows().map((row) => getPrizeUploadSignature(row)),
          });
        }

        function hasUnsavedChanges() {
          return modal && !modal.classList.contains('hidden') && formSnapshot && currentFormSignature() !== formSnapshot;
        }

        function hasCustomWinnerMessage() {
          const current = String(fields.winnerMessage?.value || '').trim();
          return Boolean(current && current !== DEFAULT_WINNER_MESSAGE.trim());
        }

        function updateWinnerMessageBadge() {
          winnerMessageBadge?.classList.toggle('hidden', !hasCustomWinnerMessage());
        }

        function setWinnerMessagePanel(open) {
          const isOpen = Boolean(open);
          winnerMessageField?.classList.toggle('is-open', isOpen);
          winnerMessageToggle?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          if (winnerMessagePanel) winnerMessagePanel.hidden = !isOpen;
          if (winnerMessageToggleLabel) winnerMessageToggleLabel.textContent = isOpen ? 'Ocultar mensaje' : 'Editar mensaje';
          updateWinnerMessageBadge();
        }

        function closeOpenMenus(except = null) {
          document.querySelectorAll('.raffle-menu-panel:not([hidden])').forEach((panel) => {
            if (panel !== except) {
              panel.hidden = true;
              panel.closest('.raffle-menu')?.querySelector('.raffle-menu-button')?.setAttribute('aria-expanded', 'false');
              panel.closest('.raffle-row')?.classList.remove('is-menu-open');
            }
          });
          document.querySelectorAll('.raffle-row.is-menu-open').forEach((row) => {
            const openPanel = row.querySelector('.raffle-menu-panel:not([hidden])');
            if (!openPanel || openPanel !== except) row.classList.remove('is-menu-open');
          });
        }

        function closePassed(raffle) {
          const closesAt = raffle?.closes_at ? new Date(raffle.closes_at) : null;
          return !closesAt || Number.isNaN(closesAt.getTime()) || closesAt.getTime() <= Date.now();
        }

        function canOpenSelection(raffle) {
          const status = calculatedStatus(raffle);
          return raffle?.is_configured === true && !['winner_published', 'no_winner_published', 'finalized'].includes(status);
        }

        function hasPublishedResult(raffle) {
          return Boolean(raffle?.winner_number || raffle?.no_winner_number || raffle?.result_published_at)
            || ['winner_published', 'no_winner_published'].includes(String(raffle?.status || ''));
        }

        function adminIconSvg(name, className = 'pz-admin-dropdown-item-icon') {
          const icons = {
            view: '<path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12Z"></path><circle cx="12" cy="12" r="3"></circle>',
            settings: '<path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"></path><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.38a1.7 1.7 0 0 0-1 .92V20a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1-.92 1.7 1.7 0 0 0-1.88.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.62 15a1.7 1.7 0 0 0-.92-1H3.6a2 2 0 1 1 0-4h.09a1.7 1.7 0 0 0 .92-1 1.7 1.7 0 0 0-.34-1.88l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.62a1.7 1.7 0 0 0 1-.92V3.6a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1 .92 1.7 1.7 0 0 0 1.88-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.38 9c.14.34.44.68.92 1h.1a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-.92 1Z"></path>',
            copy: '<rect x="8" y="8" width="11" height="13" rx="2"></rect><path d="M5 16H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>',
            edit: '<path d="M4 20h4.5L19 9.5a2.12 2.12 0 0 0-3-3L5.5 17H4v3Z"></path><path d="m14.5 7.5 3 3"></path>',
            hide: '<path d="M3 3l18 18"></path><path d="M10.6 10.6a2 2 0 0 0 2.8 2.8"></path><path d="M9.9 5.2A9.6 9.6 0 0 1 12 5c6 0 9.5 7 9.5 7a16 16 0 0 1-2.25 3.1"></path><path d="M6.6 6.9C3.9 8.7 2.5 12 2.5 12s3.5 7 9.5 7c1.6 0 3.05-.5 4.3-1.2"></path>',
            visible: '<path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12Z"></path><circle cx="12" cy="12" r="3"></circle>',
            save: '<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z"></path><path d="M17 21v-8H7v8"></path><path d="M7 3v5h8"></path>',
            close: '<path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>',
          };
          const icon = icons[name] || icons.view;
          return `<svg class="${className}" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icon}</svg>`;
        }

        function raffleMenuIcon(action) {
          const icons = {
            copy_link: 'copy',
            close_selection: 'hide',
            open_selection: 'visible',
            open_raffle: 'visible',
            finalize: 'save',
            reset: 'close',
          };
          return adminIconSvg(icons[action] || 'view');
        }

        function actionMenuHtml(raffle, status, fullHref = '') {
          const configured = raffle?.is_configured === true;
          const items = [];
          items.push({
            action: 'copy_link',
            label: 'Copiar enlace',
            className: '',
            href: fullHref,
          });
          if (configured && status === 'active') {
            items.push({ action: 'close_selection', label: 'Cerrar selección', className: '' });
          }
          if (configured && ['selection_closed', 'result_pending'].includes(status) && canOpenSelection(raffle)) {
            items.push({ action: 'open_selection', label: 'Abrir selección', className: '' });
          }
          if (configured && status === 'finalized' && !hasPublishedResult(raffle)) {
            items.push({ action: 'open_raffle', label: 'Abrir rifa', className: '' });
          }
          if (configured && !['draft', 'finalized'].includes(status)) {
            items.push({ action: 'finalize', label: 'Finalizar rifa', className: '' });
          }
          if (configured) {
            items.push({ action: 'reset', label: 'Restablecer rifa', className: 'danger' });
          }
          return `
            <div class="raffle-menu">
              <button class="raffle-menu-button pz-admin-kebab-btn" type="button" aria-label="Acciones de ${escapeHtml(slotLabel(raffle))}" aria-expanded="false" data-menu-button>
                <span class="pz-admin-kebab-dots" aria-hidden="true"><span></span><span></span><span></span></span>
              </button>
              <div class="raffle-menu-panel pz-admin-dropdown" hidden>
                ${items.map((item) => `
                  <button
                    class="pz-admin-dropdown-item ${escapeHtml(item.className || '')}"
                    type="button"
                    data-control-action="${escapeHtml(item.action)}"
                    ${item.action === 'copy_link' ? `data-copy-href="${escapeHtml(item.href || '')}"` : ''}
                  >
                    ${raffleMenuIcon(item.action)}
                    <span>${escapeHtml(item.label)}</span>
                  </button>
                `).join('')}
              </div>
            </div>
          `;
        }

        function updateControlButtons(container, raffle, status) {
          if (!container) return;
          const configured = raffle?.is_configured === true;
          container.querySelectorAll('[data-action]').forEach((button) => {
            const action = button.dataset.action || '';
            const visible = action === 'reset'
              || (configured && action === 'close_selection' && status === 'active')
              || (configured && action === 'open_selection' && ['selection_closed', 'result_pending'].includes(status) && canOpenSelection(raffle))
              || (configured && action === 'open_raffle' && status === 'finalized' && !hasPublishedResult(raffle))
              || (configured && action === 'finalize' && !['draft', 'finalized'].includes(status));
            button.hidden = !visible;
            button.disabled = !visible;
          });
        }

        function getToken() {
          return ADMIN_AUTH_TOKEN;
        }

        async function pbRequest(path, options = {}) {
          const headers = { ...(options.headers || {}) };
          const token = getToken();
          if (token) headers.Authorization = `Bearer ${token}`;
          const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
          const result = await response.json().catch(() => null);
          if (!response.ok) throw new Error(result?.message || 'Error de comunicación con la plataforma.');
          return result;
        }

        async function adminRequest(path, options = {}) {
          const response = await fetch(path, options);
          const result = await response.json().catch(() => null);
          if (!response.ok || !result?.ok) throw new Error(result?.message || 'No se pudo completar la acción.');
          return result;
        }

        function fileUrl(raffle, filename, thumb = '320x220') {
          if (!raffle?.id || !filename || !POCKETBASE_URL) return '';
          return `${POCKETBASE_URL}/api/files/raffles/${encodeURIComponent(raffle.id)}/${encodeURIComponent(filename)}${thumb ? `?thumb=${encodeURIComponent(thumb)}` : ''}`;
        }

        function firstImage(raffle) {
          const prizes = prizesFromRaffle(raffle);
          const prizeImage = prizes.find((prize) => prize.image)?.image || '';
          if (prizeImage) return prizeImage;
          const images = Array.isArray(raffle?.images) ? raffle.images : (raffle?.images ? [raffle.images] : []);
          return images[0] || '';
        }

        function publicRaffleHref(raffle) {
          return `${PUBLIC_STORE_PATH}/rifa/${encodeURIComponent(raffle.slug || '')}`;
        }

        function openForm(raffle = null) {
          if (!raffle) return;
          closeOpenMenus();
          modal?.classList.remove('hidden');
          modal?.setAttribute('aria-hidden', 'false');
          show(formAlert, '');
          const configured = raffle?.is_configured === true;
          if (modalTitle) modalTitle.textContent = `${configured ? 'Editar' : 'Configurar'} ${slotLabel(raffle)}`;
          if (modalKicker) modalKicker.textContent = 'Administrar rifa';
          fields.id.value = raffle?.id || '';
          fields.title.value = configured ? (raffle?.title || '') : '';
          fields.accessCode.value = raffle?.access_code || '';
          fields.starts.value = toDatetimeLocal(raffle?.starts_at);
          fields.closes.value = toDatetimeLocal(raffle?.closes_at);
          fields.draw.value = toDatetimeLocal(raffle?.draw_at);
          fields.linkEnabled.checked = configured ? isLinkEnabled(raffle) : false;
          fields.showInStore.checked = configured ? raffle.show_in_store === true : false;
          fields.description.value = raffle?.description || '';
          fields.conditions.value = raffle?.conditions || '';
          fields.winnerMessage.value = raffle?.winner_message || DEFAULT_WINNER_MESSAGE;
          setWinnerMessagePanel(false);
          setPrizeDisplayMode(raffle?.prizes_display_mode || 'fixed');
          prizeState = raffle ? prizesFromRaffle(raffle) : [{
            id: makePrizeId(),
            name: '',
            description: '',
            image: '',
            raffleId: '',
          }];
          renderPrizeEditor();
          const status = calculatedStatus(raffle);
          if (currentStatusBadge) {
            currentStatusBadge.className = `raffle-status-pill ${status}`;
            currentStatusBadge.textContent = statusLabels[status] || status;
          }
          controlCard?.classList.toggle('hidden', raffle?.is_configured !== true);
          updateControlButtons(controlCard, raffle, status);
          formSnapshot = currentFormSignature();
          fields.title.focus();
        }

        function closeForm() {
          modal?.classList.add('hidden');
          modal?.setAttribute('aria-hidden', 'true');
          form?.reset();
          fields.id.value = '';
          fields.winnerMessage.value = DEFAULT_WINNER_MESSAGE;
          setWinnerMessagePanel(false);
          prizeState = [];
          renderPrizeEditor();
          controlCard?.classList.add('hidden');
          show(formAlert, '');
          formSnapshot = '';
        }

        async function requestCloseForm() {
          if (hasUnsavedChanges()) {
            const ok = await window.AdminDialog.confirm({
              title: 'Cerrar sin guardar',
              message: 'Los cambios no guardados se perderan.',
              confirmText: 'Cerrar sin guardar',
              cancelText: 'Seguir editando',
              tone: 'warning',
            });
            if (!ok) return;
          }
          closeForm();
        }

        async function saveRaffle(event) {
          event.preventDefault();
          show(formAlert, 'Guardando rifa...', 'info');
          const data = new FormData();
          data.append('id', fields.id.value.trim());
          data.append('title', fields.title.value.trim());
          const accessCode = fields.accessCode.value.trim();
          if (!accessCode) {
            show(formAlert, 'El código del grupo es obligatorio para guardar la rifa.', 'error');
            fields.accessCode.focus();
            return;
          }
          data.append('access_code', accessCode);
          data.append('starts_at', fields.starts.value);
          data.append('closes_at', fields.closes.value);
          data.append('draw_at', fields.draw.value);
          data.append('link_enabled', fields.linkEnabled.checked ? 'true' : 'false');
          data.append('show_in_store', fields.showInStore.checked ? 'true' : 'false');
          data.append('description', fields.description.value.trim());
          data.append('conditions', fields.conditions.value.trim());
          data.append('winner_message', fields.winnerMessage.value.trim() || DEFAULT_WINNER_MESSAGE);
          const prizes = readPrizeRows();
          const prizesDisplayMode = prizes.length > PRIZE_FIXED_LIMIT ? 'carousel' : getPrizeDisplayMode();
          data.append('prizes_display_mode', prizesDisplayMode);
          data.append('prizes_json', JSON.stringify(prizes));
          for (const row of currentPrizeRows()) {
            const file = await getOptimizedPrizeFileForRow(row);
            const id = row.dataset.prizeId || '';
            if (file && id) data.append(`prize_image_${id}`, file);
          }
          await adminRequest('/api/admin/raffles', { method: 'POST', body: data });
          closeForm();
          show(alertBox, 'Rifa guardada correctamente.', 'success');
          await loadData();
        }

        function renderSummary() {
          if (fields.total) fields.total.textContent = String(raffles.length);
          if (fields.active) fields.active.textContent = String(raffles.filter((raffle) => isLinkEnabled(raffle) && calculatedStatus(raffle) === 'active').length);
          if (fields.entries) fields.entries.textContent = String(allEntries.filter((entry) => entry.status === 'active').length);
        }

        function renderList() {
          if (!list) return;
          if (!raffles.length) {
            list.innerHTML = '<div class="empty-state">No hay rifas creadas todavía.</div>';
            return;
          }

          list.innerHTML = raffles.map((raffle) => {
            const image = firstImage(raffle);
            const thumb = image ? `<img src="${fileUrl(raffle, image)}" alt="">` : 'RF';
            const status = calculatedStatus(raffle);
            const isSelected = raffle.id === selectedRaffleId;
            const href = publicRaffleHref(raffle);
            const fullHref = `${window.location.origin}${href}`;
            const titleText = displayTitle(raffle);
            const editText = raffle.is_configured === true ? 'Editar' : 'Configurar';
            const participants = activeEntryCount(raffle.id);
            const accessEnabled = isLinkEnabled(raffle);
            const accessText = accessEnabled ? 'Acceso activado' : 'Desactivado';
            const accessClass = accessEnabled ? 'is-enabled' : 'is-disabled';
            return `
              <article class="raffle-row ${isSelected ? 'is-selected' : ''}" data-raffle-id="${escapeHtml(raffle.id)}" tabindex="0" role="button" aria-pressed="${isSelected ? 'true' : 'false'}">
                <div class="raffle-row-main">
                  <div class="raffle-thumb">${thumb}</div>
                  <div class="raffle-row-copy">
                    <p class="raffle-row-slot">${escapeHtml(slotLabel(raffle))}</p>
                    <h3 class="raffle-row-title">${escapeHtml(titleText)}</h3>
                    <p class="raffle-row-meta raffle-row-access ${accessClass}">${escapeHtml(accessText)}</p>
                  </div>
                  <div class="raffle-row-head-actions">
                    <button class="raffle-select-pill js-raffle-select ${isSelected ? 'is-selected' : ''}" type="button">
                      ${isSelected ? 'Seleccionada' : 'Seleccionar'}
                    </button>
                    <button class="raffle-participant-pill js-raffle-select" type="button">
                      ${escapeHtml(participantLabel(participants))}
                    </button>
                  </div>
                </div>
                <div class="raffle-row-actions">
                  <a class="raffle-btn pz-admin-action-btn" href="${escapeHtml(href)}" target="_blank" rel="noopener">
                    ${adminIconSvg('view', 'pz-admin-action-icon')}
                    <span>Ver rifa pública</span>
                  </a>
                  <button class="raffle-btn pz-admin-action-btn js-raffle-edit" type="button">
                    ${adminIconSvg(raffle.is_configured === true ? 'edit' : 'settings', 'pz-admin-action-icon')}
                    <span>${escapeHtml(editText)}</span>
                  </button>
                  ${actionMenuHtml(raffle, status, fullHref)}
                </div>
              </article>
            `;
          }).join('');
        }

        function renderEntries() {
          const raffle = raffles.find((item) => item.id === selectedRaffleId);
          const configured = raffle?.is_configured === true;
          if (entriesSubtitle) {
            entriesSubtitle.textContent = raffle
              ? configured
                ? `${slotLabel(raffle)} · ${displayTitle(raffle)} · ${entries.filter((entry) => entry.status === 'active').length} participantes activos`
                : 'Esta rifa todavía no está configurada.'
              : 'Selecciona una rifa para ver sus participantes y resultado.';
          }
          resultBox?.classList.toggle('hidden', !configured);
          renderResultChecker(raffle);
          renderWinnerContact();
          if (!entryList) return;
          if (!raffle) {
            entryList.innerHTML = '<div class="empty-state">Selecciona una rifa para ver sus participantes y resultado.</div>';
            return;
          }
          if (!configured) {
            entryList.innerHTML = '<div class="empty-state">Esta rifa todavía no está configurada. Configúrala antes de revisar participantes o publicar resultado.</div>';
            return;
          }
          const activeEntries = entries.filter((entry) => entry.status === 'active');
          const cancelledEntries = entries.filter((entry) => entry.status === 'cancelled');
          if (!entries.length) {
            entryList.innerHTML = activeEntriesEmptyStateHtml(raffle);
            return;
          }
          const activePhones = new Set(activeEntries.map((entry) => entry.phone).filter(Boolean));
          const activeHtml = activeEntries.length
            ? activeEntries.map((entry) => `
            <article class="entry-row" data-entry-id="${escapeHtml(entry.id)}">
              <div class="entry-number">${escapeHtml(entry.chosen_number || '--')}</div>
              <div>
                <p class="entry-title">${escapeHtml(entry.phone || '')}</p>
                <p class="entry-meta">${escapeHtml(entry.receipt_code || '')} · ${escapeHtml(dateLabel(entry.created))} · Activo</p>
              </div>
              <button class="raffle-btn danger js-entry-cancel" type="button">Cancelar participación</button>
            </article>
          `).join('')
            : activeEntriesEmptyStateHtml(raffle);
          const cancelledHtml = cancelledEntries.length
            ? `
              <p class="entry-section-title">Participaciones canceladas</p>
              ${cancelledEntries.map((entry) => `
                <article class="entry-row" data-entry-id="${escapeHtml(entry.id)}">
                  <div class="entry-number">${escapeHtml(entry.chosen_number || '--')}</div>
                  <div>
                    <p class="entry-title">${escapeHtml(entry.phone || '')}</p>
                    <p class="entry-meta">Cancelada: ${escapeHtml(dateLabel(entry.cancelled_at || entry.updated))}${entry.cancelled_reason ? ` · ${escapeHtml(entry.cancelled_reason)}` : ''}</p>
                  </div>
                  ${activePhones.has(entry.phone)
                    ? '<span class="entry-status-badge">Ya participó nuevamente</span>'
                    : entry.can_reenter === true
                      ? '<span class="entry-status-badge allowed">Autorizado para participar de nuevo</span>'
                      : '<button class="raffle-btn js-entry-allow" type="button">Permitir participar de nuevo</button>'}
                </article>
              `).join('')}
            `
            : '';
          entryList.innerHTML = `${activeHtml}${cancelledHtml}`;
        }

        async function loadRaffles() {
          const result = await adminRequest('/api/admin/raffles');
          raffles = (result.raffles || []).sort((a, b) => Number(a.slot_number || 0) - Number(b.slot_number || 0));
          if (!raffles.some((raffle) => raffle.id === selectedRaffleId)) {
            selectedRaffleId = raffles[0]?.id || '';
          }
        }

        async function loadAllEntries() {
          if (!CURRENT_STORE_ID) {
            allEntries = [];
            return;
          }
          const items = [];
          let page = 1;
          const perPage = 200;
          while (true) {
            const query = new URLSearchParams({
              filter: STORE_FILTER,
              sort: 'raffle,chosen_number',
              page: String(page),
              perPage: String(perPage),
            });
            const result = await pbRequest(`/api/collections/raffle_entries/records?${query.toString()}`);
            items.push(...(result.items || []));
            if (page >= Number(result.totalPages || 1)) break;
            page += 1;
          }
          allEntries = items;
        }

        async function loadEntries() {
          if (!selectedRaffleId) {
            entries = [];
            return;
          }
          entries = allEntries
            .filter((entry) => entry.raffle === selectedRaffleId)
            .sort((a, b) => String(a.chosen_number || '').localeCompare(String(b.chosen_number || '')));
        }

        async function loadData() {
          await loadRaffles();
          await loadAllEntries();
          await loadEntries();
          renderSummary();
          renderList();
          renderEntries();
        }

        function activeEntriesEmptyStateHtml(raffle) {
          const title = isDrawDateReached(raffle)
            ? 'No hay participantes activos en esta rifa.'
            : 'Todavía no hay participantes activos en esta rifa.';
          const detail = isDrawDateReached(raffle)
            ? 'Puedes chequear el número sorteado y publicar el resultado sin ganador para cerrar la rifa.'
            : 'Cuando llegue la fecha del sorteo, podrás publicar el número sorteado sin ganador si nadie participa.';
          return `<div class="empty-state">${escapeHtml(title)}<br>${escapeHtml(detail)}</div>`;
        }

        async function selectRaffle(id) {
          selectedRaffleId = id;
          await loadEntries();
          renderSummary();
          renderList();
          renderEntries();
          show(entriesAlert, '');
        }

        function datetimePromptValue(value) {
          return toDatetimeLocal(value || new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString());
        }

        function closeDateModal(result = null) {
          dateModal?.classList.add('hidden');
          dateModal?.setAttribute('aria-hidden', 'true');
          if (dateError) {
            dateError.className = 'alert alert-error hidden';
            dateError.textContent = '';
          }
          const resolve = pendingDateResolve;
          pendingDateResolve = null;
          if (resolve) resolve(result);
        }

        function requestOpenDates(raffle, title = 'Abrir selección de números') {
          if (!dateModal || !dateClosesInput || !dateDrawInput) return Promise.resolve(null);
          if (dateModalTitle) dateModalTitle.textContent = title;
          dateClosesInput.value = datetimePromptValue(raffle?.closes_at);
          dateDrawInput.value = datetimePromptValue(raffle?.draw_at || raffle?.closes_at);
          dateModal.classList.remove('hidden');
          dateModal.setAttribute('aria-hidden', 'false');
          dateClosesInput.focus();
          return new Promise((resolve) => {
            pendingDateResolve = resolve;
          });
        }

        function saveDateModal() {
          if (!dateClosesInput || !dateDrawInput) return;
          const closesAt = dateClosesInput.value;
          const drawAt = dateDrawInput.value;
          const closesDate = new Date(closesAt);
          const drawDate = new Date(drawAt);
          const now = Date.now();
          if (!closesAt || Number.isNaN(closesDate.getTime()) || closesDate.getTime() <= now) {
            if (dateError) {
              dateError.className = 'alert alert-error';
              dateError.textContent = 'El nuevo cierre debe ser futuro.';
            }
            return;
          }
          if (!drawAt || Number.isNaN(drawDate.getTime()) || drawDate.getTime() <= closesDate.getTime()) {
            if (dateError) {
              dateError.className = 'alert alert-error';
              dateError.textContent = 'El sorteo debe ser posterior al cierre de selección.';
            }
            return;
          }
          closeDateModal({ closes_at: closesAt, draw_at: drawAt });
        }

        function closeWinnerModal() {
          pendingWinner = null;
          winnerModal?.classList.add('hidden');
          winnerModal?.setAttribute('aria-hidden', 'true');
          if (winnerModalWarning) {
            winnerModalWarning.className = 'alert alert-error hidden';
            winnerModalWarning.textContent = '';
          }
        }

        function openWinnerModal(entry, number) {
          pendingWinner = { entry, number };
          if (winnerModalNumber) winnerModalNumber.textContent = number || '--';
          if (winnerModalClient) winnerModalClient.textContent = entry?.phone || 'cliente';
          if (winnerModalPhone) winnerModalPhone.textContent = entry?.phone || '--';
          const validPhone = Boolean(winnerWhatsappHref(entry, 'Mensaje'));
          if (winnerModalWarning) {
            winnerModalWarning.className = validPhone ? 'alert alert-error hidden' : 'alert alert-error';
            winnerModalWarning.textContent = validPhone ? '' : 'El telefono del ganador no parece valido para WhatsApp. Revisa el numero antes de contactar.';
          }
          if (winnerModalWhatsappBtn) winnerModalWhatsappBtn.disabled = !validPhone;
          winnerModal?.classList.remove('hidden');
          winnerModal?.setAttribute('aria-hidden', 'false');
          winnerModalPublishBtn?.focus();
        }

        async function controlRaffleAction(id, action, sourceBox = alertBox) {
          const raffle = raffles.find((item) => item.id === id);
          if (!raffle) {
            show(sourceBox, 'Selecciona una rifa.', 'error');
            return;
          }

          const messages = {
            close_selection: ['¿Cerrar selección de números?', 'Los clientes ya no podrán reservar números para esta rifa.', 'Selección cerrada correctamente.'],
            open_selection: ['¿Abrir selección de números?', 'La rifa volverá a aceptar reservas si las fechas lo permiten.', 'Selección abierta correctamente.'],
            finalize: ['¿Finalizar esta rifa?', 'Esta acción cerrará la rifa y ya no se podrán publicar cambios para los clientes.', 'Rifa finalizada correctamente.'],
            open_raffle: ['¿Abrir esta rifa?', 'La rifa volverá al estado que corresponda según sus fechas. No se borrarán participantes ni premios.', 'Rifa abierta correctamente.'],
            reset: ['¿Restablecer esta rifa?', 'Se borrarán participantes, números reservados, premios, imágenes, fechas, código y resultado. El espacio volverá a Nueva rifa. Esta acción no se puede deshacer.', 'Rifa restablecida correctamente.'],
          };
          const [title, detail, success] = messages[action] || ['¿Confirmar acción?', 'Confirma para continuar.', 'Acción realizada correctamente.'];
          const confirmTextByAction = {
            close_selection: 'Cerrar seleccion',
            open_selection: 'Abrir seleccion',
            finalize: 'Finalizar rifa',
            open_raffle: 'Abrir rifa',
            reset: 'Restablecer',
          };
          const dangerousActions = new Set(['finalize', 'reset']);
          const confirmed = await window.AdminDialog.confirm({
            title,
            message: detail,
            confirmText: confirmTextByAction[action] || 'Confirmar',
            cancelText: 'Cancelar',
            tone: dangerousActions.has(action) ? 'danger' : 'warning',
          });
          if (!confirmed) return;

          const body = { id, action };
          if ((action === 'open_selection' || action === 'open_raffle') && closePassed(raffle)) {
            const nextDates = await requestOpenDates(raffle, action === 'open_raffle' ? 'Abrir rifa' : 'Abrir selección de números');
            if (!nextDates) return;
            body.closes_at = nextDates.closes_at;
            body.draw_at = nextDates.draw_at;
          }

          await adminRequest('/api/admin/raffles', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          show(sourceBox, success, 'success');
          if (action === 'reset' && selectedRaffleId === id) entries = [];
          await loadData();
        }

        async function publishWinnerConfirmed(writeWhatsapp = false) {
          if (!selectedRaffleId || !pendingWinner) return;
          const raffle = getSelectedRaffle();
          const availability = getResultCheckAvailability(raffle);
          if (!availability.enabled) {
            show(winnerModalWarning || entriesAlert, resultAvailabilityMessage(availability, true), 'error');
            return;
          }
          const number = normalizeNumber(pendingWinner.number);
          const checkedEntryId = String(resultCheck?.entry?.id || '');
          const pendingEntryId = String(pendingWinner.entry?.id || '');
          if (!resultCheck || resultCheck.number !== number || resultCheck.outcome !== 'winner' || !checkedEntryId || checkedEntryId !== pendingEntryId) {
            show(winnerModalWarning || entriesAlert, 'Primero chequea el número sorteado.', 'error');
            return;
          }
          await adminRequest('/api/admin/raffles', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: selectedRaffleId, action: 'publish_winner', number }),
          });
          closeWinnerModal();
          show(entriesAlert, writeWhatsapp ? 'Ganador publicado. Puedes contactar al cliente por WhatsApp.' : 'Ganador publicado correctamente.', 'success');
          await loadData();
          const data = winnerContactData();
          if (writeWhatsapp) openWinnerWhatsapp(data);
        }

        async function publishResult(action) {
          const raffle = getSelectedRaffle();
          const availability = getResultCheckAvailability(raffle);
          if (!availability.enabled) {
            show(entriesAlert, resultAvailabilityMessage(availability, true), 'error');
            return;
          }
          const number = normalizeNumber(resultNumber.value);
          if (!resultCheck || resultCheck.number !== number) {
            show(entriesAlert, 'Primero chequea el número sorteado.', 'error');
            return;
          }

          if (action === 'publish_winner') {
            if (resultCheck.outcome !== 'winner' || !resultCheck.entry) {
              show(entriesAlert, 'Primero chequea el número sorteado.', 'error');
              return;
            }
            openWinnerModal(resultCheck.entry, resultCheck.number);
            return;
          }

          if (action !== 'publish_no_winner' || resultCheck.outcome !== 'no_winner') {
            show(entriesAlert, 'Primero chequea el número sorteado.', 'error');
            return;
          }

          const ok = await window.AdminDialog.confirm({
            title: '¿Publicar resultado sin ganador?',
            message: `Vas a publicar que el número ${number} salió sorteado, pero no pertenece a ningún participante activo.`,
            confirmText: 'Publicar sin ganador',
            cancelText: 'Volver',
            tone: 'warning',
          });
          if (!ok) return;

          await adminRequest('/api/admin/raffles', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: selectedRaffleId, action: 'publish_no_winner', number }),
          });
          show(entriesAlert, 'Resultado publicado correctamente.', 'success');
          await loadData();
        }

        async function cancelEntry(entryId) {
          if (!selectedRaffleId) return;
          const ok = await window.AdminDialog.confirm({
            title: 'Cancelar participacion',
            message: 'Este numero quedara disponible para otros clientes, pero este telefono no podra volver a participar salvo que lo autorices.',
            confirmText: 'Cancelar participacion',
            cancelText: 'Volver',
            tone: 'danger',
          });
          if (!ok) return;
          const reason = await window.AdminDialog.prompt({
            title: 'Motivo de cancelacion',
            message: 'Puedes indicar un motivo para dejar registro interno.',
            inputLabel: 'Motivo opcional',
            inputPlaceholder: 'No pertenece al grupo, telefono incorrecto, duplicado u otro',
            inputValue: '',
            required: false,
            confirmText: 'Continuar',
            cancelText: 'Volver',
            tone: 'info',
          });
          if (reason === null) return;
          await adminRequest('/api/admin/raffles', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: selectedRaffleId, action: 'cancel_entry', entryId, reason }),
          });
          show(entriesAlert, 'Participación cancelada correctamente.', 'success');
          await loadAllEntries();
          await loadEntries();
          renderSummary();
          renderEntries();
          renderList();
        }

        async function allowEntryReenter(entryId) {
          if (!selectedRaffleId) return;
          const ok = await window.AdminDialog.confirm({
            title: 'Permitir participar de nuevo',
            message: 'El cliente podra entrar nuevamente con su telefono y escoger un numero disponible.',
            confirmText: 'Permitir',
            cancelText: 'Cancelar',
            tone: 'warning',
          });
          if (!ok) return;
          await adminRequest('/api/admin/raffles', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: selectedRaffleId, action: 'allow_entry_reenter', entryId }),
          });
          show(entriesAlert, 'El cliente ya puede participar nuevamente.', 'success');
          await loadAllEntries();
          await loadEntries();
          renderSummary();
          renderEntries();
          renderList();
        }

        sidebarOpenBtn?.addEventListener('click', openSidebar);
        sidebarOverlay?.addEventListener('click', closeSidebar);
        document.addEventListener('click', (event) => {
          if (!event.target.closest('.raffle-menu')) closeOpenMenus();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          if (winnerModal && !winnerModal.classList.contains('hidden')) {
            closeWinnerModal();
            return;
          }
          if (dateModal && !dateModal.classList.contains('hidden')) {
            closeDateModal(null);
            return;
          }
          if (modal && !modal.classList.contains('hidden')) {
            requestCloseForm();
            return;
          }
          closeOpenMenus();
          closeSidebar();
        });
        newBtn?.addEventListener('click', () => loadData().catch((error) => show(alertBox, error.message || 'No se pudieron cargar las rifas.', 'error')));
        dateCancelX?.addEventListener('click', () => closeDateModal(null));
        dateCancelBtn?.addEventListener('click', () => closeDateModal(null));
        dateSaveBtn?.addEventListener('click', saveDateModal);
        dateModal?.addEventListener('click', (event) => {
          if (event.target === dateModal) closeDateModal(null);
        });
        winnerModalCancelX?.addEventListener('click', closeWinnerModal);
        winnerModalCancelBtn?.addEventListener('click', closeWinnerModal);
        winnerModalPublishBtn?.addEventListener('click', () => publishWinnerConfirmed(false).catch((error) => show(entriesAlert, error.message || 'No se pudo publicar el ganador.', 'error')));
        winnerModalWhatsappBtn?.addEventListener('click', () => publishWinnerConfirmed(true).catch((error) => show(entriesAlert, error.message || 'No se pudo publicar el ganador.', 'error')));
        winnerModal?.addEventListener('click', (event) => {
          if (event.target === winnerModal) closeWinnerModal();
        });
        winnerWhatsappBtn?.addEventListener('click', () => openWinnerWhatsapp(winnerContactData()));
        winnerCopyBtn?.addEventListener('click', async () => {
          const data = winnerContactData();
          if (!data) return;
          try {
            await navigator.clipboard.writeText(data.message);
            show(entriesAlert, 'Mensaje copiado correctamente.', 'success');
          } catch (_) {
            show(entriesAlert, 'No se pudo copiar el mensaje automáticamente.', 'error');
          }
        });
        fields.addPrize?.addEventListener('click', () => {
          if (!fields.prizesList) return;
          const nextPrize = { id: makePrizeId(), name: '', description: '', image: '', raffleId: fields.id.value || '' };
          const count = currentPrizeRows().length;
          if (!count) fields.prizesList.innerHTML = '';
          fields.prizesList.insertAdjacentHTML('beforeend', prizeEditorRowHtml(nextPrize, count));
          updatePrizeDisplayModeAvailability();
        });
        fields.prizesList?.addEventListener('click', (event) => {
          const removeButton = event.target.closest('.js-prize-remove');
          if (!removeButton) return;
          const row = removeButton.closest('[data-prize-id]');
          clearPrizeRowUpload(row);
          row?.remove();
          if (!currentPrizeRows().length) {
            prizeState = [];
            renderPrizeEditor();
          } else {
            updatePrizeDisplayModeAvailability();
          }
        });
        fields.prizesList?.addEventListener('change', (event) => {
          const input = event.target.closest('.js-prize-file');
          if (!input) return;
          handleRafflePrizeFileChange(input).catch((error) => show(formAlert, error?.message || 'No se pudo optimizar la imagen del premio.', 'error'));
        });
        winnerMessageToggle?.addEventListener('click', () => {
          setWinnerMessagePanel(winnerMessagePanel?.hidden !== false);
        });
        fields.winnerMessage?.addEventListener('input', updateWinnerMessageBadge);
        form?.addEventListener('submit', (event) => saveRaffle(event).catch((error) => show(formAlert, error.message || 'No se pudo guardar la rifa.', 'error')));
        document.getElementById('raffle-cancel-btn')?.addEventListener('click', requestCloseForm);
        modalCloseBtn?.addEventListener('click', requestCloseForm);
        modal?.addEventListener('click', (event) => {
          if (event.target === modal) requestCloseForm();
        });
        controlCard?.addEventListener('click', (event) => {
          const button = event.target.closest('.js-form-control-action');
          if (!button || !fields.id.value) return;
          const action = button.dataset.action || '';
          controlRaffleAction(fields.id.value, action, formAlert).catch((error) => show(formAlert, error.message || 'No se pudo actualizar la rifa.', 'error'));
        });
        list?.addEventListener('click', (event) => {
          const row = event.target.closest('[data-raffle-id]');
          if (!row) return;
          const id = row.dataset.raffleId || '';
          const menuButton = event.target.closest('[data-menu-button]');
          if (menuButton) {
            event.preventDefault();
            event.stopPropagation();
            const menu = menuButton.closest('.raffle-menu');
            const rowWithMenu = menuButton.closest('.raffle-row');
            const panel = menu?.querySelector('.raffle-menu-panel');
            if (panel) {
              const willOpen = panel.hidden;
              closeOpenMenus(panel);
              panel.hidden = !willOpen;
              menuButton.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
              rowWithMenu?.classList.toggle('is-menu-open', willOpen);
            }
            return;
          }
          const controlButton = event.target.closest('[data-control-action]');
          if (controlButton) {
            const action = controlButton.dataset.controlAction || '';
            if (action === 'copy_link') {
              const href = controlButton.dataset.copyHref || '';
              closeOpenMenus();
              if (href && navigator.clipboard?.writeText) {
                navigator.clipboard.writeText(href)
                  .then(() => show(alertBox, 'Enlace copiado correctamente.', 'success'))
                  .catch(() => show(alertBox, 'No se pudo copiar el enlace automáticamente.', 'error'));
              } else if (href) {
                show(alertBox, 'No se pudo copiar el enlace automáticamente.', 'error');
              }
              return;
            }
            closeOpenMenus();
            if (action === 'edit') {
              const raffle = raffles.find((item) => item.id === id);
              if (raffle) openForm(raffle);
              return;
            }
            controlRaffleAction(id, action, alertBox).catch((error) => show(alertBox, error.message || 'No se pudo actualizar la rifa.', 'error'));
            return;
          }
          if (event.target.closest('.js-raffle-select')) {
            selectRaffle(id).catch((error) => show(entriesAlert, error.message || 'No se pudieron cargar participantes.', 'error'));
            return;
          }
          if (event.target.closest('.js-raffle-edit')) {
            const raffle = raffles.find((item) => item.id === id);
            if (raffle) openForm(raffle);
            return;
          }
          if (!event.target.closest('a,button,input,textarea,select,.raffle-menu-panel')) {
            selectRaffle(id).catch((error) => show(entriesAlert, error.message || 'No se pudieron cargar participantes.', 'error'));
          }
        });
        list?.addEventListener('keydown', (event) => {
          const row = event.target.closest('[data-raffle-id]');
          if (!row || !['Enter', ' '].includes(event.key)) return;
          if (event.target !== row) return;
          event.preventDefault();
          selectRaffle(row.dataset.raffleId || '').catch((error) => show(entriesAlert, error.message || 'No se pudieron cargar participantes.', 'error'));
        });
        entryList?.addEventListener('click', (event) => {
          const cancelButton = event.target.closest('.js-entry-cancel');
          const allowButton = event.target.closest('.js-entry-allow');
          if (!cancelButton && !allowButton) return;
          const row = (cancelButton || allowButton).closest('[data-entry-id]');
          const id = row?.dataset?.entryId || '';
          if (!id) return;
          if (cancelButton) {
            cancelEntry(id).catch((error) => show(entriesAlert, error.message || 'No se pudo cancelar la participación.', 'error'));
            return;
          }
          allowEntryReenter(id).catch((error) => show(entriesAlert, error.message || 'No se pudo autorizar una nueva participación.', 'error'));
        });
        resultStartCheckBtn?.addEventListener('click', openResultCheckPanel);
        checkResultBtn?.addEventListener('click', checkResultNumber);
        resultResetCheckBtn?.addEventListener('click', () => {
          clearResultCheck(true);
          resultNumber?.focus();
        });
        resultNumber?.addEventListener('input', () => {
          resultNumber.value = String(resultNumber.value || '').replace(/\D/g, '').slice(0, 2);
          if (resultCheck) clearResultCheck(true);
        });
        resultNumber?.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter') return;
          event.preventDefault();
          checkResultNumber();
        });
        publishWinnerBtn?.addEventListener('click', () => publishResult('publish_winner').catch((error) => show(entriesAlert, error.message || 'No se pudo publicar el ganador.', 'error')));
        publishNoWinnerBtn?.addEventListener('click', () => publishResult('publish_no_winner').catch((error) => show(entriesAlert, error.message || 'No se pudo publicar el resultado.', 'error')));
        loadData().catch((error) => {
          if (list) list.innerHTML = `<div class="empty-state">${escapeHtml(error.message || 'No se pudieron cargar las rifas.')}</div>`;
        });
      })();
    </script>
  </body>
</html>
