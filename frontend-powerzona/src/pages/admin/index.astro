			.expiration-list {
				display: grid;
				grid-template-columns: minmax(0, 1fr);
				gap: 10px;
				margin-top: 18px;
				padding-right: 8px;
				min-width: 0;
				max-width: 100%;
				overflow: hidden;
			}

			.expiration-item {
				display: grid;
				grid-template-columns: 14px minmax(0, 1fr) auto;
				align-items: center;
				gap: 12px;
				padding: 14px 14px 14px 16px;
				box-sizing: border-box;
				max-width: 100%;
				border-radius: 22px;
				background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
				border: 1px solid rgba(226, 232, 240, 0.96);
				box-shadow:
					0 18px 34px rgba(15, 23, 42, 0.075),
					inset 0 1px 0 rgba(255,255,255,0.95);
				position: relative;
				overflow: hidden;
				isolation: isolate;
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
			}

			.expiration-item:hover {
				transform: translateY(-2px);
				box-shadow:
					0 22px 42px rgba(15, 23, 42, 0.11),
					inset 0 1px 0 rgba(255,255,255,0.95);
				border-color: color-mix(in srgb, var(--expiration-alert, #2563eb) 28%, #e2e8f0);
			}

			.expiration-item::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 5px;
				background: var(--expiration-alert, #2563eb);
				box-shadow: 0 0 28px color-mix(in srgb, var(--expiration-alert, #2563eb) 50%, transparent);
			}

			.expiration-item::after {
				content: '';
				position: absolute;
				inset: -40% auto auto -18%;
				width: 180px;
				height: 180px;
				border-radius: 50%;
				background: color-mix(in srgb, var(--expiration-alert, #2563eb) 10%, transparent);
				z-index: -1;
			}

			.expiration-item.expired,
			.expiration-item.one-month { --expiration-alert: #dc2626; --expiration-soft: #fee2e2; --expiration-text: #991b1b; }
			.expiration-item.two-months { --expiration-alert: #f59e0b; --expiration-soft: #fef3c7; --expiration-text: #92400e; }
			.expiration-item.three-months { --expiration-alert: #2563eb; --expiration-soft: #dbeafe; --expiration-text: #1d4ed8; }

			.expiration-signal {
				width: 12px;
				height: 12px;
				border-radius: 999px;
				background: var(--expiration-alert, #2563eb);
				box-shadow:
					0 0 0 5px var(--expiration-soft, #dbeafe),
					0 8px 18px color-mix(in srgb, var(--expiration-alert, #2563eb) 35%, transparent);
