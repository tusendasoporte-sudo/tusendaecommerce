		const totalStyle = 'display:inline-flex;align-items:center;justify-content:center;padding:7px 11px;border-radius:999px;background:#ecfdf5;color:#166534;border:1px solid rgba(22,163,74,0.18);font-size:12px;font-weight:950;white-space:nowrap;';

