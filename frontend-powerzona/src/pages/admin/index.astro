			.expiration-side {
				display: flex;
				align-items: center;
				justify-content: flex-end;
			}

			.expiration-view {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 7px;
				min-height: 38px;
				padding: 0 15px 0 16px;
				border-radius: 999px;
				background: var(--expiration-alert, #2563eb);
				color: #ffffff;
				font-size: 12px;
				font-weight: 950;
				text-decoration: none;
				box-shadow:
					0 16px 30px color-mix(in srgb, var(--expiration-alert, #2563eb) 32%, transparent),
					inset 0 1px 0 rgba(255,255,255,0.28);
