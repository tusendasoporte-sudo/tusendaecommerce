			function getProductsNearExpiration() {
				const now = new Date();
				now.setHours(0, 0, 0, 0);

				const limit = new Date(now);
				limit.setDate(limit.getDate() + Number(selectedExpirationRange || 30));
				limit.setHours(23, 59, 59, 999);

				return products
					.map((product) => {
						if (!product.expiration_date) return null;
						const expirationDate = new Date(product.expiration_date);
						if (Number.isNaN(expirationDate.getTime())) return null;
						expirationDate.setHours(0, 0, 0, 0);
						if (expirationDate > limit) return null;
						const daysLeft = Math.ceil((expirationDate - now) / 86400000);
						return { product, expirationDate, daysLeft };
					})
					.filter(Boolean)
					.sort((a, b) => a.daysLeft - b.daysLeft);
			}

			function getExpirationStatus(item) {
				if (item.daysLeft < 0) return { label: 'Vencido', className: 'expired' };
				if (item.daysLeft <= 30) return { label: '1 mes', className: 'one-month' };
				if (item.daysLeft <= 60) return { label: '2 meses', className: 'two-months' };
				return { label: '3 meses', className: 'three-months' };
			}

			function getExpirationPalette(className) {
				if (className === 'two-months') {
					return { main: '#f59e0b', soft: '#fffbeb', chip: '#fef3c7', text: '#92400e', border: 'rgba(245, 158, 11, 0.28)' };
				}
				if (className === 'three-months') {
					return { main: '#2563eb', soft: '#eff6ff', chip: '#dbeafe', text: '#1d4ed8', border: 'rgba(37, 99, 235, 0.24)' };
				}
				return { main: '#dc2626', soft: '#fff1f2', chip: '#fee2e2', text: '#991b1b', border: 'rgba(220, 38, 38, 0.28)' };
			}

			function getExpirationDaysText(daysLeft) {
				if (daysLeft < 0) return `Vencido hace ${Math.abs(daysLeft)} día${Math.abs(daysLeft) === 1 ? '' : 's'}`;
				if (daysLeft === 0) return 'Vence hoy';
				if (daysLeft === 1) return 'Vence mañana';
				return `Faltan ${daysLeft} días`;
			}

			function renderExpirationProducts() {
				const nearExpiration = getProductsNearExpiration();
				const expiredCount = nearExpiration.filter((item) => item.daysLeft < 0).length;
				const validCount = nearExpiration.length - expiredCount;
				const rangeText = selectedExpirationRange === 30 ? '1 mes' : selectedExpirationRange === 60 ? '2 meses' : '3 meses';

				expirationProductsMeta.textContent = expiredCount
					? `${validCount} por vencer en ${rangeText} · ${expiredCount} vencido${expiredCount === 1 ? '' : 's'}`
					: `${validCount} producto${validCount === 1 ? '' : 's'} por vencer en ${rangeText}`;

				if (!nearExpiration.length) {
					expirationProductsList.innerHTML = '<div class="empty-state" style="grid-column: 1 / -1;">No hay productos con vencimiento dentro de este rango.</div>';
					return;
				}

				expirationProductsList.innerHTML = nearExpiration.map((item) => {
					const product = item.product;
					const status = getExpirationStatus(item);
					const palette = getExpirationPalette(status.className);
					const stock = Number(product.stock || 0);
					const rowStyle = `display:flex;align-items:center;gap:10px;width:calc(100% - 8px);max-width:calc(100% - 8px);box-sizing:border-box;min-width:0;margin-right:8px;padding:14px 14px 14px 16px;border-radius:22px;background:linear-gradient(135deg, ${palette.soft}, #ffffff 62%);border:1px solid ${palette.border};box-shadow:0 18px 34px rgba(15,23,42,0.08), inset 0 1px 0 rgba(255,255,255,0.95);position:relative;overflow:hidden;flex-wrap:wrap;`;
					const leftBarStyle = `position:absolute;left:0;top:0;bottom:0;width:5px;background:${palette.main};box-shadow:0 0 26px ${palette.border};`;
					const dotStyle = `width:12px;height:12px;border-radius:999px;background:${palette.main};box-shadow:0 0 0 5px ${palette.chip}, 0 8px 18px ${palette.border};flex:0 0 auto;`;
					const contentStyle = 'display:flex;align-items:center;gap:9px;min-width:0;flex:1 1 360px;flex-wrap:wrap;max-width:100%;';
					const nameStyle = 'margin:0;font-size:15px;font-weight:950;letter-spacing:-0.02em;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;min-width:0;flex:1 1 180px;';
					const neutralChipStyle = 'display:inline-flex;align-items:center;min-height:30px;padding:0 10px;border-radius:999px;background:#ffffff;border:1px solid rgba(226,232,240,0.98);color:#334155;font-size:12px;font-weight:900;white-space:nowrap;';
					const priorityChipStyle = `display:inline-flex;align-items:center;min-height:30px;padding:0 11px;border-radius:999px;background:${palette.chip};color:${palette.text};font-size:11px;font-weight:950;white-space:nowrap;box-shadow:inset 0 0 0 1px ${palette.border};`;
					const daysStyle = `font-size:12px;font-weight:950;color:${palette.text};white-space:nowrap;`;
					const viewStyle = `display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:0 16px;border-radius:999px;background:${palette.main};color:#ffffff;font-size:12px;font-weight:950;text-decoration:none;box-shadow:0 12px 22px ${palette.border}, inset 0 1px 0 rgba(255,255,255,0.28);white-space:nowrap;flex:0 0 auto;margin-left:auto;max-width:calc(100% - 4px);`;

					return `
						<div class="expiration-item ${status.className}" style="${rowStyle}">
							<span style="${leftBarStyle}" aria-hidden="true"></span>
							<span class="expiration-signal" style="${dotStyle}" aria-hidden="true"></span>
							<div class="expiration-main" style="${contentStyle}">
								<p class="expiration-name" style="${nameStyle}">${escapeHtml(product.name || 'Producto sin nombre')}</p>
								<span class="expiration-stock" style="${neutralChipStyle}">Stock: ${escapeHtml(stock)}</span>
								<span class="expiration-pill ${status.className}" style="${priorityChipStyle}">${escapeHtml(status.label)}</span>
								<span class="expiration-date-chip" style="${neutralChipStyle}">${escapeHtml(formatDateOnly(product.expiration_date))}</span>
								<span class="expiration-days" style="${daysStyle}">${escapeHtml(getExpirationDaysText(item.daysLeft))}</span>
							</div>
							<a class="expiration-view" style="${viewStyle}" href="${productAdminUrl(product)}" aria-label="Ver producto ${escapeHtml(product.name || 'Producto')}">Ver →</a>
						</div>
					`;
				}).join('');
			}

			function renderStatusGrid(metrics) {
				const statuses = ['confirmed', 'pending', 'preparing', 'delivered', 'cancelled'];
				statusGrid.classList.add('order-status-list');

				statusGrid.innerHTML = statuses.map((status) => `
					<div class="order-status-row">
						<span>${escapeHtml(statusLabels[status])}</span>
						<strong>${metrics.statusCounts[status] || 0}</strong>
					</div>
				`).join('');
			}

			function renderRatingSummary() {
				if (!ratingSummaryGrid) return;
				const approvedStoreReviews = reviews.filter((review) => review.status === 'approved' && review.type === 'store');
				const ratingCount = approvedStoreReviews.length;
				const ratingAverage = ratingCount
					? approvedStoreReviews.reduce((sum, review) => sum + Number(review.rating || 0), 0) / ratingCount
					: 0;
				const pendingCount = reviews.filter((review) => review.status === 'pending').length;
				const monthStart = getMonthStart();
				const approvedThisMonth = reviews.filter((review) => {
					if (review.status !== 'approved' || !review.created) return false;
					const createdAt = new Date(review.created);
					return !Number.isNaN(createdAt.getTime()) && createdAt >= monthStart;
				}).length;
				const readyOrdersCount = orders.filter(isOrderReadyForReview).length;

				ratingSummaryGrid.innerHTML = [
					['Rating general', ratingCount ? ratingAverage.toFixed(1) : '0.0', ratingCount ? `${ratingCount} reseña${ratingCount === 1 ? '' : 's'} aprobada${ratingCount === 1 ? '' : 's'}` : 'Sin reseñas aprobadas'],
					['Pendientes de aprobar', String(pendingCount), 'Moderación requerida'],
					['Órdenes listas', String(readyOrdersCount), `Delay configurado: ${getReviewRequestDelayHours()} horas`],
					['Aprobadas este mes', String(approvedThisMonth), 'Creadas desde el inicio del mes'],
				].map(([label, value, meta]) => `
					<div class="status-box" style="display:grid;gap:8px;align-content:start;min-height:112px;">
						<span>${escapeHtml(label)}</span>
						<strong style="margin-top:0;font-size:28px;line-height:1;">${escapeHtml(value)}</strong>
						<small style="color:#64748b;font-size:12px;font-weight:850;line-height:1.35;">${escapeHtml(meta)}</small>
					</div>
				`).join('');

				if (ratingSummaryNote) {
					ratingSummaryNote.textContent = reviewsCollectionAvailable
						? ''
						: 'Las reseñas no están disponibles en este momento. Contacta a soporte para activar estas métricas.';
					ratingSummaryNote.classList.toggle('hidden', reviewsCollectionAvailable);
				}
			}

			function renderDashboard() {
				selectedRange = normalizeSummaryRange(selectedRange);
				persistSummaryRange(selectedRange);
				syncSummaryRangeButtons();
				const metrics = computeMetrics();
				dashboardSubtitle.textContent = formatFullDate(new Date()) + '.';
				rangeLabel.textContent = `Mostrando: ${getSummaryRangeLabel()}.`;
				renderTrafficAnalytics();
				renderLandingQrAnalytics();
				renderKpis(metrics);
				renderCharts(metrics);
				renderTopProducts(metrics);
				renderMostViewedProducts();
				renderRecentOrders(metrics);
				renderExpirationProducts();
				renderStatusGrid(metrics);
				renderRatingSummary();
			}

			async function loadDashboardData() {
				if (businessProductsDetails) businessProductsDetails.innerHTML = '<div class="business-empty-state">Cargando productos...</div>';
				if (businessSalesChart) businessSalesChart.innerHTML = '<div class="business-empty-state">Cargando ventas...</div>';
				if (businessProfitChart) businessProfitChart.innerHTML = '<div class="business-empty-state">Cargando ganancia estimada...</div>';
				if (businessOrdersChart) businessOrdersChart.innerHTML = '<div class="business-empty-state">Cargando pedidos...</div>';
				if (kpiGrid) kpiGrid.innerHTML = '<div class="card empty-state">Cargando métricas...</div>';
				if (profitKpiGrid) profitKpiGrid.innerHTML = '<div class="card empty-state">Cargando control...</div>';
				topProductsList.classList.add('is-empty');
				recentOrders.classList.add('is-empty');
				statusGrid.classList.remove('order-status-list');
				topProductsList.innerHTML = '<div class="activity-empty-text">Cargando productos más vendidos...</div>';
				if (mostViewedProductsList) mostViewedProductsList.innerHTML = '<div class="empty-state">Cargando productos más vistos...</div>';
				if (mostViewedProductsMeta) mostViewedProductsMeta.textContent = 'Cargando...';
				if (trafficLandingClicksList) trafficLandingClicksList.innerHTML = '<div class="empty-state">Cargando clics Landing QR...</div>';
				if (trafficLandingClicksMeta) trafficLandingClicksMeta.textContent = 'Cargando...';
				recentOrders.innerHTML = '<div class="activity-empty-text">Cargando pedidos recientes...</div>';
				statusGrid.innerHTML = '<div class="empty-state">Cargando estados...</div>';
				if (ratingSummaryGrid) ratingSummaryGrid.innerHTML = '<div class="empty-state">Cargando rating y reseñas...</div>';
				if (ratingSummaryNote) ratingSummaryNote.classList.add('hidden');
				expirationProductsList.innerHTML = '<div class="empty-state" style="grid-column: 1 / -1;">Cargando vencimientos...</div>';
				expirationProductsMeta.textContent = 'Cargando productos...';

				await loadSettingsRecord();
				await runAnalyticsCleanupIfNeeded();

				const [ordersResult, itemsResult, productsResult, analyticsResult] = await Promise.all([
					loadAllRecords('orders', 'sort=-created&expand=shipping_zone,currency'),
					loadAllRecords('order_items', `${ORDER_ITEMS_STORE_FILTER}${ORDER_ITEMS_STORE_FILTER ? '&' : ''}sort=-created&expand=product,variation`),
					loadAllRecords('products', 'sort=expiration_date&expand=category,subcategory'),
					loadAllRecords('store_analytics_events', buildAnalyticsEventsQuery()),
				]);

				await loadRatingSupportData();

				orders = ordersResult || [];
				orderItems = itemsResult || [];
				products = productsResult || [];
				analyticsEvents = analyticsResult || [];
				renderDashboard();
			}

			function closeSidebar() {
				document.body.classList.remove('sidebar-open');
				sidebar?.classList.remove('open');
				sidebar?.setAttribute('aria-hidden', 'true');
				if (sidebarOverlay) {
					sidebarOverlay.classList.remove('show');
					window.setTimeout(() => {
						if (!document.body.classList.contains('sidebar-open') && !sidebar?.classList.contains('open')) {
							sidebarOverlay.hidden = true;
						}
					}, 240);
				}
			}

			function closeBellDropdown() {
				adminBellDropdown?.classList.add('hidden');
				adminBellBtn?.setAttribute('aria-expanded', 'false');
			}

			function setupRecentActivityTabs() {
				const tabs = Array.from(document.querySelectorAll('[data-recent-tab]'));
				const panels = Array.from(document.querySelectorAll('[data-recent-panel]'));

				if (!tabs.length || !panels.length) return;

				function activateRecentTab(tabName) {
					tabs.forEach((tab) => {
						const isActive = tab.getAttribute('data-recent-tab') === tabName;
						tab.classList.toggle('is-active', isActive);
						tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
					});

					panels.forEach((panel) => {
						const isActive = panel.getAttribute('data-recent-panel') === tabName;
						panel.classList.toggle('is-active', isActive);
						panel.hidden = !isActive;
					});
				}

				tabs.forEach((tab) => {
					tab.addEventListener('click', () => {
						activateRecentTab(tab.getAttribute('data-recent-tab') || 'orders');
					});
				});

				activateRecentTab('orders');
			}

			setupRecentActivityTabs();

			adminBellBtn?.addEventListener('click', (event) => {
				event.stopPropagation();
				const isHidden = adminBellDropdown?.classList.contains('hidden') ?? true;
				adminBellDropdown?.classList.toggle('hidden', !isHidden);
				adminBellBtn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
			});

			document.addEventListener('click', (event) => {
				if (!adminBellDropdown || !adminBellBtn) return;
				const target = event.target;
				if (!(target instanceof Node)) return;
				if (adminBellDropdown.contains(target) || adminBellBtn.contains(target)) return;
				closeBellDropdown();
			});

			function getVisitAnalyticsTargetFromHash() {
				const hash = String(window.location.hash || '').trim().toLowerCase();
				if (hash === '#landing-qr' || hash === '#landingqr' || hash === '#qr-landing') return 'landingqr';
				return '';
			}

			function activateVisitAnalyticsTab(target, options = {}) {
				const normalizedTarget = String(target || 'visitors').trim() || 'visitors';
				visitAnalyticsTabs.forEach((item) => {
					const isActive = item.dataset.analyticsTab === normalizedTarget;
					item.classList.toggle('is-active', isActive);
					item.setAttribute('aria-selected', isActive ? 'true' : 'false');
				});
				visitAnalyticsPanels.forEach((panel) => {
					panel.classList.toggle('is-active', panel.dataset.analyticsPanel === normalizedTarget);
				});

				if (options.syncHash === false) return;
				const shouldUseLandingHash = normalizedTarget === 'landingqr';
				const hasLandingHash = Boolean(getVisitAnalyticsTargetFromHash());
				if (shouldUseLandingHash && window.location.hash !== '#landing-qr') {
					window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}#landing-qr`);
				} else if (!shouldUseLandingHash && hasLandingHash) {
					window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
				}
			}

			visitAnalyticsTabs.forEach((button) => {
				button.addEventListener('click', () => {
					activateVisitAnalyticsTab(button.dataset.analyticsTab || 'visitors');
				});
			});

			window.addEventListener('hashchange', () => {
				const target = getVisitAnalyticsTargetFromHash();
				if (target) activateVisitAnalyticsTab(target, { syncHash: false });
			});
			activateVisitAnalyticsTab(getVisitAnalyticsTargetFromHash() || 'visitors', { syncHash: false });

			businessSummaryTabs.forEach((button) => {
				button.addEventListener('click', () => {
					const target = button.dataset.businessSummaryTab || '';
					businessSummaryTabs.forEach((item) => {
						const isActive = item === button;
						item.classList.toggle('is-active', isActive);
						item.setAttribute('aria-selected', isActive ? 'true' : 'false');
					});
					businessSummaryPanels.forEach((panel) => {
						panel.classList.toggle('is-active', panel.dataset.businessSummaryPanel === target);
					});
				});
			});

			periodButtons.forEach((button) => {
				button.addEventListener('click', () => {
					selectedRange = normalizeSummaryRange(button.dataset.range || '7');
					persistSummaryRange(selectedRange);
					syncSummaryRangeButtons();
					renderDashboard();
				});
			});

			expirationButtons.forEach((button) => {
				button.addEventListener('click', () => {
					selectedExpirationRange = Number(button.dataset.expirationRange || 30);
					expirationButtons.forEach((item) => item.classList.toggle('active', item === button));
					renderExpirationProducts();
				});
			});
			sidebarOverlay?.addEventListener('click', closeSidebar);
			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeSidebar();
					closeBellDropdown();
				}
			});
			sidebar?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSidebar));

			sidebarLogoutBtn?.addEventListener('click', () => {
				clearAdminToken();
				orders = [];
				orderItems = [];
				products = [];
				analyticsEvents = [];
				closeSidebar();
				document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax';
				window.location.assign('/login');
			});

			syncSummaryRangeButtons();

			if (!POCKETBASE_URL) {
				showAdmin();
				if (businessProductsDetails) businessProductsDetails.innerHTML = '<div class="business-empty-state">Falta PUBLIC_POCKETBASE_URL en el archivo .env del frontend.</div>';
				if (kpiGrid) kpiGrid.innerHTML = '<div class="card empty-state">Falta PUBLIC_POCKETBASE_URL en el archivo .env del frontend.</div>';
			} else if (getAdminToken()) {
				showAdmin();
				loadDashboardData().catch((error) => {
					if (businessProductsDetails) businessProductsDetails.innerHTML = '<div class="business-empty-state">No se pudieron cargar las métricas de esta tienda.</div>';
					if (kpiGrid) kpiGrid.innerHTML = '<div class="card empty-state">No se pudieron cargar las métricas de esta tienda.</div>';
				});
			} else {
				showAdmin();
				if (businessProductsDetails) businessProductsDetails.innerHTML = '<div class="business-empty-state">No se pudo validar la sesión administrativa.</div>';
				if (kpiGrid) kpiGrid.innerHTML = '<div class="card empty-state">No se pudo validar la sesión administrativa.</div>';
			}
		</script>
	</body>
</html>
