			.expiration-kpi-action {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 8px;
				min-height: 38px;
				width: max-content;
				max-width: 100%;
				margin-top: 13px;
				margin-left: auto;
				padding: 0 16px 0 17px;
				border-radius: 999px;
				background: linear-gradient(135deg, #ef4444 0%, #dc2626 52%, #991b1b 100%);
				color: #ffffff;
				font-size: 12px;
				font-weight: 950;
				letter-spacing: -0.01em;
				text-decoration: none;
				box-shadow:
					0 18px 34px rgba(220, 38, 38, 0.30),
					0 0 0 4px rgba(254, 226, 226, 0.85),
					inset 0 1px 0 rgba(255,255,255,0.28);
				position: relative;
				z-index: 2;
				overflow: hidden;
				transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
			}

			.expiration-kpi-action::before {
				content: '';
				position: absolute;
				inset: 1px;
				border-radius: inherit;
				background: linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0));
				pointer-events: none;
			}

			.expiration-kpi-action::after {
				content: '→';
				font-size: 13px;
				line-height: 1;
				transform: translateY(-1px);
			}

			.expiration-kpi-action:hover {
				transform: translateY(-2px) scale(1.015);
				filter: saturate(1.06) brightness(0.98);
				box-shadow:
					0 22px 42px rgba(220, 38, 38, 0.36),
					0 0 0 5px rgba(254, 226, 226, 0.95),
					inset 0 1px 0 rgba(255,255,255,0.28);
			}

			@media (max-width: 1100px) {
				.expiration-main {
					grid-template-columns: minmax(0, 1fr) auto auto;
