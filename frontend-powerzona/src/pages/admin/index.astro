			function createChartMarkup(points, field, strokeColor, fillColor) {
				if (!points.length || points.every((point) => Number(point[field] || 0) === 0)) {
					return '<div class="empty-chart">Todavía no hay suficientes datos para mostrar esta gráfica.</div>';
				}

				const width = 760;
				const height = 300;
				const paddingX = 42;
				const paddingTop = 20;
				const paddingBottom = 48;
				const innerWidth = width - paddingX * 2;
				const innerHeight = height - paddingTop - paddingBottom;
				const maxValue = Math.max(...points.map((point) => Number(point[field] || 0)), 1);
				const stepX = points.length > 1 ? innerWidth / (points.length - 1) : innerWidth;

				const labelStep = points.length > 24 ? 5 : points.length > 15 ? 3 : points.length > 10 ? 2 : 1;

				const coords = points.map((point, index) => {
					const x = paddingX + index * stepX;
					const y = paddingTop + innerHeight - ((Number(point[field] || 0) / maxValue) * innerHeight);
					return { ...point, x, y, index };
				});

				function buildSmoothPath(items) {
					if (items.length === 1) return `M ${items[0].x} ${items[0].y}`;

					return items.map((point, index) => {
						if (index === 0) return `M ${point.x} ${point.y}`;
						const previous = items[index - 1];
						const middleX = (previous.x + point.x) / 2;
						return `C ${middleX} ${previous.y}, ${middleX} ${point.y}, ${point.x} ${point.y}`;
					}).join(' ');
				}

				const linePath = buildSmoothPath(coords);
				const areaPath = `${linePath} L ${coords[coords.length - 1].x} ${height - paddingBottom} L ${coords[0].x} ${height - paddingBottom} Z`;
				const gradientId = `chart-${field}-${selectedRange}`;
				const grid = field === 'count'
					? Array.from({ length: Math.min(Math.ceil(maxValue), 4) + 1 }, (_, index) => {
						const topValue = Math.max(Math.ceil(maxValue), 1);
						const value = index;
						const y = paddingTop + innerHeight - ((value / topValue) * innerHeight);
						return { y, value };
					})
					: Array.from({ length: 5 }, (_, index) => {
						const y = paddingTop + innerHeight - (innerHeight / 4) * index;
						const value = (maxValue / 4) * index;
						return { y, value };
					});

				const visibleLabels = coords.filter((point) => {
					const isFirst = point.index === 0;
					const isLast = point.index === coords.length - 1;
					return isFirst || isLast || point.index % labelStep === 0;
				});

				return `
					<svg class="chart-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="Gráfico de analítica">
						<defs>
							<linearGradient id="${gradientId}" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="${fillColor}" stop-opacity="0.30" />
								<stop offset="100%" stop-color="${fillColor}" stop-opacity="0.02" />
							</linearGradient>
						</defs>
						${grid.map((tick) => `
							<line x1="${paddingX}" y1="${tick.y}" x2="${width - paddingX}" y2="${tick.y}" stroke="#e2e8f0" stroke-width="1" />
							<text x="${width - paddingX + 8}" y="${tick.y + 4}" font-size="12" font-weight="600" fill="#64748b">${tick.value.toFixed(0)}</text>
						`).join('')}
						<path d="${areaPath}" fill="url(#${gradientId})"></path>
						<path d="${linePath}" fill="none" stroke="${strokeColor}" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
						${coords.map((point) => `
							<circle cx="${point.x}" cy="${point.y}" r="5" fill="#ffffff" stroke="${strokeColor}" stroke-width="3" />
						`).join('')}
						${visibleLabels.map((point) => `
							<text x="${point.x}" y="${height - 13}" text-anchor="middle" font-size="12" font-weight="650" fill="#475569">${escapeHtml(point.label)}</text>
						`).join('')}
					</svg>
				`;
			}

