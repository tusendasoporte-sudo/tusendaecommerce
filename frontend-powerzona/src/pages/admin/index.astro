				if (productsWithStockField.length) {
					productRows.push({
						label: 'Sin stock',
						value: productsWithStockField.filter((product) => Number(product.stock || 0) <= 0).length,
					});
				}

				renderBusinessDetailRows(businessProductsDetails, productRows, 'Todavía no hay productos registrados.');

				const series = getChartSeries(metrics.filteredOrders, metrics.profitByOrder);
				if (businessSalesChart) businessSalesChart.innerHTML = createChartMarkup(series, 'sales', '#2563eb', '#3b82f6', 'business-chart');
				if (businessProfitChart) businessProfitChart.innerHTML = createChartMarkup(series, 'profit', '#2563eb', '#3b82f6', 'business-chart');
				if (businessOrdersChart) businessOrdersChart.innerHTML = createChartMarkup(series, 'count', '#2563eb', '#3b82f6', 'business-chart');

				const orderRows = ['pending', 'confirmed', 'preparing', 'delivered', 'cancelled']
					.filter((status) => Number(metrics.statusCounts[status] || 0) > 0)
					.map((status) => ({
						label: statusLabels[status] || status,
						value: metrics.statusCounts[status] || 0,
					}));
				renderBusinessDetailRows(businessOrdersDetails, orderRows, 'Sin pedidos en este periodo.');
			}

			function renderKpis(metrics) {
				renderBusinessSummary(metrics);
				const summaryRangeLabel = getSummaryRangeLabel();
				const expirationSummary = getOneMonthExpirationSummary();
				const expirationMeta = expirationSummary.validCount
					? 'Productos con vencimiento en 30 días o menos.'
					: 'Sin productos por vencer en 1 mes.';
				const expirationBadge = expirationSummary.expiredCount
					? `${expirationSummary.expiredCount} vencido${expirationSummary.expiredCount === 1 ? '' : 's'}`
					: '1 mes';
				const topLabel = metrics.topProduct ? metrics.topProduct.name : 'Aún sin ventas';
				const topMeta = metrics.topProduct ? `${metrics.topProduct.quantity} unidades vendidas en este período` : 'Sin datos para este período';
				const cardStyle = 'position:relative;min-height:178px;padding:22px;border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.99),rgba(248,250,252,.97));border:1px solid rgba(226,232,240,.98);box-shadow:0 22px 52px rgba(15,23,42,.10),0 8px 20px rgba(15,23,42,.05),inset 0 1px 0 rgba(255,255,255,.96);overflow:hidden;';
				const topStyle = 'position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;';
				const iconStyle = 'width:50px;height:50px;border-radius:18px;display:grid;place-items:center;background:var(--metric-soft);color:var(--metric-color);box-shadow:0 12px 24px rgba(15,23,42,.08);';
				const badgeStyle = 'border-radius:999px;padding:7px 11px;background:var(--metric-soft);color:var(--metric-color);font-size:11px;font-weight:800;letter-spacing:.03em;text-transform:uppercase;white-space:nowrap;';
				const labelStyle = 'position:relative;z-index:1;margin:0 0 8px;font-size:14px;font-weight:700;color:#475569;letter-spacing:-.01em;';
