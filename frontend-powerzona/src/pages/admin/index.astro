			function getProductsNearExpiration() {
				const now = new Date();
				now.setHours(0, 0, 0, 0);

				const limit = new Date(now);
				limit.setDate(limit.getDate() + Number(selectedExpirationRange || 30));
				limit.setHours(23, 59, 59, 999);

				return products
					.map((product) => {
						if (!product.expiration_date) return null;
						const expirationDate = new Date(product.expiration_date);
						if (Number.isNaN(expirationDate.getTime())) return null;
						expirationDate.setHours(0, 0, 0, 0);
						if (expirationDate > limit) return null;
						const daysLeft = Math.ceil((expirationDate - now) / 86400000);
						return { product, expirationDate, daysLeft };
					})
					.filter(Boolean)
					.sort((a, b) => a.daysLeft - b.daysLeft);
			}

			function getExpirationStatus(item) {
				if (item.daysLeft < 0) return { label: 'Vencido', className: 'expired' };
				if (item.daysLeft <= 30) return { label: '1 mes', className: 'one-month' };
				if (item.daysLeft <= 60) return { label: '2 meses', className: 'two-months' };
				return { label: '3 meses', className: 'three-months' };
			}

			function getExpirationPalette(className) {
				if (className === 'two-months') {
					return { main: '#f59e0b', soft: '#fffbeb', chip: '#fef3c7', text: '#92400e', border: 'rgba(245, 158, 11, 0.28)' };
				}
				if (className === 'three-months') {
					return { main: '#2563eb', soft: '#eff6ff', chip: '#dbeafe', text: '#1d4ed8', border: 'rgba(37, 99, 235, 0.24)' };
				}
				return { main: '#dc2626', soft: '#fff1f2', chip: '#fee2e2', text: '#991b1b', border: 'rgba(220, 38, 38, 0.28)' };
			}

			function getExpirationDaysText(daysLeft) {
				if (daysLeft < 0) return `Vencido hace ${Math.abs(daysLeft)} día${Math.abs(daysLeft) === 1 ? '' : 's'}`;
				if (daysLeft === 0) return 'Vence hoy';
				if (daysLeft === 1) return 'Vence mañana';
				return `Faltan ${daysLeft} días`;
			}

			function renderExpirationProducts() {
				const nearExpiration = getProductsNearExpiration();
				const expiredCount = nearExpiration.filter((item) => item.daysLeft < 0).length;
				const validCount = nearExpiration.length - expiredCount;
				const rangeText = selectedExpirationRange === 30 ? '1 mes' : selectedExpirationRange === 60 ? '2 meses' : '3 meses';

				expirationProductsMeta.textContent = expiredCount
					? `${validCount} por vencer en ${rangeText} · ${expiredCount} vencido${expiredCount === 1 ? '' : 's'}`
					: `${validCount} producto${validCount === 1 ? '' : 's'} por vencer en ${rangeText}`;

				if (!nearExpiration.length) {
					expirationProductsList.innerHTML = '<div class="empty-state" style="grid-column: 1 / -1;">No hay productos con vencimiento dentro de este rango.</div>';
					return;
				}

				expirationProductsList.innerHTML = nearExpiration.map((item) => {
					const product = item.product;
					const status = getExpirationStatus(item);
					const palette = getExpirationPalette(status.className);
					const stock = Number(product.stock || 0);
					const rowStyle = `display:flex;align-items:center;gap:10px;width:calc(100% - 8px);max-width:calc(100% - 8px);box-sizing:border-box;min-width:0;margin-right:8px;padding:14px 14px 14px 16px;border-radius:22px;background:linear-gradient(135deg, ${palette.soft}, #ffffff 62%);border:1px solid ${palette.border};box-shadow:0 18px 34px rgba(15,23,42,0.08), inset 0 1px 0 rgba(255,255,255,0.95);position:relative;overflow:hidden;flex-wrap:wrap;`;
					const leftBarStyle = `position:absolute;left:0;top:0;bottom:0;width:5px;background:${palette.main};box-shadow:0 0 26px ${palette.border};`;
					const dotStyle = `width:12px;height:12px;border-radius:999px;background:${palette.main};box-shadow:0 0 0 5px ${palette.chip}, 0 8px 18px ${palette.border};flex:0 0 auto;`;
					const contentStyle = 'display:flex;align-items:center;gap:9px;min-width:0;flex:1 1 360px;flex-wrap:wrap;max-width:100%;';
					const nameStyle = 'margin:0;font-size:15px;font-weight:950;letter-spacing:-0.02em;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;min-width:0;flex:1 1 180px;';
					const neutralChipStyle = 'display:inline-flex;align-items:center;min-height:30px;padding:0 10px;border-radius:999px;background:#ffffff;border:1px solid rgba(226,232,240,0.98);color:#334155;font-size:12px;font-weight:900;white-space:nowrap;';
					const priorityChipStyle = `display:inline-flex;align-items:center;min-height:30px;padding:0 11px;border-radius:999px;background:${palette.chip};color:${palette.text};font-size:11px;font-weight:950;white-space:nowrap;box-shadow:inset 0 0 0 1px ${palette.border};`;
					const daysStyle = `font-size:12px;font-weight:950;color:${palette.text};white-space:nowrap;`;
					const viewStyle = `display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:0 16px;border-radius:999px;background:${palette.main};color:#ffffff;font-size:12px;font-weight:950;text-decoration:none;box-shadow:0 12px 22px ${palette.border}, inset 0 1px 0 rgba(255,255,255,0.28);white-space:nowrap;flex:0 0 auto;margin-left:auto;max-width:calc(100% - 4px);`;

					return `
						<div class="expiration-item ${status.className}" style="${rowStyle}">
							<span style="${leftBarStyle}" aria-hidden="true"></span>
							<span class="expiration-signal" style="${dotStyle}" aria-hidden="true"></span>
							<div class="expiration-main" style="${contentStyle}">
								<p class="expiration-name" style="${nameStyle}">${escapeHtml(product.name || 'Producto sin nombre')}</p>
								<span class="expiration-stock" style="${neutralChipStyle}">Stock: ${escapeHtml(stock)}</span>
								<span class="expiration-pill ${status.className}" style="${priorityChipStyle}">${escapeHtml(status.label)}</span>
								<span class="expiration-date-chip" style="${neutralChipStyle}">${escapeHtml(formatDateOnly(product.expiration_date))}</span>
								<span class="expiration-days" style="${daysStyle}">${escapeHtml(getExpirationDaysText(item.daysLeft))}</span>
							</div>
							<a class="expiration-view" style="${viewStyle}" href="${productAdminUrl(product)}" aria-label="Ver producto ${escapeHtml(product.name || 'Producto')}">Ver →</a>
						</div>
					`;
				}).join('');
			}

			function renderStatusGrid(metrics) {
	const statuses = ['confirmed', 'pending', 'preparing', 'delivered', 'cancelled'];

	statusGrid.innerHTML = statuses.map((status) => `
		<div class="status-box" style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
			<span>${escapeHtml(statusLabels[status])}</span>
			<strong style="margin-top:0; font-size:20px;">${metrics.statusCounts[status] || 0}</strong>
		</div>
	`).join('');
}

			function renderDashboard() {
				const metrics = computeMetrics();
				dashboardSubtitle.textContent = formatFullDate(new Date()) + '.';
				rangeLabel.textContent = `Mostrando: ${rangeLabels[selectedRange]}.`;
				renderKpis(metrics);
				renderCharts(metrics);
				renderTopProducts(metrics);
				renderRecentOrders(metrics);
				renderExpirationProducts();
				renderStatusGrid(metrics);
			}

			async function loadDashboardData() {
				kpiGrid.innerHTML = '<div class="card empty-state">Cargando métricas...</div>';
				profitKpiGrid.innerHTML = '<div class="card empty-state">Cargando control...</div>';
				topProductsList.innerHTML = '<div class="empty-state">Cargando productos más vendidos...</div>';
				recentOrders.innerHTML = '<div class="empty-state">Cargando pedidos recientes...</div>';
				statusGrid.innerHTML = '<div class="empty-state">Cargando estados...</div>';
				expirationProductsList.innerHTML = '<div class="empty-state" style="grid-column: 1 / -1;">Cargando vencimientos...</div>';
				expirationProductsMeta.textContent = 'Cargando productos...';

				const [ordersResult, itemsResult, productsResult] = await Promise.all([
					loadAllRecords('orders', 'sort=-created&expand=shipping_zone,currency'),
					loadAllRecords('order_items', 'sort=-created&expand=product,variation'),
					loadAllRecords('products', 'sort=expiration_date&expand=category,subcategory'),
				]);

				orders = ordersResult || [];
				orderItems = itemsResult || [];
				products = productsResult || [];
				renderDashboard();
			}

			function openSidebar() {
				document.body.classList.add('sidebar-open');
				sidebar?.classList.add('open');
				sidebar?.setAttribute('aria-hidden', 'false');
				sidebarOpenBtn?.setAttribute('aria-expanded', 'true');
				if (sidebarOverlay) {
					sidebarOverlay.hidden = false;
					sidebarOverlay.classList.add('show');
				}
			}

			function closeSidebar() {
				document.body.classList.remove('sidebar-open');
				sidebar?.classList.remove('open');
				sidebar?.setAttribute('aria-hidden', 'true');
				sidebarOpenBtn?.setAttribute('aria-expanded', 'false');
				if (sidebarOverlay) {
					sidebarOverlay.classList.remove('show');
					window.setTimeout(() => {
						if (!document.body.classList.contains('sidebar-open') && !sidebar?.classList.contains('open')) {
							sidebarOverlay.hidden = true;
						}
					}, 240);
				}
			}

			periodButtons.forEach((button) => {
				button.addEventListener('click', () => {
					selectedRange = button.dataset.range || '7';
					periodButtons.forEach((item) => item.classList.toggle('active', item === button));
					renderDashboard();
				});
			});

			expirationButtons.forEach((button) => {
				button.addEventListener('click', () => {
					selectedExpirationRange = Number(button.dataset.expirationRange || 30);
					expirationButtons.forEach((item) => item.classList.toggle('active', item === button));
					renderExpirationProducts();
				});
			});
			sidebarOpenBtn?.addEventListener('click', openSidebar);
			sidebarCloseBtn?.addEventListener('click', closeSidebar);
			sidebarOverlay?.addEventListener('click', closeSidebar);
			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') closeSidebar();
			});
			sidebar?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSidebar));

			sidebarLogoutBtn?.addEventListener('click', () => {
				clearAdminToken();
				orders = [];
				orderItems = [];
				products = [];
				closeSidebar();
				document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax';
				window.location.assign('/login');
			});
			if (!POCKETBASE_URL) {
				showAdmin();
				kpiGrid.innerHTML = '<div class="card empty-state">Falta PUBLIC_POCKETBASE_URL en el archivo .env del frontend.</div>';
			} else if (getAdminToken()) {
				showAdmin();
				loadDashboardData().catch((error) => {
					console.error(error);
					kpiGrid.innerHTML = '<div class="card empty-state">No se pudieron cargar las metricas de esta tienda.</div>';
				});
			} else {
				showAdmin();
				kpiGrid.innerHTML = '<div class="card empty-state">No se pudo validar la sesion administrativa.</div>';
			}
		</script>
	</body>
</html>
