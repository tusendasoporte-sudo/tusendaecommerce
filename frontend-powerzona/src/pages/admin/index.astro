---
// PowerZona admin resumen vencimientos y pedidos V13 - 2026-06-03
// V14 - Ajuste visual pedidos recientes: fila tipo botón y estado resaltado inline.
// V15 - Top 10 productos: filas modernas tipo cápsula con cantidad y total resaltados.
import { refreshAuthFromCookie } from '../../lib/auth';
import { getStoreAdminPath } from '../../lib/adminRoutes';
import { getStoreFilterForAdmin, requireCurrentStoreForAdmin } from '../../lib/storeContext';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreName = adminContext.store.name || 'tu tienda';
const currentStoreId = adminContext.storeId;
const currentStoreSlug = adminContext.store.slug || '';
const currentStoreRoleLabel = adminContext.roleLabel;
const currentStoreFilter = await getStoreFilterForAdmin('store', authPb);
const adminAuthToken = authPb.authStore.token;
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminProfitsPath = getStoreAdminPath(currentStoreSlug, 'profits');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const adminPromosPath = getStoreAdminPath(currentStoreSlug, 'promos');
const adminOrganizationPath = getStoreAdminPath(currentStoreSlug, 'organization');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Admin | PowerZona</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<style>
			:root {
				font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				--page: #eef3f9;
				--surface: #ffffff;
				--surface-soft: #f8fafc;
				--text: #0f172a;
				--muted: #64748b;
				--border: #e2e8f0;
				--dark: #071226;
				--blue: #2563eb;
				--green: #16a34a;
				--orange: #f97316;
				--purple: #7c3aed;
				--red: #dc2626;
				--shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
				--shadow-lg: 0 30px 90px rgba(15, 23, 42, 0.18);
			}

			* { box-sizing: border-box; }
			html, body { margin: 0; min-height: 100%; }
			body {
				color: var(--text);
				background:
					radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.16), transparent 30%),
					radial-gradient(circle at 85% 8%, rgba(22, 163, 74, 0.10), transparent 25%),
					linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
			}

			button, input { font: inherit; }
			button { cursor: pointer; }
			a { color: inherit; text-decoration: none; }
			.hidden { display: none !important; }

			.login-wrap {
				min-height: 100vh;
				display: grid;
				place-items: center;
				padding: 24px;
			}

			.login-card {
				width: min(100%, 460px);
				background: rgba(255, 255, 255, 0.94);
				border: 1px solid rgba(226, 232, 240, 0.9);
				border-radius: 32px;
				box-shadow: var(--shadow-lg);
				padding: 30px;
			}

			.brand-chip {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 8px 12px;
				border-radius: 999px;
				background: #eff6ff;
				color: #1d4ed8;
				font-size: 13px;
				font-weight: 950;
			}

			.login-title {
				font-size: 34px;
				font-weight: 950;
				letter-spacing: -0.04em;
				margin: 18px 0 8px;
			}

			.login-subtitle {
				color: var(--muted);
				line-height: 1.55;
				margin: 0 0 24px;
			}

			.form-grid { display: grid; gap: 14px; }
			label {
				display: block;
				font-size: 13px;
				font-weight: 850;
				color: #334155;
				margin-bottom: 8px;
			}

			input {
				width: 100%;
				border: 1px solid var(--border);
				border-radius: 16px;
				background: #f8fafc;
				padding: 13px 14px;
				outline: none;
			}

			input:focus {
				border-color: rgba(37, 99, 235, 0.45);
				box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
			}

			.btn {
				border: 0;
				border-radius: 16px;
				padding: 12px 18px;
				font-weight: 950;
				transition: transform 0.18s ease, opacity 0.18s ease;
			}

			.btn:hover { transform: translateY(-1px); }
			.btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

			.btn-primary {
				background: linear-gradient(135deg, #2563eb, #1d4ed8);
				color: #ffffff;
				box-shadow: 0 14px 32px rgba(37, 99, 235, 0.24);
			}

			.alert {
				border-radius: 16px;
				padding: 12px 14px;
				font-size: 13px;
				font-weight: 850;
			}

			.alert-error { background: #fee2e2; color: #991b1b; }

			.admin-view { min-height: 100vh; }

			.main-wrap {
				width: min(1500px, 100%);
				margin: 0 auto;
				padding: 28px;
			}

			.close-btn, .menu-btn {
				width: 48px;
				height: 48px;
				border-radius: 18px;
				border: 1px solid rgba(255, 255, 255, 0.08);
				background: rgba(255, 255, 255, 0.08);
				color: #ffffff;
				display: grid;
				place-items: center;
			}

			.menu-btn {
				background: #ffffff;
				color: #0f172a;
				border-color: rgba(226, 232, 240, 0.9);
				box-shadow: var(--shadow);
			}

			.nav-group { margin: 18px 0; }
			.nav-label {
				font-size: 11px;
				font-weight: 950;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #64748b;
				margin: 0 0 8px;
			}

			.nav-link {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				width: 100%;
				padding: 13px;
				margin-bottom: 8px;
				border: 0;
				border-radius: 18px;
				background: transparent;
				color: #cbd5e1;
				font-weight: 850;
			}

			.nav-link:hover {
				background: rgba(255, 255, 255, 0.08);
				color: #ffffff;
			}

			.nav-link.active {
				background: rgba(255, 255, 255, 0.10);
				color: #ffffff;
				box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
			}

			.nav-left {
				display: inline-flex;
				align-items: center;
				gap: 12px;
			}

			.nav-pill {
				font-size: 11px;
				font-weight: 950;
				padding: 5px 8px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.10);
				color: #cbd5e1;
			}

			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 18px;
				margin-bottom: 22px;
			}

			.page-title {
				font-size: clamp(30px, 4vw, 44px);
				font-weight: 950;
				letter-spacing: -0.045em;
				line-height: 1;
				margin: 0;
			}

			.page-title span {
				color: #334155;
				font-weight: 750;
			}

			.page-subtitle {
				margin: 8px 0 0;
				font-size: 15px;
				color: var(--muted);
			}

			.action-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 10px;
				border-radius: 18px;
				padding: 13px 16px;
				background: #ffffff;
				border: 1px solid rgba(226, 232, 240, 0.9);
				box-shadow: var(--shadow);
				font-weight: 900;
			}

			.section-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				margin: 16px 0;
				flex-wrap: wrap;
			}

			.section-title {
				font-size: 16px;
				font-weight: 950;
				margin: 0;
			}

			.period-tabs {
				display: flex;
				gap: 8px;
				flex-wrap: wrap;
				padding: 6px;
				border-radius: 22px;
				background: rgba(255, 255, 255, 0.82);
				border: 1px solid rgba(226, 232, 240, 0.95);
				box-shadow: var(--shadow);
			}

			.period-btn {
				border: 0;
				border-radius: 16px;
				background: transparent;
				padding: 10px 13px;
				font-size: 13px;
				font-weight: 950;
				color: #475569;
			}

			.period-btn.active {
				background: #0f172a;
				color: #ffffff;
				box-shadow: 0 10px 22px rgba(15, 23, 42, 0.18);
			}

			.grid { display: grid; gap: 18px; }
			.kpi-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
			.two-grid { grid-template-columns: 1.14fr 0.86fr; }

			.dashboard-block {
				margin-top: 20px;
			}

			.dashboard-block-head {
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 16px;
				margin-bottom: 14px;
				flex-wrap: wrap;
			}

			.dashboard-block-title {
				font-size: 19px;
				font-weight: 950;
				letter-spacing: -0.035em;
				margin: 0;
			}

			.dashboard-block-subtitle {
				font-size: 13px;
				font-weight: 720;
				color: var(--muted);
				margin: 5px 0 0;
			}

			.analytics-card-grid {
				display: grid;
				gap: 16px;
			}

			.analytics-card-grid-main {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}

			.analytics-card-grid-secondary {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}

			.dashboard-status-card {
				padding: 18px;
			}

			.card {
				background: #ffffff;
				border: 1px solid rgba(226, 232, 240, 0.95);
				border-radius: 30px;
				box-shadow: var(--shadow);
			}

			.kpi-card {
				padding: 20px;
				min-height: 168px;
				position: relative;
				overflow: hidden;
			}

			.kpi-card::after {
				content: "";
				position: absolute;
				right: -44px;
				bottom: -44px;
				width: 130px;
				height: 130px;
				border-radius: 999px;
				background: rgba(37, 99, 235, 0.06);
			}

			.kpi-top {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 12px;
				position: relative;
				z-index: 1;
			}

			.icon-box {
				width: 48px;
				height: 48px;
				border-radius: 18px;
				display: grid;
				place-items: center;
			}

			.icon-blue { background: #eff6ff; color: #1d4ed8; }
			.icon-green { background: #ecfdf5; color: #15803d; }
			.icon-orange { background: #fff7ed; color: #c2410c; }
			.icon-purple { background: #f5f3ff; color: #6d28d9; }

			.trend-pill {
				font-size: 12px;
				font-weight: 950;
				padding: 6px 9px;
				border-radius: 999px;
				background: #f8fafc;
				color: #475569;
			}

			.trend-pill.good {
				background: #ecfdf5;
				color: #15803d;
			}

			.kpi-label {
				position: relative;
				z-index: 1;
				margin: 18px 0 7px;
				font-size: 14px;
				font-weight: 850;
				color: #475569;
			}

			.kpi-value {
				position: relative;
				z-index: 1;
				font-size: clamp(25px, 3.6vw, 34px);
				line-height: 1;
				font-weight: 950;
				letter-spacing: -0.04em;
			}

			.kpi-meta {
				position: relative;
				z-index: 1;
				margin-top: 8px;
				font-size: 13px;
				color: var(--muted);
			}

			.wide-kpi { grid-column: span 2; }

			.chart-card, .list-card { padding: 22px; }

			.card-head {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 16px;
				margin-bottom: 16px;
			}

			.card-title {
				font-size: 22px;
				font-weight: 950;
				letter-spacing: -0.03em;
				margin: 0;
			}

			.card-sub {
				font-size: 13px;
				color: var(--muted);
				margin: 6px 0 0;
			}

			.card-total {
				font-size: 13px;
				font-weight: 950;
				color: #334155;
				white-space: nowrap;
			}

			.chart-box {
				height: 300px;
				border-radius: 24px;
				background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
				border: 1px solid #edf2f7;
				padding: 12px;
			}

			.chart-svg {
				display: block;
				width: 100%;
				height: 100%;
			}

			.empty-chart {
				height: 100%;
				display: grid;
				place-items: center;
				text-align: center;
				color: var(--muted);
				font-weight: 850;
			}

			.order-list { display: grid; gap: 12px; }

			.top-products-list {
				display: grid;
				gap: 12px;
			}

			.top-product-item {
				display: grid;
				grid-template-columns: auto minmax(0, 1fr) auto;
				align-items: center;
				gap: 12px;
				padding: 13px 14px;
				border-radius: 20px;
				background: #f8fafc;
				border: 1px solid #edf2f7;
			}

			.top-product-rank {
				width: 34px;
				height: 34px;
				border-radius: 14px;
				display: grid;
				place-items: center;
				background: #0f172a;
				color: #ffffff;
				font-size: 13px;
				font-weight: 950;
			}

			.top-product-name {
				margin: 0;
				font-weight: 950;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.top-product-meta {
				margin: 4px 0 0;
				font-size: 12px;
				font-weight: 850;
				color: var(--muted);
			}

			.top-product-qty {
				text-align: right;
				font-size: 18px;
				font-weight: 950;
				color: #0f172a;
				white-space: nowrap;
			}

			.top-product-qty span {
				display: block;
				margin-top: 2px;
				font-size: 11px;
				font-weight: 950;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: #64748b;
			}

			.order-item {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 14px;
				padding: 14px 16px;
				border-radius: 20px;
				background: #f8fafc;
				border: 1px solid #edf2f7;
			}

			.order-title {
				margin: 0 0 5px;
				font-weight: 950;
			}

			.order-meta {
				margin: 0;
				font-size: 13px;
				color: var(--muted);
			}

			.order-total {
				text-align: right;
				font-weight: 950;
				margin-bottom: 6px;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border-radius: 999px;
				padding: 5px 9px;
				font-size: 12px;
				font-weight: 950;
				white-space: nowrap;
			}

			.status-pending { background: #fef3c7; color: #92400e; }
			.status-confirmed { background: #dcfce7; color: #166534; }
			.status-preparing { background: #ede9fe; color: #5b21b6; }
			.status-delivered { background: #dcfce7; color: #166534; }
			.status-cancelled { background: #fee2e2; color: #991b1b; }

			.recent-order-compact {
				display: flex !important;
				align-items: center !important;
				justify-content: space-between !important;
				gap: 10px !important;
				width: 100% !important;
				min-width: 0 !important;
				padding: 12px 14px !important;
				border-radius: 18px !important;
				background: #ffffff !important;
				border: 1px solid rgba(226, 232, 240, 0.92) !important;
				box-shadow: 0 12px 26px rgba(15, 23, 42, 0.04) !important;
				overflow: hidden !important;
			}

			.recent-order-line {
				display: flex !important;
				align-items: center !important;
				gap: 8px !important;
				min-width: 0 !important;
				width: 100% !important;
				flex-wrap: wrap !important;
				font-size: 14px !important;
				line-height: 1.35 !important;
				color: #0f172a !important;
			}

			.recent-order-number {
				font-weight: 900 !important;
				color: #020617 !important;
				white-space: nowrap !important;
			}

			.recent-order-date,
			.recent-order-total,
			.recent-order-sep {
				font-weight: 760 !important;
				color: #334155 !important;
				white-space: nowrap !important;
			}

			.recent-status-badge {
				display: inline-flex !important;
				align-items: center !important;
				justify-content: center !important;
				border-radius: 999px !important;
				padding: 5px 10px !important;
				font-size: 12px !important;
				font-weight: 900 !important;
				line-height: 1 !important;
				white-space: nowrap !important;
				box-shadow: inset 0 1px 0 rgba(255,255,255,0.75) !important;
			}

			.recent-status-pending { background: #fef3c7 !important; color: #92400e !important; border: 1px solid #fde68a !important; }
			.recent-status-confirmed { background: #dcfce7 !important; color: #166534 !important; border: 1px solid #bbf7d0 !important; }
			.recent-status-delivered { background: #dcfce7 !important; color: #166534 !important; border: 1px solid #bbf7d0 !important; }
			.recent-status-cancelled { background: #fee2e2 !important; color: #991b1b !important; border: 1px solid #fecaca !important; }
			.recent-status-preparing { background: #ede9fe !important; color: #5b21b6 !important; border: 1px solid #ddd6fe !important; }

			.status-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 12px;
			}

			.status-box {
				padding: 16px;
				border-radius: 22px;
				background: #f8fafc;
				border: 1px solid #edf2f7;
			}

			.status-box span {
				display: block;
				font-size: 13px;
				color: var(--muted);
				font-weight: 850;
			}

			.status-box strong {
				display: block;
				font-size: 30px;
				font-weight: 950;
				letter-spacing: -0.04em;
				margin-top: 8px;
			}

			.empty-state {
				padding: 28px;
				text-align: center;
				color: var(--muted);
				font-weight: 850;
			}

			.metric-card {
				background: #ffffff;
				border: 1px solid rgba(226, 232, 240, 0.95);
				border-radius: 30px;
				box-shadow: var(--shadow);
				padding: 22px;
				min-height: 178px;
				position: relative;
				overflow: hidden;
			}

			.metric-card::after {
				content: "";
				position: absolute;
				right: -46px;
				bottom: -46px;
				width: 138px;
				height: 138px;
				border-radius: 999px;
				background: var(--metric-glow, rgba(37, 99, 235, 0.08));
			}

			.metric-top {
				position: relative;
				z-index: 1;
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 12px;
			}

			.metric-icon {
				width: 56px;
				height: 56px;
				border-radius: 22px;
				display: grid;
				place-items: center;
				background: var(--metric-gradient);
				color: #ffffff;
				box-shadow: 0 16px 28px var(--metric-shadow);
			}

			.metric-icon svg {
				width: 24px;
				height: 24px;
			}

			.metric-badge {
				font-size: 12px;
				font-weight: 950;
				padding: 7px 10px;
				border-radius: 999px;
				background: var(--metric-soft);
				color: var(--metric-color);
				white-space: nowrap;
			}

			.metric-label {
				position: relative;
				z-index: 1;
				margin: 18px 0 8px;
				font-size: 14px;
				font-weight: 900;
				color: #475569;
			}

			.metric-value {
				position: relative;
				z-index: 1;
				font-size: clamp(30px, 3.8vw, 42px);
				line-height: 1;
				font-weight: 1000 !important;
				letter-spacing: -0.045em;
				color: #0f172a;
			}

			.metric-value strong,
			.metric-number-strong {
				font-weight: 1000 !important;
				color: #020617;
			}

			.metric-meta {
				position: relative;
				z-index: 1;
				margin-top: 9px;
				font-size: 13px;
				color: var(--muted);
				line-height: 1.35;
			}

			.metric-blue { --metric-soft: #eff6ff; --metric-color: #1d4ed8; --metric-glow: rgba(37,99,235,0.10); --metric-gradient: linear-gradient(135deg, #2563eb, #60a5fa); --metric-shadow: rgba(37,99,235,0.22); }
