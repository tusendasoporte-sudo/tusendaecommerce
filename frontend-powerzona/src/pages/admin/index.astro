					0 18px 34px rgba(15, 23, 42, 0.075),
					inset 0 1px 0 rgba(255,255,255,0.95);
				position: relative;
				overflow: hidden;
				isolation: isolate;
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
