				box-shadow: 0 0 28px color-mix(in srgb, var(--expiration-alert, #2563eb) 50%, transparent);
			}

			.expiration-item::after {
				content: '';
				position: absolute;
				inset: -40% auto auto -18%;
				width: 180px;
				height: 180px;
				border-radius: 50%;
				background: color-mix(in srgb, var(--expiration-alert, #2563eb) 10%, transparent);
				z-index: -1;
			}

