					padding-bottom: 4px;
				}

				.period-btn,
				.expiration-btn {
					flex: 0 0 auto;
				}
			}</style>
		<style is:global>
			/* PZ-ADMIN-ACTIVITY-TEXT-LIST-FIX-003 */
			.activity-text-list,
			.recent-list {
				display: grid !important;
				gap: 0 !important;
				border: 0 !important;
				background: transparent !important;
				border-radius: 0 !important;
				overflow: visible !important;
				box-shadow: none !important;
			}

			.activity-text-row,
			.recent-list-row {
				min-height: auto !important;
				display: grid !important;
				grid-template-columns: minmax(0, 1fr) auto !important;
				align-items: center !important;
				gap: 12px !important;
				padding: 10px 0 !important;
				border: 0 !important;
				border-bottom: 1px solid #eef2f7 !important;
				border-radius: 0 !important;
				background: transparent !important;
				box-shadow: none !important;
				color: inherit !important;
				text-decoration: none !important;
			}

			.activity-text-row:last-child,
			.recent-list-row:last-child {
				border-bottom: 0 !important;
			}

			.activity-order-row {
				cursor: pointer !important;
			}

			.activity-order-row:hover {
				background: rgba(37, 99, 235, 0.035) !important;
			}

			.activity-product-row,
			.recent-product-row {
				grid-template-columns: 34px minmax(0, 1fr) !important;
				cursor: default !important;
			}

			.activity-text-main,
			.recent-list-main {
				min-width: 0 !important;
				display: flex !important;
				align-items: baseline !important;
				gap: 7px !important;
				flex-wrap: wrap !important;
			}

			.activity-text-title,
			.recent-list-title {
				max-width: 100% !important;
				color: #0f172a !important;
				font-size: 13.5px !important;
				font-weight: 1000 !important;
				line-height: 1.25 !important;
				overflow: hidden !important;
				text-overflow: ellipsis !important;
				white-space: nowrap !important;
			}

			.activity-text-meta,
			.recent-list-subtitle {
				color: #475569 !important;
				font-size: 12.5px !important;
				font-weight: 750 !important;
				line-height: 1.25 !important;
				white-space: nowrap !important;
			}

			.activity-rank-text,
			.recent-rank-badge {
				width: auto !important;
				height: auto !important;
				min-width: 0 !important;
				display: inline-flex !important;
				align-items: center !important;
				justify-content: flex-start !important;
				border-radius: 0 !important;
				background: transparent !important;
				color: #0f172a !important;
				font-size: 12.5px !important;
				font-weight: 1000 !important;
				box-shadow: none !important;
			}

			.activity-status-badge,
			.recent-status-badge {
				min-height: 22px !important;
				display: inline-flex !important;
				align-items: center !important;
				justify-content: center !important;
				border-radius: 999px !important;
				padding: 0 9px !important;
				font-size: 10.5px !important;
				font-weight: 1000 !important;
				line-height: 1 !important;
				white-space: nowrap !important;
				box-shadow: none !important;
			}

			.activity-status-badge.status-pending,
			.recent-status-badge.status-pending { background: #fef3c7 !important; color: #92400e !important; border: 1px solid #fde68a !important; }
			.activity-status-badge.status-confirmed,
			.recent-status-badge.status-confirmed { background: #dcfce7 !important; color: #166534 !important; border: 1px solid #bbf7d0 !important; }
			.activity-status-badge.status-preparing,
			.recent-status-badge.status-preparing { background: #ede9fe !important; color: #5b21b6 !important; border: 1px solid #ddd6fe !important; }
			.activity-status-badge.status-delivered,
			.recent-status-badge.status-delivered { background: #dcfce7 !important; color: #166534 !important; border: 1px solid #bbf7d0 !important; }
			.activity-status-badge.status-cancelled,
			.recent-status-badge.status-cancelled { background: #fee2e2 !important; color: #991b1b !important; border: 1px solid #fecaca !important; }

			.activity-empty-text,
			.recent-empty-state {
				border: 0 !important;
				border-radius: 0 !important;
				background: transparent !important;
				color: #64748b !important;
				font-size: 13px !important;
				font-weight: 850 !important;
				padding: 12px 0 !important;
				text-align: left !important;
				box-shadow: none !important;
			}

			.activity-product-row .recent-money-badge,
			.activity-product-row .activity-money-badge,
			.activity-product-row .money-badge,
			.activity-product-row .revenue-badge {
				display: none !important;
			}

			@media (max-width: 720px) {
				.activity-text-row,
				.recent-list-row {
					grid-template-columns: minmax(0, 1fr) auto !important;
					gap: 6px 10px !important;
					padding: 11px 0 !important;
				}

				.activity-product-row,
				.recent-product-row {
					grid-template-columns: 28px minmax(0, 1fr) !important;
				}

				.activity-text-main,
				.recent-list-main {
					display: grid !important;
					gap: 3px !important;
				}

				.activity-text-meta,
				.recent-list-subtitle {
					white-space: normal !important;
				}
