				truck: '<svg width="26" height="26" viewBox="0 0 28 28" fill="none"><path d="M3.5 8h13v10h-13V8Z" fill="#FFEDD5" stroke="#F97316" stroke-width="1.8" stroke-linejoin="round"/><path d="M16.5 12h4l3.5 4v2h-7.5v-6Z" fill="#FED7AA" stroke="#EA580C" stroke-width="1.8" stroke-linejoin="round"/><circle cx="8" cy="20" r="2.4" fill="#EA580C"/><circle cx="20" cy="20" r="2.4" fill="#EA580C"/><path d="M7 11h5.5" stroke="#FDBA74" stroke-width="2" stroke-linecap="round"/></svg>',
				expiration: '<svg width="26" height="26" viewBox="0 0 28 28" fill="none"><path d="M14 3.5 25 22.5H3L14 3.5Z" fill="#FEE2E2" stroke="#DC2626" stroke-width="1.9" stroke-linejoin="round"/><path d="M14 10v5.8" stroke="#B91C1C" stroke-width="2.4" stroke-linecap="round"/><circle cx="14" cy="19.5" r="1.4" fill="#B91C1C"/></svg>',
				trophy: '<svg width="26" height="26" viewBox="0 0 28 28" fill="none"><path d="M9 4h10v5.2a5 5 0 0 1-10 0V4Z" fill="#FEF3C7" stroke="#D97706" stroke-width="1.8"/><path d="M9 6H4.5v2.4A5 5 0 0 0 9 13m10-7h4.5v2.4A5 5 0 0 1 19 13" stroke="#F59E0B" stroke-width="1.8" stroke-linecap="round"/><path d="M14 14.5v5M9.5 24h9" stroke="#92400E" stroke-width="2" stroke-linecap="round"/><path d="M10.8 24h6.4v-3.8h-6.4V24Z" fill="#F59E0B"/></svg>',
			};
			function showAdmin() {
				adminView.classList.remove('hidden');
			}

			function getAdminToken() { return SESSION_TOKEN; }
			function clearAdminToken() { document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax'; }

			function escapeHtml(value) {
				return String(value ?? '')
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/"/g, '&quot;')
					.replace(/'/g, '&#039;');
			}

			function escapePbFilterValue(value) {
				return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
			}

			function normalizeSummaryRange(value) {
				const raw = String(value || '').trim().toLowerCase();

				if (raw === 'today' || raw === '1') return 'today';
				if (raw === '7') return '7';
				if (raw === '15') return '15';
				if (raw === '30') return '30';

				return '7';
			}

			function readInitialSummaryRange() {
				try {
					const params = new URLSearchParams(window.location.search || '');
					const urlRange = params.get('summary_range') || params.get('range') || '';
					if (urlRange) return urlRange;
				} catch (_) {}

				try {
					return localStorage.getItem(SUMMARY_RANGE_STORAGE_KEY) || '';
				} catch (_) {
					return '';
				}
			}

			function persistSummaryRange(value) {
				try {
					localStorage.setItem(SUMMARY_RANGE_STORAGE_KEY, normalizeSummaryRange(value));
				} catch (_) {}
			}

			function getSummaryRangeDays() {
				const range = normalizeSummaryRange(selectedRange);

				if (range === 'today') return 1;

				const days = Number(range || 7);
				if (!Number.isFinite(days)) return 7;

				return Math.max(1, Math.min(30, Math.floor(days)));
			}

			function getSummaryRangeLabel() {
				const range = normalizeSummaryRange(selectedRange);

				if (range === 'today') return 'Hoy';
				if (range === '7') return 'Últimos 7 días';
				if (range === '15') return 'Últimos 15 días';
				if (range === '30') return 'Últimos 30 días';

				return 'Últimos 7 días';
			}

			function syncSummaryRangeButtons() {
				const normalized = normalizeSummaryRange(selectedRange);
				periodButtons.forEach((button) => {
					const isActive = normalizeSummaryRange(button.dataset.range || '') === normalized;
					button.classList.toggle('active', isActive);
					button.setAttribute('aria-selected', isActive ? 'true' : 'false');
				});
			}

			function formatUSD(value) {
				return Number(value || 0).toLocaleString('en-US', {
					minimumFractionDigits: 2,
					maximumFractionDigits: 2,
				}) + ' USD';
			}

			function formatFullDate(value) {
				return new Intl.DateTimeFormat('es-US', { dateStyle: 'full' }).format(new Date(value));
			}

			function formatShortDate(value) {
				return new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short' }).format(new Date(value));
			}


			function formatDateOnly(value) {
				if (!value) return 'Sin fecha';
				return new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(value));
			}

			function parseProductImageOrder(product) {
				const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
				let stored = [];
				try {
					stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
				} catch (_) {
					stored = [];
				}
				const ordered = stored.filter((name) => images.includes(name));
				images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
				return ordered;
			}

			function productImageUrl(product) {
				const images = parseProductImageOrder(product);
				const firstImage = images[0] || '';
				if (!product?.id || !firstImage || !POCKETBASE_URL) return '';
				return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
			}

			function productExpirationThumbMarkup(product) {
				const url = productImageUrl(product);
				const name = product?.name || 'Producto';
				if (!url) return '<span class="expiration-thumb">📦</span>';
				return `<img class="expiration-thumb" src="${url}" alt="${escapeHtml(name)}" loading="lazy" />`;
			}


			function productAdminUrl(product) {
				if (!product?.id) return ADMIN_PRODUCTS_PATH;
				return `${ADMIN_PRODUCTS_PATH}?product=${encodeURIComponent(product.id)}`;
			}

			function orderDetailPath(order) {
				if (!order?.id) return ADMIN_ORDERS_PATH;
				return `${ADMIN_ORDERS_PATH.replace(/\/$/, '')}/${encodeURIComponent(order.id)}`;
			}

			function isProfitOrder(order) {
				return ['confirmed', 'delivered'].includes(String(order?.status || '').toLowerCase());
			}

			function formatMonth(value) {
				return new Intl.DateTimeFormat('es-ES', { month: 'short', year: '2-digit' }).format(new Date(value));
			}

			async function apiRequest(path, options = {}) {
				const headers = { ...(options.headers || {}) };
				const token = getAdminToken();
				if (token) headers.Authorization = `Bearer ${token}`;

				const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
				const result = await response.json().catch(() => null);

				if (!response.ok) {
					throw new Error(result?.message || 'Error de comunicación con la plataforma.');
				}

				return result;
			}
			async function loadAllRecords(collection, params = '') {
				let page = 1;
				const perPage = 200;
				let items = [];
				let totalPages = 1;
				const query = new URLSearchParams(params || '');
				const collectionHasStore = collection !== 'order_items' && collection !== 'product_variations' && collection !== 'manual_coupon_usages';
				if (collectionHasStore && STORE_FILTER && !query.has('filter')) query.set('filter', STORE_FILTER);

				do {
					query.set('page', String(page));
					query.set('perPage', String(perPage));
					const result = await apiRequest(`/api/collections/${collection}/records?${query.toString()}`);
					items = items.concat(result.items || []);
					totalPages = result.totalPages || 1;
					page += 1;
				} while (page <= totalPages);

				return items;
			}

			function getAnalyticsRetentionDays() {
				const configured = Number(settingsRecord?.analytics_retention_days ?? ANALYTICS_MAX_RETENTION_DAYS);
				if (!Number.isFinite(configured) || configured <= 0) return ANALYTICS_MAX_RETENTION_DAYS;
				return Math.max(1, Math.min(ANALYTICS_MAX_RETENTION_DAYS, Math.floor(configured)));
			}

			function getAnalyticsCutoffDate() {
				const date = new Date();
				date.setDate(date.getDate() - getAnalyticsRetentionDays());
				return date;
			}

			function getAnalyticsCutoffIso() {
				return getAnalyticsCutoffDate().toISOString();
			}

			function buildAnalyticsEventsQuery() {
				if (!CURRENT_STORE_ID) return 'sort=created';

				const filter = [
					`store="${escapePbFilterValue(CURRENT_STORE_ID)}"`,
					`created >= "${escapePbFilterValue(getAnalyticsCutoffIso())}"`,
				].join(' && ');

				const query = new URLSearchParams();
				query.set('filter', filter);
				query.set('sort', 'created');

				return query.toString();
			}

			function shouldRunAnalyticsCleanup() {
				if (settingsRecord?.analytics_cleanup_enabled === false) return false;

				const lastRunValue = String(settingsRecord?.analytics_cleanup_last_run_at || '').trim();
				if (!lastRunValue) return true;

				const lastRun = new Date(lastRunValue);
				if (Number.isNaN(lastRun.getTime())) return true;

				return Date.now() - lastRun.getTime() >= ANALYTICS_CLEANUP_INTERVAL_MS;
			}

			async function updateAnalyticsCleanupLastRun(dateIso) {
				if (!settingsRecord?.id) return;

				await apiRequest(`/api/collections/settings/records/${encodeURIComponent(settingsRecord.id)}`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						analytics_cleanup_last_run_at: dateIso,
					}),
				});

				settingsRecord.analytics_cleanup_last_run_at = dateIso;
			}

			async function deleteOldAnalyticsEvents(cutoffIso) {
				if (!CURRENT_STORE_ID || !cutoffIso) return 0;

				let deleted = 0;

				const filter = [
					`store="${escapePbFilterValue(CURRENT_STORE_ID)}"`,
					`created < "${escapePbFilterValue(cutoffIso)}"`,
				].join(' && ');

				for (let index = 0; index < 50; index += 1) {
					const query = new URLSearchParams();
					query.set('filter', filter);
					query.set('fields', 'id');
					query.set('sort', 'created');
					query.set('page', '1');
					query.set('perPage', '100');

					const result = await apiRequest(`/api/collections/store_analytics_events/records?${query.toString()}`);
					const ids = (result.items || []).map((item) => item.id).filter(Boolean);

					if (!ids.length) break;

					await Promise.all(ids.map((id) => (
						apiRequest(`/api/collections/store_analytics_events/records/${encodeURIComponent(id)}`, {
							method: 'DELETE',
						})
					)));

					deleted += ids.length;

					if (ids.length < 100) break;
				}

				return deleted;
			}

			async function runAnalyticsCleanupIfNeeded() {
				try {
					if (!settingsRecord) return;
					if (!shouldRunAnalyticsCleanup()) return;

					const cutoffIso = getAnalyticsCutoffIso();
					await deleteOldAnalyticsEvents(cutoffIso);
					await updateAnalyticsCleanupLastRun(new Date().toISOString());
				} catch (error) {
					}
			}

			function isReviewsCollectionMissing(error) {
				const text = String(error?.message || error?.data?.message || error || '').toLowerCase();
				return text.includes('reviews') || text.includes('collection') || text.includes('not found') || error?.status === 404;
			}

			function hasValue(value) {
				return value !== null && value !== undefined && String(value).trim() !== '';
			}

			function getReviewRequestDelayHours() {
				const hours = Number(settingsRecord?.review_request_delay_hours);
				return Number.isFinite(hours) && hours >= 0 ? hours : 24;
			}

			function getMonthStart() {
				const now = new Date();
				return new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
			}

			function orderHasCompletedReview(orderId) {
				if (!reviewsCollectionAvailable) return false;
				return reviews.some((review) => String(review.order || '') === String(orderId || '') && review.source === 'order_review_link');
			}

			function isOrderReadyForReview(order) {
				if (!order || order.status !== 'delivered') return false;
				if (!hasValue(order.delivered_at)) return false;
				if (hasValue(order.review_requested_at) || hasValue(order.review_skipped_at) || hasValue(order.review_completed_at)) return false;
				const deliveredAt = new Date(order.delivered_at);
				if (Number.isNaN(deliveredAt.getTime())) return false;
				const delayMs = getReviewRequestDelayHours() * 60 * 60 * 1000;
				if (Date.now() - deliveredAt.getTime() < delayMs) return false;
				return !orderHasCompletedReview(order.id);
			}

			async function loadSettingsRecord() {
				try {
					const settingsRecords = await loadAllRecords('settings');
					settingsRecord = (settingsRecords || []).find((record) => record.active === true) || settingsRecords?.[0] || null;
				} catch (error) {
					settingsRecord = null;
				}

				return settingsRecord;
			}

			async function loadRatingSupportData() {
				if (!settingsRecord) {
					await loadSettingsRecord();
				}

				try {
					reviews = await loadAllRecords('reviews', 'sort=-created');
					reviewsCollectionAvailable = true;
				} catch (error) {
					reviews = [];
					reviewsCollectionAvailable = false;
				}
			}

			function getRangeStart() {
				const days = getSummaryRangeDays();
				const start = new Date();
				start.setHours(0, 0, 0, 0);
				start.setDate(start.getDate() - (days - 1));
				return start;
			}

			function getFilteredOrders() {
				const start = getRangeStart();
				if (!start) return [...orders];
				return orders.filter((order) => new Date(order.created) >= start);
			}

			function getFilteredItems(filteredOrders) {
				const allowedOrders = new Set(filteredOrders.map((order) => order.id));
				return orderItems.filter((item) => allowedOrders.has(item.order));
			}

			function getItemProductName(item) {
				return item.product_name
					|| item.expand?.product?.name
					|| item.expand?.product?.title
					|| 'Producto sin nombre';
			}

			function getTopProducts(filteredItems) {
				const productsMap = new Map();

				for (const item of filteredItems) {
					const name = getItemProductName(item);
					const quantity = Number(item.quantity || 0);
					const unitPrice = Number(item.unit_price_usd || item.unit_price_selected_currency || 0);
					const current = productsMap.get(name) || { name, quantity: 0, total: 0 };
					current.quantity += quantity;
					current.total += quantity * unitPrice;
					productsMap.set(name, current);
				}

				return Array.from(productsMap.values())
					.sort((a, b) => b.quantity - a.quantity || b.total - a.total)
					.slice(0, 10);
			}

			function getItemEstimatedUnitProfit(item) {
				const savedUnitProfit = item.unit_profit_usd;
				if (savedUnitProfit !== undefined && savedUnitProfit !== null && savedUnitProfit !== '') {
					const numericSaved = Number(savedUnitProfit);
					if (Number.isFinite(numericSaved) && numericSaved !== 0) return numericSaved;
				}

				const unitPrice = Number(item.unit_price_usd || item.variation_price_usd || item.unit_price_selected_currency || 0);
				const variationCost = item.expand?.variation ? Number(item.expand.variation.cost_usd || 0) : 0;
				const productCost = item.expand?.product ? Number(item.expand.product.cost_usd || 0) : 0;
				const unitCost = variationCost || productCost;
				return unitPrice - unitCost;
			}

			function getItemEstimatedLineProfit(item) {
				if (item.is_gift) return 0;
				const savedLineProfit = item.line_profit_usd;
				if (savedLineProfit !== undefined && savedLineProfit !== null && savedLineProfit !== '') {
					const numericSaved = Number(savedLineProfit);
					if (Number.isFinite(numericSaved) && numericSaved !== 0) return numericSaved;
				}
				return getItemEstimatedUnitProfit(item) * Number(item.quantity || 0);
			}

			function getOrderProfitMap(filteredItems) {
				return filteredItems.reduce((acc, item) => {
					const orderId = item.order;
					if (!orderId) return acc;
					acc[orderId] = (acc[orderId] || 0) + getItemEstimatedLineProfit(item);
					return acc;
				}, {});
			}

			function isSameDay(dateA, dateB) {
				return dateA.getFullYear() === dateB.getFullYear()
					&& dateA.getMonth() === dateB.getMonth()
					&& dateA.getDate() === dateB.getDate();
			}

			function getDaySeries(filteredOrders, days, profitByOrder = {}) {
				const today = new Date();
				today.setHours(0, 0, 0, 0);
				const result = [];

				for (let i = days - 1; i >= 0; i -= 1) {
					const day = new Date(today);
					day.setDate(today.getDate() - i);
					const dayOrders = filteredOrders.filter((order) => isSameDay(new Date(order.created), day));
					result.push({
						label: formatShortDate(day),
						sales: dayOrders.reduce((sum, order) => sum + Number(order.total || 0), 0),
						profit: dayOrders.reduce((sum, order) => sum + Number(profitByOrder[order.id] || 0), 0),
						count: dayOrders.length,
					});
				}

				return result;
			}

			function getMonthSeries(filteredOrders, monthsBack = null, profitByOrder = {}) {
				const map = new Map();
				const today = new Date();

				if (monthsBack) {
					for (let i = monthsBack - 1; i >= 0; i -= 1) {
						const monthDate = new Date(today.getFullYear(), today.getMonth() - i, 1);
						const key = `${monthDate.getFullYear()}-${String(monthDate.getMonth() + 1).padStart(2, '0')}`;
						map.set(key, { label: formatMonth(monthDate), sales: 0, profit: 0, count: 0, date: monthDate });
					}
				}

				for (const order of filteredOrders) {
					const date = new Date(order.created);
					const monthDate = new Date(date.getFullYear(), date.getMonth(), 1);
					const key = `${monthDate.getFullYear()}-${String(monthDate.getMonth() + 1).padStart(2, '0')}`;
					if (!map.has(key)) {
						map.set(key, { label: formatMonth(monthDate), sales: 0, profit: 0, count: 0, date: monthDate });
					}
					const bucket = map.get(key);
					bucket.sales += Number(order.total || 0);
					bucket.profit += Number(profitByOrder[order.id] || 0);
					bucket.count += 1;
				}

				return Array.from(map.values()).sort((a, b) => a.date - b.date);
			}

			function getChartSeries(filteredOrders, profitByOrder = {}) {
				return getDaySeries(filteredOrders, getSummaryRangeDays(), profitByOrder);
			}

			function computeMetrics() {
				const filteredOrders = getFilteredOrders();
				const filteredItems = getFilteredItems(filteredOrders);
				const profitOrders = filteredOrders.filter(isProfitOrder);
				const profitItems = getFilteredItems(profitOrders);
				const totalSales = filteredOrders.reduce((sum, order) => sum + Number(order.total || 0), 0);
				const totalShipping = filteredOrders.reduce((sum, order) => sum + Number(order.shipping || 0), 0);
				const profitByOrder = getOrderProfitMap(profitItems);
				const totalProfit = profitItems.reduce((sum, item) => sum + getItemEstimatedLineProfit(item), 0);
				const averageTicket = filteredOrders.length ? totalSales / filteredOrders.length : 0;
				const openOrders = filteredOrders.filter((order) => ['pending', 'confirmed', 'preparing'].includes(order.status)).length;

				const topProducts = getTopProducts(filteredItems);
				const topProduct = topProducts[0] || null;

				const statusCounts = filteredOrders.reduce((acc, order) => {
					const status = order.status || 'pending';
					acc[status] = (acc[status] || 0) + 1;
					return acc;
				}, {});

				return { filteredOrders, filteredItems, totalSales, totalShipping, totalProfit, profitByOrder, averageTicket, openOrders, topProduct, topProducts, statusCounts };
			}

			function getOneMonthExpirationSummary() {
				const now = new Date();
				now.setHours(0, 0, 0, 0);

				const limit = new Date(now);
				limit.setDate(limit.getDate() + 30);
				limit.setHours(23, 59, 59, 999);

				const items = products
					.map((product) => {
						if (!product.expiration_date) return null;
						const expirationDate = new Date(product.expiration_date);
						if (Number.isNaN(expirationDate.getTime())) return null;
						expirationDate.setHours(0, 0, 0, 0);
						if (expirationDate > limit) return null;
						const daysLeft = Math.ceil((expirationDate - now) / 86400000);
						return { product, expirationDate, daysLeft };
					})
					.filter(Boolean)
					.sort((a, b) => a.daysLeft - b.daysLeft);

				const expiredCount = items.filter((item) => item.daysLeft < 0).length;
				const validCount = items.length - expiredCount;
				return { items, expiredCount, validCount };
			}

			function localDayKey(date) {
				const value = date instanceof Date ? date : new Date(date);
				if (Number.isNaN(value.getTime())) return '';
				const local = new Date(value.getTime() - value.getTimezoneOffset() * 60000);
				return local.toISOString().slice(0, 10);
			}

			function shortDayLabel(dayKey) {
				const date = new Date(`${dayKey}T00:00:00`);
				if (Number.isNaN(date.getTime())) return dayKey;
				return date.toLocaleDateString('es', { day: '2-digit', month: 'short' }).replace('.', '');
			}

			function shouldShowAnalyticsTickLabel(index, total) {
				if (total <= 1) return true;
				if (total <= 7) return true;
				if (total <= 15) return index === 0 || index === total - 1 || index % 3 === 0;
				if (total <= 30) return index === 0 || index === total - 1 || index % 5 === 0;
				if (total <= 90) return index === 0 || index === total - 1 || index % 14 === 0;
				const step = Math.max(1, Math.ceil(total / 10));
				return index === 0 || index === total - 1 || index % step === 0;
			}

			function getNiceAnalyticsMax(value) {
				const numeric = Number(value || 0);
				if (numeric <= 0) return 4;
				if (numeric <= 2) return 4;
				if (numeric <= 5) return 6;
				if (numeric <= 10) return 10;
				if (numeric <= 20) return 20;
				if (numeric <= 50) return 50;
				const magnitude = Math.pow(10, Math.floor(Math.log10(numeric)));
				return Math.ceil(numeric / magnitude) * magnitude;
			}

			function getNiceAnalyticsStep(value) {
				const numeric = Number(value || 0);
				if (numeric <= 4) return 1;
				if (numeric <= 10) return 2;
				if (numeric <= 20) return 5;
				if (numeric <= 50) return 10;

				const rawStep = numeric / 4;
				const magnitude = Math.pow(10, Math.floor(Math.log10(rawStep)));
				const normalized = rawStep / magnitude;
				if (normalized <= 1) return magnitude;
				if (normalized <= 2) return 2 * magnitude;
				if (normalized <= 2.5) return 2.5 * magnitude;
				if (normalized <= 5) return 5 * magnitude;
				return 10 * magnitude;
			}

			function getAnalyticsGridScale(value) {
				const baseMax = getNiceAnalyticsMax(value);
				const step = getNiceAnalyticsStep(baseMax);
				const max = Math.max(step, Math.ceil(baseMax / step) * step);
				const ticks = [];

				for (let tick = 0; tick <= max; tick += step) {
					ticks.push(Math.round(tick * 100) / 100);
				}

				if (ticks[ticks.length - 1] !== max) ticks.push(max);
				return { max, ticks };
			}

			function getAnalyticsRangeDays() {
				const maxDays = Math.min(getAnalyticsRetentionDays(), ANALYTICS_MAX_RETENTION_DAYS);
				const total = Math.max(1, Math.min(maxDays, getSummaryRangeDays()));

				return Array.from({ length: total }, (_, index) => {
					const date = new Date();
					date.setDate(date.getDate() - (total - 1 - index));
					return localDayKey(date);
				});
			}

			function computeTrafficAnalytics() {
				const days = getAnalyticsRangeDays();
				const daySet = new Set(days);
				const grouped = new Map(days.map((day) => [day, {
					day,
					label: shortDayLabel(day),
					pageViews: 0,
					visitors: new Set(),
					visitorSessions: new Map(),
				}]));
				const periodVisitors = new Set();
				const periodVisitorSessions = new Map();

				analyticsEvents.forEach((event) => {
					const day = String(event.day || '').slice(0, 10) || localDayKey(event.created);
					if (!daySet.has(day)) return;

					const bucket = grouped.get(day);
					if (!bucket) return;

					const eventType = String(event.event_type || 'pageview').trim().toLowerCase();

					if (eventType === 'pageview') {
						bucket.pageViews += 1;
					}

					const visitor = String(event.visitor_id || '').trim();
					const session = String(event.session_id || '').trim();

					if (visitor) {
						bucket.visitors.add(visitor);
						periodVisitors.add(visitor);
						if (!bucket.visitorSessions.has(visitor)) bucket.visitorSessions.set(visitor, new Set());
						if (!periodVisitorSessions.has(visitor)) periodVisitorSessions.set(visitor, new Set());
						bucket.visitorSessions.get(visitor).add(session || `legacy-${day}`);
						periodVisitorSessions.get(visitor).add(session || `legacy-${day}`);
					}
				});

				const series = days.map((day) => {
					const bucket = grouped.get(day);
					const recurrentVisitors = Array.from(bucket?.visitorSessions?.values() || [])
						.filter((sessions) => sessions.size >= 2)
						.length;
					return {
						day,
						label: shortDayLabel(day),
						pageViews: bucket?.pageViews || 0,
						uniqueVisitors: bucket?.visitors?.size || 0,
						recurrentVisitors,
					};
				});

				const totalPageViews = series.reduce((sum, item) => sum + item.pageViews, 0);
				const totalUniqueVisitors = periodVisitors.size;
				const totalRecurrentVisitors = Array.from(periodVisitorSessions.values())
					.filter((sessions) => sessions.size >= 2)
					.length;
				const divisor = Math.max(series.length, 1);

				return {
					series,
					totalPageViews,
					totalUniqueVisitors,
					totalRecurrentVisitors,
					averagePageViews: totalPageViews / divisor,
					averageUniqueVisitors: series.reduce((sum, item) => sum + item.uniqueVisitors, 0) / divisor,
					averageRecurrentVisitors: series.reduce((sum, item) => sum + item.recurrentVisitors, 0) / divisor,
				};
			}

			function createTrafficChartMarkup(points, field, strokeColor, fillColor) {
				if (!points.length || points.every((point) => Number(point[field] || 0) === 0)) {
					return `
						<div class="traffic-empty-state">
							<strong>Sin actividad visible todavía</strong>
							<small>Cuando haya visitas en este periodo, la tendencia aparecerá aquí.</small>
						</div>
					`;
				}

				const width = 900;
				const height = 300;
				const paddingX = 58;
				const paddingTop = 26;
				const paddingBottom = 56;
				const innerWidth = width - paddingX * 2;
				const innerHeight = height - paddingTop - paddingBottom;
				const values = points.map((point) => Number(point[field] || 0));
				const maxValue = Math.max(...values, 0);
				const scale = getAnalyticsGridScale(maxValue);
				const stepX = points.length > 1 ? innerWidth / (points.length - 1) : 0;

				const coords = points.map((point, index) => {
					const value = Number(point[field] || 0);
					const x = points.length > 1 ? paddingX + index * stepX : paddingX + innerWidth / 2;
					const y = paddingTop + innerHeight - ((value / scale.max) * innerHeight);
					return { ...point, value, x, y, index };
				});

				function buildSmoothPath(items) {
					if (items.length === 1) return `M ${paddingX} ${items[0].y} L ${width - paddingX} ${items[0].y}`;

					return items.map((point, index) => {
						if (index === 0) return `M ${point.x} ${point.y}`;
						const previous = items[index - 1];
						const middleX = (previous.x + point.x) / 2;
						return `C ${middleX} ${previous.y}, ${middleX} ${point.y}, ${point.x} ${point.y}`;
					}).join(' ');
				}

				const linePath = buildSmoothPath(coords);
				const baselineY = height - paddingBottom;
				const areaPath = coords.length === 1
					? `${linePath} L ${width - paddingX} ${baselineY} L ${paddingX} ${baselineY} Z`
					: `${linePath} L ${coords[coords.length - 1].x} ${baselineY} L ${coords[0].x} ${baselineY} Z`;
				const gradientId = `traffic-${field}-${selectedRange}-${coords.length}`;
				const grid = scale.ticks.map((value) => {
					const y = paddingTop + innerHeight - ((value / scale.max) * innerHeight);
					return { y, value };
				});

				const visibleLabels = coords.filter((point) => shouldShowAnalyticsTickLabel(point.index, coords.length));
				const visiblePoints = coords.filter((point) => {
					if (coords.length <= 15) return true;
					if (point.index === 0 || point.index === coords.length - 1) return true;
					if (point.index % 5 === 0) return true;
					if (point.value <= 0) return false;
					const previousValue = coords[point.index - 1]?.value || 0;
					const nextValue = coords[point.index + 1]?.value || 0;
					if (point.value > previousValue && point.value >= nextValue) return true;
					return false;
				});

				return `
					<svg class="traffic-chart-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="Gráfico de analítica de tienda">
						<defs>
							<linearGradient id="${gradientId}" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="${fillColor}" stop-opacity="0.26" />
								<stop offset="100%" stop-color="${fillColor}" stop-opacity="0.03" />
							</linearGradient>
						</defs>
						${grid.map((tick) => `
							<line x1="${paddingX}" y1="${tick.y}" x2="${width - paddingX}" y2="${tick.y}" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="5 7" stroke-linecap="round" />
							<text x="${width - paddingX + 12}" y="${tick.y + 4}" font-size="11" font-weight="750" fill="#64748b">${tick.value}</text>
						`).join('')}
						<path d="${areaPath}" fill="url(#${gradientId})"></path>
						<path d="${linePath}" fill="none" stroke="${strokeColor}" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round"></path>
						${coords.length ? `
							<circle cx="${coords[coords.length - 1].x}" cy="${coords[coords.length - 1].y}" r="10" fill="${strokeColor}" fill-opacity="0.12" />
						` : ''}
						${visiblePoints.map((point) => {
							const isLast = point.index === coords.length - 1;
							const radius = isLast ? 6.4 : point.value > 0 ? 4.4 : 3.2;
							const opacity = isLast || point.value > 0 ? 1 : 0.52;
							return `
								<circle cx="${point.x}" cy="${point.y}" r="${radius}" fill="${strokeColor}" fill-opacity="${opacity}" stroke="#ffffff" stroke-width="${isLast ? 3 : 2}" />
							`;
						}).join('')}
						${visibleLabels.map((point) => `
							<text x="${point.x}" y="${height - 16}" text-anchor="middle" font-size="11" font-weight="800" fill="#475569">${escapeHtml(point.label)}</text>
						`).join('')}
					</svg>
				`;
			}

			function renderTrafficAnalytics() {
				const traffic = computeTrafficAnalytics();

				if (trafficVisitsTotal) trafficVisitsTotal.textContent = String(traffic.totalUniqueVisitors);
				if (trafficVisitorsTotal) trafficVisitorsTotal.textContent = String(traffic.totalRecurrentVisitors);
				if (trafficPageviewsTotal) trafficPageviewsTotal.textContent = String(traffic.totalPageViews);
				if (trafficVisitsAverage) trafficVisitsAverage.innerHTML = `Promedio diario: <strong>${traffic.averageUniqueVisitors.toFixed(1)}</strong>`;
				if (trafficVisitorsAverage) trafficVisitorsAverage.innerHTML = `Promedio diario: <strong>${traffic.averageRecurrentVisitors.toFixed(1)}</strong>`;
				if (trafficPageviewsAverage) trafficPageviewsAverage.innerHTML = `Promedio diario: <strong>${traffic.averagePageViews.toFixed(1)}</strong>`;
				if (trafficVisitsChart) trafficVisitsChart.innerHTML = createTrafficChartMarkup(traffic.series, 'uniqueVisitors', '#2563eb', '#60a5fa');
				if (trafficVisitorsChart) trafficVisitorsChart.innerHTML = createTrafficChartMarkup(traffic.series, 'recurrentVisitors', '#0f172a', '#64748b');
				if (trafficPageviewsChart) trafficPageviewsChart.innerHTML = createTrafficChartMarkup(traffic.series, 'pageViews', '#2563eb', '#60a5fa');
			}

			function isLandingQrViewEvent(event) {
				const eventType = String(event?.event_type || 'pageview').trim().toLowerCase();
				const pageType = String(event?.page_type || '').trim().toLowerCase();
				return eventType === 'landing_qr_view' || (eventType === 'pageview' && pageType === 'landing_qr');
			}

			function isLandingQrClickEvent(event) {
				return String(event?.event_type || '').trim().toLowerCase() === 'landing_qr_click';
			}

			function computeLandingQrAnalytics() {
				const days = getAnalyticsRangeDays();
				const grouped = new Map(days.map((day) => [day, {
					day,
					label: shortDayLabel(day),
					views: 0,
					clicks: 0,
				}]));
				const buttonCounts = new Map();
				let views = 0;
				let clicks = 0;

				getAnalyticsEventsForSelectedRange().forEach((event) => {
					const day = String(event.day || '').slice(0, 10) || localDayKey(event.created);
					const bucket = grouped.get(day);

					if (isLandingQrViewEvent(event)) {
						views += 1;
						if (bucket) bucket.views += 1;
						return;
					}

					if (!isLandingQrClickEvent(event)) return;

					clicks += 1;
					if (bucket) bucket.clicks += 1;

					const linkId = String(event.link_id || event.link_label || event.link_type || 'link').trim() || 'link';
					const label = String(event.link_label || 'Enlace').trim() || 'Enlace';
					const type = String(event.link_type || 'link').trim() || 'link';
					const current = buttonCounts.get(linkId) || { link_id: linkId, label, type, clicks: 0 };
					current.clicks += 1;
					buttonCounts.set(linkId, current);
				});

				const clicksByButton = Array.from(buttonCounts.values())
					.sort((a, b) => b.clicks - a.clicks || a.label.localeCompare(b.label))
					.map((item) => ({
						...item,
						percentage: clicks > 0 ? Math.round((item.clicks / clicks) * 100) : 0,
					}));

				return {
					views,
					clicks,
					interactionRate: views > 0 ? Math.round((clicks / views) * 100) : 0,
					topButton: clicksByButton[0] || null,
					clicksByButton,
					series: days.map((day) => grouped.get(day) || { day, label: shortDayLabel(day), views: 0, clicks: 0 }),
				};
			}

			function renderLandingQrAnalytics() {
				const metrics = computeLandingQrAnalytics();
				const formatCount = (value) => Number(value || 0).toLocaleString('es-US');

				if (trafficLandingViewsTotal) trafficLandingViewsTotal.textContent = formatCount(metrics.views);
				if (trafficLandingClicksTotal) trafficLandingClicksTotal.textContent = formatCount(metrics.clicks);
				if (trafficLandingRateTotal) trafficLandingRateTotal.textContent = `${formatCount(metrics.interactionRate)}%`;
				if (trafficLandingTopButton) trafficLandingTopButton.textContent = metrics.topButton ? metrics.topButton.label : 'Sin datos';
				if (trafficLandingChart) trafficLandingChart.innerHTML = createTrafficChartMarkup(metrics.series, 'views', '#16a34a', '#22c55e');

				if (trafficLandingClicksMeta) {
					trafficLandingClicksMeta.textContent = metrics.clicks
						? `${formatCount(metrics.clicks)} clics registrados`
						: 'Sin clics en este periodo';
				}

				if (!trafficLandingClicksList) return;

				if (!metrics.clicksByButton.length) {
					trafficLandingClicksList.innerHTML = '<div class="visit-analytics-empty">Todavía no hay clics de Landing QR en este periodo.</div>';
					return;
				}

				trafficLandingClicksList.innerHTML = metrics.clicksByButton.slice(0, 10).map((item) => `
					<div class="landing-qr-click-row">
						<span class="landing-qr-click-main">
							<strong>${escapeHtml(item.label)}</strong>
							<span>${escapeHtml(item.type)}</span>
						</span>
						<span class="landing-qr-click-count">${escapeHtml(formatCount(item.clicks))} clics</span>
						<span class="landing-qr-click-percent">${escapeHtml(formatCount(item.percentage))}%</span>
					</div>
				`).join('');
			}

			function getAnalyticsEventsForSelectedRange() {
				const days = getAnalyticsRangeDays();
				const daySet = new Set(days);

				return analyticsEvents.filter((event) => {
					const day = String(event.day || '').slice(0, 10) || localDayKey(event.created);
					return daySet.has(day);
				});
			}

			function getProductNameById(productId) {
				const product = products.find((item) => String(item.id || '') === String(productId || ''));
				return product?.name || product?.title || 'Producto sin nombre';
			}

			function getMostViewedProducts() {
				const counts = new Map();

				getAnalyticsEventsForSelectedRange().forEach((event) => {
					const pageType = String(event.page_type || '').trim().toLowerCase();
					const eventType = String(event.event_type || 'pageview').trim().toLowerCase();
					if (pageType !== 'product' || eventType !== 'pageview') return;

					const productId = String(event.entity_id || event.page_id || '').trim();
					if (!productId) return;

					const current = counts.get(productId) || { productId, name: getProductNameById(productId), views: 0 };
					current.views += 1;
					counts.set(productId, current);
				});

				return Array.from(counts.values())
					.sort((a, b) => b.views - a.views || a.name.localeCompare(b.name))
					.slice(0, 5);
			}

			function renderMostViewedProducts() {
				if (!mostViewedProductsList || !mostViewedProductsMeta) return;
				const mostViewed = getMostViewedProducts();
				const totalViews = mostViewed.reduce((sum, item) => sum + Number(item.views || 0), 0);
				mostViewedProductsMeta.textContent = totalViews ? `${totalViews} vista${totalViews === 1 ? '' : 's'} registradas en productos.` : '';

				if (!mostViewed.length) {
					mostViewedProductsList.innerHTML = '<div class="visit-analytics-empty">Todavía no hay productos vistos en este periodo.</div>';
					return;
				}

				const maxViews = Math.max(...mostViewed.map((product) => Number(product.views || 0)), 1);
				mostViewedProductsList.innerHTML = mostViewed.map((product, index) => {
					const viewsText = `${product.views} vista${product.views === 1 ? '' : 's'}`;
					const width = Math.max(6, Math.round((Number(product.views || 0) / maxViews) * 100));
					return `
						<div class="visit-analytics-top-row">
							<span class="visit-analytics-product-name">${index + 1}. ${escapeHtml(product.name)}</span>
							<span class="visit-analytics-product-bar" aria-hidden="true"><span style="width: ${width}%"></span></span>
							<span class="visit-analytics-product-count">${escapeHtml(viewsText)}</span>
						</div>
					`;
				}).join('');
			}

			function renderBusinessDetailRows(container, rows, emptyText = 'Sin datos suficientes') {
				if (!container) return;
				const validRows = rows.filter((row) => row && row.label);
				if (!validRows.length) {
					container.innerHTML = `<div class="business-empty-state">${escapeHtml(emptyText)}</div>`;
					return;
				}

				container.innerHTML = validRows.map((row) => `
					<div class="business-detail-row">
						<span class="business-detail-label">${escapeHtml(row.label)}</span>
						<span class="business-detail-value">${escapeHtml(row.value)}</span>
					</div>
				`).join('');
			}

			function renderBusinessSummary(metrics) {
				if (businessProductsTotal) businessProductsTotal.textContent = String(products.length);
				if (businessSalesTotal) businessSalesTotal.textContent = formatUSD(metrics.totalSales);
				if (businessProfitTotal) businessProfitTotal.textContent = formatUSD(metrics.totalProfit);
				if (businessOrdersTotal) businessOrdersTotal.textContent = String(metrics.filteredOrders.length);

				const hasVariationField = products.some((product) => Object.prototype.hasOwnProperty.call(product, 'has_variations'));
				const productsWithStockField = products.filter((product) => Object.prototype.hasOwnProperty.call(product, 'stock'));
				const productRows = [
					{ label: 'Registrados', value: products.length },
				];

