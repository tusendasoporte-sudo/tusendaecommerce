			.expiration-view:hover {
				transform: translateY(-2px) scale(1.02);
				filter: saturate(1.08) brightness(0.96);
				box-shadow:
					0 20px 38px color-mix(in srgb, var(--expiration-alert, #2563eb) 42%, transparent),
					0 0 0 4px color-mix(in srgb, var(--expiration-alert, #2563eb) 12%, transparent),
					inset 0 1px 0 rgba(255,255,255,0.28);
