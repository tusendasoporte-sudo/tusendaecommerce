			.expiration-item::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 5px;
				background: var(--expiration-alert, #2563eb);
				box-shadow: 0 0 28px color-mix(in srgb, var(--expiration-alert, #2563eb) 50%, transparent);
			}

			.expiration-item::after {
				content: '';
				position: absolute;
				inset: -40% auto auto -18%;
				width: 180px;
				height: 180px;
				border-radius: 50%;
				background: color-mix(in srgb, var(--expiration-alert, #2563eb) 10%, transparent);
				z-index: -1;
			}

			.expiration-item.expired,
			.expiration-item.one-month { --expiration-alert: #dc2626; --expiration-soft: #fee2e2; --expiration-text: #991b1b; }
			.expiration-item.two-months { --expiration-alert: #f59e0b; --expiration-soft: #fef3c7; --expiration-text: #92400e; }
			.expiration-item.three-months { --expiration-alert: #2563eb; --expiration-soft: #dbeafe; --expiration-text: #1d4ed8; }

			.expiration-signal {
				width: 12px;
				height: 12px;
