		</style>
	</head>
	<body>
		<main>
			<section id="admin-view" class="admin-view pz-admin-content">
				<div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
      <AdminSidebar storeId={currentStoreId} pocketbaseUrl={pocketbaseUrl} authToken={adminAuthToken} storeSlug={currentStoreSlug} storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'} activeSection="overview" />

				<div class="main-wrap pz-admin-content-inner">
					<AdminSectionHeader
            kicker="Resumen"
            title={`Panel de ${currentStoreName}`}
            description="Cargando resumen del negocio..."
            titleId="dashboard-page-title"
            descriptionId="dashboard-subtitle"
            bellId="admin-overview-bell"
          />

					<section class="summary-period-card" aria-label="Periodo del resumen">
						<div class="summary-period-head">
							<div>
								<h2>Periodo del resumen</h2>
								<p>Este resumen muestra actividad reciente del periodo seleccionado.</p>
							</div>
							<p id="range-label" class="dashboard-range-note">Mostrando: Últimos 7 días.</p>
						</div>

						<div class="summary-period-actions period-tabs" role="tablist" aria-label="Período del resumen" data-pz-scroll-hint>
							<button class="period-btn" type="button" data-range="today" aria-selected="false">Hoy</button>
							<button class="period-btn active" type="button" data-range="7" aria-selected="true">7 días</button>
							<button class="period-btn" type="button" data-range="15" aria-selected="false">15 días</button>
							<button class="period-btn" type="button" data-range="30" aria-selected="false">1 mes</button>
						</div>
					</section>

					<section class="visit-analytics-card dashboard-traffic-block" aria-labelledby="dashboard-traffic-title">
						<div class="visit-analytics-header">
							<p class="visit-analytics-kicker">Analíticas</p>
							<h2 id="dashboard-traffic-title">Analíticas de visitas</h2>
							<p>Revisa navegación pública reciente con el historial disponible de la tienda.</p>
						</div>

						<div class="visit-analytics-toolbar">
							<div class="visit-analytics-tabs" role="tablist" aria-label="Analíticas de visitas" data-pz-scroll-hint>
								<button class="visit-analytics-tab is-active" type="button" data-analytics-tab="visitors" aria-selected="true">Visitantes del periodo</button>
								<button class="visit-analytics-tab" type="button" data-analytics-tab="recurrent" aria-selected="false">Recurrentes</button>
								<button class="visit-analytics-tab" type="button" data-analytics-tab="pageviews" aria-selected="false">Páginas vistas</button>
								<button class="visit-analytics-tab" type="button" data-analytics-tab="products" aria-selected="false">Productos más vistos</button>
								<button class="visit-analytics-tab" type="button" data-analytics-tab="landingqr" aria-selected="false">Landing QR</button>
							</div>
						</div>

						<div class="visit-analytics-panel is-active" data-analytics-panel="visitors">
							<h3 class="visit-analytics-panel-title">Visitantes del periodo</h3>
							<strong id="traffic-visits-total" class="visit-analytics-big-number">0</strong>
							<p class="visit-analytics-panel-help">Clientes únicos que visitaron la tienda durante el periodo seleccionado.</p>
							<p id="traffic-visits-average" class="visit-analytics-average-note">Promedio diario: 0</p>
							<div id="traffic-visits-chart" class="analytics-line-chart"></div>
						</div>

						<div class="visit-analytics-panel" data-analytics-panel="recurrent">
							<h3 class="visit-analytics-panel-title">Visitantes recurrentes</h3>
							<strong id="traffic-visitors-total" class="visit-analytics-big-number">0</strong>
							<p class="visit-analytics-panel-help">Clientes que volvieron a navegar más de una vez durante el periodo.</p>
							<p id="traffic-visitors-average" class="visit-analytics-average-note">Promedio diario: 0</p>
							<div id="traffic-visitors-chart" class="analytics-line-chart"></div>
						</div>

						<div class="visit-analytics-panel" data-analytics-panel="pageviews">
							<h3 class="visit-analytics-panel-title">Páginas vistas</h3>
							<strong id="traffic-pageviews-total" class="visit-analytics-big-number">0</strong>
							<p class="visit-analytics-panel-help">Total de páginas públicas abiertas durante el periodo.</p>
							<p id="traffic-pageviews-average" class="visit-analytics-average-note">Promedio diario: 0</p>
							<div id="traffic-pageviews-chart" class="analytics-line-chart"></div>
						</div>

						<div class="visit-analytics-panel" data-analytics-panel="products">
							<h3 class="visit-analytics-panel-title">Productos más vistos</h3>
							<p class="visit-analytics-panel-help">Top de productos públicos visitados en el periodo.</p>
							<div id="most-viewed-products-list" class="visit-analytics-top-list"></div>
							<p id="most-viewed-products-meta" class="mini-panel-meta">Cargando...</p>
						</div>

						<div class="visit-analytics-panel" data-analytics-panel="landingqr">
							<h3 class="visit-analytics-panel-title">Landing QR</h3>
							<p class="visit-analytics-panel-help">Rendimiento de la página abierta desde el QR durante el periodo seleccionado.</p>
							<div class="landing-qr-analytics-grid">
								<div class="landing-qr-analytics-stat">
									<span>Visitas Landing QR</span>
									<strong id="traffic-landing-views-total">0</strong>
								</div>
								<div class="landing-qr-analytics-stat">
									<span>Clics Landing QR</span>
									<strong id="traffic-landing-clicks-total">0</strong>
								</div>
								<div class="landing-qr-analytics-stat">
									<span>Interacción</span>
									<strong id="traffic-landing-rate-total">0%</strong>
								</div>
								<div class="landing-qr-analytics-stat">
									<span>Botón más tocado</span>
									<strong id="traffic-landing-top-button">Sin datos</strong>
								</div>
							</div>
							<div id="traffic-landing-chart" class="analytics-line-chart"></div>
							<div class="landing-qr-clicks-head">
								<h4>Clics por botón</h4>
								<p id="traffic-landing-clicks-meta">Cargando...</p>
							</div>
							<div id="traffic-landing-clicks-list" class="landing-qr-clicks-list"></div>
						</div>
					</section>

					<section class="business-summary-card dashboard-business-block" aria-labelledby="dashboard-main-title">
						<div class="business-summary-header">
							<p class="business-summary-kicker">Resumen</p>
							<h2 id="dashboard-main-title">Resumen del negocio</h2>
							<p>Productos, ventas, ganancia estimada y pedidos del periodo seleccionado.</p>
						</div>

						<div class="business-summary-tabs" role="tablist" aria-label="Resumen del negocio" data-pz-scroll-hint>
							<button class="business-summary-tab is-active" type="button" data-business-summary-tab="products" aria-selected="true">Productos</button>
							<button class="business-summary-tab" type="button" data-business-summary-tab="sales" aria-selected="false">Ventas</button>
							<button class="business-summary-tab" type="button" data-business-summary-tab="profit" aria-selected="false">Ganancia estimada</button>
							<button class="business-summary-tab" type="button" data-business-summary-tab="orders" aria-selected="false">Pedidos</button>
						</div>

						<div class="business-summary-panel is-active" data-business-summary-panel="products">
							<h3 class="business-summary-panel-title">Productos</h3>
							<strong id="business-products-total" class="business-summary-big-number">0</strong>
							<p class="business-summary-panel-help">Productos registrados en la tienda.</p>
							<div id="business-products-details" class="business-detail-list">
								<div class="business-empty-state">Cargando productos...</div>
							</div>
						</div>

						<div class="business-summary-panel" data-business-summary-panel="sales">
							<h3 class="business-summary-panel-title">Ventas</h3>
							<strong id="business-sales-total" class="business-summary-big-number">0.00 USD</strong>
							<p class="business-summary-panel-help">Total vendido durante el periodo seleccionado.</p>
							<div id="business-sales-chart" class="business-line-chart"></div>
						</div>

						<div class="business-summary-panel" data-business-summary-panel="profit">
							<h3 class="business-summary-panel-title">Ganancia estimada</h3>
							<strong id="business-profit-total" class="business-summary-big-number">0.00 USD</strong>
							<p class="business-summary-panel-help">Ganancia calculada según costos y ventas del periodo.</p>
							<div id="business-profit-chart" class="business-line-chart"></div>
						</div>

						<div class="business-summary-panel" data-business-summary-panel="orders">
							<h3 class="business-summary-panel-title">Pedidos</h3>
							<strong id="business-orders-total" class="business-summary-big-number">0</strong>
							<p class="business-summary-panel-help">Cantidad de pedidos recibidos durante el periodo.</p>
							<div id="business-orders-chart" class="business-line-chart"></div>
							<div id="business-orders-details" class="business-detail-list"></div>
						</div>
					</section>

					<section class="dashboard-block dashboard-profit-control-block" aria-labelledby="dashboard-profit-title"><div class="dashboard-block-head"><div><h2 id="dashboard-profit-title" class="dashboard-block-title">Ganancia y control</h2><p class="dashboard-block-subtitle">Controla rentabilidad, envíos, vencimientos y stock.</p></div><a class="pz-admin-btn pz-admin-btn--secondary pz-admin-btn--compact" href={adminProfitsPath}><span class="pz-admin-btn__label">Ver detalle de ganancias</span></a></div><div class="analytics-card-grid analytics-card-grid-secondary" id="profit-kpi-grid"></div></section>

					<section class="dashboard-block dashboard-activity-block admin-recent-activity-card" aria-labelledby="dashboard-activity-title">
						<div class="recent-activity-head">
							<div>
								<h2 id="dashboard-activity-title">Actividad reciente</h2>
								<p>Últimos movimientos del período seleccionado.</p>
							</div>
						</div>

						<div class="recent-activity-tabs" role="tablist" aria-label="Actividad reciente" data-pz-scroll-hint>
							<button class="recent-activity-tab is-active" type="button" role="tab" data-recent-tab="orders" aria-selected="true">Pedidos recientes</button>
							<button class="recent-activity-tab" type="button" role="tab" data-recent-tab="products" aria-selected="false">Productos más vendidos</button>
						</div>

						<div class="recent-activity-panel is-active" role="tabpanel" data-recent-panel="orders">
							<div class="recent-panel-head">
								<div>
									<strong>Pedidos recientes</strong>
									<span>Últimos pedidos recibidos.</span>
								</div>
								<a class="recent-panel-link" href={adminOrdersPath}>Ver todos</a>
							</div>
							<div id="recent-orders" class="activity-text-list recent-list recent-orders-list is-empty"></div>
						</div>

						<div class="recent-activity-panel" role="tabpanel" data-recent-panel="products" hidden>
							<div class="recent-panel-head">
								<div>
									<strong>Productos más vendidos</strong>
									<span id="top-products-meta">Ranking del período seleccionado.</span>
								</div>
							</div>
							<div id="top-products-list" class="activity-text-list recent-list top-products-list is-empty"></div>
						</div>
					</section>

					<section class="dashboard-block order-status-summary-card" aria-labelledby="dashboard-order-status-title">
						<div class="order-status-summary-head">
							<div>
								<h2 id="dashboard-order-status-title">Estado de pedidos</h2>
								<p>Distribución del período seleccionado.</p>
							</div>
						</div>
						<div id="status-grid" class="order-status-list"></div>
					</section>

					<section class="dashboard-block" aria-labelledby="dashboard-reviews-title"><div class="dashboard-block-head"><div><h2 id="dashboard-reviews-title" class="dashboard-block-title">Rating y reseñas</h2><p class="dashboard-block-subtitle">Resumen rápido de reputación, moderación y pedidos listos para solicitar opinión.</p></div><a class="pz-admin-btn pz-admin-btn--secondary pz-admin-btn--compact" href={`${adminStoreSettingsPath}#rating`}><span class="pz-admin-btn__label">Gestionar rating y reseñas</span></a></div><div id="rating-summary-grid" class="status-grid"><div class="empty-state">Cargando rating y reseñas...</div></div><p id="rating-summary-note" class="page-subtitle hidden" style="margin-top: 10px;"></p></section>

					<section id="productos-proximos-vencer" class="dashboard-block" aria-labelledby="expiration-title"><div class="dashboard-block-head"><div><h2 id="expiration-title" class="dashboard-block-title">Productos próximos a vencer</h2><p id="expiration-products-meta" class="dashboard-block-subtitle">Cargando productos...</p></div><div class="expiration-tabs" data-pz-scroll-hint><button class="expiration-btn active" type="button" data-expiration-range="30">1 mes</button><button class="expiration-btn" type="button" data-expiration-range="60">2 meses</button><button class="expiration-btn" type="button" data-expiration-range="90">3 meses</button></div></div><div id="expiration-products-list" class="expiration-products-list"></div></section>
				</div>
			</section>
		</main>

		<script define:vars={{ pocketbaseUrl, adminAuthToken, currentStoreFilter, currentStoreId, adminProductsPath, adminOrdersPath }}>
			const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
			const SESSION_TOKEN = String(adminAuthToken || '');
			const STORE_FILTER = String(currentStoreFilter || '');
			const CURRENT_STORE_ID = String(currentStoreId || '');
			const ORDER_ITEMS_STORE_FILTER = CURRENT_STORE_ID ? `filter=order.store%3D%22${encodeURIComponent(CURRENT_STORE_ID)}%22` : '';
			const ADMIN_PRODUCTS_PATH = String(adminProductsPath || '/admin/products');
			const ADMIN_ORDERS_PATH = String(adminOrdersPath || '/admin/orders');
			const ANALYTICS_MAX_RETENTION_DAYS = 30;
			const ANALYTICS_CLEANUP_INTERVAL_MS = 23 * 60 * 60 * 1000;
			const SUMMARY_RANGE_STORAGE_KEY = 'pz_admin_summary_range';
			const adminView = document.getElementById('admin-view');
			const dashboardSubtitle = document.getElementById('dashboard-subtitle');
			const rangeLabel = document.getElementById('range-label');
			const adminBellBtn = document.getElementById('admin-bell-btn');
			const adminBellDropdown = document.getElementById('admin-bell-dropdown');
			const kpiGrid = document.getElementById('kpi-grid');
			const profitKpiGrid = document.getElementById('profit-kpi-grid');
			const recentOrders = document.getElementById('recent-orders');
			const topProductsList = document.getElementById('top-products-list');
			const topProductsMeta = document.getElementById('top-products-meta');
			const mostViewedProductsList = document.getElementById('most-viewed-products-list');
			const mostViewedProductsMeta = document.getElementById('most-viewed-products-meta');
			const statusGrid = document.getElementById('status-grid');
			const expirationProductsList = document.getElementById('expiration-products-list');
			const expirationProductsMeta = document.getElementById('expiration-products-meta');
			const ratingSummaryGrid = document.getElementById('rating-summary-grid');
			const ratingSummaryNote = document.getElementById('rating-summary-note');
			const salesChart = document.getElementById('sales-chart');
			const ordersChart = document.getElementById('orders-chart');
			const profitChart = document.getElementById('profit-chart');
			const salesChartMeta = document.getElementById('sales-chart-meta');
			const ordersChartMeta = document.getElementById('orders-chart-meta');
			const profitChartMeta = document.getElementById('profit-chart-meta');
			const businessProductsTotal = document.getElementById('business-products-total');
			const businessProductsDetails = document.getElementById('business-products-details');
			const businessSalesTotal = document.getElementById('business-sales-total');
			const businessProfitTotal = document.getElementById('business-profit-total');
			const businessOrdersTotal = document.getElementById('business-orders-total');
			const businessSalesChart = document.getElementById('business-sales-chart');
			const businessProfitChart = document.getElementById('business-profit-chart');
			const businessOrdersChart = document.getElementById('business-orders-chart');
			const businessOrdersDetails = document.getElementById('business-orders-details');
			const trafficVisitsTotal = document.getElementById('traffic-visits-total');
			const trafficVisitorsTotal = document.getElementById('traffic-visitors-total');
			const trafficPageviewsTotal = document.getElementById('traffic-pageviews-total');
			const trafficVisitsAverage = document.getElementById('traffic-visits-average');
			const trafficVisitorsAverage = document.getElementById('traffic-visitors-average');
			const trafficPageviewsAverage = document.getElementById('traffic-pageviews-average');
			const trafficVisitsChart = document.getElementById('traffic-visits-chart');
			const trafficVisitorsChart = document.getElementById('traffic-visitors-chart');
			const trafficPageviewsChart = document.getElementById('traffic-pageviews-chart');
			const trafficLandingViewsTotal = document.getElementById('traffic-landing-views-total');
			const trafficLandingClicksTotal = document.getElementById('traffic-landing-clicks-total');
			const trafficLandingRateTotal = document.getElementById('traffic-landing-rate-total');
			const trafficLandingTopButton = document.getElementById('traffic-landing-top-button');
			const trafficLandingChart = document.getElementById('traffic-landing-chart');
			const trafficLandingClicksList = document.getElementById('traffic-landing-clicks-list');
			const trafficLandingClicksMeta = document.getElementById('traffic-landing-clicks-meta');
			const sidebar = document.querySelector('[data-admin-sidebar-root]');
			const sidebarOverlay = document.getElementById('sidebar-overlay');
			const sidebarLogoutBtn = document.getElementById('sidebar-logout-btn');
			const periodButtons = Array.from(document.querySelectorAll('.period-btn'));
			const expirationButtons = Array.from(document.querySelectorAll('.expiration-btn'));
			const visitAnalyticsTabs = Array.from(document.querySelectorAll('.visit-analytics-tab'));
			const visitAnalyticsPanels = Array.from(document.querySelectorAll('.visit-analytics-panel'));
			const businessSummaryTabs = Array.from(document.querySelectorAll('[data-business-summary-tab]'));
			const businessSummaryPanels = Array.from(document.querySelectorAll('[data-business-summary-panel]'));

			let orders = [];
			let orderItems = [];
			let products = [];
			let analyticsEvents = [];
			let reviews = [];
			let settingsRecord = null;
			let reviewsCollectionAvailable = true;
			let selectedRange = normalizeSummaryRange(readInitialSummaryRange());
			let selectedExpirationRange = 30;

			const statusLabels = {
				pending: 'Pendiente',
				confirmed: 'Confirmado',
				preparing: 'Preparando',
				delivered: 'Entregado',
