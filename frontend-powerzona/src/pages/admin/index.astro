			.expiration-stock {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 30px;
				padding: 0 10px;
				border-radius: 999px;
				background: #f8fafc;
				border: 1px solid rgba(226, 232, 240, 0.98);
				color: #334155;
				font-size: 12px;
				font-weight: 900;
				white-space: nowrap;
			}

			.expiration-pill {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 30px;
				border-radius: 999px;
				padding: 0 11px;
				font-size: 11px;
				font-weight: 950;
				white-space: nowrap;
				background: var(--expiration-soft, #dbeafe);
				color: var(--expiration-text, #1d4ed8);
				box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--expiration-alert, #2563eb) 14%, transparent);
			}

			.expiration-date-chip {
				display: inline-flex;
				align-items: center;
				gap: 6px;
