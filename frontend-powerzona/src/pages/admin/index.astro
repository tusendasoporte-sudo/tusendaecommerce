			.expiration-main {
				min-width: 0;
				display: grid;
				grid-template-columns: minmax(180px, 1fr) auto auto auto;
				align-items: center;
				gap: 10px;
			}

			.expiration-name {
				margin: 0;
				font-size: 15px;
				font-weight: 950;
				letter-spacing: -0.02em;
				color: #0f172a;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.expiration-meta {
				margin: 0;
				font-size: 12px;
				font-weight: 850;
				color: #64748b;
				white-space: nowrap;
