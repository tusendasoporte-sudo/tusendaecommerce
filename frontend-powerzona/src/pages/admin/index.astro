				delivered: 'status-delivered',
				cancelled: 'status-cancelled',
			};

			function getRecentStatusStyle(status) {
				const normalizedStatus = String(status || 'pending').toLowerCase();
				const base = 'display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:950;line-height:1;white-space:nowrap;box-shadow:inset 0 1px 0 rgba(255,255,255,0.75);';

				if (normalizedStatus === 'confirmed') return base + 'background:#dcfce7;color:#166534;border:1px solid #bbf7d0;';
				if (normalizedStatus === 'delivered') return base + 'background:#dcfce7;color:#166534;border:1px solid #bbf7d0;';
				if (normalizedStatus === 'cancelled' || normalizedStatus === 'canceled') return base + 'background:#fee2e2;color:#991b1b;border:1px solid #fecaca;';
				if (normalizedStatus === 'preparing') return base + 'background:#ede9fe;color:#5b21b6;border:1px solid #ddd6fe;';
				return base + 'background:#fef3c7;color:#92400e;border:1px solid #fde68a;';
			}

			const icons = {
				money: '<svg width="26" height="26" viewBox="0 0 28 28" fill="none"><rect x="3" y="6" width="22" height="16" rx="4" fill="#DCFCE7"/><rect x="3" y="6" width="22" height="16" rx="4" stroke="#16A34A" stroke-width="1.8"/><circle cx="14" cy="14" r="4.2" fill="#22C55E"/><path d="M14 11.3v5.4M11.7 14h4.6" stroke="#FFFFFF" stroke-width="1.8" stroke-linecap="round"/></svg>',
