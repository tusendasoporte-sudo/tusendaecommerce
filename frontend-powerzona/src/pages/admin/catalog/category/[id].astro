        font-weight: 1000;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .category-subcategory-card-meta,
      .category-product-card-stock,
      .category-subcategory-group-count {
        margin: 5px 0 10px;
        color: #64748b;
        font-size: 12px;
        line-height: 1.35;
        font-weight: 850;
      }
      .category-subcategory-actions,
      .category-subcategory-group-actions,
      .category-products-tools {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .category-products-tools { justify-content: flex-end; }
      .category-search {
        min-width: 260px;
        min-height: 40px;
        padding: 0 12px;
        display: inline-flex;
