          min-height: auto;
          padding: 0 10px;
          border: 0;
          border-radius: 0;
          box-shadow: none;
        }
        .category-overview-stat-icon { display: none; }
        .category-overview-actions,
        .category-products-tools,
        .category-edit-actions {
          display: grid;
          grid-template-columns: 1fr;
          width: 100%;
        }
