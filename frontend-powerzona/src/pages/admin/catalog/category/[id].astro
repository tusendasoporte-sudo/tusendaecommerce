        margin: 0 0 14px !important;
      }
      .nav-list { display: grid !important; gap: 6px !important; }
      @media (min-width: 1024px) {
        .app-shell { width: auto !important; max-width: none !important; }}
      @media (max-width: 620px) {}</style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
          <AdminSidebar
            storeSlug={currentStoreSlug}
            storeName={currentStoreName}
            activeSection="catalog"
            mobileTitle="Categoría"
            mobileBackHref={adminCatalogPath}
            mobileBackLabel="Volver a Categorías"
          />
    <div class="app-shell pz-admin-content">
      <header class="topbar editor-topbar">
        <div class="topbar-left editor-heading">
          <a class="square-back" href={adminCatalogPath} aria-label="Volver a categorías">←</a>
          <div>
            <h1 class="page-title">Editar categoría</h1>
            <p class="breadcrumb">Categorías &gt; Editar categoría &gt; <span id="breadcrumb-category-name">Cargando...</span></p>
          </div>
        </div>
        <div class="topbar-actions">
          <button id="admin-notifications-btn" class="notifications-btn" type="button" aria-label="Notificaciones del admin">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 9a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Z"></path><path d="M10 21a2 2 0 0 0 4 0"></path></svg>
            <span class="notifications-dot" aria-hidden="true"></span>
          </button>
          <button class="primary-blue-btn" type="submit" form="category-form">Guardar cambios</button>
        </div>
      </header>
      <section id="admin-view">
        <main class="category-premium-main pz-admin-content-inner">
          <div class="hidden" aria-hidden="true">
            <div id="category-hero-thumb"></div>
            <h1 id="category-title">Cargando categoria...</h1>
            <p id="category-subtitle"></p>
            <span id="category-status"></span>
            <div id="rail-category-thumb"></div>
            <h2 id="rail-category-title"></h2>
            <p id="rail-category-slug"></p>
            <span id="rail-category-status"></span>
            <div id="rail-summary-list"></div>
          </div>

          <section class="category-overview-card">
            <div id="category-overview-image" class="category-overview-image">+</div>

            <div class="category-overview-copy">
              <div class="category-overview-title-row">
                <h2 id="category-overview-title">Cargando categoria...</h2>
                <span id="category-overview-status" class="category-status-pill is-visible">Visible en tienda</span>
              </div>

              <p id="category-overview-description" class="category-overview-description">
                Administra la informacion, subcategorias y productos de esta categoria.
              </p>

              <div class="category-overview-meta">
                <span>Catalogo</span>
                <span>Categorias</span>
                <span id="category-overview-id">ID de categoria</span>
              </div>
            </div>

            <div class="category-overview-stats">
              <article>
                <span class="category-overview-stat-icon blue" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M21 7.5 12 3 3 7.5l9 4.5 9-4.5ZM5 10.7V17l6 3v-6.3l-6-3Zm8 9.3 6-3v-6.3l-6 3V20Z"/></svg>
                </span>
                <strong id="overview-direct-count">0</strong>
                <small>Productos directos</small>
              </article>

              <article>
                <span class="category-overview-stat-icon green" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3V6Zm0 5h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7Z"/></svg>
                </span>
                <strong id="overview-subcategories-count">0</strong>
                <small>Subcategorias</small>
              </article>

              <article>
                <span class="category-overview-stat-icon purple" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M7 4h4v4H7V4Zm6 0h4v4h-4V4ZM7 10h4v4H7v-4Zm6 0h4v4h-4v-4ZM7 16h4v4H7v-4Zm6 0h4v4h-4v-4Z"/></svg>
                </span>
                <strong id="overview-nested-count">0</strong>
                <small>Productos en subcategorias</small>
              </article>
            </div>

            <div class="category-overview-actions">
              <button id="category-edit-toggle-btn" class="pz-admin-btn pz-admin-btn--secondary" type="button">
                <span class="pz-admin-btn__icon" aria-hidden="true">✎</span>
                <span class="pz-admin-btn__label">Editar categoria</span>
              </button>

              <button id="quick-new-subcategory-btn" class="pz-admin-btn pz-admin-btn--primary" type="button">
                <span class="pz-admin-btn__icon" aria-hidden="true">+</span>
                <span class="pz-admin-btn__label">Nueva subcategoria</span>
              </button>
            </div>
          </section>

          <section id="category-edit-panel" class="category-edit-panel hidden">
            <div class="category-panel-head">
              <div>
                <h2>Editar categoria</h2>
                <p>Actualiza el nombre, descripcion, imagen y visibilidad de esta categoria.</p>
              </div>
