        .app-shell { padding: 14px; }
        .item-row { grid-template-columns: 1fr; }
        .row-actions, .delete-confirm-actions { justify-content: flex-start; }
        .delete-confirm-actions .mini-btn { width: 100%; }
        .hero-thumb { width: 68px; height: 68px; }
      }
