      .checkline { padding: 12px 14px; border-radius: 16px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .submit-btn { background: #2563eb; box-shadow: 0 14px 28px rgba(37,99,235,.22); }
      .summary-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
      .summary-tile { padding: 14px; border-radius: 18px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .summary-tile strong { display: block; font-size: 22px; color: #0f172a; line-height: 1; }
      .summary-tile span { display: block; margin-top: 7px; color: #64748b; font-size: 11px; font-weight: 950; text-transform: uppercase; letter-spacing: .05em; }
      .summary-panel { order: -1; }
      .list-head { background: #fff; padding: 18px 20px; }
      .item-row { border-bottom-color: #eef2f7; }
      .product-list-body .item-row, .subcategory-list-body .item-row { align-items: start; }
      .subcategory-products-list { display: grid; gap: 14px; padding: 18px; }
      .subcategory-group { border: 1px solid #e2e8f0; border-radius: 20px; overflow: hidden; background: #fff; }
      .subcategory-group-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 16px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
      .subcategory-group-title { margin: 0; font-size: 15px; font-weight: 1000; color: #0f172a; }
      .subcategory-group-count { margin: 4px 0 0; color: #64748b; font-size: 12px; font-weight: 850; }
      .quick-actions-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
      .quick-actions-grid .mini-btn { width: 100%; text-align: center; }
      .mobile-bottom-bar { display: none; }
      @media (min-width: 1180px) {
        .app-shell { padding-right: 36px; }
      }
      @media (max-width: 980px) {
        .app-shell { padding: 82px 16px 94px; }
        .sidebar { transform: translateX(-112%); top: 12px; left: 12px; bottom: 12px; width: min(320px, calc(100vw - 24px)); transition: transform .22s ease; }
        body.sidebar-open .sidebar { transform: translateX(0); }
        .sidebar-close { display: inline-flex; align-items: center; justify-content: center; }
        .mobile-topbar {
          position: fixed; top: 10px; left: 10px; right: 10px; z-index: 60; display: flex; align-items: center; justify-content: space-between;
          padding: 10px 12px; border-radius: 20px; background: rgba(255,255,255,.96); border: 1px solid #e2e8f0; box-shadow: 0 14px 34px rgba(15,23,42,.10);
        }
        .menu-btn { width: 42px; height: 42px; border: 0; border-radius: 14px; background: #eff6ff; color: #1d4ed8; font-size: 19px; font-weight: 1000; }
        .topbar { margin-top: 0; }
        .topbar-left { width: 100%; }
        .topbar-actions { width: 100%; justify-content: flex-start; }
        .grid, .form-row { grid-template-columns: 1fr; }
        .grid > .stack:first-child { position: static; }
        .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .hero-card::after { display: none; }
        .mobile-bottom-bar {
          position: fixed; left: 10px; right: 10px; bottom: 10px; z-index: 55; display: grid; grid-template-columns: 1fr 1.3fr; gap: 10px;
          padding: 10px; border-radius: 20px; background: rgba(255,255,255,.96); border: 1px solid #e2e8f0; box-shadow: 0 18px 40px rgba(15,23,42,.14);
        }
        .bottom-action { border: 0; border-radius: 15px; background: #f1f5f9; color: #0f172a; font-weight: 1000; padding: 13px; text-align: center; }
        .bottom-action.primary { background: #2563eb; color: #fff; }
      }
      @media (max-width: 620px) {
        .topbar { display: grid; }
        .topbar-actions .action-btn { display: none; }
        .topbar-actions .primary-blue-btn { display: none; }
        .hero-card { padding: 18px; }
        .page-title { font-size: 28px; }
        .panel-card { padding: 18px; }
        .item-main { align-items: flex-start; }
        .row-actions .mini-btn { flex: 1 1 auto; }
        .summary-grid { grid-template-columns: 1fr 1fr; }
        .quick-actions-grid { grid-template-columns: 1fr; }
      }
      /* PZ-EDIT-CATEGORY-VISUAL-FINAL-213020A */
      .legacy-hero { display: none; }
      .app-shell { padding-left: 300px; }
      .nav-item.active { background: #0f172a; color: #fff; box-shadow: 0 14px 28px rgba(15,23,42,.18); }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.16); color: #fff; }
      .brand-logo { background: #0f172a; box-shadow: 0 12px 24px rgba(15,23,42,.18); }
      .editor-topbar {
        display: flex; align-items: center; justify-content: space-between; gap: 16px;
        padding: 16px 18px; margin-bottom: 18px; border-radius: 24px;
      }
