      .rail-summary-list span { color: #64748b; font-size: 12px; font-weight: 850; }
      .rail-summary-list strong { color: #0f172a; font-size: 12px; font-weight: 1000; text-align: right; }
      .quick-actions-panel .quick-actions-grid { grid-template-columns: 1fr; margin-top: 12px; }
      .quick-actions-panel .mini-btn { white-space: normal; }
      .subcategory-group { border-radius: 16px; }
      .subcategory-group-head { display: grid; gap: 10px; padding: 12px; }
      @media (max-width: 1180px) {
        .editor-layout { grid-template-columns: minmax(0, 1fr) 240px; }
        .content-columns { grid-template-columns: 1fr; }
      }
      @media (max-width: 980px) {
        .app-shell { padding: 82px 14px 94px; }
        .editor-topbar { margin-top: 0; }
        .editor-layout { grid-template-columns: 1fr; }
        .editor-rail { position: static; order: 2; }
        .editor-main { order: 1; }
        .info-panel { order: 1; }
        .content-panel { order: 4; }
        .category-form-grid { grid-template-columns: 1fr; }
        .category-submit-inline { display: inline-flex; }
        .content-columns { grid-template-columns: 1fr; }
      }
      @media (max-width: 620px) {
        .editor-topbar { display: none; }
        .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .summary-tile { padding: 12px; }
        .summary-tile strong { font-size: 20px; }
        .panel-card { border-radius: 20px; }
        .content-panel { padding: 14px; }
      }
      .list-card,
      .content-column,
      .content-panel { overflow: visible; }
      .subcategory-row { grid-template-columns: minmax(0, 1fr) auto; position: relative; }
      .subcategory-row-actions {
        display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap;
      }
      .subcategory-menu-button {
        width: 36px; height: 36px; border-radius: 999px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a;
        display: inline-flex; align-items: center; justify-content: center; font-size: 20px; line-height: 1; font-weight: 1000;
        box-shadow: 0 8px 18px rgba(15,23,42,.06);
      }
      .subcategory-actions-menu {
        position: fixed; z-index: 140; width: 190px; padding: 8px; border-radius: 16px; background: #fff;
        border: 1px solid #e2e8f0; box-shadow: 0 22px 55px rgba(15,23,42,.18);
      }
      .subcategory-actions-menu button {
        width: 100%; border: 0; border-radius: 12px; background: transparent; color: #0f172a; padding: 10px 11px;
        text-align: left; font-size: 13px; font-weight: 900;
      }
      .subcategory-actions-menu button:hover { background: #f8fafc; }
      .subcategory-actions-menu button.danger { color: #991b1b; }
      .subcategory-modal-overlay {
        position: fixed; inset: 0; z-index: 130; display: flex; align-items: center; justify-content: center;
        padding: 18px; background: rgba(15,23,42,.45); backdrop-filter: blur(6px);
      }
      .subcategory-modal-overlay.hidden,
      .subcategory-actions-menu.hidden { display: none; }
      .subcategory-modal { width: min(520px, 100%); max-height: min(760px, calc(100vh - 36px)); overflow: auto; }
      .subcategory-modal-card {
        border-radius: 26px; background: #fff; border: 1px solid rgba(226,232,240,.96);
        box-shadow: 0 30px 90px rgba(15,23,42,.24); padding: 20px;
      }
      .subcategory-modal-head {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 16px;
      }
      .subcategory-modal-head h2 { margin: 0; color: #0f172a; font-size: 22px; font-weight: 1000; letter-spacing: -.03em; }
      .modal-close-btn {
        width: 38px; height: 38px; border-radius: 14px; border: 1px solid #e2e8f0; background: #f8fafc; color: #0f172a;
        font-size: 20px; font-weight: 1000;
      }
      .subcategory-modal-actions { display: flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
      .subcategory-form-grid.confirming-delete > .field,
      .subcategory-form-grid.confirming-delete > .switch-line,
      .subcategory-form-grid.confirming-delete > .subcategory-modal-actions { display: none; }
      .subcategory-form-grid.confirming-delete .delete-confirm { display: block; }
      @media (max-width: 620px) {
        .subcategory-row { grid-template-columns: 1fr; }
        .subcategory-row-actions { justify-content: flex-start; }
        .subcategory-row-actions .mini-btn { flex: 1 1 auto; }
        .subcategory-modal-overlay { align-items: flex-end; padding: 10px; }
        .subcategory-modal-card { border-radius: 24px; padding: 16px; }
        .subcategory-modal-actions .mini-btn,
        .subcategory-modal-actions .submit-btn { flex: 1 1 100%; }
      }
      .category-premium-main {
        display: grid;
        gap: 18px;
        min-width: 0;
      }
      .category-overview-card,
      .category-edit-panel,
      .category-section-card {
        border: 1px solid rgba(226, 232, 240, .96);
        border-radius: 26px;
        background: rgba(255, 255, 255, .96);
        box-shadow: 0 18px 45px rgba(15, 23, 42, .07);
        backdrop-filter: blur(10px);
      }
      .category-overview-card {
        padding: 18px;
        display: grid;
        grid-template-columns: 150px minmax(0, 1fr) auto auto;
        gap: 18px;
        align-items: center;
      }
      .category-overview-image {
        width: 150px;
        height: 110px;
        border-radius: 20px;
        overflow: hidden;
        display: grid;
        place-items: center;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #94a3b8;
        font-size: 34px;
        font-weight: 1000;
        box-shadow: 0 14px 28px rgba(15, 23, 42, .08);
      }
      .category-overview-image img,
      .category-product-card .row-thumb img,
      .category-subcategory-card .row-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .category-overview-copy { min-width: 0; }
      .category-overview-title-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .category-overview-title-row h2 {
        margin: 0;
        color: #0f172a;
        font-size: 28px;
        line-height: 1.05;
        font-weight: 1000;
        letter-spacing: -.04em;
      }
      .category-status-pill {
        min-height: 30px;
        padding: 6px 11px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border-radius: 999px;
        font-size: 12px;
        line-height: 1;
        font-weight: 1000;
      }
      .category-status-pill::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: currentColor;
      }
      .category-status-pill.is-visible {
        background: #dcfce7;
        color: #16a34a;
        border: 1px solid #bbf7d0;
      }
      .category-status-pill.is-hidden {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
      }
      .category-overview-description {
        margin: 10px 0 0;
        max-width: 540px;
        color: #64748b;
        font-size: 14px;
        line-height: 1.55;
        font-weight: 800;
      }
      .category-overview-meta {
        margin-top: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        color: #64748b;
        font-size: 12px;
        font-weight: 850;
      }
      .category-overview-meta span + span::before {
        content: '•';
        margin-right: 10px;
        color: #cbd5e1;
      }
      .category-overview-stats {
        display: grid;
        grid-template-columns: repeat(3, 116px);
        gap: 10px;
      }
      .category-overview-stats article {
        min-height: 108px;
        padding: 14px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .04);
      }
      .category-overview-stat-icon {
        width: 34px;
        height: 34px;
        margin-bottom: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 13px;
      }
      .category-overview-stat-icon svg,
      .category-section-icon svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
      }
      .category-overview-stat-icon.blue,
      .category-section-icon.blue { background: #dbeafe; color: #2563eb; }
      .category-overview-stat-icon.green,
      .category-section-icon.green { background: #dcfce7; color: #16a34a; }
      .category-overview-stat-icon.purple,
      .category-section-icon.purple { background: #ede9fe; color: #7c3aed; }
      .category-overview-stats strong {
        display: block;
        color: #2563eb;
        font-size: 26px;
        line-height: 1;
        font-weight: 1000;
        letter-spacing: -.04em;
      }
      .category-overview-stats small {
        display: block;
        margin-top: 6px;
        color: #64748b;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 900;
      }
      .category-overview-actions {
        display: grid;
        gap: 10px;
        min-width: 190px;
      }
      .category-edit-panel,
      .category-section-card { padding: 18px; }
      .category-panel-head { margin-bottom: 14px; }
      .category-panel-head h2,
      .category-section-head h2 {
        margin: 0;
        color: #0f172a;
        font-size: 21px;
        line-height: 1.1;
        font-weight: 1000;
        letter-spacing: -.035em;
      }
      .category-panel-head p,
      .category-section-head p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: 13px;
        line-height: 1.45;
        font-weight: 800;
      }
      .category-edit-actions {
        grid-column: 1 / -1;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
      }
      .category-section-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 14px;
      }
      .category-section-title-wrap {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        min-width: 0;
      }
      .category-section-icon {
        width: 42px;
        height: 42px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
      }
      .category-link-btn,
      .category-show-more-btn {
        min-height: 42px;
        padding: 9px 12px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: #2563eb;
        font-size: 13px;
        font-weight: 1000;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
      }
      .category-subcategory-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
      }
      .category-subcategory-card,
      .category-product-card {
        min-width: 0;
        padding: 12px;
        display: grid;
        gap: 12px;
        align-items: center;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .04);
