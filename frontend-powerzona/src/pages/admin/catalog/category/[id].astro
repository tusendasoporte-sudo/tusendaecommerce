      .category-fields { display: grid; gap: 13px; }
      .switch-line {
        display: inline-flex; align-items: center; gap: 10px; width: fit-content; min-height: 42px;
        padding: 8px 12px; border-radius: 999px; background: #f8fafc; border: 1px solid #e2e8f0; color: #334155; font-weight: 950;
      }
      .switch-line input { position: absolute; opacity: 0; pointer-events: none; }
      .switch-ui { width: 42px; height: 24px; border-radius: 999px; background: #cbd5e1; position: relative; transition: background .18s ease; }
      .switch-ui::after { content: ''; position: absolute; width: 18px; height: 18px; border-radius: 999px; background: #fff; top: 3px; left: 3px; box-shadow: 0 3px 8px rgba(15,23,42,.2); transition: transform .18s ease; }
      .switch-line input:checked + .switch-ui { background: #16a34a; }
      .switch-line input:checked + .switch-ui::after { transform: translateX(18px); }
      .image-edit-card { display: grid; gap: 10px; padding: 12px; border-radius: 20px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .form-image-preview, .rail-thumb {
        width: 100%; aspect-ratio: 16 / 9; border-radius: 16px; border: 1px solid #e2e8f0; background: #eef2f7;
        display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 28px; font-weight: 1000; overflow: hidden;
      }
      .form-image-preview img, .rail-thumb img { width: 100%; height: 100%; object-fit: cover; }
      .image-picker-btn {
        display: inline-flex; justify-content: center; align-items: center; border-radius: 14px; padding: 11px 13px;
        background: #fff; border: 1px solid #e2e8f0; color: #0f172a; font-weight: 1000; cursor: pointer;
      }
      .sr-only-file { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
      .category-submit-inline { display: none; }
      .category-form-grid #category-alert { grid-column: 1 / -1; }
      .content-panel { padding: 20px; }
      .content-panel-head { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; }
      .content-columns { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 16px; }
      .content-column {
        min-width: 0; border: 1px solid #e2e8f0; border-radius: 20px; background: #fff; overflow: hidden;
        display: flex; flex-direction: column;
      }
      .column-head { display: grid; gap: 10px; padding: 14px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
      .column-head h3 { margin: 0; font-size: 15px; font-weight: 1000; color: #0f172a; }
      .column-head p { margin: 4px 0 0; color: #64748b; font-size: 12px; font-weight: 800; line-height: 1.35; }
      .compact-list .item-row, .compact-groups .item-row { grid-template-columns: 1fr; gap: 10px; padding: 12px; }
      .compact-list .row-actions, .compact-groups .row-actions { justify-content: flex-start; }
      .compact-list .row-thumb, .compact-groups .row-thumb { width: 42px; height: 42px; min-width: 42px; border-radius: 13px; }
      .subcategory-form-grid { display: grid; gap: 10px; }
      .danger-link { color: #991b1b !important; background: #fff !important; border-color: #fecaca !important; box-shadow: none !important; }
      .rail-card { padding: 16px; }
      .rail-kicker { margin: 0 0 10px; color: #64748b; font-size: 11px; font-weight: 1000; letter-spacing: .08em; text-transform: uppercase; }
      .rail-card h2, .rail-title { margin: 10px 0 0; color: #0f172a; font-size: 16px; font-weight: 1000; letter-spacing: -.02em; }
      .rail-card #rail-category-slug { margin: 4px 0 10px; color: #64748b; font-size: 12px; font-weight: 850; }
      .rail-note { margin: 12px 0 0; color: #64748b; font-size: 12px; line-height: 1.45; font-weight: 800; }
      .rail-summary-list { display: grid; gap: 8px; margin-top: 12px; }
      .rail-summary-list div { display: flex; justify-content: space-between; gap: 10px; padding: 9px 0; border-bottom: 1px solid #eef2f7; }
      .rail-summary-list span { color: #64748b; font-size: 12px; font-weight: 850; }
      .rail-summary-list strong { color: #0f172a; font-size: 12px; font-weight: 1000; text-align: right; }
      .quick-actions-panel .quick-actions-grid { grid-template-columns: 1fr; margin-top: 12px; }
