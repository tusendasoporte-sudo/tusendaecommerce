        display: grid;
        grid-template-columns: minmax(0, 1fr) auto 20px;
        gap: 12px;
        align-items: center;
        padding: 14px 16px;
        background: #f8fafc;
      }
      .category-subcategory-group-toggle {
        min-height: 38px;
        padding: 8px 12px;
