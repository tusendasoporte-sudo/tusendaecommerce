    <script define:vars={{ pocketbaseUrl, categoryId, currentStoreId, adminProductsPath, adminAuthToken }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CATEGORY_ID = String(categoryId || '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_PRODUCTS_PATH = String(adminProductsPath || '/admin/products');
      const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      const adminView = document.getElementById('admin-view');
      const logoutBtn = document.getElementById('logout-btn');

      const categoryHeroThumb = document.getElementById('category-hero-thumb');
      const categoryTitle = document.getElementById('category-title');
      const categorySubtitle = document.getElementById('category-subtitle');
      const categoryStatus = document.getElementById('category-status');
      const categoryForm = document.getElementById('category-form');
      const categoryName = document.getElementById('category-name');
      const categoryDescription = document.getElementById('category-description');
      const categoryImage = document.getElementById('category-image');
      const categoryFormThumb = document.getElementById('category-form-thumb');
      const categoryActive = document.getElementById('category-active');
      const categoryAlert = document.getElementById('category-alert');

      const subcategoryForm = document.getElementById('subcategory-form');
      const subcategoryName = document.getElementById('subcategory-name');
      const subcategoryImage = document.getElementById('subcategory-image');
      const subcategoryActive = document.getElementById('subcategory-active');
      const subcategoryAlert = document.getElementById('subcategory-alert');
      const subcategorySubmit = document.getElementById('subcategory-submit');
      const subcategoriesList = document.getElementById('subcategories-list');
      const subcategoriesCount = document.getElementById('subcategories-count');
      const productsList = document.getElementById('products-list');
      const productsCount = document.getElementById('products-count');
      const newProductBtn = document.getElementById('new-product-btn');
      const contentSummaryGrid = document.getElementById('content-summary-grid');
      const subcategoryProductsList = document.getElementById('subcategory-products-list');
      const sidebar = document.getElementById('admin-sidebar');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarCloseBtn = document.getElementById('sidebar-close');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const breadcrumbCategoryName = document.getElementById('breadcrumb-category-name');
      const subcategoryModalOverlay = document.getElementById('subcategory-modal-overlay');
      const subcategoryModalTitle = document.getElementById('subcategory-modal-title');
      const subcategoryCreateClose = document.getElementById('subcategory-create-close');
      const subcategoryModalCancel = document.getElementById('subcategory-modal-cancel');
      const subcategoryDeleteConfirm = document.getElementById('subcategory-delete-confirm');
      const subcategoryActionsMenu = document.getElementById('subcategory-actions-menu');
      const railCategoryThumb = document.getElementById('rail-category-thumb');
      const railCategoryTitle = document.getElementById('rail-category-title');
      const railCategorySlug = document.getElementById('rail-category-slug');
      const railCategoryStatus = document.getElementById('rail-category-status');
      const railSummaryList = document.getElementById('rail-summary-list');

      let category = null;
      let categories = [];
      let subcategories = [];
      let products = [];
      let pendingDeleteSubcategoryId = '';
      let currentEditingSubcategoryId = '';
      let activeSubcategoryMenuId = '';

      function escapeHtml(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function slugify(value) {
        return String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      function normalizeName(value) {
        return String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim()
          .replace(/\s+/g, ' ');
      }


      // PZ-CATALOG-IMAGE-OPTIMIZER-V28-20260605
      // Optimiza fotos de categorías/subcategorías antes de enviarlas a la plataforma.
      async function optimizeCatalogImageFile(file) {
        if (!file || !file.type?.startsWith('image/')) return file;
        let objectUrl = '';
        try {
          const image = await new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve(img);
            img.onerror = reject;
            objectUrl = URL.createObjectURL(file);
            img.src = objectUrl;
          });

          const targetWidth = 1200;
          const targetHeight = 675;
          const targetRatio = targetWidth / targetHeight;
          const sourceWidth = image.naturalWidth || image.width;
          const sourceHeight = image.naturalHeight || image.height;
          const sourceRatio = sourceWidth / sourceHeight;

          let sx = 0;
          let sy = 0;
          let sw = sourceWidth;
          let sh = sourceHeight;

          if (sourceRatio > targetRatio) {
            sw = sourceHeight * targetRatio;
            sx = (sourceWidth - sw) / 2;
          } else if (sourceRatio < targetRatio) {
            sh = sourceWidth / targetRatio;
            sy = (sourceHeight - sh) / 2;
          }

          const canvas = document.createElement('canvas');
          canvas.width = targetWidth;
          canvas.height = targetHeight;
          const ctx = canvas.getContext('2d');
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          ctx.drawImage(image, sx, sy, sw, sh, 0, 0, targetWidth, targetHeight);

          const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/webp', 0.82));
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          if (!blob) return file;
          const safeName = String(file.name || 'categoria')
            .replace(/\.[^.]+$/, '')
            .replace(/[^a-z0-9_-]+/gi, '_')
            .toLowerCase();
          return new File([blob], `${safeName}_categoria_1200x675.webp`, { type: 'image/webp', lastModified: Date.now() });
        } catch (error) {
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          console.warn('No se pudo optimizar la imagen de categoría. Se usará la original.', error);
          return file;
        }
      }
      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function showAdmin() { adminView?.classList.remove('hidden'); logoutBtn?.classList.remove('hidden'); }

      function setAlert(element, message, type = 'info') {
        if (!element) return;
        element.textContent = message;
        element.className = `alert alert-${type}`;
        element.classList.toggle('hidden', !message);
      }

      function openSidebar() {
        document.body.classList.add('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'false');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'true');
        if (sidebarOverlay) sidebarOverlay.hidden = false;
      }

      function closeSidebar() {
        document.body.classList.remove('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'true');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'false');
        setTimeout(() => {
          if (!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true;
        }, 220);
      }

      function closeSubcategoryMenu() {
        activeSubcategoryMenuId = '';
        subcategoryActionsMenu?.classList.add('hidden');
        subcategoryActionsMenu?.setAttribute('aria-hidden', 'true');
        if (subcategoryActionsMenu) subcategoryActionsMenu.innerHTML = '';
      }

      function resetSubcategoryModal() {
        subcategoryForm?.reset();
        if (subcategoryActive) subcategoryActive.checked = true;
        if (subcategoryImage) subcategoryImage.value = '';
        currentEditingSubcategoryId = '';
        pendingDeleteSubcategoryId = '';
        if (subcategorySubmit) {
          subcategorySubmit.textContent = 'Crear subcategoría';
          subcategorySubmit.classList.remove('hidden');
        }
        if (subcategoryModalTitle) subcategoryModalTitle.textContent = 'Nueva subcategoría';
        subcategoryDeleteConfirm?.classList.add('hidden');
        subcategoryForm?.classList.remove('confirming-delete');
        if (subcategoryDeleteConfirm) subcategoryDeleteConfirm.innerHTML = '';
        setAlert(subcategoryAlert, '', 'info');
      }

      function openSubcategoryModal(mode = 'create', subcategoryId = '') {
        closeSubcategoryMenu();
        resetSubcategoryModal();
        if (mode === 'edit') {
          const subcategory = subcategories.find((item) => String(item.id) === String(subcategoryId));
          if (!subcategory) {
            setAlert(subcategoryAlert, 'No se encontró la subcategoría seleccionada.', 'error');
            return;
          }
          currentEditingSubcategoryId = subcategory.id;
          if (subcategoryModalTitle) subcategoryModalTitle.textContent = 'Editar subcategoría';
          if (subcategorySubmit) subcategorySubmit.textContent = 'Guardar subcategoría';
          subcategoryName.value = subcategory.name || '';
          subcategoryActive.checked = subcategory.active === true;
          if (subcategoryImage) subcategoryImage.value = '';
        } else {
          currentEditingSubcategoryId = '';
          if (subcategoryModalTitle) subcategoryModalTitle.textContent = 'Nueva subcategoría';
          if (subcategorySubmit) subcategorySubmit.textContent = 'Crear subcategoría';
        }
        subcategoryModalOverlay?.classList.remove('hidden');
        subcategoryModalOverlay?.setAttribute('aria-hidden', 'false');
        setTimeout(() => subcategoryName?.focus(), 80);
      }

      function closeSubcategoryModal() {
        subcategoryModalOverlay?.classList.add('hidden');
        subcategoryModalOverlay?.setAttribute('aria-hidden', 'true');
        resetSubcategoryModal();
      }

      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(result?.message || 'Error de comunicación con la plataforma.');
        return result;
      }

      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${params}${separator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }

      function withStoreFilter(params = '') {
        const query = new URLSearchParams(params || '');
        const existing = query.get('filter');
        if (existing) query.set('filter', `(${existing}) && ${STORE_FILTER}`);
        else query.set('filter', STORE_FILTER);
        return query.toString();
      }

      function isCurrentStoreRecord(record) {
        const value = record?.store;
        return Array.isArray(value) ? value.includes(CURRENT_STORE_ID) : String(value || '') === CURRENT_STORE_ID;
      }

      function recordImageUrl(collection, record) {
        if (!record?.image) return '';
        return `${POCKETBASE_URL}/api/files/${collection}/${encodeURIComponent(record.id)}/${encodeURIComponent(record.image)}`;
      }

      function imageMarkup(collection, record, label, placeholder = '+') {
        const url = recordImageUrl(collection, record);
        if (!url) return `<span class="row-thumb" aria-label="Sin imagen">${escapeHtml(placeholder)}</span>`;
        return `<img class="row-thumb" src="${escapeHtml(url)}" alt="${escapeHtml(label)}" loading="lazy" />`;
      }

      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }
      function productImageUrl(product) {
        const images = parseProductImageOrder(product);
        const firstImage = images[0];
        if (!product?.id || !firstImage || !POCKETBASE_URL) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }

      function productImageMarkup(product) {
        const url = productImageUrl(product);
        if (!url) return '<span class="row-thumb">P</span>';
        return `<img class="row-thumb" src="${escapeHtml(url)}" alt="${escapeHtml(product?.name || 'Producto')}" loading="lazy" />`;
      }

      function formatUsd(value) {
        const amount = Number(value || 0);
        return `${amount.toFixed(2)} USD`;
      }

      function productHasRealSubcategory(product) {
        return Boolean(product?.subcategory && subcategories.some((item) => item.id === product.subcategory));
      }

      function directProducts() {
        return products.filter((product) => product.category === CATEGORY_ID && !productHasRealSubcategory(product));
      }

      function subcategoryProducts() {
        return products.filter((product) => product.category === CATEGORY_ID && productHasRealSubcategory(product));
      }

      function contentCounts() {
        const direct = directProducts().length;
        const nested = subcategoryProducts().length;
        return {
          subcategories: subcategories.length,
          direct,
          nested,
          total: direct + nested,
        };
      }

      function subcategoryNameExists(name, exceptId = '') {
        const normalized = normalizeName(name);
        return subcategories.some((item) => item.id !== exceptId && item.category === CATEGORY_ID && normalizeName(item.name) === normalized);
      }

      function categoryNameExists(name) {
        const normalized = normalizeName(name);
        return categories.some((item) => item.id !== CATEGORY_ID && normalizeName(item.name) === normalized);
      }

      function nextOrder(items) {
        if (!items.length) return 1;
        return Math.max(...items.map((item) => Number(item.order || 0))) + 1;
      }

      function productCreateUrl(categoryId = '', subcategoryId = '') {
        const params = new URLSearchParams();
        params.set('new', '1');
        if (categoryId) params.set('category', categoryId);
        if (subcategoryId) params.set('subcategory', subcategoryId);
        return `${ADMIN_PRODUCTS_PATH}?${params.toString()}`;
      }

      function productEditUrl(productId = '') {
        const params = new URLSearchParams();
        if (productId) params.set('product', productId);
        return `${ADMIN_PRODUCTS_PATH}?${params.toString()}`;
      }

      function renderHero() {
        categoryTitle.textContent = category?.name || 'Categoría sin nombre';
        if (breadcrumbCategoryName) breadcrumbCategoryName.textContent = category?.name || 'Cargando...';
        const childCount = subcategories.length;
        const directCount = directProducts().length;
        const nestedCount = subcategoryProducts().length;
        categorySubtitle.textContent = `${childCount} subcategorías · ${directCount} productos directos · ${nestedCount} en subcategorías`;
        categoryStatus.textContent = category?.active ? 'Visible' : 'Oculta';
        categoryStatus.className = `status-pill ${category?.active ? 'status-visible' : 'status-hidden'}`;
        const url = recordImageUrl('categories', category);
        categoryHeroThumb.innerHTML = url ? `<img src="${escapeHtml(url)}" alt="${escapeHtml(category?.name || 'Categoría')}" style="width:100%;height:100%;object-fit:cover;border-radius:24px;" />` : '+';
        if (categoryFormThumb) {
          categoryFormThumb.innerHTML = url ? `<img src="${escapeHtml(url)}" alt="${escapeHtml(category?.name || 'Categoría')}" />` : '+';
        }
        if (railCategoryThumb) {
          railCategoryThumb.innerHTML = url ? `<img src="${escapeHtml(url)}" alt="${escapeHtml(category?.name || 'Categoría')}" />` : '+';
        }
        if (railCategoryTitle) railCategoryTitle.textContent = category?.name || 'Categoría sin nombre';
        if (railCategorySlug) railCategorySlug.textContent = category?.slug || slugify(category?.name || '');
        if (railCategoryStatus) {
          railCategoryStatus.textContent = category?.active ? 'Visible' : 'Oculta';
          railCategoryStatus.className = `status-pill ${category?.active ? 'status-visible' : 'status-hidden'}`;
        }
        categoryName.value = category?.name || '';
        categoryDescription.value = category?.description || '';
        categoryActive.checked = category?.active === true;
      }

      function renderSummary() {
        if (!contentSummaryGrid) return;
        const counts = contentCounts();
        const tiles = [
          ['Subcategorías', counts.subcategories],
          ['Productos directos', counts.direct],
          ['Productos en subcategorías', counts.nested],
          ['Total productos', counts.total],
        ];
        contentSummaryGrid.innerHTML = tiles.map(([label, value]) => `
          <div class="summary-tile">
            <strong>${value}</strong>
            <span>${escapeHtml(label)}</span>
          </div>
        `).join('');
        if (railSummaryList) {
          railSummaryList.innerHTML = `
            <div><span>Visibilidad</span><strong>${category?.active ? 'Visible' : 'Oculta'}</strong></div>
            <div><span>Subcategorías</span><strong>${counts.subcategories}</strong></div>
            <div><span>Productos directos</span><strong>${counts.direct}</strong></div>
            <div><span>Productos en subcategorías</span><strong>${counts.nested}</strong></div>
            <div><span>Total productos</span><strong>${counts.total}</strong></div>
          `;
        }
      }

      function openSubcategoryMenu(subcategoryId, anchorButton) {
        const subcategory = subcategories.find((item) => item.id === subcategoryId);
        if (!subcategory || !subcategoryActionsMenu || !anchorButton) return;
        activeSubcategoryMenuId = subcategoryId;
        const rect = anchorButton.getBoundingClientRect();
        const menuWidth = 190;
        const left = Math.min(Math.max(12, rect.right - menuWidth), window.innerWidth - menuWidth - 12);
        const top = Math.min(rect.bottom + 8, window.innerHeight - 150);
        subcategoryActionsMenu.style.left = `${left}px`;
        subcategoryActionsMenu.style.top = `${Math.max(12, top)}px`;
        subcategoryActionsMenu.innerHTML = `
          <button type="button" data-menu-action="edit" data-subcategory-id="${escapeHtml(subcategory.id)}">Editar</button>
          <button type="button" data-menu-action="toggle" data-subcategory-id="${escapeHtml(subcategory.id)}">${subcategory.active ? 'Ocultar' : 'Activar'}</button>
          <button type="button" class="danger" data-menu-action="delete" data-subcategory-id="${escapeHtml(subcategory.id)}">Eliminar</button>
        `;
        subcategoryActionsMenu.classList.remove('hidden');
        subcategoryActionsMenu.setAttribute('aria-hidden', 'false');
      }

      function showSubcategoryDeleteConfirm(subcategoryId) {
        const subcategory = subcategories.find((item) => item.id === subcategoryId);
        if (!subcategory || !subcategoryDeleteConfirm) return;
        const count = productsForSubcategory(subcategory.id).length;
        const deleteTitle = count > 0 ? `Esta subcategoría tiene ${count} productos.` : '¿Eliminar esta subcategoría?';
        const deleteText = count > 0
          ? `Si la eliminas, los productos no se borrarán. Pasarán a la categoría principal "${escapeHtml(category?.name || 'esta categoría')}" sin subcategoría.`
          : 'Esta acción no se puede deshacer.';
        const deleteButtonText = count > 0 ? 'Eliminar y mover productos' : 'Eliminar subcategoría';
        openSubcategoryModal('edit', subcategory.id);
        pendingDeleteSubcategoryId = subcategory.id;
        if (subcategoryModalTitle) subcategoryModalTitle.textContent = 'Eliminar subcategoría';
        if (subcategorySubmit) subcategorySubmit.classList.add('hidden');
        subcategoryForm?.classList.add('confirming-delete');
        subcategoryDeleteConfirm.innerHTML = `
          <p class="delete-confirm-title">${deleteTitle}</p>
          <p class="delete-confirm-text">${deleteText}</p>
          <div class="delete-confirm-actions">
            <button class="mini-btn soft js-modal-delete-cancel" type="button">Cancelar</button>
            <button class="mini-btn red js-modal-delete-confirm" type="button">${deleteButtonText}</button>
          </div>
        `;
        subcategoryDeleteConfirm.classList.remove('hidden');
      }

      function renderSubcategories() {
        const ordered = [...subcategories].sort((a, b) => Number(a.order || 0) - Number(b.order || 0) || String(a.name || '').localeCompare(String(b.name || '')));
        subcategoriesCount.textContent = `${ordered.length} subcategorías · ${ordered.filter((item) => item.active).length} visibles`;
        if (!ordered.length) {
          subcategoriesList.innerHTML = '<div class="empty">Esta categoría todavía no tiene subcategorías.</div>';
          return;
        }
        subcategoriesList.innerHTML = ordered.map((subcategory) => {
          const count = productsForSubcategory(subcategory.id).length;
          const statusText = category?.active === false ? 'Oculta por categoría' : (subcategory.active ? 'Visible' : 'Oculta');
          const statusClass = category?.active === true && subcategory.active ? 'status-visible' : 'status-hidden';
          return `
            <article class="item-row subcategory-row" data-subcategory-id="${subcategory.id}">
              <div class="item-main">
                ${imageMarkup('subcategories', subcategory, subcategory.name || 'Subcategoría')}
                <div style="min-width:0;">
                  <p class="item-title">${escapeHtml(subcategory.name || 'Subcategoría sin nombre')}</p>
                  <p class="item-meta">${escapeHtml(subcategory.slug || 'sin-slug')} · ${count} productos · ${escapeHtml(statusText)}</p>
                </div>
              </div>
              <div class="subcategory-row-actions">
                <span class="status-pill ${statusClass}">${escapeHtml(statusText)}</span>
                <button class="mini-btn soft js-subcategory-products" type="button">+ Producto</button>
                <button class="subcategory-menu-button js-subcategory-menu" type="button" aria-label="Más acciones" aria-expanded="${activeSubcategoryMenuId === subcategory.id ? 'true' : 'false'}">⋯</button>
              </div>
            </article>
          `;
        }).join('');
      }

      function renderProductRow(product) {
        const isVisible = product.active !== false;
        return `
          <article class="item-row" data-product-id="${product.id}">
            <div class="item-main">
              ${productImageMarkup(product)}
              <div style="min-width:0;">
                <p class="item-title">${escapeHtml(product.name || 'Producto sin nombre')}</p>
                <p class="item-meta">${escapeHtml(formatUsd(product.base_price_usd))} · Stock: ${Number(product.stock || 0)} · ${isVisible ? 'Visible' : 'Oculto'}</p>
              </div>
            </div>
            <div class="row-actions">
              <span class="product-price">${isVisible ? 'Visible' : 'Oculto'}</span>
              <button class="mini-btn soft js-product-edit" type="button">Editar</button>
            </div>
          </article>
        `;
      }

      function renderProducts() {
        const items = directProducts().sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));
        productsCount.textContent = `${items.length} productos directos en esta categoría`;
        if (!items.length) {
          productsList.innerHTML = '<div class="empty">No hay productos directos en esta categoría.<br/>Puedes crear uno o usar subcategorías.</div>';
          return;
        }
        productsList.innerHTML = items.map(renderProductRow).join('');
      }

      function renderSubcategoryProducts() {
        if (!subcategoryProductsList) return;
        const ordered = [...subcategories].sort((a, b) => Number(a.order || 0) - Number(b.order || 0) || String(a.name || '').localeCompare(String(b.name || '')));
        if (!ordered.length) {
          subcategoryProductsList.innerHTML = '<div class="empty">No hay subcategorías para agrupar productos todavía.</div>';
          return;
        }
        subcategoryProductsList.innerHTML = ordered.map((subcategory) => {
          const items = productsForSubcategory(subcategory.id).sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));
          return `
            <section class="subcategory-group">
              <div class="subcategory-group-head">
                <div>
                  <p class="subcategory-group-title">${escapeHtml(subcategory.name || 'Subcategoría')}</p>
                  <p class="subcategory-group-count">${items.length} productos</p>
                </div>
                <button class="mini-btn soft js-subcategory-group-product" type="button" data-subcategory-id="${subcategory.id}">+ Agregar producto</button>
              </div>
              <div class="list-body">
                ${items.length ? items.map(renderProductRow).join('') : '<div class="empty">Sin productos todavía.</div>'}
              </div>
            </section>
          `;
        }).join('');
      }

      function renderAll() {
        renderHero();
        renderSummary();
        renderSubcategories();
        renderProducts();
        renderSubcategoryProducts();
      }

      async function loadPage() {
        try {
          categoryTitle.textContent = 'Cargando categoría...';
          const [categoryRecord, allCategories, subcategoryRecords, productRecords] = await Promise.all([
            apiRequest(`/api/collections/categories/records/${CATEGORY_ID}`),
            loadAllRecords('categories', withStoreFilter('sort=order,name')),
            loadAllRecords('subcategories', withStoreFilter(`filter=category%3D%22${encodeURIComponent(CATEGORY_ID)}%22&sort=order,name`)),
            loadAllRecords('products', withStoreFilter(`filter=category%3D%22${encodeURIComponent(CATEGORY_ID)}%22&sort=name`)),
          ]);
          if (!isCurrentStoreRecord(categoryRecord)) {
            throw new Error('Esta categoria no pertenece a tu tienda.');
          }
          category = categoryRecord;
          categories = allCategories;
          subcategories = subcategoryRecords;
          products = productRecords;
          renderAll();
        } catch (error) {
          console.error(error);
          categoryTitle.textContent = 'No se pudo cargar la categoría';
          categorySubtitle.textContent = error.message || 'Revisa tu sesión admin o si la categoría existe.';
        }
      }

      async function saveCategory(event) {
        event.preventDefault();
        const name = categoryName.value.trim();
        if (!name) {
          setAlert(categoryAlert, 'El nombre de la categoría no puede estar vacío.', 'error');
          return;
        }
        if (categoryNameExists(name)) {
          setAlert(categoryAlert, `Ya existe una categoría llamada "${name}".`, 'error');
          return;
        }
        setAlert(categoryAlert, 'Guardando categoría...', 'info');
        const imageFile = categoryImage.files?.[0];
        const changes = { name, slug: slugify(name), description: categoryDescription.value.trim(), active: categoryActive.checked, store: CURRENT_STORE_ID };
        if (imageFile) {
          const formData = new FormData();
          Object.entries(changes).forEach(([key, value]) => formData.append(key, String(value)));
          formData.append('image', await optimizeCatalogImageFile(imageFile));
          category = await apiRequest(`/api/collections/categories/records/${CATEGORY_ID}`, { method: 'PATCH', body: formData });
        } else {
          category = await apiRequest(`/api/collections/categories/records/${CATEGORY_ID}`, {
            method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(changes),
          });
        }
        categoryImage.value = '';
        setAlert(categoryAlert, 'Categoría guardada correctamente.', 'success');
        await loadPage();
      }

      async function createSubcategory(event) {
        event.preventDefault();
        const name = subcategoryName.value.trim();
        if (!name) {
          setAlert(subcategoryAlert, 'Escribe el nombre de la subcategoría.', 'error');
          return;
        }
        if (subcategoryNameExists(name, currentEditingSubcategoryId)) {
          setAlert(subcategoryAlert, `Ya existe una subcategoría llamada "${name}" dentro de esta categoría.`, 'error');
          return;
        }
        const editing = Boolean(currentEditingSubcategoryId);
        setAlert(subcategoryAlert, editing ? 'Guardando subcategoría...' : 'Creando subcategoría...', 'info');
        try {
          const formData = new FormData();
          formData.append('category', CATEGORY_ID);
          formData.append('name', name);
          formData.append('slug', slugify(name));
          formData.append('active', subcategoryActive.checked ? 'true' : 'false');
          if (!editing) formData.append('order', String(nextOrder(subcategories)));
          formData.append('store', CURRENT_STORE_ID);
          if (subcategoryImage.files?.[0]) formData.append('image', await optimizeCatalogImageFile(subcategoryImage.files[0]));
          if (editing) {
            const subcategory = subcategories.find((item) => String(item.id) === String(currentEditingSubcategoryId));
            if (!subcategory || subcategory.category !== CATEGORY_ID || !isCurrentStoreRecord(subcategory)) {
              throw new Error('No se pudo validar la subcategoría.');
            }
            await apiRequest(`/api/collections/subcategories/records/${currentEditingSubcategoryId}`, { method: 'PATCH', body: formData });
          } else {
            await apiRequest('/api/collections/subcategories/records', { method: 'POST', body: formData });
          }
          subcategoryForm.reset();
          subcategoryActive.checked = true;
          setAlert(subcategoryAlert, editing ? 'Subcategoría guardada correctamente.' : 'Subcategoría creada correctamente.', 'success');
          closeSubcategoryModal();
          await loadPage();
        } catch (error) {
          console.error(error);
          setAlert(subcategoryAlert, error.message || 'No se pudo guardar la subcategoría.', 'error');
        }
      }

      async function updateSubcategory(rowOrId, changes) {
        const id = typeof rowOrId === 'string' ? rowOrId : rowOrId.dataset.subcategoryId;
        const imageFile = typeof rowOrId === 'string' ? null : rowOrId.querySelector('.js-subcategory-image')?.files?.[0];
        if (imageFile) {
          const formData = new FormData();
          Object.entries(changes).forEach(([key, value]) => formData.append(key, String(value)));
          formData.append('image', await optimizeCatalogImageFile(imageFile));
          await apiRequest(`/api/collections/subcategories/records/${id}`, { method: 'PATCH', body: formData });
        } else {
          await apiRequest(`/api/collections/subcategories/records/${id}`, {
            method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(changes),
          });
        }
        await loadPage();
      }

      function productsForSubcategory(subcategoryId) {
        return products.filter((product) => (
          product.subcategory === subcategoryId
          && product.category === CATEGORY_ID
          && isCurrentStoreRecord(product)
        ));
      }

      async function moveProductToParentCategory(product) {
        const formData = new FormData();
        formData.append('category', CATEGORY_ID);
        formData.append('subcategory', '');
        formData.append('store', CURRENT_STORE_ID);
        await apiRequest(`/api/collections/products/records/${product.id}`, { method: 'PATCH', body: formData });
      }

      async function deleteSubcategorySafely(subcategoryId) {
        if (!category?.id || category.id !== CATEGORY_ID || !isCurrentStoreRecord(category)) {
          throw new Error('No se pudo validar la categoria actual.');
        }
        const subcategory = subcategories.find((item) => item.id === subcategoryId);
        if (!subcategory) throw new Error('No se encontro la subcategoria.');
        if (subcategory.category !== CATEGORY_ID) throw new Error('La subcategoria no pertenece a esta categoria.');
        if (!isCurrentStoreRecord(subcategory)) throw new Error('La subcategoria no pertenece a esta tienda.');

        const affectedProducts = productsForSubcategory(subcategoryId);
        for (const product of affectedProducts) {
          await moveProductToParentCategory(product);
        }

        await apiRequest(`/api/collections/subcategories/records/${subcategoryId}`, { method: 'DELETE' });
        pendingDeleteSubcategoryId = '';
        setAlert(
          subcategoryAlert,
          affectedProducts.length
            ? 'Subcategoria eliminada. Los productos se movieron a la categoria principal.'
            : 'Subcategoria eliminada correctamente.',
          'success',
        );
        await loadPage();
      }
      logoutBtn?.addEventListener('click', () => {
        document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax';
        window.location.assign('/login');
      });
      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarCloseBtn?.addEventListener('click', closeSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeSidebar();
          closeSubcategoryMenu();
          closeSubcategoryModal();
        }
      });
      sidebar?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSidebar));

      categoryForm?.addEventListener('submit', saveCategory);
      subcategoryForm?.addEventListener('submit', createSubcategory);
      newProductBtn?.addEventListener('click', () => {
        window.location.href = productCreateUrl(CATEGORY_ID, '');
      });
      subcategoryCreateClose?.addEventListener('click', closeSubcategoryModal);
      subcategoryModalCancel?.addEventListener('click', closeSubcategoryModal);
      subcategoryModalOverlay?.addEventListener('click', (event) => {
        if (event.target === subcategoryModalOverlay) closeSubcategoryModal();
      });
      document.querySelectorAll('[data-action="new-product"]').forEach((button) => {
        button.addEventListener('click', () => newProductBtn.click());
      });

      document.addEventListener('click', (event) => {
        const newSubcategoryButton = event.target.closest('#quick-new-subcategory-btn, [data-action="new-subcategory"]');
        if (!newSubcategoryButton) return;
        event.preventDefault();
        event.stopPropagation();
        openSubcategoryModal('create');
      });

      subcategoriesList.addEventListener('click', async (event) => {
        const button = event.target.closest('button');
        if (!button) return;
        const row = button.closest('[data-subcategory-id]');
        if (!row) return;
        const subcategory = subcategories.find((item) => item.id === row.dataset.subcategoryId);
        if (!subcategory) return;

        try {
          if (button.classList.contains('js-subcategory-products')) {
            closeSubcategoryMenu();
            window.location.href = productCreateUrl(CATEGORY_ID, subcategory.id);
            return;
          }
          if (button.classList.contains('js-subcategory-menu')) {
            if (activeSubcategoryMenuId === subcategory.id && !subcategoryActionsMenu?.classList.contains('hidden')) closeSubcategoryMenu();
            else openSubcategoryMenu(subcategory.id, button);
            return;
          }
        } catch (error) {
          console.error(error);
          alert(error.message || 'No se pudo actualizar la subcategoría.');
        } finally {
          button.disabled = false;
        }
      });

      document.addEventListener('click', async (event) => {
        const button = event.target.closest('#subcategory-actions-menu [data-menu-action]');
        if (!button) return;
        event.preventDefault();
        event.stopPropagation();
        const subcategoryId = button.dataset.subcategoryId || '';
        const action = button.dataset.menuAction || '';
        const subcategory = subcategories.find((item) => String(item.id) === String(subcategoryId));
        if (!subcategory) {
          setAlert(subcategoryAlert, 'No se encontró la subcategoría seleccionada.', 'error');
          closeSubcategoryMenu();
          return;
        }
        closeSubcategoryMenu();
        try {
          if (action === 'edit') {
            openSubcategoryModal('edit', subcategoryId);
            return;
          }
          if (action === 'toggle') {
            button.disabled = true;
            await updateSubcategory(subcategoryId, { active: !subcategory.active });
            return;
          }
          if (action === 'delete') {
            showSubcategoryDeleteConfirm(subcategoryId);
          }
        } catch (error) {
          console.error(error);
          setAlert(subcategoryAlert, error.message || 'No se pudo actualizar la subcategoría.', 'error');
        } finally {
          button.disabled = false;
        }
      });

      subcategoryDeleteConfirm?.addEventListener('click', async (event) => {
        const cancelButton = event.target.closest('.js-modal-delete-cancel');
        if (cancelButton) {
          closeSubcategoryModal();
          return;
        }
        const confirmButton = event.target.closest('.js-modal-delete-confirm');
        if (!confirmButton || !pendingDeleteSubcategoryId) return;
        confirmButton.disabled = true;
        confirmButton.textContent = 'Eliminando...';
        try {
          await deleteSubcategorySafely(pendingDeleteSubcategoryId);
          closeSubcategoryModal();
        } catch (error) {
          console.error(error);
          setAlert(subcategoryAlert, error.message || 'No se pudo eliminar la subcategoría.', 'error');
          await loadPage();
        } finally {
          confirmButton.disabled = false;
        }
      });

      document.addEventListener('click', (event) => {
        if (
          !subcategoryActionsMenu?.classList.contains('hidden')
          && !event.target.closest('.subcategory-actions-menu')
          && !event.target.closest('.js-subcategory-menu')
        ) {
          closeSubcategoryMenu();
        }
      });

      productsList.addEventListener('click', (event) => {
        const button = event.target.closest('.js-product-edit');
        const row = button?.closest('[data-product-id]');
        if (row?.dataset?.productId) window.location.href = productEditUrl(row.dataset.productId);
      });
      subcategoryProductsList?.addEventListener('click', (event) => {
        const productButton = event.target.closest('.js-product-edit');
        const productRow = productButton?.closest('[data-product-id]');
        if (productRow?.dataset?.productId) {
          window.location.href = productEditUrl(productRow.dataset.productId);
          return;
        }
        const addButton = event.target.closest('.js-subcategory-group-product');
        if (addButton?.dataset?.subcategoryId) {
          window.location.href = productCreateUrl(CATEGORY_ID, addButton.dataset.subcategoryId);
        }
      });
      showAdmin();
      if (POCKETBASE_URL && getAdminToken()) {
        loadPage();
      } else {
        setAlert(categoryAlert, 'No se pudo validar la sesion administrativa.', 'error');
      }
    </script>
  </body>
</html>
