        width: 44px; height: 44px; border-radius: 15px; display: inline-flex; align-items: center; justify-content: center;
        background: #fff; border: 1px solid #e2e8f0; color: #0f172a; font-size: 20px; font-weight: 1000;
      }
      .editor-topbar .page-title { margin: 0; font-size: clamp(24px, 2.5vw, 34px); letter-spacing: -.035em; }
      .breadcrumb { margin: 5px 0 0; color: #64748b; font-size: 12px; font-weight: 850; }
