---
export const prerender = false;

import { refreshAuthFromCookie } from '../../../../lib/auth';
import { getPublicStorePath, getStoreAdminPath } from '../../../../lib/adminRoutes';
import { requireCurrentStoreForAdmin } from '../../../../lib/storeContext';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const categoryId = Astro.params.id;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreId = adminContext.storeId;
const adminAuthToken = authPb.authStore.token;
const currentStoreSlug = adminContext.store.slug || '';
const currentStoreName = adminContext.store.name || adminContext.store.title || currentStoreSlug || 'Tienda';
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminCatalogPath = getStoreAdminPath(currentStoreSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const publicStorePath = getPublicStorePath(currentStoreSlug);
const masterSupportWhatsapp = String(import.meta.env.PUBLIC_MASTER_SUPPORT_WHATSAPP || '').replace(/[^0-9]/g, '');
const masterSupportEmail = String(import.meta.env.PUBLIC_MASTER_SUPPORT_EMAIL || '').trim();
const supportMessage = `Hola soporte de Tu Senda 84, necesito ayuda con editar categoria de la tienda ${currentStoreName} (${currentStoreSlug || 'sin-slug'}).`;
const masterSupportHref = masterSupportWhatsapp
  ? `https://wa.me/${masterSupportWhatsapp}?text=${encodeURIComponent(supportMessage)}`
  : (masterSupportEmail ? `mailto:${masterSupportEmail}?subject=${encodeURIComponent('Soporte Editar Categoria Tu Senda 84')}&body=${encodeURIComponent(supportMessage)}` : '');
const masterSupportLabel = masterSupportHref ? 'Contactar a soporte' : 'Soporte Tu Senda 84';
---
<!-- PZ-CATALOG-ADMIN-CATEGORY-DETAIL-V1-20260603
  Bloque: Categorías admin visual
  Cambio: página dedicada para editar una categoría, cambiar foto, visibilidad y gestionar subcategorías/productos directos.
-->
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categoría admin | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --green: #16a34a;
        --red: #dc2626;
        --blue: #2563eb;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }
      * { box-sizing: border-box; }
      html, body { min-height: 100%; margin: 0; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 12% 0%, rgba(37, 99, 235, 0.15), transparent 30%),
          radial-gradient(circle at 90% 12%, rgba(22, 163, 74, 0.10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 52%, #e8eef7 100%);
      }
      a { color: inherit; text-decoration: none; }
      button, input, select { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .65; }
      .hidden { display: none !important; }
      .app-shell { width: min(1320px, 100%); margin: 0 auto; padding: 24px; }
      .topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
      .topbar-left, .topbar-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .action-btn, .back-link {
        display: inline-flex; align-items: center; justify-content: center; gap: 9px;
        border: 1px solid rgba(226, 232, 240, .95); border-radius: 18px; padding: 12px 15px;
        background: rgba(255,255,255,.92); color: #0f172a; font-weight: 1000;
        box-shadow: 0 12px 26px rgba(15,23,42,.07);
      }
      .action-btn.dark { background: #0f172a; color: #fff; border-color: #0f172a; }
      .action-btn.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .hero-card, .panel-card, .list-card {
        background: rgba(255,255,255,.93); border: 1px solid rgba(226,232,240,.96);
        border-radius: 30px; box-shadow: var(--shadow); backdrop-filter: blur(10px);
      }
      .hero-card { padding: 26px; margin-bottom: 18px; display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 16px; align-items: center; overflow: hidden; position: relative; }
      .hero-thumb { width: 82px; height: 82px; border-radius: 24px; object-fit: cover; border: 1px solid #e2e8f0; background: #f1f5f9; box-shadow: 0 16px 30px rgba(15,23,42,.10); display: flex; align-items: center; justify-content: center; font-size: 30px; font-weight: 1000; color: #94a3b8; }
      .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 8px 12px; background: #dbeafe; color: #1d4ed8; font-size: 12px; font-weight: 1000; }
      .page-title { margin: 10px 0 0; font-size: clamp(26px, 4vw, 42px); font-weight: 1000; letter-spacing: -.045em; line-height: 1.05; }
      .page-subtitle { margin: 8px 0 0; color: var(--muted); line-height: 1.5; font-size: 14px; font-weight: 760; }
      .status-pill { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 9px 12px; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .035em; border: 1px solid transparent; white-space: nowrap; }
      .status-visible { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .status-hidden { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .grid { display: grid; grid-template-columns: minmax(0, .95fr) minmax(0, 1.25fr); gap: 18px; align-items: start; }
      .stack { display: grid; gap: 18px; }
      .panel-card { padding: 22px; }
      .panel-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -.025em; }
      .panel-text { margin: 8px 0 18px; color: var(--muted); line-height: 1.55; font-size: 14px; font-weight: 750; }
      .form-grid { display: grid; gap: 12px; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .04em; }
      .field input, .field select, .field textarea {
        width: 100%; border: 1px solid var(--border); border-radius: 16px; background: #fff; color: var(--text);
        padding: 12px 13px; outline: none; font-weight: 850; box-shadow: inset 0 1px 0 rgba(15,23,42,.02);
      }
      .field textarea { min-height: 92px; resize: vertical; line-height: 1.45; }
      .field input[type="file"] { padding: 10px; background: #f8fafc; }
      .image-help { margin: 2px 0 0; color: #64748b; font-size: 11px; line-height: 1.4; font-weight: 800; }
      .field input:focus, .field select:focus { border-color: #93c5fd; box-shadow: 0 0 0 4px rgba(37,99,235,.12); }
      .form-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      .checkline { display: flex; align-items: center; gap: 10px; font-weight: 950; color: #334155; }
      .checkline input { width: 18px; height: 18px; accent-color: #16a34a; }
      .submit-btn, .mini-btn {
        border: 0; border-radius: 18px; padding: 12px 15px; background: #0f172a; color: #fff;
        font-weight: 1000; box-shadow: 0 14px 28px rgba(15,23,42,.18); display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      }
      .mini-btn { padding: 10px 13px; border-radius: 999px; font-size: 12px; }
      .mini-btn.soft { background: #fff; color: #0f172a; border: 1px solid #e2e8f0; box-shadow: 0 10px 22px rgba(15,23,42,.06); }
      .mini-btn.green { background: #16a34a; }
      .mini-btn.red { background: #dc2626; }
      .alert { margin-top: 12px; border-radius: 16px; padding: 11px 12px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
      .list-card { overflow: hidden; }
      .list-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; flex-wrap: wrap; padding: 20px 22px; border-bottom: 1px solid var(--border); background: linear-gradient(180deg, rgba(248,250,252,.9), rgba(255,255,255,.6)); }
      .list-title { margin: 0; font-size: 18px; font-weight: 1000; letter-spacing: -.02em; }
      .list-subtitle { margin: 5px 0 0; color: var(--muted); font-size: 13px; font-weight: 750; }
      .list-body { display: grid; gap: 0; }
      .item-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 14px; align-items: center; padding: 15px 18px; border-bottom: 1px solid #eef2f7; }
      .item-row:last-child { border-bottom: 0; }
      .item-main { display: flex; align-items: center; gap: 12px; min-width: 0; }
      .row-thumb { width: 54px; height: 54px; min-width: 54px; border-radius: 16px; object-fit: cover; background: #f1f5f9; border: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-weight: 1000; }
      .item-title { margin: 0; font-size: 14px; font-weight: 1000; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .item-meta { margin: 4px 0 0; color: #64748b; font-size: 12px; font-weight: 800; }
      .row-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap; }
      .delete-confirm {
        grid-column: 1 / -1;
        margin-top: 2px;
        padding: 15px;
        border-radius: 22px;
        border: 1px solid #fecaca;
        background: linear-gradient(180deg, #fff7f7 0%, #ffffff 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.92);
      }
      .delete-confirm-title { margin: 0; color: #991b1b; font-size: 15px; font-weight: 1000; letter-spacing: -.01em; }
      .delete-confirm-text { margin: 6px 0 14px; color: #7f1d1d; font-size: 13px; font-weight: 800; line-height: 1.45; }
      .delete-confirm-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap; }
      .empty { padding: 22px; color: #64748b; font-weight: 850; }
      .product-price { border-radius: 999px; padding: 8px 10px; font-size: 11px; font-weight: 1000; background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; white-space: nowrap; }
      .login-card { max-width: 520px; margin: 24px auto 0; }
      @media (max-width: 900px) {
        .grid { grid-template-columns: 1fr; }
        .hero-card { grid-template-columns: 1fr; }
        .form-row { grid-template-columns: 1fr; }
      }
      @media (max-width: 620px) {
        .app-shell { padding: 14px; }
        .item-row { grid-template-columns: 1fr; }
        .row-actions, .delete-confirm-actions { justify-content: flex-start; }
        .delete-confirm-actions .mini-btn { width: 100%; }
        .hero-thumb { width: 68px; height: 68px; }
      }
      /* PZ-EDIT-CATEGORY-VISUAL-V18 */
      body { background: #eef3f9; overflow-x: hidden; }
      .app-shell { width: auto; max-width: none; margin: 0; padding: 28px 28px 34px 304px; }
      .sidebar-overlay {
        position: fixed; inset: 0; z-index: 80; background: rgba(15,23,42,.36);
        opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(2px);
      }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar {
        position: fixed; z-index: 90; top: 18px; left: 18px; bottom: 18px; width: min(286px, calc(100vw - 36px));
        border-radius: 30px; border: 1px solid rgba(226,232,240,.95); background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        color: #0f172a; box-shadow: 0 28px 80px rgba(15,23,42,.22); padding: 18px; overflow: hidden; transform: none;
      }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo { width: 42px; height: 42px; border-radius: 16px; background: #0f172a; color: #fff; display: inline-flex; align-items: center; justify-content: center; font-weight: 1000; box-shadow: 0 14px 30px rgba(15,23,42,.18); }
      .brand-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; color: #0f172a; }
      .brand-subtitle { margin: 2px 0 0; color: #64748b; font-size: 11px; font-weight: 850; }
      .sidebar-label { margin: 18px 9px 9px; color: #64748b; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .nav-list { display: grid; gap: 8px; }
      .nav-item {
        width: 100%; display: flex; align-items: center; gap: 11px; border-radius: 18px; padding: 11px 12px;
        background: transparent; color: #334155; font-size: 13px; font-weight: 950; text-align: left; border: 1px solid transparent;
      }
      .nav-item:hover { background: #f1f5f9; border-color: #e2e8f0; color: #0f172a; }
      .nav-item.active { background: #0f172a; border-color: #0f172a; color: #fff; box-shadow: 0 12px 26px rgba(15,23,42,.16); }
      .nav-item.danger { color: #991b1b; background: #fff1f2; }
      .nav-icon { width: 34px; height: 34px; flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center; border-radius: 14px; background: #f8fafc; color: #0f172a; border: 1px solid #e2e8f0; }
      .nav-icon svg { width: 18px; height: 18px; display: block; fill: currentColor; }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.20); }
      .sidebar-utility { margin-top: auto; display: grid; gap: 8px; padding-top: 14px; }
      .sidebar-footer { margin-top: 12px; padding: 14px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .sidebar-footer strong { display: block; color: #0f172a; font-size: 12px; margin-bottom: 5px; }
      .sidebar-footer span { display: block; color: #475569; font-size: 11px; line-height: 1.45; font-weight: 750; }
      .sidebar-close { margin-left: auto; width: 36px; height: 36px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-weight: 1000; box-shadow: 0 8px 18px rgba(15,23,42,.05); display: none; }
      .mobile-topbar { display: none; }
      .topbar {
        margin-bottom: 20px; padding: 18px 20px; border-radius: 26px; border: 1px solid rgba(226,232,240,.96);
        background: rgba(255,255,255,.92); box-shadow: 0 18px 45px rgba(15,23,42,.08);
      }
      .back-link, .action-btn { border-radius: 16px; box-shadow: none; }
      .primary-blue-btn, .mini-btn.blue {
        border: 0; border-radius: 16px; padding: 12px 16px; background: #2563eb; color: #fff; font-weight: 1000;
        box-shadow: 0 14px 28px rgba(37,99,235,.22);
      }
      .notifications-btn {
        position: relative; width: 44px; height: 44px; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff;
        color: #0f172a; display: inline-flex; align-items: center; justify-content: center;
      }
      .notifications-btn svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
      .notifications-dot { position: absolute; top: 9px; right: 10px; width: 8px; height: 8px; border-radius: 999px; background: #ef4444; border: 2px solid #fff; }
      .hero-card { border-radius: 28px; }
      .hero-card::after { content: 'Vista previa'; position: absolute; right: 24px; bottom: 20px; color: #94a3b8; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .1em; }
      .grid { grid-template-columns: minmax(0, .72fr) minmax(0, 1.28fr); gap: 20px; }
      .grid > .stack:first-child { position: sticky; top: 24px; }
      .panel-card, .list-card, .hero-card { background: #fff; border-radius: 24px; border-color: rgba(226,232,240,.96); box-shadow: 0 18px 45px rgba(15,23,42,.07); }
      .panel-title { font-size: 18px; }
      .form-grid, .category-form-grid, .subcategory-form-grid { display: grid; gap: 14px; }
      .field input, .field select, .field textarea { border-radius: 14px; font-weight: 800; }
