        if (!couponFormHasChanges()) { updateCouponFormState(); return; }
        isSavingCoupon = true;
        updateCouponFormState();
        showCouponNotice('Guardando cupón...', 'info');
        try {
          await apiRequest(`/api/collections/manual_coupons/records${id ? `/${id}` : ''}`, { method: id ? 'PATCH' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
          const message = id ? 'Cambios guardados correctamente' : 'Cupón creado correctamente';
          await loadData();
