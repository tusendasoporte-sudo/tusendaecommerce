          if (marketingBarPreviewSubtext) marketingBarPreviewSubtext.textContent = previewItem ? marketingPreviewSubtext(previewItem) : 'Promoción disponible por tiempo limitado';
          if (marketingBarPreviewButton) {
            const buttonText = previewItem?.button_text || 'Ver oferta';
            marketingBarPreviewButton.innerHTML = `${escapeMarketingHtml(buttonText)}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 5 20 12l-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6L13 5Z"/></svg>`;
            marketingBarPreviewButton.classList.toggle('hidden', !previewItem);
