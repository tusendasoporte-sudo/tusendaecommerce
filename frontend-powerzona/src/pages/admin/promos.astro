        if (payload.ends_at && payload.starts_at && promotionDateTime(payload.ends_at, 'end') < promotionDateTime(payload.starts_at, 'start')) return 'La fecha fin no puede ser menor que la fecha inicio.';
        if (payload.scope !== 'free_shipping') {
