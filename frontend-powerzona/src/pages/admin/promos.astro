      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function setAdminToken(_token) {}
      function clearAdminToken() {}
      function showAlert(el, message = '', type = 'info') {
        if (!el) return;
        if (!message) { el.className = 'alert alert-info hidden'; el.textContent = ''; return; }
        el.className = `alert alert-${type}`;
        el.textContent = message;
      }
      function showPromotionNotice(message = '', type = 'info') {
        if (!promotionAlert) return;
        window.clearTimeout(promotionNoticeTimer);
        if (!message) {
          promotionAlert.className = 'alert alert-info hidden';
          promotionAlert.textContent = '';
          return;
        }
        promotionAlert.className = `alert alert-${type}`;
        promotionAlert.textContent = message;
        if (type === 'info') return;
        promotionNoticeTimer = window.setTimeout(() => {
          promotionAlert.className = `alert alert-${type} hidden`;
          promotionAlert.textContent = '';
        }, type === 'error' ? 4600 : 2800);
      }
      function showCouponNotice(message = '', type = 'info') {
        if (!couponAlert) return;
        window.clearTimeout(couponNoticeTimer);
        if (!message) {
          couponAlert.className = 'alert alert-info hidden';
          couponAlert.textContent = '';
          return;
        }
        couponAlert.className = `alert alert-${type}`;
        couponAlert.textContent = message;
        if (type === 'info') return;
        couponNoticeTimer = window.setTimeout(() => {
          couponAlert.className = `alert alert-${type} hidden`;
          couponAlert.textContent = '';
        }, type === 'error' ? 4600 : 2800);
      }
      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
      }
      function normalizeSearchText(value) {
        return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      }
      function pocketBaseErrorMessage(result, fallback = 'Error de comunicación con PocketBase.') {
        const base = result?.message || fallback;
        const fieldErrors = result?.data && typeof result.data === 'object'
          ? Object.entries(result.data).map(([field, info]) => {
              const message = info?.message || (Array.isArray(info) ? info.map((item) => item?.message).filter(Boolean).join(', ') : '');
              return message ? `${field}: ${message}` : field;
            }).filter(Boolean)
          : [];
        return fieldErrors.length ? `${base} ${fieldErrors.join(' · ')}` : base;
      }
      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(pocketBaseErrorMessage(result));
        return result;
      }
      function withStoreFilter(params = '') {
        if (!STORE_FILTER) return params;
        const query = new URLSearchParams(params || '');
        const current = query.get('filter');
        query.set('filter', current ? `(${current}) && ${STORE_FILTER}` : STORE_FILTER);
        return query.toString();
      }
      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const scopedParams = withStoreFilter(params);
          const scopedSeparator = scopedParams ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${scopedParams}${scopedSeparator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }
      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }
      function productImageUrl(product) {
        const images = parseProductImageOrder(product);
        const firstImage = images[0] || '';
        if (!product?.id || !firstImage) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }
      function visualImageUrl(item) {
        const image = Array.isArray(item?.image) ? item.image[0] : item?.image;
        if (!item?.id || !image) return '';
        return `${POCKETBASE_URL}/api/files/store_visual_items/${encodeURIComponent(item.id)}/${encodeURIComponent(image)}?thumb=300x200`;
      }
      function visualAttachmentName(item) {
        const attachment = Array.isArray(item?.attachment) ? item.attachment[0] : item?.attachment;
        return attachment || '';
      }
      function thumbMarkup(url, fallback = '📦') {
        if (!url) return `<span class="thumb placeholder">${fallback}</span>`;
        return `<img class="thumb" src="${url}" alt="" loading="lazy" />`;
      }
      function formatUsd(value) { return `$${Number(value || 0).toFixed(2)} USD`; }
      function readOnlyVisualRow(item) {
        return `
          <article class="item-row">
            <div class="item-main">
              ${thumbMarkup(visualImageUrl(item), '🏷️')}
              <div>
                <p class="item-title">${escapeHtml(item.title || 'Sin título')}</p>
                <p class="item-meta">Promo visual · Orden ${Number(item.sort_order || 0)} · ${item.active !== false ? 'Visible' : 'Oculta'}</p>
              </div>
            </div>
            <div class="item-actions"><span class="pill ${item.active !== false ? 'pill-visible' : 'pill-hidden'}">${item.active !== false ? 'Visible' : 'Oculta'}</span></div>
          </article>
        `;
      }
      function renderStats() {
        document.getElementById('stat-featured').textContent = String(products.filter((p) => p.featured === true).length);
        document.getElementById('stat-promos').textContent = String(visualItems.filter((item) => item.type === 'promo_visual').length);
        document.getElementById('stat-shortcuts').textContent = String(visualItems.filter((item) => item.type === 'acceso_rapido').length);
      }
      function renderProductSelect() {
        const available = products.filter((product) => product.active !== false);
        featuredProductSelect.innerHTML = '<option value="">Selecciona un producto</option>' + available
          .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
          .map((product) => `<option value="${product.id}">${escapeHtml(product.name || 'Sin nombre')} · ${formatUsd(product.base_price_usd)}</option>`).join('');
        renderFeaturedProductResults();
      }
      function productCategoryText(product) {
        const category = product.expand?.category?.name || categories.find((item) => item.id === product.category)?.name || '';
        const subcategory = product.expand?.subcategory?.name || product.subcategory_name || '';
        return [category, subcategory].filter(Boolean).join(' · ');
      }
      function productSearchText(product) {
        return normalizeSearchText([
          product.name,
          product.internal_ref,
          product.sku,
          product.slug,
          productCategoryText(product),
        ].filter(Boolean).join(' '));
      }
      function renderFeaturedProductResults() {
        if (!featuredProductResults) return;
        const query = normalizeSearchText(featuredProductSearch?.value || '');
        if (!query) {
          featuredProductResults.innerHTML = '<div class="empty-state">Escribe para buscar productos.</div>';
          return;
        }
        const matches = products
          .filter((product) => product.active !== false || product.featured === true)
          .filter((product) => productSearchText(product).includes(query))
          .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
          .slice(0, 15);
        if (!matches.length) {
          featuredProductResults.innerHTML = '<div class="empty-state">No se encontraron productos.</div>';
          return;
        }
        featuredProductResults.innerHTML = matches.map((product) => {
          const alreadyFeatured = product.featured === true;
          const categoryText = productCategoryText(product);
          const meta = [
            formatUsd(product.base_price_usd),
            `Stock ${Number(product.stock || 0)}`,
            product.active === false ? 'Oculto' : 'Visible',
            product.internal_ref ? `Ref ${product.internal_ref}` : '',
            categoryText,
          ].filter(Boolean).join(' · ');
          return `
            <article class="featured-result-row">
              <div>
                <p class="featured-result-title">${escapeHtml(product.name || 'Sin nombre')}</p>
                <p class="featured-result-meta">${escapeHtml(meta)}</p>
              </div>
              <button class="mini-btn ${alreadyFeatured ? '' : 'primary'} js-featured-result-add" data-product-id="${product.id}" type="button" ${alreadyFeatured ? 'disabled' : ''}>${alreadyFeatured ? 'Ya agregado' : 'Agregar'}</button>
            </article>
          `;
        }).join('');
      }
      function getFeaturedProductsSorted() {
        return products
          .filter((product) => product.featured === true)
          .sort((a, b) => (Number(a.featured_order || 0) - Number(b.featured_order || 0)) || String(a.name || '').localeCompare(String(b.name || '')));
      }
      function getVisualItemsSorted(type) {
        return visualItems
          .filter((item) => item.type === type)
          .sort((a, b) => (Number(a.sort_order || 0) - Number(b.sort_order || 0)) || String(a.title || '').localeCompare(String(b.title || '')));
      }
      function getAllVisualItemsSorted() {
        return [...visualItems]
          .sort((a, b) => (Number(a.sort_order || 0) - Number(b.sort_order || 0)) || String(a.title || '').localeCompare(String(b.title || '')));
      }
      function renderAdminReadPanels() {
        const featured = getFeaturedProductsSorted();
        const visuals = getAllVisualItemsSorted();
        document.querySelectorAll('[data-featured-total]').forEach((node) => { node.textContent = `Total de destacados: ${featured.length}`; });
        document.querySelectorAll('[data-featured-summary-action]').forEach((button) => { button.textContent = featured.length > 0 ? 'Editar' : 'Agregar'; });
        document.querySelectorAll('[data-visual-total]').forEach((node) => { node.textContent = `Total de promos: ${visuals.length}`; });
        document.querySelectorAll('[data-visual-summary-action]').forEach((button) => { button.textContent = visuals.length > 0 ? 'Editar' : 'Agregar'; });
        if (adminBlockModes.visual === 'view') adminBlockModes.visual = 'closed';
        if (adminBlockModes.orgPromos === 'view') adminBlockModes.orgPromos = 'closed';
      }
      function setAdminBlockMode(block, mode = 'closed') {
        adminBlockModes[block] = mode;
        const summary = document.querySelector(`[data-admin-block-summary="${block}"]`);
        const viewPanel = document.querySelector(`[data-admin-block-panel="${block}-view"]`);
        const editorPanel = document.querySelector(`[data-admin-block-panel="${block}-editor"]`);
        summary?.classList.toggle('hidden', mode !== 'closed');
        viewPanel?.classList.toggle('hidden', mode !== 'view');
        editorPanel?.classList.toggle('hidden', mode !== 'edit');
        if (mode !== 'edit' && block === 'visual') resetVisualForm();
      }
      function syncAdminBlockPanels() {
        renderAdminReadPanels();
        setAdminBlockMode('featured', adminBlockModes.featured);
        setAdminBlockMode('visual', adminBlockModes.visual);
        setAdminBlockMode('orgFeatured', adminBlockModes.orgFeatured);
        setAdminBlockMode('orgPromos', adminBlockModes.orgPromos);
