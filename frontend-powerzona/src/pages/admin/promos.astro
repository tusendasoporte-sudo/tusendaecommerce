          font-size: 15px !important;
          line-height: 1.5 !important;
          font-weight: 850 !important;
        }

        body #admin-view,
        body .tab-panel,
        body .panel-card,
        body .marketing-featured-panel,
        body .marketing-featured-accordion,
        body #marketing-bar-panel,
        body #tab-destacados,
        body #tab-promociones,
        body #tab-cupones,
        body #tab-visuales {
          scroll-margin-top: 160px !important;
        }
      }
      </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell pz-admin-content">
      <AdminSidebar
        storeSlug={currentStoreSlug}
        storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'}
        activeSection="marketing"
        mobileTitle="Marketing"
      />

      <main class="main-wrap pz-admin-content-inner">
        <section class="marketing-settings-hero" aria-labelledby="marketing-featured-title">
          <div>
            <p id="marketing-mobile-eyebrow" class="marketing-settings-eyebrow">Marketing y Visual / Destacados visuales</p>
            <h1 id="marketing-featured-title" class="marketing-settings-title">Destacados visuales</h1>
            <p id="admin-subtitle" class="marketing-settings-subtitle">
              Configura qué productos aparecen destacados en la portada pública de tu tienda.
            </p>
          </div>
          <div class="marketing-settings-actions">
            <button class="notification-btn desktop-notification-btn" type="button" aria-label="Notificaciones">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 22a2.8 2.8 0 0 0 2.7-2h-5.4a2.8 2.8 0 0 0 2.7 2Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/>
              </svg>
            </button>
          </div>
        </section>

        <section id="marketing-summary-card" class="marketing-summary-card hidden" aria-label="Resumen de marketing" aria-hidden="true">
          <div class="marketing-summary-grid">
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Productos destacados</p>
              <p id="stat-featured" class="marketing-summary-value">0</p>
            </article>
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Promo Visuales</p>
              <p id="stat-promos" class="marketing-summary-value">0</p>
            </article>
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Accesos Rápidos</p>
              <p id="stat-shortcuts" class="marketing-summary-value">0</p>
            </article>
          </div>
        </section>

        <section id="login-view" class="panel-card login-card hidden">
          <h2 class="page-title" style="font-size: 24px; margin: 0;">Entrar como admin</h2>
          <p class="page-subtitle">Usa el mismo usuario administrador de PocketBase para modificar ajustes de tienda.</p>
          <form id="login-form" class="form-grid" style="margin-top: 18px;">
            <div class="field"><label for="admin-email">Email</label><input id="admin-email" type="email" autocomplete="username" required /></div>
            <div class="field"><label for="admin-password">Contraseña</label><input id="admin-password" type="password" autocomplete="current-password" required /></div>
            <button id="login-btn" class="submit-btn" type="submit">Entrar al panel</button>
            <div id="login-alert" class="alert alert-error hidden"></div>
          </form>
        </section>

        <section id="admin-view" class="hidden">
          <div class="tabs">
            <button class="tab-btn active" data-tab="destacados" type="button">Destacados</button>
            <button class="tab-btn" data-tab="promociones" type="button">Promociones automáticas</button>
            <button class="tab-btn" data-tab="cupones" type="button">Cupón manual</button>
            <button class="tab-btn" data-tab="visuales" type="button">Promo visual / Acceso rápido</button>
          </div>

          <div class="stats-grid hidden" aria-hidden="true">
            <article class="stat-card"><p class="stat-label">Productos destacados</p><p id="stat-featured-old" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Promos visuales</p><p id="stat-promos-old" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Accesos rápidos</p><p id="stat-shortcuts-old" class="stat-value">0</p></article>
          </div>

          <section id="marketing-bar-panel" class="marketing-bar-screen hidden">
            <div class="marketing-featured-summary-grid marketing-bar-summary-grid" data-marketing-bar-active-only>
              <article class="marketing-featured-summary-card marketing-bar-summary-card">
                <span class="marketing-summary-icon green" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm5 7.4-6.2 6.2L7 11.8l1.4-1.4 2.4 2.4 4.8-4.8L17 9.4Z"/></svg>
                </span>
                <div>
                  <p class="marketing-summary-label">Estado</p>
                  <p id="marketing-bar-summary-status" class="marketing-summary-value is-inactive">Inactivo</p>
                  <p id="marketing-bar-summary-status-help" class="marketing-summary-help">El cintillo no está visible</p>
                </div>
              </article>

              <article class="marketing-featured-summary-card marketing-bar-summary-card">
                <span class="marketing-summary-icon blue" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M20 10.5V6a2 2 0 0 0-2-2h-4.5a2 2 0 0 0-1.4.6L4.6 12.1a2 2 0 0 0 0 2.8l4.5 4.5a2 2 0 0 0 2.8 0l7.5-7.5a2 2 0 0 0 .6-1.4ZM16.5 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"/></svg>
                </span>
                <div>
                  <p class="marketing-summary-label">Ofertas activas</p>
                  <p id="marketing-bar-summary-offers" class="marketing-summary-value">0 de 3</p>
                  <p id="marketing-bar-summary-offers-help" class="marketing-summary-help">Puedes agregar 3 ofertas</p>
                </div>
              </article>

              <article class="marketing-featured-summary-card marketing-bar-summary-card">
                <span class="marketing-summary-icon purple" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M4 5h16v11H4V5Zm2 2v7h12V7H6Zm4 11h4v2h4v2H6v-2h4v-2Z"/></svg>
                </span>
                <div>
                  <p class="marketing-summary-label">Presentación</p>
                  <p id="marketing-bar-summary-presentation" class="marketing-summary-value purple">Carrusel</p>
                  <p id="marketing-bar-summary-theme" class="marketing-summary-help">Estilo: Azul</p>
                </div>
              </article>
            </div>

            <form id="marketing-bar-form" class="marketing-featured-panel marketing-bar-panel">
              <div class="marketing-bar-panel-head">
                <div class="marketing-featured-summary-main">
                  <span class="marketing-featured-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M3 10v4h4l9 5V5l-9 5H3Zm16.5 2a5.5 5.5 0 0 0-2.5-4.6v9.2a5.5 5.5 0 0 0 2.5-4.6Z"/></svg>
                  </span>
                  <div class="marketing-featured-copy">
                    <h2>Cintillo promocional</h2>
                    <p>Mensajes cortos que aparecen arriba en la tienda pública.</p>
                  </div>
                </div>

                <div class="marketing-bar-panel-actions">
                  <button id="marketing-bar-readme-btn" class="pz-admin-btn pz-admin-btn--readme pz-admin-btn--full-mobile" type="button">
                    <span class="pz-admin-btn__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24"><path d="M5 4h10a3 3 0 0 1 3 3v13H8a3 3 0 0 0-3-3V4Zm2 2v9.2c.3-.1.7-.2 1-.2h8V7a1 1 0 0 0-1-1H7Zm12 0h1a1 1 0 0 1 1 1v13h-1V6Z"/></svg>
                    </span>
                    <span class="pz-admin-btn__label">Léeme</span>
                  </button>
                </div>
              </div>

              <div id="marketing-bar-alert" class="alert alert-info hidden"></div>

              <section class="marketing-bar-section marketing-bar-status-section">
                <div class="marketing-bar-section-label">
                  <span class="marketing-bar-section-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"/></svg>
                  </span>
                  <div>
                    <h3>Estado del cintillo</h3>
                    <p>Activa o desactiva la visualización del cintillo en tu tienda pública.</p>
                  </div>
                </div>

                <label class="marketing-bar-switch">
                  <span>Activar cintillo</span>
                  <input id="marketing-bar-active" type="checkbox" />
                  <strong aria-hidden="true"></strong>
                </label>
              </section>

              <section class="marketing-bar-section" data-marketing-bar-active-only>
                <div class="marketing-bar-section-label">
                  <span class="marketing-bar-section-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M12 5c5.5 0 9.5 5 10 7-.5 2-4.5 7-10 7S2.5 14 2 12c.5-2 4.5-7 10-7Zm0 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"/></svg>
                  </span>
                  <div>
                    <h3>Vista previa pública</h3>
                    <p>Así se verá tu cintillo en la tienda pública.</p>
                  </div>
                </div>

                <div id="marketing-bar-preview" class="marketing-bar-preview theme-blue">
                  <button class="marketing-bar-preview-arrow" type="button" aria-label="Oferta anterior" disabled>‹</button>

                  <div class="marketing-bar-premium-banner">
                    <div class="marketing-bar-premium-decor decor-one"></div>
                    <div class="marketing-bar-premium-decor decor-two"></div>
                    <div class="marketing-bar-premium-lines"></div>

                    <span class="marketing-bar-premium-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24"><path d="M20 10.5V6a2 2 0 0 0-2-2h-4.5a2 2 0 0 0-1.4.6L4.6 12.1a2 2 0 0 0 0 2.8l4.5 4.5a2 2 0 0 0 2.8 0l7.5-7.5a2 2 0 0 0 .6-1.4ZM16.5 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"/></svg>
                    </span>

                    <div class="marketing-bar-premium-copy">
                      <span class="marketing-bar-premium-kicker">Oferta destacada</span>
                      <strong id="marketing-bar-preview-text">Agrega una oferta para ver la vista previa</strong>
                      <p id="marketing-bar-preview-subtext">Promoción disponible por tiempo limitado</p>
                    </div>

                    <span id="marketing-bar-preview-button" class="marketing-bar-premium-button">
                      Ver oferta
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 5 20 12l-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6L13 5Z"/></svg>
                    </span>
                  </div>

                  <button class="marketing-bar-preview-arrow" type="button" aria-label="Oferta siguiente" disabled>›</button>
                </div>

                <div id="marketing-bar-preview-dots" class="marketing-bar-preview-dots" aria-hidden="true"></div>
              </section>

              <section class="marketing-bar-section" data-marketing-bar-active-only>
                <div class="marketing-bar-section-label">
                  <span class="marketing-bar-section-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a7.5 7.5 0 0 0-2.6-1.5L14 2h-4l-.4 2.5A7.5 7.5 0 0 0 7 6L4.6 5l-2 3.5 2 1.5c-.1.5-.1 1-.1 1.5s0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a7.5 7.5 0 0 0 2.6 1.5L10 22h4l.4-2.5A7.5 7.5 0 0 0 17 18l2.4 1 2-3.5-2-1.5ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z"/></svg>
                  </span>
                  <div>
                    <h3>Configuración</h3>
                    <p>Personaliza el estilo y movimiento del cintillo.</p>
                  </div>
                </div>

                <div class="marketing-bar-config-grid">
                  <div class="field">
                    <label for="marketing-bar-theme">Estilo / color</label>
                    <select id="marketing-bar-theme">
                      <option value="black">Negro premium</option>
                      <option value="gold">Dorado premium</option>
                      <option value="green">Verde premium</option>
                      <option value="red">Rojo premium</option>
                      <option value="blue">Azul premium</option>
                    </select>
                  </div>

                  <div class="field">
                    <label for="marketing-bar-motion">Movimiento</label>
                    <select id="marketing-bar-motion">
                      <option value="carousel">Carrusel por oferta</option>
                      <option value="marquee">Cinta continua</option>
                    </select>
                  </div>
                </div>
              </section>

              <section class="marketing-bar-section" data-marketing-bar-active-only>
                <div class="marketing-bar-section-head">
                  <div class="marketing-bar-section-label">
                    <span class="marketing-bar-section-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24"><path d="M4 6h4v4H4V6Zm6 0h10v4H10V6ZM4 14h4v4H4v-4Zm6 0h10v4H10v-4Z"/></svg>
                    </span>
                    <div>
                      <h3>Ofertas del cintillo <span>(máximo 3)</span></h3>
                      <p>Administra y ordena las ofertas que se mostrarán en tu cintillo promocional.</p>
                    </div>
                  </div>

                  <div class="marketing-bar-offers-actions">
                    <p id="marketing-bar-available-hint" class="marketing-bar-available-hint">Puedes agregar 3 ofertas</p>

                    <button id="marketing-add-offer-btn" class="pz-admin-btn pz-admin-btn--primary pz-admin-btn--full-mobile" type="button">
                      <span class="pz-admin-btn__icon" aria-hidden="true">+</span>
                      <span class="pz-admin-btn__label">Agregar oferta</span>
                    </button>
                  </div>
                </div>

                <div id="marketing-offers-list" class="marketing-offers-list"></div>

                <div class="marketing-bar-hidden-fields" aria-hidden="true">
                  {[1, 2, 3].map((index) => (
                    <fieldset>
                      <input id={`marketing-bar-item-${index}-active`} type="checkbox" tabindex="-1" />
                      <textarea id={`marketing-bar-item-${index}-text`} tabindex="-1"></textarea>
                      <input id={`marketing-bar-item-${index}-button-text`} type="text" tabindex="-1" />
                      <input id={`marketing-bar-item-${index}-url`} type="text" tabindex="-1" />
                    </fieldset>
                  ))}
                </div>
              </section>

              <div class="editor-actions marketing-bar-save-row" data-marketing-bar-active-only>
                <button id="marketing-bar-save-btn" class="pz-admin-btn pz-admin-btn--primary pz-admin-btn--wide" type="submit">
                  <span class="pz-admin-btn__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M5 3h12l2 2v16H5V3Zm2 2v5h9V5H7Zm0 14h10v-7H7v7Z"/></svg>
                  </span>
                  <span class="pz-admin-btn__label">Guardar cambios</span>
                </button>
              </div>
            </form>

            <div id="marketing-bar-readme-modal" class="marketing-modal hidden" aria-hidden="true">
              <div class="marketing-modal-card">
                <div class="marketing-modal-head">
                  <div>
                    <h3 class="marketing-modal-title">Cintillo promocional</h3>
                    <p class="marketing-modal-subtitle">Usa el cintillo para mostrar mensajes cortos en la parte superior de la tienda.</p>
                  </div>
                  <button id="marketing-bar-readme-close-btn" class="marketing-modal-close" type="button" aria-label="Cerrar">&times;</button>
                </div>

                <div class="marketing-readme-body">
                  <p><strong>Máximo 3 ofertas.</strong> Puedes activar o desactivar cada mensaje de forma independiente.</p>
                  <p><strong>Vista pública.</strong> El cliente verá estos mensajes en la parte superior de la tienda.</p>
                  <p><strong>Enlaces.</strong> Puedes enviar al cliente a un producto, categoría, subcategoría o enlace externo.</p>
                </div>
              </div>
            </div>
          </section>

          <div id="marketing-offer-modal" class="marketing-modal hidden" aria-hidden="true">
            <form id="marketing-offer-form" class="marketing-modal-card marketing-offer-modal-card">
              <div class="marketing-modal-head">
                <div>
                  <h3 id="marketing-offer-modal-title" class="marketing-modal-title">Oferta del cintillo</h3>
                  <p class="marketing-modal-subtitle">Edita el texto, botón y enlace que verá el cliente.</p>
                </div>
                <button id="marketing-offer-close-btn" class="marketing-modal-close" type="button" aria-label="Cerrar">&times;</button>
              </div>

              <input id="marketing-offer-index" type="hidden" />

              <div class="marketing-offer-form-section">
                <div class="marketing-offer-form-section-title">
                  <span class="marketing-offer-form-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M20 10.5V6a2 2 0 0 0-2-2h-4.5a2 2 0 0 0-1.4.6L4.6 12.1a2 2 0 0 0 0 2.8l4.5 4.5a2 2 0 0 0 2.8 0l7.5-7.5a2 2 0 0 0 .6-1.4ZM16.5 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"/></svg>
                  </span>
                  <strong>Oferta</strong>
                </div>

                <div class="visual-form-grid">
                  <div class="field full">
                    <label class="marketing-bar-switch marketing-bar-switch-inline">
                      <span>Activa</span>
                      <input id="marketing-offer-active" type="checkbox" />
                      <strong aria-hidden="true"></strong>
                    </label>
                  </div>

                  <div class="field full">
                    <label for="marketing-offer-text">Texto de la oferta</label>
                    <textarea id="marketing-offer-text" placeholder="Ej: Oferta de Creatinas esta semana"></textarea>
                  </div>

                  <div class="field">
                    <label for="marketing-offer-button-text">Texto del botón</label>
                    <input id="marketing-offer-button-text" type="text" placeholder="Ej: Ver oferta" />
                  </div>

                  <div class="field">
                    <label for="marketing-offer-url">Enlace</label>
                    <input id="marketing-offer-url" type="text" placeholder="https://... o /categoria/creatinas" />
                  </div>
                </div>
              </div>

              <div class="editor-actions">
                <button id="marketing-offer-cancel-btn" class="pz-admin-btn pz-admin-btn--secondary" type="button">
                  <span class="pz-admin-btn__label">Cancelar</span>
                </button>

                <button class="pz-admin-btn pz-admin-btn--primary" type="submit">
                  <span class="pz-admin-btn__label">Guardar oferta</span>
                </button>
              </div>
            </form>
          </div>

          <section id="tab-generales" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Ajustes generales públicos</h2>
                <p class="section-subtitle">Edita los datos principales que verá el cliente en la tienda pública.</p>
              </div>
              <button id="settings-refresh-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <div class="settings-preview">
              <div id="settings-logo-preview" class="settings-logo-box">Logo / icono</div>
              <div id="settings-cover-preview" class="settings-cover-box">Foto de portada / banner</div>
            </div>
            <form id="settings-form" class="visual-form-grid">
              <div class="field"><label for="settings-store-name">Nombre público de la tienda</label><input id="settings-store-name" type="text" placeholder="Ej: PowerZona" required /></div>
              <div class="field"><label for="settings-whatsapp-number">WhatsApp principal</label><input id="settings-whatsapp-number" type="text" placeholder="Ej: +53 5 000 0000" required /></div>
              <div class="field"><label for="settings-logo-image">Icono o logo del negocio</label><input id="settings-logo-image" type="file" accept="image/*" /><p class="form-help">Recomendado: imagen cuadrada, mínimo 512 x 512 px.</p><p id="settings-current-logo" class="settings-current-file"></p></div>
              <div class="field"><label for="settings-cover-image">Foto de portada / banner</label><input id="settings-cover-image" type="file" accept="image/*" /><p class="form-help">Recomendado: imagen horizontal 16:9, mínimo 1600 x 900 px.</p><p id="settings-current-cover" class="settings-current-file"></p></div>
              <div class="field full"><label for="settings-welcome-text">Texto corto de bienvenida</label><textarea id="settings-welcome-text" placeholder="Ej: Suplementos, vitaminas y ofertas seleccionadas para ti."></textarea></div>
              <div class="field"><label for="settings-address">Dirección</label><textarea id="settings-address" placeholder="Dirección pública de la tienda"></textarea></div>
              <div class="field"><label for="settings-business-hours">Horarios</label><textarea id="settings-business-hours" placeholder="Ej: Lunes a sábado · 9:00 AM - 6:00 PM"></textarea></div>
              <div class="field full"><label for="settings-public-services-text">Servicios</label><textarea id="settings-public-services-text" placeholder="Ej: Envíos, recogida, asesoría por WhatsApp..."></textarea></div>
              <div class="field full"><label for="settings-reviews-text">Reseña / texto de confianza</label><textarea id="settings-reviews-text" placeholder="Ej: Gracias por elegir PowerZona. Atención personalizada y productos seleccionados."></textarea></div>
              <div id="settings-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full"><button class="submit-btn" type="submit">Guardar ajustes generales</button></div>
