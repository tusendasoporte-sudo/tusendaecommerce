        });
        marketingBarForm && marketingBarForm.addEventListener('change', () => {
          updateMarketingBarVisualState();
          updateMarketingBarFormState();
        });
        marketingBarForm && marketingBarForm.addEventListener('submit', (event) => saveMarketingBar(event).catch(() => showMarketingBar('No se pudo guardar el cintillo', 'error')));
        if (token()) loadSettings().catch(() => {});
      })();
    </script>


    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      // PZ-AJUSTES-MONEDAS-CLIENT-V1-20260604
      (() => {
        const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
        const list = document.getElementById('currency-list');
        const alertBox = document.getElementById('currency-alert');
        const refreshBtn = document.getElementById('currency-refresh-btn');
        const createForm = document.getElementById('currency-create-form');
        const codeInput = document.getElementById('currency-code');
        const nameInput = document.getElementById('currency-name');
        const symbolInput = document.getElementById('currency-symbol');
        const rateInput = document.getElementById('currency-rate');
        let currencies = [];
        let settingsRecord = null;
        function token() { return ADMIN_AUTH_TOKEN; }
        function show(message = '', type = 'info') {
          if (!alertBox) return;
          if (!message) { alertBox.className = 'alert alert-info hidden'; alertBox.textContent = ''; return; }
          alertBox.className = 'alert alert-' + type;
          alertBox.textContent = message;
        }
        async function api(path, options = {}) {
          const headers = Object.assign({}, options.headers || {});
          if (token()) headers.Authorization = 'Bearer ' + token();
          const response = await fetch(POCKETBASE_URL + path, Object.assign({}, options, { headers }));
          const result = await response.json().catch(() => null);
          if (!response.ok) throw new Error((result && result.message) || 'Error de comunicación con PocketBase.');
          return result;
        }
        function escapeHtml(value) {
          return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
        }
        function currencyDefaultId() {
          const value = settingsRecord?.default_currency;
          return Array.isArray(value) ? value[0] : value || '';
        }
        async function loadCurrencies() {
          if (!token()) return;
          const [currencyResult, settingsResult] = await Promise.all([
            api('/api/collections/currencies/records?sort=code&perPage=100'),
            api('/api/collections/settings/records?filter=' + encodeURIComponent(ACTIVE_STORE_FILTER) + '&sort=-updated&page=1&perPage=1'),
          ]);
          currencies = currencyResult.items || [];
          settingsRecord = (settingsResult.items || [])[0] || null;
          renderCurrencies();
        }
        function renderCurrencies() {
          if (!list) return;
          const defaultId = currencyDefaultId();
          if (!currencies.length) {
            list.innerHTML = '<p class="form-help">No hay monedas creadas. Agrega USD y CUP para comenzar.</p>';
            return;
          }
          list.innerHTML = currencies.map((currency) => `
            <div data-currency-id="${currency.id}" style="display:grid; grid-template-columns: 1fr 1fr 1fr auto; gap:10px; align-items:end; padding:12px; border:1px solid #e2e8f0; border-radius:18px; background:#fff;">
              <div class="field"><label>${escapeHtml(currency.code || '')}</label><input class="js-currency-name" type="text" value="${escapeHtml(currency.name || '')}" /></div>
              <div class="field"><label>Símbolo</label><input class="js-currency-symbol" type="text" value="${escapeHtml(currency.symbol || '')}" /></div>
              <div class="field"><label>Tasa</label><input class="js-currency-rate" type="number" min="0" step="0.01" value="${Number(currency.exchange_rate || 0)}" ${String(currency.code || '').toUpperCase() === 'USD' ? 'readonly' : ''} /></div>
              <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; justify-content:flex-end;">
                <label style="font-size:12px; font-weight:950; color:#334155;"><input class="js-currency-active" type="checkbox" ${currency.active !== false ? 'checked' : ''} /> Activa</label>
                <label style="font-size:12px; font-weight:950; color:#334155;"><input class="js-currency-default" name="currency-default" type="radio" ${currency.id === defaultId ? 'checked' : ''} /> Default</label>
                <button class="mini-btn primary js-currency-save" type="button">Guardar</button>
              </div>
            </div>
          `).join('');
        }
        async function saveCurrency(row) {
          const id = row?.dataset?.currencyId;
          const currency = currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          const code = String(currency.code || '').toUpperCase();
          const data = {
            name: row.querySelector('.js-currency-name')?.value?.trim() || code,
            symbol: row.querySelector('.js-currency-symbol')?.value?.trim() || code,
            exchange_rate: code === 'USD' ? 1 : Math.max(0, Number(row.querySelector('.js-currency-rate')?.value || 0)),
            active: row.querySelector('.js-currency-active')?.checked === true,
            is_default: row.querySelector('.js-currency-default')?.checked === true,
          };
          await api('/api/collections/currencies/records/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (data.is_default && settingsRecord?.id) {
            await api('/api/collections/settings/records/' + settingsRecord.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ default_currency: id }),
            });
          }
          show('Moneda guardada correctamente.', 'success');
          await loadCurrencies();
        }
        async function createCurrency(event) {
          event.preventDefault();
          const code = String(codeInput?.value || '').trim().toUpperCase();
          if (!code) return show('Escribe el código de la moneda.', 'error');
          const payload = {
            code,
            name: nameInput?.value?.trim() || code,
            symbol: symbolInput?.value?.trim() || code,
            exchange_rate: code === 'USD' ? 1 : Math.max(0, Number(rateInput?.value || 0)),
            active: true,
            is_default: false,
          };
          await api('/api/collections/currencies/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          createForm?.reset();
          show('Moneda agregada correctamente.', 'success');
          await loadCurrencies();
        }
        list?.addEventListener('click', (event) => {
          const btn = event.target.closest('.js-currency-save');
          if (!btn) return;
          const row = btn.closest('[data-currency-id]');
          saveCurrency(row).catch((error) => show(error.message || 'No se pudo guardar la moneda.', 'error'));
        });
        refreshBtn?.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error')));
        createForm?.addEventListener('submit', (event) => createCurrency(event).catch((error) => show(error.message || 'No se pudo crear la moneda.', 'error')));
        document.querySelector('[data-tab="monedas"]')?.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error')));
        if (token()) loadCurrencies().catch(() => {});
      })();
    </script>

  </body>
</html>
