          discount_value: type === 'buy_x_pay_y' ? 0 : Number(promotionDiscountValue.value || 0),
          buy_qty: Number(promotionBuyQty.value || 0),
          pay_qty: Number(promotionPayQty.value || 0),
          min_qty: Number(promotionMinQty.value || 0),
          min_subtotal_usd: Number(promotionMinSubtotal.value || 0),
          product: ['product_discount', 'volume_discount', 'buy_x_pay_y'].includes(type) ? promotionProduct.value : '',
          category: ['category_discount', 'subcategory_discount'].includes(type) ? promotionCategory.value : '',
          subcategory: type === 'subcategory_discount' ? promotionSubcategory.value : '',
          starts_at: promotionStarts.value || '',
          ends_at: promotionEnds.value || '',
          badge_text: promotionBadge.value.trim(),
          priority: Number(promotionPriority.value || 0),
          stackable: false,
        };
        const error = validatePromotionPayload(payload);
        if (error) return showAlert(promotionAlert, error, 'error');
        const id = promotionId.value;
        await apiRequest(`/api/collections/automatic_promotions/records${id ? `/${id}` : ''}`, { method: id ? 'PATCH' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
