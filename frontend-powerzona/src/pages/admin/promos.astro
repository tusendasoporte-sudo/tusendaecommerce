      function validatePromotionPayload(payload) {
        if (!payload.name) return 'Escribe el nombre de la promoción.';
        if (payload.ends_at && payload.starts_at && promotionDateTime(payload.ends_at, 'end') < promotionDateTime(payload.starts_at, 'start')) return 'La fecha fin no puede ser menor que la fecha inicio.';
        if (payload.type === 'buy_x_pay_y') {
          if (!(Number(payload.buy_qty) > Number(payload.pay_qty))) return 'Compra cantidad debe ser mayor que paga cantidad.';
          if (!(Number(payload.pay_qty) > 0)) return 'Paga cantidad debe ser mayor que 0.';
          if (!payload.product) return 'Selecciona el producto para esta promoción.';
          return '';
        }
        if (payload.discount_type === 'percentage' && (Number(payload.discount_value) < 1 || Number(payload.discount_value) > 100)) return 'El porcentaje debe estar entre 1 y 100.';
        if (payload.discount_type === 'fixed_usd' && !(Number(payload.discount_value) > 0)) return 'El valor fijo USD debe ser mayor que 0.';
        if (payload.type === 'volume_discount' && !(Number(payload.min_qty) > 0)) return 'Define la cantidad mínima.';
        if (payload.type === 'product_discount' && !payload.product) return 'Selecciona el producto.';
        if (payload.type === 'category_discount' && !payload.category) return 'Selecciona la categoría.';
        if (payload.type === 'subcategory_discount' && !payload.subcategory) return 'Selecciona la subcategoría.';
        if (payload.type === 'cart_subtotal_discount' && !(Number(payload.min_subtotal_usd) > 0)) return 'Define el subtotal mínimo USD.';
        return '';
      }
