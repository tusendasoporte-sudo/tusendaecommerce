          line-height: 1.5 !important;
          font-weight: 850 !important;
        }
      }</style>
      <style is:global>
      /* PZ-MARKETING-MOBILE-TOPBAR-SAFE-OFFSET-20260620
         Corrige que la barra superior fija global tape el breadcrumb/descripcion
         en todas las secciones de Marketing y Visual. */

      @media (max-width: 1023px) {
        body .app-shell.pz-admin-content {
