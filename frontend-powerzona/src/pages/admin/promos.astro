<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Marketing | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --green: #16a34a;
        --blue: #2563eb;
        --red: #dc2626;
        --orange: #f97316;
        --purple: #7c3aed;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.16), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, 0.10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }
      a { color: inherit; text-decoration: none; }
      button, input, select, textarea { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .65; }
      .hidden { display: none !important; }

      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; display: block; }
      .sidebar-overlay { position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .36); opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(2px); }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar { position: fixed; top: 18px; left: 18px; bottom: 18px; z-index: 90; width: min(286px, calc(100vw - 36px)); border-radius: 30px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); color: #0f172a; border: 1px solid rgba(226, 232, 240, .95); box-shadow: 0 28px 80px rgba(15, 23, 42, .22); overflow: hidden; transform: translateX(calc(-100% - 28px)); transition: transform .24s ease; }
      body.sidebar-open .sidebar { transform: translateX(0); }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; background: #0f172a; color: #fff; box-shadow: 0 14px 30px rgba(15, 23, 42, .18); font-weight: 1000; }
      .brand-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; }
      .brand-subtitle { margin: 2px 0 0; color: #64748b; font-size: 11px; font-weight: 850; }
      .sidebar-label { margin: 18px 9px 9px; color: #64748b; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .nav-list { display: grid; gap: 8px; }
      .nav-item { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: 18px; color: #334155; font-size: 13px; font-weight: 950; border: 1px solid transparent; }
      .nav-item:hover { background: #f1f5f9; border-color: #e2e8f0; color: #0f172a; }
      .nav-item.active { background: #0f172a; border-color: #0f172a; color: #fff; box-shadow: 0 12px 26px rgba(15,23,42,.16); }
      .nav-icon { width: 34px; height: 34px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; background: #f8fafc; color: #0f172a; border: 1px solid #e2e8f0; flex: 0 0 auto; }
      .nav-icon svg { width: 18px; height: 18px; display: block; fill: currentColor; }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.20); }
      .sidebar-footer { margin-top: auto; padding: 14px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .sidebar-footer strong { display: block; font-size: 12px; margin-bottom: 5px; color: #0f172a; }
      .sidebar-footer span { display: block; color: #475569; font-size: 11px; line-height: 1.45; font-weight: 750; }
      .sidebar-close { margin-left: auto; width: 36px; height: 36px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-weight: 1000; box-shadow: 0 8px 18px rgba(15,23,42,.05); }
      .menu-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; border-radius: 18px; padding: 12px 15px; background: #0f172a; color: #fff; border: 1px solid #0f172a; box-shadow: 0 12px 26px rgba(15,23,42,.16); font-weight: 1000; }

      .main-wrap { min-width: 0; padding: 2px 0 28px; }
      .topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; flex-wrap: wrap; }
      .action-btn, .mini-btn { display: inline-flex; align-items: center; justify-content: center; gap: 9px; border-radius: 16px; padding: 11px 14px; background: rgba(255,255,255,.92); border: 1px solid rgba(226, 232, 240, 0.95); box-shadow: 0 12px 26px rgba(15,23,42,.07); font-weight: 950; }
      .action-btn.dark, .mini-btn.primary { background: #0f172a; color: #fff; border-color: #0f172a; }
      .action-btn.danger, .mini-btn.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; position: relative; z-index: 1; }
      .hero-card, .panel-card, .list-card { background: rgba(255, 255, 255, 0.92); border: 1px solid rgba(226, 232, 240, 0.96); border-radius: 30px; box-shadow: var(--shadow); backdrop-filter: blur(10px); }
      .hero-card { padding: 26px; margin-bottom: 18px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 18px; align-items: center; position: relative; overflow: hidden; }
      .hero-card::after { content: ''; position: absolute; right: -80px; top: -90px; width: 230px; height: 230px; background: radial-gradient(circle, rgba(37,99,235,.16), transparent 66%); pointer-events: none; }
      .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 8px 12px; background: #dcfce7; color: #166534; font-size: 13px; font-weight: 1000; }
      .page-title { font-size: clamp(25px, 3vw, 40px); font-weight: 1000; letter-spacing: -0.045em; line-height: 1.05; margin: 14px 0 0; }
      .page-title span { color: #334155; font-weight: 800; }
      .page-subtitle { margin: 9px 0 0; font-size: 15px; color: var(--muted); line-height: 1.55; max-width: 820px; }
      .panel-card { padding: 22px; margin-bottom: 18px; }
      .login-card { max-width: 520px; margin: 28px auto; }
      .form-grid, .visual-form-grid { display: grid; gap: 12px; }
      .visual-form-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .visual-form-grid .full { grid-column: 1 / -1; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .04em; }
      .field input, .field select, .field textarea { width: 100%; border: 1px solid var(--border); border-radius: 16px; background: #fff; color: var(--text); padding: 12px 13px; outline: none; font-weight: 800; box-shadow: inset 0 1px 0 rgba(15,23,42,.02); }
      .field textarea { min-height: 96px; resize: vertical; line-height: 1.45; }
      .form-help { margin: 0; color: #64748b; font-size: 12px; font-weight: 750; line-height: 1.45; }
      .submit-btn { border: 0; border-radius: 16px; padding: 12px 16px; background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; font-weight: 1000; box-shadow: 0 14px 28px rgba(15,23,42,.20); }
      .alert { margin-top: 12px; border-radius: 16px; padding: 11px 12px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
      .tabs { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }
      .tab-btn { border: 1px solid #e2e8f0; background: rgba(255,255,255,.92); color: #334155; border-radius: 999px; padding: 11px 14px; font-weight: 1000; box-shadow: 0 12px 26px rgba(15,23,42,.05); }
      .tab-btn.active { background: #0f172a; border-color: #0f172a; color: #fff; }
      .stats-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
      .stat-card { padding: 18px; border-radius: 24px; background: rgba(255,255,255,.92); border: 1px solid rgba(226,232,240,.96); box-shadow: 0 14px 34px rgba(15,23,42,.06); }
      .stat-label { margin: 0; color: var(--muted); font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .05em; }
      .stat-value { margin: 7px 0 0; font-size: 25px; font-weight: 1000; letter-spacing: -.04em; }
      .marketing-summary-card { margin: -2px 0 18px; padding: 18px; border-radius: 26px; background: rgba(255,255,255,.92); border: 1px solid rgba(226,232,240,.96); box-shadow: var(--shadow); backdrop-filter: blur(10px); }
      .marketing-summary-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1px; overflow: hidden; border-radius: 20px; border: 1px solid #e2e8f0; background: #e2e8f0; }
      .marketing-summary-item { display: grid; place-items: center; gap: 6px; min-height: 92px; padding: 16px 10px; background: linear-gradient(180deg, #fff, #f8fafc); text-align: center; }
      .marketing-summary-label { margin: 0; color: #64748b; font-size: 12px; font-weight: 1000; text-transform: uppercase; letter-spacing: .045em; }
      .marketing-summary-value { margin: 0; color: #0f172a; font-size: 30px; line-height: 1; font-weight: 1000; letter-spacing: -.035em; }
      .section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; margin-bottom: 14px; }
      .section-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -.03em; }
      .section-subtitle { margin: 6px 0 0; color: #64748b; font-size: 13px; font-weight: 800; line-height: 1.45; }
      .product-picker { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 12px; align-items: end; }
      .featured-search-results { margin-top: 10px; display: grid; gap: 10px; max-height: 420px; overflow: auto; padding-right: 3px; }
      .featured-result-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 12px; align-items: center; border: 1px solid #e2e8f0; border-radius: 18px; background: #fff; padding: 12px; }
      .featured-result-title { margin: 0; color: #0f172a; font-size: 14px; font-weight: 1000; line-height: 1.25; }
      .featured-result-meta { margin: 5px 0 0; color: #64748b; font-size: 12px; font-weight: 800; line-height: 1.35; }
      .promotion-product-selected { display: none; margin-top: 10px; border: 1px solid #bbf7d0; background: #ecfdf5; color: #166534; border-radius: 16px; padding: 10px 12px; font-size: 12px; font-weight: 950; }
      .promotion-product-selected.show { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
      .promotion-readme-btn { border: 0; background: transparent; color: #2563eb; font-size: 13px; font-weight: 1000; padding: 10px 4px; box-shadow: none; }
      .promotion-guide-list { display: grid; gap: 12px; margin: 0; padding: 0; list-style: none; }
      .promotion-guide-list li { border: 1px solid #e2e8f0; border-radius: 18px; background: #f8fafc; padding: 12px; }
      .promotion-guide-list strong { display: block; color: #0f172a; font-size: 13px; font-weight: 1000; margin-bottom: 4px; }
      .promotion-guide-list p { margin: 0; color: #475569; font-size: 13px; font-weight: 750; line-height: 1.45; }
      .items-list { display: grid; gap: 10px; }
      .item-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 14px; align-items: center; padding: 14px; border: 1px solid #e2e8f0; border-radius: 22px; background: rgba(255,255,255,.88); }
      .item-main { display: flex; align-items: center; gap: 12px; min-width: 0; }
      .thumb { width: 58px; height: 58px; border-radius: 16px; object-fit: contain; flex: 0 0 58px; border: 1px solid #e2e8f0; background: #f1f5f9; box-shadow: 0 8px 18px rgba(15,23,42,.08); }
      .thumb.placeholder { display: inline-flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 22px; font-weight: 1000; }
      .item-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; }
      .item-meta { margin: 5px 0 0; color: #64748b; font-size: 12px; font-weight: 750; word-break: break-word; }
      .item-actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
      .pill { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 8px 10px; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .035em; border: 1px solid transparent; white-space: nowrap; }
      .pill-visible { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .pill-hidden { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .pill-type { background: #eef2ff; color: #3730a3; border-color: #c7d2fe; }
      .empty-state { border: 1px dashed #cbd5e1; background: #f8fafc; border-radius: 22px; padding: 18px; color: #64748b; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .editor-actions { display: flex; justify-content: flex-end; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
      .organization-grid { display: grid; gap: 16px; }
      .organization-card { border: 1px solid #e2e8f0; background: rgba(248,250,252,.86); border-radius: 26px; padding: 16px; }
      .organization-card + .organization-card { margin-top: 16px; }
      .organization-title { margin: 0; font-size: 16px; font-weight: 1000; letter-spacing: -.025em; }
      .organization-help { margin: 5px 0 14px; color: #64748b; font-size: 12px; font-weight: 800; line-height: 1.45; }
      .admin-block-summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .admin-block-summary-main { min-width: 0; }
      .admin-block-summary-actions { display: flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }
      .admin-block-total { display: inline-flex; width: fit-content; margin-top: 10px; border-radius: 999px; padding: 8px 11px; background: #f8fafc; border: 1px solid #e2e8f0; color: #334155; font-size: 12px; font-weight: 1000; }
      .admin-read-panel { margin-top: 16px; display: grid; gap: 14px; }
      .admin-read-list { display: grid; gap: 10px; }
      .order-btn { min-width: 42px; padding-left: 12px; padding-right: 12px; }
      .mini-btn.warning { background: #fff7ed; color: #9a3412; border-color: #fed7aa; }
      .mini-btn.success { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .marketing-offers-head { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 2px; }
      #marketing-bar-form > fieldset.full { display: none !important; }
      .marketing-offers-title { margin: 0; color: #0f172a; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; }
      .marketing-offers-list { grid-column: 1 / -1; display: grid; gap: 10px; overflow: visible; }
      .marketing-offer-row { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 12px; padding: 12px; border: 1px solid #e2e8f0; border-radius: 20px; background: rgba(255,255,255,.92); box-shadow: 0 10px 24px rgba(15,23,42,.05); }
      .marketing-offer-row.menu-open { z-index: 10020; }
      .marketing-offer-title { margin: 0; color: #0f172a; font-size: 14px; font-weight: 1000; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .marketing-offer-link { margin: 4px 0 0; color: #64748b; font-size: 11px; font-weight: 800; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .marketing-switch { display: inline-flex; align-items: center; gap: 8px; color: #334155; font-size: 12px; font-weight: 950; white-space: nowrap; }
      .marketing-switch input { width: 18px; height: 18px; accent-color: #0f172a; }
      .marketing-menu-wrap, .visual-menu-wrap, .promotion-menu-wrap { position: relative; display: inline-flex; justify-content: flex-end; z-index: 2; }
      .marketing-menu-wrap.open, .visual-menu-wrap.open, .promotion-menu-wrap.open { z-index: 10030; }
      .marketing-kebab-btn, .visual-kebab-btn, .promotion-kebab-btn { width: 40px; height: 40px; border-radius: 15px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-size: 22px; font-weight: 1000; line-height: 1; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(15,23,42,.06); }
      .marketing-floating-menu, .visual-floating-menu, .promotion-floating-menu { position: absolute; top: calc(100% + 8px); right: 0; z-index: 10040; min-width: 210px; display: none; gap: 6px; padding: 8px; border-radius: 18px; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 24px 70px rgba(15,23,42,.22); }
      .marketing-menu-wrap.open .marketing-floating-menu, .visual-menu-wrap.open .visual-floating-menu, .promotion-menu-wrap.open .promotion-floating-menu { display: grid; }
      .marketing-floating-menu.drop-up, .visual-floating-menu.drop-up, .promotion-floating-menu.drop-up { top: auto; bottom: calc(100% + 8px); }
      .marketing-floating-menu button, .visual-floating-menu button, .promotion-floating-menu button { width: 100%; border: 0; border-radius: 13px; background: transparent; color: #0f172a; padding: 10px 11px; text-align: left; font-size: 13px; font-weight: 950; }
      .marketing-floating-menu button:hover, .visual-floating-menu button:hover, .promotion-floating-menu button:hover { background: #f8fafc; }
      .marketing-floating-menu button.danger, .visual-floating-menu button.danger, .promotion-floating-menu button.danger { color: #991b1b; }
      .marketing-floating-menu button.danger:hover, .visual-floating-menu button.danger:hover, .promotion-floating-menu button.danger:hover { background: #fee2e2; }
      .marketing-floating-menu button.success, .visual-floating-menu button.success, .promotion-floating-menu button.success { color: #166534; }
      .marketing-floating-menu button.success:hover, .visual-floating-menu button.success:hover, .promotion-floating-menu button.success:hover { background: #dcfce7; }
      .promotion-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
      .promotion-filter-btn { border: 1px solid #e2e8f0; border-radius: 999px; background: #fff; color: #334155; padding: 9px 12px; font-size: 12px; font-weight: 1000; box-shadow: 0 10px 20px rgba(15,23,42,.05); }
      .promotion-filter-btn.active { background: #0f172a; border-color: #0f172a; color: #fff; }
      .promotion-group { border: 1px solid #e2e8f0; border-radius: 22px; background: rgba(248,250,252,.86); overflow: visible; }
      .promotion-group + .promotion-group { margin-top: 10px; }
      .promotion-group-summary { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px; cursor: pointer; color: #0f172a; font-weight: 1000; }
      .promotion-group-summary::-webkit-details-marker { display: none; }
      .promotion-group-summary span { color: #64748b; font-size: 12px; }
      .promotion-group-body { display: grid; gap: 10px; padding: 0 14px 14px; }
      .marketing-modal { position: fixed; inset: 0; z-index: 12000; display: flex; align-items: center; justify-content: center; padding: 18px; background: rgba(15,23,42,.42); backdrop-filter: blur(4px); }
      .marketing-modal.hidden { display: none !important; }
      .marketing-modal-card { width: min(560px, 100%); max-height: calc(100vh - 36px); overflow: auto; background: #fff; border: 1px solid #e2e8f0; border-radius: 28px; box-shadow: 0 32px 90px rgba(15,23,42,.28); padding: 22px; }
      .marketing-modal-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; margin-bottom: 16px; }
      .marketing-modal-title { margin: 0; font-size: 21px; font-weight: 1000; letter-spacing: -.03em; }
      .marketing-modal-subtitle { margin: 5px 0 0; color: #64748b; font-size: 13px; font-weight: 800; line-height: 1.45; }
      .marketing-modal-close { width: 40px; height: 40px; border-radius: 15px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-weight: 1000; }
      @media (max-width: 980px) { .hero-card, .visual-form-grid, .stats-grid, .marketing-summary-grid, .product-picker, .item-row { grid-template-columns: 1fr; } .hero-actions, .action-btn { width: 100%; } .item-actions, .admin-block-summary-actions { justify-content: flex-start; } .admin-block-summary { align-items: flex-start; flex-direction: column; } }
      @media (max-width: 640px) { .app-shell { padding: 14px; } .hero-card, .panel-card, .list-card { border-radius: 24px; } .marketing-offer-row { grid-template-columns: minmax(0, 1fr) auto; } .marketing-switch { grid-column: 1 / -1; order: 3; } .marketing-menu-wrap { justify-content: flex-end; } }


      /* PZ-V25C-SIDEBAR-UNIFICADO-20260605
         Menú lateral único: estilo premium como Resumen, activo sombreado negro, sin flechas. */
      .sidebar-overlay,
      #sidebar-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 80 !important;
        background: rgba(15, 23, 42, .36) !important;
        opacity: 0;
        pointer-events: none;
        transition: opacity .22s ease !important;
        backdrop-filter: blur(3px) !important;
      }
      .sidebar-overlay.show,
      body.sidebar-open .sidebar-overlay,
      body.sidebar-open #sidebar-overlay {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
      .sidebar,
      #admin-sidebar {
        position: fixed !important;
        top: 18px !important;
        left: 18px !important;
        bottom: 18px !important;
        z-index: 90 !important;
        width: min(286px, calc(100vw - 36px)) !important;
        border-radius: 30px !important;
        padding: 18px !important;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%) !important;
        color: #0f172a !important;
        border: 1px solid rgba(226, 232, 240, .95) !important;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.95) !important;
        overflow: hidden auto !important;
        transform: translateX(calc(-100% - 36px)) !important;
        transition: transform .24s ease !important;
      }
      .sidebar.open,
      body.sidebar-open .sidebar,
      body.sidebar-open #admin-sidebar {
        transform: translateX(0) !important;
      }
      .sidebar::before,
      #admin-sidebar::before {
        content: '' !important;
        position: absolute !important;
        inset: 0 !important;
        background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%) !important;
        pointer-events: none !important;
      }
      .sidebar-inner { position: relative !important; z-index: 1 !important; display: flex !important; flex-direction: column !important; min-height: 100% !important; }
      .sidebar-top,
      .brand,
      .sidebar-brand-row {
        display: flex !important;
        align-items: center !important;
        gap: 11px !important;
        padding: 8px 8px 18px !important;
        border-bottom: 1px solid #e2e8f0 !important;
        margin: 0 0 14px !important;
      }
      .sidebar-brand,
      .brand-title,
      .sidebar-title {
        margin: 0 !important;
        font-size: 22px !important;
        font-weight: 1000 !important;
        letter-spacing: -.035em !important;
        color: #0f172a !important;
        line-height: 1.1 !important;
      }
      .sidebar-sub,
      .brand-subtitle,
      .sidebar-subtitle {
        margin: 4px 0 0 !important;
        color: #334155 !important;
        font-size: 12px !important;
        font-weight: 850 !important;
        line-height: 1.2 !important;
      }
      .brand-logo {
        width: 42px !important;
        height: 42px !important;
        border-radius: 16px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        background: linear-gradient(135deg, #0f172a, #020617) !important;
        color: #ffffff !important;
        font-size: 12px !important;
        font-weight: 1000 !important;
        box-shadow: 0 14px 26px rgba(15,23,42,.18) !important;
      }
      .close-btn,
      .sidebar-close,
      #sidebar-close,
      #sidebar-close-btn {
        margin-left: auto !important;
        width: 42px !important;
        height: 42px !important;
        min-width: 42px !important;
        border-radius: 16px !important;
        border: 1px solid #e2e8f0 !important;
        background: #ffffff !important;
        color: #0f172a !important;
        font-size: 18px !important;
        font-weight: 1000 !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        box-shadow: 0 10px 20px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.95) !important;
      }
      .nav-group { margin: 14px 0 !important; }
      .sidebar-label,
      .nav-label {
        margin: 18px 9px 9px !important;
        color: #475569 !important;
        font-size: 10px !important;
        font-weight: 1000 !important;
        text-transform: uppercase !important;
        letter-spacing: .14em !important;
      }
      .nav-list { display: grid !important; gap: 6px !important; }
      .nav-item,
      .nav-link {
        min-height: 50px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: flex-start !important;
        gap: 11px !important;
        width: 100% !important;
        padding: 8px 10px !important;
        border-radius: 16px !important;
        background: transparent !important;
        color: #0f172a !important;
        border: 1px solid transparent !important;
        font-size: 15px !important;
        font-weight: 1000 !important;
        line-height: 1.18 !important;
        text-decoration: none !important;
        box-shadow: none !important;
        transition: transform .16s ease, background .16s ease, box-shadow .16s ease, border-color .16s ease, color .16s ease !important;
      }
      .nav-left { display: inline-flex !important; align-items: center !important; gap: 11px !important; min-width: 0 !important; }
      .nav-item:hover,
      .nav-link:hover {
        transform: translateX(2px) !important;
        background: #f8fafc !important;
        color: #020617 !important;
        border-color: #e2e8f0 !important;
        box-shadow: 0 12px 26px rgba(15,23,42,.07), inset 0 1px 0 rgba(255,255,255,.95) !important;
      }
      .nav-item.active,
      .nav-link.active {
        background: linear-gradient(135deg, #0f172a, #020617) !important;
        color: #ffffff !important;
        border-color: rgba(15,23,42,.95) !important;
        box-shadow: 0 16px 32px rgba(15,23,42,.18), inset 0 1px 0 rgba(255,255,255,.12) !important;
      }
      .nav-icon,
      .premium-icon {
        width: 34px !important;
        height: 34px !important;
        min-width: 34px !important;
        border-radius: 14px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        background: #ffffff !important;
        color: #0f172a !important;
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 9px 18px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.95) !important;
      }
      .nav-icon svg,
      .premium-icon svg { width: 18px !important; height: 18px !important; display: block !important; fill: currentColor !important; }
      .nav-icon svg path,
      .premium-icon svg path { stroke: currentColor; }
      .nav-item.active .nav-icon,
      .nav-link.active .nav-icon,
      .nav-link.active .premium-icon,
      .nav-item:hover .nav-icon,
      .nav-link:hover .nav-icon,
      .nav-link:hover .premium-icon {
        background: rgba(255,255,255,.12) !important;
        color: #ffffff !important;
        border-color: rgba(255,255,255,.20) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.12) !important;
      }
      .nav-item:hover:not(.active) .nav-icon,
      .nav-link:hover:not(.active) .nav-icon,
      .nav-link:hover:not(.active) .premium-icon {
        background: #020617 !important;
        color: #ffffff !important;
        border-color: #020617 !important;
        box-shadow: 0 12px 22px rgba(15,23,42,.20), inset 0 1px 0 rgba(255,255,255,.12) !important;
      }
      .nav-link > span:last-child:not(.nav-left):not(.nav-pill),
      .nav-link > .arrow,
      .nav-item > .arrow,
      .nav-arrow { display: none !important; }
      .nav-pill {
        margin-left: auto !important;
        background: #f1f5f9 !important;
        color: #64748b !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 999px !important;
        padding: 5px 9px !important;
        font-size: 11px !important;
        font-weight: 1000 !important;
      }
      .nav-link.active .nav-pill,
      .nav-item.active .nav-pill { background: rgba(255,255,255,.14) !important; color: #fff !important; border-color: rgba(255,255,255,.25) !important; }
      .sidebar-footer {
        margin-top: auto !important;
        padding: 14px !important;
        border-radius: 22px !important;
        background: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
      }
      .sidebar-footer strong { display: block !important; font-size: 12px !important; margin-bottom: 5px !important; color: #0f172a !important; }
      .sidebar-footer span { display: block !important; color: #475569 !important; font-size: 11px !important; line-height: 1.45 !important; font-weight: 750 !important; }
      @media (max-width: 620px) {
        .sidebar,
        #admin-sidebar { top: 12px !important; left: 12px !important; bottom: 12px !important; width: calc(100vw - 24px) !important; }
      }

      /* V25J: oculta notas internas del menú lateral para clientes finales */
      .sidebar-footer,
      .admin-sidebar-footer,
      .sidebar-note {
        display: none !important;
      }


      .sidebar-plan-meta {
        margin-top: 10px;
        display: grid;
        gap: 4px;
        padding: 9px 10px;
        border-radius: 14px;
        background: rgba(37, 99, 235, .06);
        border: 1px solid rgba(37, 99, 235, .10);
      }
      .sidebar-plan-meta p {
        margin: 0;
        color: #475569;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 800;
      }
      .sidebar-plan-meta strong {
        color: #0f172a;
        font-weight: 1000;
      }
    </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell pz-admin-content">
      <AdminSidebar storeSlug={currentStoreSlug} storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'} activeSection="marketing" />

      <main class="main-wrap pz-admin-content-inner">
        <header class="topbar">
          <button id="sidebar-open" class="menu-btn" type="button" aria-controls="pz-admin-sidebar" aria-expanded="false">☰ Menú</button>
          <div class="hero-actions">
            <a class="action-btn" href={adminProductsPath}>Productos</a>
            <a class="action-btn" href="/">Ver tienda pública</a>
            <button id="logout-btn" class="action-btn danger hidden" type="button">Cerrar sesión</button>
          </div>
        </header>

        <section class="hero-card">
          <div>
            <span class="badge">⚙️ Ajustes de la tienda</span>
            <h1 class="page-title">Crear <span>Producto/Promo</span></h1>
            <p id="admin-subtitle" class="page-subtitle">Gestiona productos destacados, promos visuales y accesos rápidos sin mezclar esta parte con la edición normal del inventario.</p>
          </div>
        </section>

        <section id="marketing-summary-card" class="marketing-summary-card hidden" aria-label="Resumen de marketing">
          <div class="marketing-summary-grid">
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Productos destacados</p>
              <p id="stat-featured" class="marketing-summary-value">0</p>
            </article>
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Promo Visuales</p>
              <p id="stat-promos" class="marketing-summary-value">0</p>
            </article>
            <article class="marketing-summary-item">
              <p class="marketing-summary-label">Accesos Rápidos</p>
              <p id="stat-shortcuts" class="marketing-summary-value">0</p>
            </article>
          </div>
        </section>

        <section id="login-view" class="panel-card login-card hidden">
          <h2 class="page-title" style="font-size: 24px; margin: 0;">Entrar como admin</h2>
          <p class="page-subtitle">Usa el mismo usuario administrador de PocketBase para modificar ajustes de tienda.</p>
          <form id="login-form" class="form-grid" style="margin-top: 18px;">
            <div class="field"><label for="admin-email">Email</label><input id="admin-email" type="email" autocomplete="username" required /></div>
            <div class="field"><label for="admin-password">Contraseña</label><input id="admin-password" type="password" autocomplete="current-password" required /></div>
            <button id="login-btn" class="submit-btn" type="submit">Entrar al panel</button>
            <div id="login-alert" class="alert alert-error hidden"></div>
          </form>
        </section>

        <section id="admin-view" class="hidden">
          <div class="tabs">
            <button class="tab-btn active" data-tab="destacados" type="button">Destacados</button>
            <button class="tab-btn" data-tab="promociones" type="button">Promociones automáticas</button>
            <button class="tab-btn" data-tab="cupones" type="button">Cupón manual</button>
            <button class="tab-btn" data-tab="visuales" type="button">Promo visual / Acceso rápido</button>
          </div>

          <div class="stats-grid hidden" aria-hidden="true">
            <article class="stat-card"><p class="stat-label">Productos destacados</p><p id="stat-featured-old" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Promos visuales</p><p id="stat-promos-old" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Accesos rápidos</p><p id="stat-shortcuts-old" class="stat-value">0</p></article>
          </div>

          <section id="marketing-bar-panel" class="panel-card hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Cintillo promocional</h2>
                <p class="section-subtitle">Configura un mensaje corto para mostrarlo en la tienda pública.</p>
              </div>
            </div>
            <form id="marketing-bar-form" class="visual-form-grid">
              <div class="field full">
                <label style="display:flex;align-items:center;gap:10px;text-transform:none;letter-spacing:0;font-size:13px;">
                  <input id="marketing-bar-active" type="checkbox" style="width:auto;box-shadow:none;" />
                  Activar cintillo
                </label>
              </div>
              <div class="field full" data-marketing-bar-advanced>
                <label for="marketing-bar-theme">Estilo/color del cintillo</label>
                <select id="marketing-bar-theme">
                  <option value="black">Negro</option>
                  <option value="gold">Dorado</option>
                  <option value="green">Verde</option>
                  <option value="red">Rojo</option>
                  <option value="blue">Azul</option>
                </select>
              </div>
              <div class="field full" data-marketing-bar-advanced>
                <label for="marketing-bar-motion">Movimiento del cintillo</label>
                <select id="marketing-bar-motion">
                  <option value="carousel">Carrusel por oferta</option>
                  <option value="marquee">Cinta continua</option>
                </select>
              </div>
              <div class="marketing-offers-head" data-marketing-bar-advanced>
                <h3 class="marketing-offers-title">Ofertas del cintillo</h3>
                <button id="marketing-add-offer-btn" class="mini-btn primary" type="button">Agregar oferta</button>
              </div>
              <div id="marketing-offers-list" class="marketing-offers-list" data-marketing-bar-advanced></div>
              {[1, 2, 3].map((index) => (
                <fieldset class="full" data-marketing-bar-advanced style="display:grid;gap:12px;border:1px solid #e2e8f0;border-radius:22px;padding:14px;background:#f8fafc;">
                  <legend style="padding:0 8px;color:#0f172a;font-size:13px;font-weight:1000;">Oferta {index}</legend>
                  <div class="field">
                    <label style="display:flex;align-items:center;gap:10px;text-transform:none;letter-spacing:0;font-size:13px;">
                      <input id={`marketing-bar-item-${index}-active`} type="checkbox" style="width:auto;box-shadow:none;" />
                      Activa
                    </label>
                  </div>
                  <div class="field"><label for={`marketing-bar-item-${index}-text`}>Texto</label><textarea id={`marketing-bar-item-${index}-text`} placeholder="Ej: Oferta de Creatinas esta semana"></textarea></div>
                  <div class="visual-form-grid">
                    <div class="field"><label for={`marketing-bar-item-${index}-button-text`}>Texto del botón</label><input id={`marketing-bar-item-${index}-button-text`} type="text" placeholder="Ej: Ver" /></div>
                    <div class="field"><label for={`marketing-bar-item-${index}-url`}>Enlace</label><input id={`marketing-bar-item-${index}-url`} type="text" placeholder="https://... o /categoria/creatinas" /></div>
                  </div>
                </fieldset>
              ))}
              <div id="marketing-bar-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full" data-marketing-bar-advanced><button id="marketing-bar-save-btn" class="submit-btn" type="submit">Guardar cambios</button></div>
            </form>
          </section>

          <div id="marketing-offer-modal" class="marketing-modal hidden" aria-hidden="true">
            <form id="marketing-offer-form" class="marketing-modal-card">
              <div class="marketing-modal-head">
                <div>
                  <h3 id="marketing-offer-modal-title" class="marketing-modal-title">Oferta del cintillo</h3>
                  <p class="marketing-modal-subtitle">Edita el texto, botón y enlace que verá el cliente.</p>
                </div>
                <button id="marketing-offer-close-btn" class="marketing-modal-close" type="button" aria-label="Cerrar">×</button>
              </div>
              <input id="marketing-offer-index" type="hidden" />
              <div class="visual-form-grid">
                <div class="field full">
                  <label style="display:flex;align-items:center;gap:10px;text-transform:none;letter-spacing:0;font-size:13px;">
                    <input id="marketing-offer-active" type="checkbox" style="width:auto;box-shadow:none;" />
                    Activa
                  </label>
                </div>
                <div class="field full"><label for="marketing-offer-text">Texto de la oferta</label><textarea id="marketing-offer-text" placeholder="Ej: Oferta de Creatinas esta semana"></textarea></div>
                <div class="field"><label for="marketing-offer-button-text">Texto del botón</label><input id="marketing-offer-button-text" type="text" placeholder="Ej: Ver" /></div>
                <div class="field"><label for="marketing-offer-url">Enlace</label><input id="marketing-offer-url" type="text" placeholder="https://... o /categoria/creatinas" /></div>
              </div>
              <div class="editor-actions">
                <button id="marketing-offer-cancel-btn" class="mini-btn" type="button">Cancelar</button>
                <button class="submit-btn" type="submit">Guardar</button>
              </div>
            </form>
          </div>

          <section id="tab-generales" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Ajustes generales públicos</h2>
                <p class="section-subtitle">Edita los datos principales que verá el cliente en la tienda pública.</p>
              </div>
              <button id="settings-refresh-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <div class="settings-preview">
              <div id="settings-logo-preview" class="settings-logo-box">Logo / icono</div>
              <div id="settings-cover-preview" class="settings-cover-box">Foto de portada / banner</div>
            </div>
            <form id="settings-form" class="visual-form-grid">
              <div class="field"><label for="settings-store-name">Nombre público de la tienda</label><input id="settings-store-name" type="text" placeholder="Ej: PowerZona" required /></div>
              <div class="field"><label for="settings-whatsapp-number">WhatsApp principal</label><input id="settings-whatsapp-number" type="text" placeholder="Ej: +53 5 000 0000" required /></div>
              <div class="field"><label for="settings-logo-image">Icono o logo del negocio</label><input id="settings-logo-image" type="file" accept="image/*" /><p class="form-help">Recomendado: imagen cuadrada, mínimo 512 x 512 px.</p><p id="settings-current-logo" class="settings-current-file"></p></div>
              <div class="field"><label for="settings-cover-image">Foto de portada / banner</label><input id="settings-cover-image" type="file" accept="image/*" /><p class="form-help">Recomendado: imagen horizontal 16:9, mínimo 1600 x 900 px.</p><p id="settings-current-cover" class="settings-current-file"></p></div>
              <div class="field full"><label for="settings-welcome-text">Texto corto de bienvenida</label><textarea id="settings-welcome-text" placeholder="Ej: Suplementos, vitaminas y ofertas seleccionadas para ti."></textarea></div>
              <div class="field"><label for="settings-address">Dirección</label><textarea id="settings-address" placeholder="Dirección pública de la tienda"></textarea></div>
              <div class="field"><label for="settings-business-hours">Horarios</label><textarea id="settings-business-hours" placeholder="Ej: Lunes a sábado · 9:00 AM - 6:00 PM"></textarea></div>
              <div class="field full"><label for="settings-public-services-text">Servicios</label><textarea id="settings-public-services-text" placeholder="Ej: Envíos, recogida, asesoría por WhatsApp..."></textarea></div>
              <div class="field full"><label for="settings-reviews-text">Reseña / texto de confianza</label><textarea id="settings-reviews-text" placeholder="Ej: Gracias por elegir PowerZona. Atención personalizada y productos seleccionados."></textarea></div>
              <div id="settings-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full"><button class="submit-btn" type="submit">Guardar ajustes generales</button></div>
            </form>
          </section>

          <section id="tab-footer" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Footer público</h2>
                <p class="section-subtitle">Agrega la información inferior que saldrá en portada, categoría, subcategoría y producto.</p>
              </div>
            </div>
            <form id="footer-settings-form" class="visual-form-grid">
              <div class="field"><label for="settings-footer-title">Título del footer</label><input id="settings-footer-title" type="text" placeholder="Ej: PowerZona" /></div>
              <div class="field"><label for="settings-footer-contact-text">Texto de contacto</label><textarea id="settings-footer-contact-text" placeholder="Ej: Escríbenos para confirmar disponibilidad, combos o entregas."></textarea></div>
              <div class="field full"><label for="settings-footer-text">Descripción del footer</label><textarea id="settings-footer-text" placeholder="Texto corto para cerrar la tienda pública."></textarea></div>
              <div class="field full"><label for="settings-footer-extra-text">Información extra</label><textarea id="settings-footer-extra-text" placeholder="Ej: Políticas, garantía, nota de confianza o información adicional."></textarea></div>
              <div class="field"><label for="settings-footer-link-1-label">Botón / enlace 1</label><input id="settings-footer-link-1-label" type="text" placeholder="Ej: Grupo de WhatsApp" /></div>
              <div class="field"><label for="settings-footer-link-1-url">URL enlace 1</label><input id="settings-footer-link-1-url" type="url" placeholder="https://..." /></div>
