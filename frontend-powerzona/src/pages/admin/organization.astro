      async function deleteVisualItem(id) {
        if (!id) return;
        const confirmed = await window.adminConfirm({
          title: 'Eliminar elemento visual',
          message: '¿Seguro que deseas eliminar este elemento visual? Esta acción no se puede deshacer.',
          confirmText: 'Eliminar',
          cancelText: 'Cancelar',
          tone: 'danger',
        });
        if (!confirmed) return;
        await apiRequest(`/api/collections/store_visual_items/records/${id}`, { method: 'DELETE' });
        await loadData();
      }
      function showTab(tab) {
        activeTab = tab;
        document.querySelectorAll('.tab-btn').forEach((btn) => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-panel').forEach((panel) => panel.classList.add('hidden'));
        document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      }
      function openSidebar() { document.body.classList.add('sidebar-open'); sidebar?.setAttribute('aria-hidden', 'false'); sidebarOverlay.hidden = false; sidebarOpenBtn?.setAttribute('aria-expanded', 'true'); }
      function closeSidebar() { document.body.classList.remove('sidebar-open'); sidebar?.setAttribute('aria-hidden', 'true'); sidebarOpenBtn?.setAttribute('aria-expanded', 'false'); setTimeout(() => { if (!document.body.classList.contains('sidebar-open')) sidebarOverlay.hidden = true; }, 220); }
      function showAdmin() { loginView.classList.add('hidden'); adminView.classList.remove('hidden'); loadData().catch((error) => showAlert(featuredAlert, error.message || 'No se pudieron cargar los datos.', 'error')); }
      function showLogin() { adminView.classList.add('hidden'); loginView.classList.remove('hidden'); }

      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeSidebar(); });
      markFeaturedBtn?.addEventListener('click', () => markFeatured().catch((error) => showAlert(featuredAlert, error.message || 'No se pudo marcar destacado.', 'error')));
      featuredProductSearch?.addEventListener('input', renderFeaturedProductResults);
      featuredProductResults?.addEventListener('click', (event) => {
        const button = event.target.closest('.js-featured-result-add');
        if (!button || button.disabled) return;
        const productId = button.dataset.productId || '';
        if (featuredProductSelect) featuredProductSelect.value = productId;
        markFeatured(productId).catch((error) => showAlert(featuredAlert, error.message || 'No se pudo marcar destacado.', 'error'));
      });
      refreshBtn?.addEventListener('click', () => loadData());
      refreshOrgBtn?.addEventListener('click', () => loadData());
      openVisualFormBtn?.addEventListener('click', () => openVisualForm());
      visualCancelBtn?.addEventListener('click', closeVisualForm);
      visualActionType?.addEventListener('change', updateActionFields);
      visualForm?.addEventListener('input', (event) => {
        if (event.target?.type === 'file') return;
        updateVisualFormState();
      });
      visualForm?.addEventListener('change', (event) => {
        if (event.target?.type === 'file') return;
        updateVisualFormState();
      });
      visualImage?.addEventListener('change', () => {
        const file = visualImage.files?.[0] || null;
        clearVisualPreviewObjectUrl();
        if (file) {
          if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
            showAlert(visualAlert, 'Solo puedes subir imágenes JPG, PNG o WebP.', 'error');
            visualImage.value = '';
          } else {
            visualPreviewObjectUrl = URL.createObjectURL(file);
            visualImageMarkedForRemoval = false;
          }
        }
        renderVisualImagePreview();
        updateVisualFormState();
      });
      visualAttachment?.addEventListener('change', updateVisualFormState);
      visualForm?.addEventListener('submit', (event) => saveVisualItem(event).catch((error) => {
        isSavingVisual = false;
        updateVisualFormState();
        showAlert(visualAlert, 'No se pudieron guardar los cambios', 'error');
      }));
      document.querySelectorAll('.js-admin-block-edit').forEach((button) => {
        button.addEventListener('click', () => setAdminBlockMode(button.dataset.adminBlock, 'edit'));
      });
      document.querySelectorAll('.js-admin-block-close').forEach((button) => {
        button.addEventListener('click', () => setAdminBlockMode(button.dataset.adminBlock, 'closed'));
      });
      document.querySelectorAll('.tab-btn').forEach((btn) => btn.addEventListener('click', () => showTab(btn.dataset.tab || 'destacados')));
      featuredList?.addEventListener('click', (event) => {
        if (event.target.closest('.js-featured-empty-add')) {
          openFeaturedAddFlow();
          return;
        }
        const btn = event.target.closest('.js-unfeature');
        if (!btn) return;
        const id = btn.closest('[data-product-id]')?.dataset.productId;
        unfeatureProduct(id).catch((error) => showAlert(featuredAlert, error.message || 'No se pudo quitar destacado.', 'error'));
      });
      visualList?.addEventListener('click', (event) => {
        const row = event.target.closest('[data-visual-id]');
        if (!row) return;
        const id = row.dataset.visualId;
        const menuBtn = event.target.closest('.js-visual-menu');
        if (menuBtn) {
          toggleVisualMenu(menuBtn.closest('.visual-menu-wrap'));
          return;
        }
        const moveBtn = event.target.closest('.js-visual-move');
        if (moveBtn) {
          closeVisualMenus();
          swapVisualOrder(id, moveBtn.dataset.direction || 'up', visualAlert).catch((error) => showAlert(visualAlert, error.message || 'No se pudo ordenar elemento visual.', 'error'));
          return;
        }
        if (event.target.closest('.js-visual-edit')) {
          closeVisualMenus();
          const item = visualItems.find((entry) => entry.id === id);
          openVisualForm(item);
          return;
        }
        if (event.target.closest('.js-visual-toggle')) {
          closeVisualMenus();
          toggleVisualActive(id, visualAlert).catch((error) => showAlert(visualAlert, error.message || 'No se pudo cambiar visibilidad.', 'error'));
          return;
        }
        if (event.target.closest('.js-visual-delete')) {
          closeVisualMenus();
          deleteVisualItem(id).catch((error) => showAlert(visualAlert, error.message || 'No se pudo borrar.', 'error'));
        }
      });

      organizationFeaturedList?.addEventListener('click', (event) => {
        if (event.target.closest('.js-featured-empty-add')) {
          openFeaturedAddFlow();
          return;
        }
        const row = event.target.closest('[data-org-product-id]');
        if (!row) return;
        const id = row.dataset.orgProductId;
        const moveBtn = event.target.closest('.js-featured-move');
        if (moveBtn) {
          swapProductFeaturedOrder(id, moveBtn.dataset.direction || 'up').catch((error) => showAlert(organizationAlert, error.message || 'No se pudo ordenar destacado.', 'error'));
          return;
        }
        if (event.target.closest('.js-featured-org-remove')) {
          unfeatureProduct(id).catch((error) => showAlert(organizationAlert, error.message || 'No se pudo quitar destacado.', 'error'));
        }
      });
      document.querySelectorAll('#organization-promos-list').forEach((list) => {
        list.addEventListener('click', (event) => {
          const row = event.target.closest('[data-org-visual-id]');
          if (!row) return;
          const id = row.dataset.orgVisualId;
          const menuBtn = event.target.closest('.js-visual-menu');
          if (menuBtn) {
            toggleVisualMenu(menuBtn.closest('.visual-menu-wrap'));
            return;
          }
          const moveBtn = event.target.closest('.js-visual-move');
          if (moveBtn) {
            closeVisualMenus();
            swapVisualOrder(id, moveBtn.dataset.direction || 'up').catch((error) => showAlert(organizationAlert, error.message || 'No se pudo ordenar elemento visual.', 'error'));
            return;
          }
          if (event.target.closest('.js-visual-toggle')) {
            closeVisualMenus();
            toggleVisualActive(id).catch((error) => showAlert(organizationAlert, error.message || 'No se pudo cambiar visibilidad.', 'error'));
            return;
          }
          if (event.target.closest('.js-visual-delete')) {
            closeVisualMenus();
            deleteVisualItem(id).catch((error) => showAlert(organizationAlert, error.message || 'No se pudo borrar.', 'error'));
            return;
          }
          if (event.target.closest('.js-visual-org-edit')) {
            closeVisualMenus();
            const item = visualItems.find((entry) => entry.id === id);
            openVisualForm(item);
          }
        });
      });
      document.addEventListener('click', (event) => {
        if (!event.target.closest('.visual-menu-wrap')) closeVisualMenus();
      });


      showAdmin();
      showTab('organizacion');
    </script>
    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      (() => {
        const POCKETBASE_URL_PUBLIC_SETTINGS = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
        const form = document.getElementById('settings-form');
        const alertBox = document.getElementById('settings-alert');
        const refreshBtn = document.getElementById('settings-refresh-btn');
        let settingsRecord = null;
        const fields = {
          storeName: document.getElementById('settings-store-name'),
          whatsapp: document.getElementById('settings-whatsapp-number'),
          logo: document.getElementById('settings-logo-image'),
          cover: document.getElementById('settings-cover-image'),
          welcome: document.getElementById('settings-welcome-text'),
          address: document.getElementById('settings-address'),
          hours: document.getElementById('settings-business-hours'),
          services: document.getElementById('settings-public-services-text'),
          reviews: document.getElementById('settings-reviews-text'),
          currentLogo: document.getElementById('settings-current-logo'),
          currentCover: document.getElementById('settings-current-cover'),
          logoPreview: document.getElementById('settings-logo-preview'),
          coverPreview: document.getElementById('settings-cover-preview'),
          footerTitle: document.getElementById('settings-footer-title'),
          footerText: document.getElementById('settings-footer-text'),
          footerContactText: document.getElementById('settings-footer-contact-text'),
          footerExtraText: document.getElementById('settings-footer-extra-text'),
          footerLink1Label: document.getElementById('settings-footer-link-1-label'),
          footerLink1Url: document.getElementById('settings-footer-link-1-url'),
          footerLink2Label: document.getElementById('settings-footer-link-2-label'),
          footerLink2Url: document.getElementById('settings-footer-link-2-url')
        };
        const footerForm = document.getElementById('footer-settings-form');
        const footerAlertBox = document.getElementById('footer-settings-alert');
        const footerRefreshBtn = document.getElementById('footer-settings-refresh-btn');
        function token() { return ADMIN_AUTH_TOKEN; }
        function showMessage(box, message = '', type = 'info') {
          if (!box) return;
          if (!message) { box.className = 'alert alert-info hidden'; box.textContent = ''; return; }
          box.className = 'alert alert-' + type;
          box.textContent = message;
        }
        function show(message = '', type = 'info') { showMessage(alertBox, message, type); }
        function showFooter(message = '', type = 'info') { showMessage(footerAlertBox, message, type); }
        function fileName(name) { const value = settingsRecord && settingsRecord[name]; return Array.isArray(value) ? value[0] : value || ''; }
        function fileUrl(name, thumb) {
          const filename = fileName(name);
          if (!settingsRecord || !settingsRecord.id || !filename) return '';
          return POCKETBASE_URL_PUBLIC_SETTINGS + '/api/files/settings/' + encodeURIComponent(settingsRecord.id) + '/' + encodeURIComponent(filename) + (thumb ? '?thumb=' + encodeURIComponent(thumb) : '');
        }
        async function api(path, options = {}) {
          const headers = Object.assign({}, options.headers || {});
          if (token()) headers.Authorization = 'Bearer ' + token();
          const response = await fetch(POCKETBASE_URL_PUBLIC_SETTINGS + path, Object.assign({}, options, { headers }));
          const result = await response.json().catch(() => null);
          if (!response.ok) throw new Error((result && result.message) || 'Error de comunicación con la plataforma.');
          return result;
        }
        async function loadSettings() {
          const result = await api('/api/collections/settings/records?filter=' + encodeURIComponent(ACTIVE_STORE_FILTER) + '&sort=-updated&page=1&perPage=1');
          settingsRecord = (result.items || [])[0] || null;
          renderSettings();
        }
        function renderImg(container, url, fallback) {
          if (!container) return;
          if (!url) { container.textContent = fallback; return; }
          container.innerHTML = '';
          const img = document.createElement('img');
          img.src = url;
          img.alt = fallback;
          container.appendChild(img);
        }
        function renderSettings() {
          const record = settingsRecord || {};
          fields.storeName.value = record.store_name || record.stored_name || 'PowerZona';
          fields.whatsapp.value = record.whatsapp_number || '';
          fields.welcome.value = record.welcome_text || '';
          fields.address.value = record.address || '';
          fields.hours.value = record.business_hours || '';
          fields.services.value = record.public_services_text || '';
          fields.reviews.value = record.reviews_text || '';
          fields.footerTitle.value = record.footer_title || '';
          fields.footerText.value = record.footer_text || '';
          fields.footerContactText.value = record.footer_contact_text || '';
          fields.footerExtraText.value = record.footer_extra_text || '';
          fields.footerLink1Label.value = record.footer_link_1_label || '';
          fields.footerLink1Url.value = record.footer_link_1_url || '';
          fields.footerLink2Label.value = record.footer_link_2_label || '';
          fields.footerLink2Url.value = record.footer_link_2_url || '';
          fields.currentLogo.textContent = fileName('logo_image') ? 'Logo actual: ' + fileName('logo_image') + '. Si subes otro, se reemplaza.' : '';
          fields.currentCover.textContent = fileName('cover_image') ? 'Portada actual: ' + fileName('cover_image') + '. Si subes otra, se reemplaza.' : '';
          renderImg(fields.logoPreview, fileUrl('logo_image', '160x160'), 'Logo / icono');
          renderImg(fields.coverPreview, fileUrl('cover_image', '700x260'), 'Foto de portada / banner');
        }
        async function save(event) {
          event.preventDefault();
          if (!settingsRecord || !settingsRecord.id) { show('No se encontró el registro activo de ajustes.', 'error'); return; }
          const data = new FormData();
          data.append('store_name', fields.storeName.value.trim() || 'PowerZona');
          data.append('store', CURRENT_STORE_ID);
          data.append('whatsapp_number', fields.whatsapp.value.trim());
          data.append('welcome_text', fields.welcome.value.trim());
          data.append('address', fields.address.value.trim());
          data.append('business_hours', fields.hours.value.trim());
          data.append('public_services_text', fields.services.value.trim());
          data.append('reviews_text', fields.reviews.value.trim());
          if (fields.logo.files && fields.logo.files[0]) data.append('logo_image', fields.logo.files[0]);
          if (fields.cover.files && fields.cover.files[0]) data.append('cover_image', fields.cover.files[0]);
          await api('/api/collections/settings/records/' + settingsRecord.id, { method: 'PATCH', body: data });
          fields.logo.value = '';
          fields.cover.value = '';
          show('Ajustes generales guardados correctamente.', 'success');
          await loadSettings();
        }
        async function saveFooter(event) {
          event.preventDefault();
          if (!settingsRecord || !settingsRecord.id) { showFooter('No se encontró el registro activo de ajustes.', 'error'); return; }
          const data = new FormData();
          data.append('footer_title', fields.footerTitle.value.trim());
          data.append('footer_text', fields.footerText.value.trim());
          data.append('footer_contact_text', fields.footerContactText.value.trim());
          data.append('footer_extra_text', fields.footerExtraText.value.trim());
          data.append('footer_link_1_label', fields.footerLink1Label.value.trim());
          data.append('footer_link_1_url', fields.footerLink1Url.value.trim());
          data.append('footer_link_2_label', fields.footerLink2Label.value.trim());
          data.append('footer_link_2_url', fields.footerLink2Url.value.trim());
          await api('/api/collections/settings/records/' + settingsRecord.id, { method: 'PATCH', body: data });
          showFooter('Footer público guardado correctamente.', 'success');
          await loadSettings();
        }
        form && form.addEventListener('submit', (event) => save(event).catch((error) => show(error.message || 'No se pudo guardar.', 'error')));
        refreshBtn && refreshBtn.addEventListener('click', () => loadSettings().catch((error) => show(error.message || 'No se pudieron cargar los ajustes.', 'error')));
        footerForm && footerForm.addEventListener('submit', (event) => saveFooter(event).catch((error) => showFooter(error.message || 'No se pudo guardar el footer.', 'error')));
        footerRefreshBtn && footerRefreshBtn.addEventListener('click', () => loadSettings().catch((error) => showFooter(error.message || 'No se pudieron cargar los ajustes.', 'error')));
        if (token()) loadSettings().catch(() => {});
      })();
    </script>


    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      (() => {
        const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
        const list = document.getElementById('currency-list');
        const alertBox = document.getElementById('currency-alert');
        const refreshBtn = document.getElementById('currency-refresh-btn');
        const createForm = document.getElementById('currency-create-form');
        const codeInput = document.getElementById('currency-code');
        const nameInput = document.getElementById('currency-name');
        const symbolInput = document.getElementById('currency-symbol');
        const rateInput = document.getElementById('currency-rate');
        let currencies = [];
        let settingsRecord = null;
        function token() { return ADMIN_AUTH_TOKEN; }
        function show(message = '', type = 'info') {
          if (!alertBox) return;
          if (!message) { alertBox.className = 'alert alert-info hidden'; alertBox.textContent = ''; return; }
          alertBox.className = 'alert alert-' + type;
          alertBox.textContent = message;
        }
        async function api(path, options = {}) {
          const headers = Object.assign({}, options.headers || {});
          if (token()) headers.Authorization = 'Bearer ' + token();
          const response = await fetch(POCKETBASE_URL + path, Object.assign({}, options, { headers }));
          const result = await response.json().catch(() => null);
          if (!response.ok) throw new Error((result && result.message) || 'Error de comunicación con la plataforma.');
          return result;
        }
        function escapeHtml(value) {
          return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
        }
        function currencyDefaultId() {
          const value = settingsRecord?.default_currency;
          return Array.isArray(value) ? value[0] : value || '';
        }
        async function loadCurrencies() {
          if (!token()) return;
          const [currencyResult, settingsResult] = await Promise.all([
            api('/api/collections/currencies/records?sort=code&perPage=100'),
            api('/api/collections/settings/records?filter=' + encodeURIComponent(ACTIVE_STORE_FILTER) + '&sort=-updated&page=1&perPage=1'),
          ]);
          currencies = currencyResult.items || [];
          settingsRecord = (settingsResult.items || [])[0] || null;
          renderCurrencies();
        }
        function renderCurrencies() {
          if (!list) return;
          const defaultId = currencyDefaultId();
          if (!currencies.length) {
            list.innerHTML = '<p class="form-help">No hay monedas creadas. Agrega USD y CUP para comenzar.</p>';
            return;
          }
          list.innerHTML = currencies.map((currency) => `
            <div data-currency-id="${currency.id}" style="display:grid; grid-template-columns: 1fr 1fr 1fr auto; gap:10px; align-items:end; padding:12px; border:1px solid #e2e8f0; border-radius:18px; background:#fff;">
              <div class="field"><label>${escapeHtml(currency.code || '')}</label><input class="js-currency-name" type="text" value="${escapeHtml(currency.name || '')}" /></div>
              <div class="field"><label>Símbolo</label><input class="js-currency-symbol" type="text" value="${escapeHtml(currency.symbol || '')}" /></div>
              <div class="field"><label>Tasa</label><input class="js-currency-rate" type="number" min="0" step="0.01" value="${Number(currency.exchange_rate || 0)}" ${String(currency.code || '').toUpperCase() === 'USD' ? 'readonly' : ''} /></div>
              <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; justify-content:flex-end;">
                <label style="font-size:12px; font-weight:950; color:#334155;"><input class="js-currency-active" type="checkbox" ${currency.active !== false ? 'checked' : ''} /> Activa</label>
                <label style="font-size:12px; font-weight:950; color:#334155;"><input class="js-currency-default" name="currency-default" type="radio" ${currency.id === defaultId ? 'checked' : ''} /> Default</label>
                <button class="mini-btn primary js-currency-save" type="button">Guardar</button>
              </div>
            </div>
          `).join('');
        }
        async function saveCurrency(row) {
          const id = row?.dataset?.currencyId;
          const currency = currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          const code = String(currency.code || '').toUpperCase();
          const data = {
            name: row.querySelector('.js-currency-name')?.value?.trim() || code,
            symbol: row.querySelector('.js-currency-symbol')?.value?.trim() || code,
            exchange_rate: code === 'USD' ? 1 : Math.max(0, Number(row.querySelector('.js-currency-rate')?.value || 0)),
            active: row.querySelector('.js-currency-active')?.checked === true,
            is_default: row.querySelector('.js-currency-default')?.checked === true,
          };
          await api('/api/collections/currencies/records/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (data.is_default && settingsRecord?.id) {
            await api('/api/collections/settings/records/' + settingsRecord.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ default_currency: id }),
            });
          }
          show('Moneda guardada correctamente.', 'success');
          await loadCurrencies();
        }
        async function createCurrency(event) {
          event.preventDefault();
          const code = String(codeInput?.value || '').trim().toUpperCase();
          if (!code) return show('Escribe el código de la moneda.', 'error');
          const payload = {
            code,
            name: nameInput?.value?.trim() || code,
            symbol: symbolInput?.value?.trim() || code,
            exchange_rate: code === 'USD' ? 1 : Math.max(0, Number(rateInput?.value || 0)),
            active: true,
            is_default: false,
          };
          await api('/api/collections/currencies/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          createForm?.reset();
          show('Moneda agregada correctamente.', 'success');
          await loadCurrencies();
        }
        list?.addEventListener('click', (event) => {
          const btn = event.target.closest('.js-currency-save');
          if (!btn) return;
          const row = btn.closest('[data-currency-id]');
          saveCurrency(row).catch((error) => show(error.message || 'No se pudo guardar la moneda.', 'error'));
        });
        refreshBtn?.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error')));
        createForm?.addEventListener('submit', (event) => createCurrency(event).catch((error) => show(error.message || 'No se pudo crear la moneda.', 'error')));
        document.querySelector('[data-tab="monedas"]')?.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error')));
        if (token()) loadCurrencies().catch(() => {});
      })();
    </script>

  </body>
