        if (visualImageMarkedForRemoval && currentVisualImageName) formData.append('image-', currentVisualImageName);
        if (imageFile && currentVisualImageName) formData.append('image-', currentVisualImageName);
        if (imageFile) formData.append('image', await optimizeVisualImageFile(imageFile));
        if (attachmentFile) formData.append('attachment', attachmentFile);
        const id = visualId.value;
        try {
          const saved = id
            ? await apiRequest(`/api/collections/store_visual_items/records/${id}`, { method: 'PATCH', body: formData })
            : await apiRequest('/api/collections/store_visual_items/records', { method: 'POST', body: formData });
          await loadData();
          const fresh = visualItems.find((item) => item.id === saved.id) || saved;
          visualId.value = fresh.id || saved.id || '';
          currentVisualImageName = visualImageFileName(fresh);
          currentVisualImageUrl = visualImageUrl(fresh);
