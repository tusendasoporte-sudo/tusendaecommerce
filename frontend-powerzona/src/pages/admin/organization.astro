    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
      let products = [];
      let categories = [];
      let visualItems = [];
      let activeTab = 'organizacion';
      const adminBlockModes = { featured: 'closed', visual: 'closed', orgFeatured: 'closed', orgPromos: 'closed' };
      const visualNoticeTimers = new WeakMap();
      let visualFormSnapshot = '';
      let visualPreviewObjectUrl = '';
      let currentVisualImageUrl = '';
      let currentVisualImageName = '';
      let visualImageMarkedForRemoval = false;
      let currentVisualAttachmentName = '';
      let isSavingVisual = false;

      const sidebar = document.querySelector('[data-admin-sidebar-root]');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const loginView = document.getElementById('login-view');
      const adminView = document.getElementById('admin-view');
      const logoutBtn = document.getElementById('logout-btn');
      const loginForm = document.getElementById('login-form');
      const loginAlert = document.getElementById('login-alert');
      const featuredProductSelect = document.getElementById('featured-product-select');
      const featuredProductSearch = document.getElementById('featured-product-search');
      const featuredProductResults = document.getElementById('featured-product-results');
      const markFeaturedBtn = document.getElementById('mark-featured-btn');
      const featuredList = document.getElementById('featured-list');
      const featuredAlert = document.getElementById('featured-alert');
      const visualForm = document.getElementById('visual-form');
      const visualList = document.getElementById('visual-list');
      const visualAlert = document.getElementById('visual-alert');
      const openVisualFormBtn = document.getElementById('open-visual-form-btn');
      const refreshBtn = document.getElementById('refresh-btn');
      const refreshOrgBtn = document.getElementById('refresh-org-btn');
      const organizationAlert = document.getElementById('organization-alert');
      const organizationFeaturedList = document.getElementById('organization-featured-list');
      const organizationPromosList = document.getElementById('organization-promos-list');
      const visualId = document.getElementById('visual-id');
      const visualType = document.getElementById('visual-type');
      const visualTitle = document.getElementById('visual-title');
      const visualDescription = document.getElementById('visual-description');
      const visualImage = document.getElementById('visual-image');
      const visualCurrentImage = document.getElementById('visual-current-image');
      const visualButtonText = document.getElementById('visual-button-text');
      const visualActionType = document.getElementById('visual-action-type');
      const visualOrder = document.getElementById('visual-order');
      const visualUrl = document.getElementById('visual-url');
      const visualWhatsappMessage = document.getElementById('visual-whatsapp-message');
      const visualCategory = document.getElementById('visual-category');
      const visualAttachment = document.getElementById('visual-attachment');
      const visualCurrentAttachment = document.getElementById('visual-current-attachment');
      const visualActive = document.getElementById('visual-active');
      const visualCancelBtn = document.getElementById('visual-cancel-btn');
      const visualSaveBtn = document.getElementById('visual-save-btn');

      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function setAdminToken(_token) {}
      function clearAdminToken() {}
      function showAlert(el, message = '', type = 'info') {
        if (!el) return;
        window.clearTimeout(visualNoticeTimers.get(el));
        if (!message) { el.className = 'alert alert-info hidden'; el.textContent = ''; return; }
        el.className = `alert alert-${type}`;
        el.textContent = message;
        if (type === 'info') return;
        const timer = window.setTimeout(() => {
          el.className = `alert alert-${type} hidden`;
          el.textContent = '';
          visualNoticeTimers.delete(el);
        }, type === 'error' ? 4600 : 2800);
        visualNoticeTimers.set(el, timer);
      }
      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
      }
      function normalizeSearchText(value) {
        return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      }
      function pocketBaseErrorMessage(result, fallback = 'Error de comunicación con la plataforma.') {
        const base = result?.message || fallback;
        const fieldErrors = result?.data && typeof result.data === 'object'
          ? Object.entries(result.data).map(([field, info]) => {
              const message = info?.message || (Array.isArray(info) ? info.map((item) => item?.message).filter(Boolean).join(', ') : '');
              return message ? `${field}: ${message}` : field;
            }).filter(Boolean)
          : [];
        return fieldErrors.length ? `${base} ${fieldErrors.join(' · ')}` : base;
      }
      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(pocketBaseErrorMessage(result));
        return result;
      }
      function withStoreFilter(params = '') {
        if (!STORE_FILTER) return params;
        const query = new URLSearchParams(params || '');
        const current = query.get('filter');
        query.set('filter', current ? `(${current}) && ${STORE_FILTER}` : STORE_FILTER);
        return query.toString();
      }
      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const scopedParams = withStoreFilter(params);
          const scopedSeparator = scopedParams ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${scopedParams}${scopedSeparator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }
      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }
      function productImageUrl(product) {
        const images = parseProductImageOrder(product);
        const firstImage = images[0] || '';
        if (!product?.id || !firstImage) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }
      function visualImageUrl(item) {
        const image = Array.isArray(item?.image) ? item.image[0] : item?.image;
        if (!item?.id || !image) return '';
        return `${POCKETBASE_URL}/api/files/store_visual_items/${encodeURIComponent(item.id)}/${encodeURIComponent(image)}?thumb=300x200`;
      }
      function visualImageFileName(item) {
        const image = Array.isArray(item?.image) ? item.image[0] : item?.image;
        return image || '';
      }
      function visualAttachmentName(item) {
        const attachment = Array.isArray(item?.attachment) ? item.attachment[0] : item?.attachment;
        return attachment || '';
      }
      function thumbMarkup(url, fallback = '📦') {
        if (!url) return `<span class="thumb placeholder">${fallback}</span>`;
        return `<img class="thumb" src="${url}" alt="" loading="lazy" />`;
      }
      function clearVisualPreviewObjectUrl() {
        if (visualPreviewObjectUrl) URL.revokeObjectURL(visualPreviewObjectUrl);
        visualPreviewObjectUrl = '';
      }
      function renderVisualImagePreview() {
        if (!visualCurrentImage) return;
        const previewUrl = visualPreviewObjectUrl || (!visualImageMarkedForRemoval ? currentVisualImageUrl : '');
        const hasImage = Boolean(previewUrl);
        visualCurrentImage.innerHTML = `
          <div class="visual-image-preview">${hasImage ? `<img src="${escapeHtml(previewUrl)}" alt="Imagen visual" />` : '+'}</div>
          <div class="visual-image-actions">
            <label class="visual-image-action" for="visual-image">${hasImage ? 'Cambiar foto' : 'Subir nueva foto'}</label>
            ${hasImage ? '<button class="visual-image-action danger" type="button" data-visual-image-remove>Borrar</button>' : ''}
          </div>
        `;
        visualCurrentImage.querySelector('[data-visual-image-remove]')?.addEventListener('click', () => {
          clearVisualPreviewObjectUrl();
          visualImage.value = '';
          visualImageMarkedForRemoval = Boolean(currentVisualImageName);
          renderVisualImagePreview();
          updateVisualFormState();
        });
      }
      function createVisualFormSnapshot() {
        const imageFile = visualImage?.files?.[0] || null;
        const attachmentFile = visualAttachment?.files?.[0] || null;
        return JSON.stringify({
          id: visualId?.value || '',
          type: visualType?.value || 'promo_visual',
          title: visualTitle?.value?.trim() || '',
          description: visualDescription?.value?.trim() || '',
          image: visualImageMarkedForRemoval ? '' : currentVisualImageName,
          image_file: imageFile ? `${imageFile.name}:${imageFile.size}:${imageFile.lastModified}` : '',
          image_remove: visualImageMarkedForRemoval,
          button_text: visualButtonText?.value?.trim() || '',
          action_type: visualActionType?.value || 'whatsapp',
          sort_order: Number(visualOrder?.value || 0),
          target_url: visualUrl?.value?.trim() || '',
          whatsapp_message: visualWhatsappMessage?.value?.trim() || '',
          category: visualCategory?.value || '',
          attachment: currentVisualAttachmentName,
          attachment_file: attachmentFile ? `${attachmentFile.name}:${attachmentFile.size}:${attachmentFile.lastModified}` : '',
          active: visualActive?.checked !== false,
        });
      }
      function visualHasMinimumData() {
        if (!visualTitle?.value?.trim()) return false;
        const action = visualActionType?.value || 'whatsapp';
        if (action === 'url' && !visualUrl?.value?.trim()) return false;
        if (action === 'categoria' && !visualCategory?.value) return false;
        if (action === 'archivo' && !currentVisualAttachmentName && !visualAttachment?.files?.[0]) return false;
        return true;
      }
      function visualFormHasChanges() {
        return Boolean(visualFormSnapshot) && createVisualFormSnapshot() !== visualFormSnapshot;
      }
      function setVisualFormSnapshotFromCurrent() {
        visualFormSnapshot = createVisualFormSnapshot();
        updateVisualFormState();
      }
      function updateVisualFormState() {
        if (!visualSaveBtn) return;
        const canSave = visualHasMinimumData() && visualFormHasChanges();
        visualSaveBtn.disabled = isSavingVisual || !canSave;
        visualSaveBtn.textContent = isSavingVisual ? 'Guardando...' : 'Guardar';
      }
      function formatUsd(value) { return `$${Number(value || 0).toFixed(2)} USD`; }
      function readOnlyVisualRow(item) {
        return `
          <article class="item-row">
            <div class="item-main">
              ${thumbMarkup(visualImageUrl(item), '🏷️')}
              <div>
                <p class="item-title">${escapeHtml(item.title || 'Sin título')}</p>
                <p class="item-meta">Promo visual · Orden ${Number(item.sort_order || 0)} · ${item.active !== false ? 'Visible' : 'Oculta'}</p>
              </div>
            </div>
            <div class="item-actions"><span class="pill ${item.active !== false ? 'pill-visible' : 'pill-hidden'}">${item.active !== false ? 'Visible' : 'Oculta'}</span></div>
          </article>
        `;
      }
      function renderStats() {
        document.getElementById('stat-featured').textContent = String(products.filter((p) => p.featured === true).length);
        document.getElementById('stat-promos').textContent = String(visualItems.filter((item) => item.type === 'promo_visual').length);
        document.getElementById('stat-shortcuts').textContent = String(visualItems.filter((item) => item.type === 'acceso_rapido').length);
      }
      function renderProductSelect() {
        const available = products.filter((product) => product.active !== false);
