    <title>Regalos | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page:#eef3f9; --surface:#fff; --soft:#f8fafc; --text:#0f172a; --muted:#64748b; --border:#e2e8f0;
        --dark:#111827; --green:#16a34a; --red:#dc2626; --shadow:0 18px 45px rgba(15,23,42,.08);
      }
      *{box-sizing:border-box} body{margin:0;min-height:100vh;color:var(--text);background:linear-gradient(180deg,#f8fbff,var(--page));} a{text-decoration:none;color:inherit} button,input,textarea{font:inherit} button{cursor:pointer}.hidden{display:none!important}
      .login-wrap{min-height:100vh;display:grid;place-items:center;padding:24px}.login-card,.card{background:#fff;border:1px solid var(--border);border-radius:28px;box-shadow:var(--shadow)}.login-card{width:min(100%,440px);padding:28px}.brand{display:inline-flex;background:#ecfdf5;color:#166534;padding:8px 12px;border-radius:999px;font-weight:1000;font-size:13px}h1{font-size:34px;letter-spacing:-.05em;margin:16px 0 8px}p{color:var(--muted);line-height:1.5}label{display:block;font-size:12px;font-weight:950;color:#334155;margin:0 0 7px}input,textarea{width:100%;border:1px solid var(--border);border-radius:16px;background:var(--soft);padding:12px 13px;outline:none}textarea{resize:vertical;min-height:84px}input:focus,textarea:focus{border-color:#93c5fd;box-shadow:0 0 0 4px rgba(37,99,235,.12)}
      .btn{border:0;border-radius:16px;padding:12px 16px;font-weight:1000;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:transform .16s ease,box-shadow .16s ease,background .16s ease}.btn:hover{transform:translateY(-1px)}.btn-primary{background:var(--dark);color:#fff;box-shadow:0 14px 28px rgba(17,24,39,.14)}.btn-green{background:var(--green);color:#fff;box-shadow:0 14px 28px rgba(22,163,74,.14)}.btn-soft{background:#fff;color:#111827;border:1px solid var(--border);box-shadow:0 10px 22px rgba(15,23,42,.06)}.btn-danger{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}.btn:disabled{opacity:.55;cursor:not-allowed;transform:none}
      .wrap{width:min(1320px,100%);margin:0 auto;padding:24px}.topbar{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:18px}.top-actions{display:flex;gap:10px;flex-wrap:wrap}.grid{display:grid;grid-template-columns:360px minmax(0,1fr);gap:18px}.card{padding:20px}.card-title{margin:0 0 4px;font-size:20px;font-weight:1000;letter-spacing:-.03em}.form-grid{display:grid;gap:13px;margin-top:16px}.two{display:grid;grid-template-columns:1fr 1fr;gap:12px}.check-row{display:flex;align-items:center;gap:10px;background:#f8fafc;border:1px solid var(--border);border-radius:16px;padding:12px}.check-row input{width:auto}.alert{border-radius:16px;padding:12px 14px;font-size:13px;font-weight:850;margin-bottom:12px}.alert-info{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}.alert-error{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}.alert-ok{background:#ecfdf5;color:#166534;border:1px solid #bbf7d0}
      .image-help{margin:7px 0 0;font-size:11px;color:#64748b;font-weight:800;line-height:1.4}
      .settings-row{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:end}.category-preview{display:flex;gap:12px;align-items:center;margin-top:10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:18px;padding:10px}.category-preview img{width:78px;height:58px;border-radius:16px;object-fit:cover;background:#fff;border:1px solid #e2e8f0;display:block;flex:0 0 auto}.category-preview span{font-size:12px;font-weight:900;color:#64748b}
      #gifts-list{display:grid;gap:10px}.gift-row-premium{width:100%;background:#fff;border:1px solid #e5e7eb;border-radius:22px;box-shadow:0 12px 28px rgba(15,23,42,.06);padding:10px;display:grid;grid-template-columns:58px minmax(0,1fr) auto;gap:12px;align-items:center}.gift-thumb-premium{width:58px!important;height:58px!important;min-width:58px!important;max-width:58px!important;max-height:58px!important;border-radius:16px;object-fit:contain;background:#f8fafc;border:1px solid #e2e8f0;display:block;padding:3px}.gift-info-premium{min-width:0;display:flex;align-items:center;gap:10px;flex-wrap:wrap}.gift-name-premium{font-weight:1000;font-size:14px;line-height:1.2;color:#111827;min-width:210px;max-width:370px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.gift-meta-premium{display:flex;align-items:center;gap:8px;flex-wrap:wrap;color:#475569;font-weight:950;font-size:12px}.pill{font-size:10px;font-weight:1000;border-radius:999px;padding:6px 8px;background:#f1f5f9;color:#334155;border:1px solid #e2e8f0}.pill.green{background:#ecfdf5;color:#166534;border-color:#bbf7d0}.pill.red{background:#fee2e2;color:#991b1b;border-color:#fecaca}.gift-actions-premium{display:flex;align-items:center;justify-content:flex-end;gap:7px;flex-wrap:wrap}.premium-action{height:38px;border-radius:14px;border:1px solid var(--border);background:#fff;color:#111827;box-shadow:0 9px 18px rgba(15,23,42,.055);padding:0 12px;font-size:12px;font-weight:1000;display:inline-flex;align-items:center;justify-content:center;transition:transform .16s ease,box-shadow .16s ease}.premium-action:hover{transform:translateY(-1px);box-shadow:0 12px 26px rgba(15,23,42,.1)}.premium-action.arrow{width:38px;padding:0;font-size:15px}.premium-action.dark{background:#111827;color:#fff;border-color:#111827}.premium-action.danger{background:#fff1f2;color:#991b1b;border-color:#fecdd3}.premium-action:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}.empty{padding:34px;text-align:center;color:#64748b;font-weight:850;border:1px dashed #cbd5e1;border-radius:24px;background:#fff}
      @media(max-width:1050px){.grid{grid-template-columns:1fr}.gift-row-premium{grid-template-columns:58px minmax(0,1fr)}.gift-actions-premium{grid-column:1/-1;justify-content:flex-start;padding-left:70px}.gift-name-premium{max-width:100%;min-width:0}}@media(max-width:620px){.wrap{padding:16px}.topbar{align-items:flex-start;flex-direction:column}.two,.settings-row{grid-template-columns:1fr}.gift-row-premium{grid-template-columns:52px minmax(0,1fr);gap:10px}.gift-thumb-premium{width:52px!important;height:52px!important;min-width:52px!important;max-width:52px!important;max-height:52px!important;border-radius:15px}.gift-info-premium{display:block}.gift-name-premium{font-size:13px;margin-bottom:5px;min-width:0}.gift-meta-premium{gap:5px}.gift-actions-premium{padding-left:0}.premium-action{height:36px;padding:0 10px}.premium-action.arrow{width:36px}}


      /* PZ V25B: menú lateral premium igual a Gestión de categorías */
      .sidebar-overlay {
        position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .36);
        opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(2px);
      }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar {
        position: fixed; top: 18px; left: 18px; bottom: 18px; z-index: 90; width: min(286px, calc(100vw - 36px));
        border-radius: 30px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        color: #0f172a; border: 1px solid rgba(226, 232, 240, .95); box-shadow: 0 28px 80px rgba(15, 23, 42, .22);
        overflow: hidden; transform: translateX(calc(-100% - 28px)); transition: transform .24s ease;
      }
      body.sidebar-open .sidebar { transform: translateX(0); }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; }
      .sidebar-brand-row { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; background: #0f172a; color: #fff; box-shadow: 0 14px 30px rgba(15, 23, 42, .18); font-weight: 1000; }
      .sidebar-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; color:#0f172a; line-height:1.2; }
      .sidebar-subtitle { margin: 2px 0 0; color: #64748b; font-size: 11px; font-weight: 850; line-height:1.2; }
      .sidebar-close { margin-left: auto; width: 34px; height: 34px; border: 0; border-radius: 13px; background: #f1f5f9; color: #0f172a; font-size: 22px; font-weight: 900; display: inline-flex; align-items: center; justify-content: center; }
      .sidebar-label { margin: 18px 9px 9px; color: #64748b; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .nav-list { display: grid; gap: 7px; }
      .nav-item { min-height: 46px; display: flex; align-items: center; gap: 10px; padding: 8px 9px; border-radius: 16px; color: #334155; font-size: 13px; font-weight: 950; border: 1px solid transparent; background: transparent; }
      .nav-item:hover { background: #fff; border-color: #e2e8f0; color: #0f172a; box-shadow: 0 12px 24px rgba(15,23,42,.07); }
      .nav-item.active { background: #0f172a; color: #fff; box-shadow: 0 14px 30px rgba(15,23,42,.16); }
      .nav-icon { width: 32px; height: 32px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; background: #fff; color: #0f172a; border: 1px solid #e2e8f0; box-shadow: 0 8px 18px rgba(15,23,42,.06); }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.14); color: #fff; border-color: rgba(255,255,255,.16); box-shadow: none; }
      .nav-icon svg { width: 18px; height: 18px; fill: currentColor; display: block; }
      .sidebar-footer { margin-top: auto; padding: 12px; border-radius: 18px; background: #f8fafc; border: 1px solid #e2e8f0; display: grid; gap: 3px; }
      .sidebar-footer strong { font-size: 12px; color: #0f172a; }
      .sidebar-footer span { font-size: 11px; color: #64748b; line-height: 1.35; }
      .menu-btn { border: 0; border-radius: 18px; padding: 13px 16px; font-weight: 1000; background: #0f172a; color: #fff; box-shadow: 0 18px 38px rgba(15, 23, 42, .18); display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
      .action-btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; border-radius:16px; padding:12px 16px; background:#fff; border:1px solid var(--border); box-shadow:0 10px 22px rgba(15,23,42,.06); color:#111827; font-weight:1000; }
      .action-btn.danger { background:#fee2e2; color:#991b1b; border-color:#fecaca; }
      #admin-view.wrap { width: min(1480px, 100%); }
      #admin-view .topbar { justify-content: space-between; align-items: center; }
      @media(max-width:620px){.menu-btn,.action-btn{width:100%;}.top-actions{width:100%;}.sidebar{top:12px;left:12px;bottom:12px;width:calc(100vw - 24px);}}

    

      /* PZ-V25C-SIDEBAR-UNIFICADO-20260605
         Menú lateral único: estilo premium como Resumen, activo sombreado negro, sin flechas. */
      .sidebar-overlay,
      #sidebar-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 80 !important;
        background: rgba(15, 23, 42, .36) !important;
        opacity: 0;
        pointer-events: none;
        transition: opacity .22s ease !important;
        backdrop-filter: blur(3px) !important;
      }
      .sidebar-overlay.show,
      body.sidebar-open .sidebar-overlay,
      body.sidebar-open #sidebar-overlay {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
      .sidebar,
      #admin-sidebar {
        position: fixed !important;
        top: 18px !important;
        left: 18px !important;
        bottom: 18px !important;
        z-index: 90 !important;
        width: min(286px, calc(100vw - 36px)) !important;
        border-radius: 30px !important;
        padding: 18px !important;
