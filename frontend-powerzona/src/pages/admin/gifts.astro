  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <main id="admin-view" class="wrap">
      <aside id="admin-sidebar" class="sidebar" aria-label="Panel lateral de administración" aria-hidden="true">
        <div class="sidebar-inner">
          <div class="sidebar-brand-row">
            <span class="brand-logo">PZ</span>
            <div>
              <p class="sidebar-title">PowerZona</p>
              <p class="sidebar-subtitle">Panel administrativo</p>
            </div>
            <button id="sidebar-close" class="sidebar-close" type="button" aria-label="Cerrar menú">×</button>
          </div>
          <p class="sidebar-label">Principal</p>
          <nav class="nav-list">
            <a class="nav-item" href={adminBasePath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"/></svg></span><span>Resumen</span></a>
            <a class="nav-item" href={adminOrdersPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Zm3 5h6V6H9v2Zm0 4h6v-2H9v2Zm0 4h4v-2H9v2Z"/></svg></span><span>Pedidos</span></a>
            <a class="nav-item" href={adminCatalogPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3V6Zm0 5h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7Z"/></svg></span><span>Categorías</span></a>
          </nav>
          <p class="sidebar-label">Tienda</p>
          <nav class="nav-list">
            <a class="nav-item" href={adminProductsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 7.5 12 3 3 7.5l9 4.5 9-4.5ZM5 10.7V17l6 3v-6.3l-6-3Zm8 9.3 6-3v-6.3l-6 3V20Z"/></svg></span><span>Productos</span></a>
            <a class="nav-item active" href={adminGiftsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Regalos</span></a>
            <a class="nav-item" href={adminShippingPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Zm2 0v7.17A3 3 0 0 1 8.83 16H13V7H5Zm12 6h2v1h-2v-1ZM6 17a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/></svg></span><span>Envíos</span></a>
            <a class="nav-item" href={adminStoreSettingsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm3 3h10V6H7v2Zm0 4h10v-2H7v2Zm0 4h6v-2H7v2Z"/></svg></span><span>Ajustes de tienda</span></a>
          </nav>
          
        </div>
      </aside>
      <div class="topbar">
        <button id="sidebar-open" class="menu-btn" type="button" aria-controls="admin-sidebar" aria-expanded="false">☰ Menú</button>
        <div class="top-actions"><a class="action-btn" href={adminBasePath}>Resumen</a><a class="action-btn" href={adminProductsPath}>Productos</a><a class="action-btn" href={adminCatalogPath}>Catálogo</a><button id="logout-btn" class="action-btn danger" type="button">Salir</button></div>
      </div>
      <div style="margin-bottom:18px;"><span class="brand">Regalos</span><h1>Gestión de regalos</h1><p>Administra los regalos disponibles para promociones de la tienda.</p></div>
      <div id="alert" class="alert alert-info hidden"></div>

      <section class="grid">
        <aside class="card">
          <h2 class="card-title" id="form-title">Crear regalo</h2>
          <p style="margin:0;font-size:13px;">Define las condiciones necesarias para que el cliente pueda seleccionar este regalo.</p>
          <form id="gift-form" class="form-grid">
            <input id="gift-id" type="hidden" />
            <div><label>Nombre del regalo *</label><input id="gift-name" required placeholder="Ej: Vitamina E de 30 Tabletas" /></div>
            <div><label>Descripción</label><textarea id="gift-description" placeholder="Texto corto para la tarjeta pública"></textarea></div>
            <div class="two"><div><label>Orden mínima USD *</label><input id="gift-min" type="number" min="0" step="0.01" value="0" required /></div><div><label>Stock *</label><input id="gift-stock" type="number" min="0" step="1" value="0" required /></div></div>
            <label class="check-row"><input id="gift-active" type="checkbox" checked /> Visible</label>
            <div><label>Foto del regalo</label><input id="gift-image" type="file" accept="image/*" /><p class="image-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p></div>
            <button class="btn btn-green" type="submit">Guardar regalo</button>
            <button id="cancel-edit-btn" class="btn btn-soft hidden" type="button">Cancelar edición</button>
          </form>
        </aside>

        <section class="card">
          <div class="settings-row" style="margin-bottom:16px;">
            <div><h2 class="card-title">Categoría pública de regalos</h2><p style="margin:0;font-size:13px;">Configura cómo se muestra la categoría de regalos en la tienda pública.</p></div>
            <button id="save-settings-btn" class="btn btn-primary" type="button">Guardar categoría</button>
          </div>
          <div class="two" style="margin-bottom:12px;">
            <label class="check-row"><input id="gifts-public-active" type="checkbox" checked /> Mostrar categoría Regalos</label>
            <div><label>Nombre de categoría</label><input id="gifts-public-title" placeholder="Regalos" /></div>
          </div>
          <div><label>Foto de categoría Regalos</label><input id="gifts-public-image" type="file" accept="image/*" /><p class="image-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p></div>
          <div id="category-preview" class="category-preview hidden"><img id="category-preview-img" alt="Categoría Regalos" /><span>Foto actual de la categoría Regalos</span></div>

          <div class="settings-row" style="margin:22px 0 14px;"><div><h2 class="card-title">Listado de regalos</h2><p style="margin:0;font-size:13px;">Consulta y edita los regalos activos de la tienda.</p></div><button id="refresh-btn" class="btn btn-soft" type="button">Actualizar</button></div>
          <div id="gifts-list"></div>
        </section>
      </section>
    </main>

    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
      const giftForm = document.getElementById('gift-form');
      const giftsList = document.getElementById('gifts-list');
      const alertBox = document.getElementById('alert');
      const logoutBtn = document.getElementById('logout-btn');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const sidebar = document.getElementById('admin-sidebar');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarCloseBtn = document.getElementById('sidebar-close');
      const refreshBtn = document.getElementById('refresh-btn');
      const saveSettingsBtn = document.getElementById('save-settings-btn');
      const formTitle = document.getElementById('form-title');
      const cancelEditBtn = document.getElementById('cancel-edit-btn');
      const categoryPreview = document.getElementById('category-preview');
      const categoryPreviewImg = document.getElementById('category-preview-img');
      let gifts = [];
      let settings = null;

      const token = () => ADMIN_AUTH_TOKEN;
      function openSidebar(){ document.body.classList.add('sidebar-open'); if(sidebarOverlay) sidebarOverlay.hidden = false; if(sidebar) sidebar.setAttribute('aria-hidden','false'); if(sidebarOpenBtn) sidebarOpenBtn.setAttribute('aria-expanded','true'); }
      function closeSidebar(){ document.body.classList.remove('sidebar-open'); if(sidebar) sidebar.setAttribute('aria-hidden','true'); if(sidebarOpenBtn) sidebarOpenBtn.setAttribute('aria-expanded','false'); setTimeout(()=>{ if(!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true; }, 220); }
      function showAlert(message, type='info'){ alertBox.textContent=message; alertBox.className=`alert alert-${type}`; alertBox.classList.remove('hidden'); setTimeout(()=>alertBox.classList.add('hidden'), 4200); }
      function escapeHtml(value){ return String(value || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;'); }
      function normalizeFile(value){ return Array.isArray(value) ? value[0] : value; }
      function fileUrl(record){ const file = normalizeFile(record.image); return file ? `${POCKETBASE_URL}/api/files/gifts/${record.id}/${file}?thumb=100x100` : 'https://placehold.co/100x100?text=Regalo'; }
      function settingsFileUrl(field){ const file = normalizeFile(settings?.[field]); return settings?.id && file ? `${POCKETBASE_URL}/api/files/settings/${settings.id}/${file}?thumb=300x200` : ''; }

      async function optimizeGiftImageFile(file) {
        if (!file || !file.type?.startsWith('image/')) return file;
        if (file.type === 'image/gif') return file;
        let objectUrl = '';
        try {
          const image = await new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve(img);
            img.onerror = reject;
            objectUrl = URL.createObjectURL(file);
            img.src = objectUrl;
          });

          const targetWidth = 1200;
          const targetHeight = 675;
          const targetRatio = targetWidth / targetHeight;
          const sourceWidth = image.naturalWidth || image.width;
          const sourceHeight = image.naturalHeight || image.height;
          const sourceRatio = sourceWidth / sourceHeight;

          let sx = 0;
          let sy = 0;
          let sw = sourceWidth;
          let sh = sourceHeight;

          if (sourceRatio > targetRatio) {
            sw = sourceHeight * targetRatio;
            sx = (sourceWidth - sw) / 2;
          } else if (sourceRatio < targetRatio) {
            sh = sourceWidth / targetRatio;
            sy = (sourceHeight - sh) / 2;
          }

          const canvas = document.createElement('canvas');
          canvas.width = targetWidth;
          canvas.height = targetHeight;
          const ctx = canvas.getContext('2d');
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          ctx.drawImage(image, sx, sy, sw, sh, 0, 0, targetWidth, targetHeight);

          const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/webp', 0.82));
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          if (!blob) return file;
          const safeName = String(file.name || 'regalo')
            .replace(/\.[^.]+$/, '')
            .replace(/[^a-z0-9_-]+/gi, '_')
            .toLowerCase();
          return new File([blob], `${safeName}_regalo_1200x675.webp`, { type: 'image/webp', lastModified: Date.now() });
        } catch (error) {
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          console.warn('No se pudo optimizar la imagen de regalos. Se usará la original.', error);
          return file;
        }
      }

      async function api(path, options = {}){
        const headers = { ...(options.headers || {}) };
        if (token()) headers.Authorization = `Bearer ${token()}`;
        const res = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const data = await res.json().catch(() => null);
        if(!res.ok) throw new Error(data?.message || 'Error de comunicación con PocketBase.');
        return data;
      }
      async function createStoreSettings(){
        await api('/api/collections/settings/records', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ active:true, store:CURRENT_STORE_ID, store_name:'PowerZona', gifts_public_active:true, gifts_public_title:'Regalos' }) });
      }
      async function loadSettings(){
        const filter = encodeURIComponent(ACTIVE_STORE_FILTER);
        const result = await api(`/api/collections/settings/records?filter=${filter}&sort=-updated&perPage=1`);
        settings = result.items?.[0] || null;
        document.getElementById('gifts-public-active').checked = settings?.gifts_public_active !== false;
        document.getElementById('gifts-public-title').value = settings?.gifts_public_title || 'Regalos';
        const preview = settingsFileUrl('gifts_public_image');
        categoryPreview.classList.toggle('hidden', !preview);
        if(preview) categoryPreviewImg.src = preview;
      }
      async function loadGifts(){
        giftsList.innerHTML = '<div class="empty">Cargando regalos...</div>';
        const result = await api(`/api/collections/gifts/records?filter=${encodeURIComponent(STORE_FILTER)}&sort=sort_order,name&perPage=200`);
        gifts = result.items || [];
        renderGifts();
      }
      function renderGifts(){
        if(!gifts.length){ giftsList.innerHTML = '<div class="empty">Aún no tienes regalos creados.</div>'; return; }
        giftsList.innerHTML = gifts.map((gift, index) => `
          <article class="gift-row-premium" style="width:100%;background:#fff;border:1px solid #e5e7eb;border-radius:22px;box-shadow:0 12px 28px rgba(15,23,42,.06);padding:10px;display:grid;grid-template-columns:58px minmax(0,1fr) auto;gap:12px;align-items:center;">
            <img class="gift-thumb-premium" style="width:58px!important;height:58px!important;min-width:58px!important;max-width:58px!important;max-height:58px!important;border-radius:16px;object-fit:contain;background:#f8fafc;border:1px solid #e2e8f0;display:block;padding:3px;" src="${escapeHtml(fileUrl(gift))}" alt="${escapeHtml(gift.name)}" />
            <div class="gift-info-premium" style="min-width:0;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
              <div class="gift-name-premium" style="font-weight:1000;font-size:14px;line-height:1.2;color:#111827;min-width:210px;max-width:370px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escapeHtml(gift.name)}</div>
              <div class="gift-meta-premium" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;color:#475569;font-weight:950;font-size:12px;">
                <span>Desde $${Number(gift.min_order_usd || 0).toFixed(2)} USD</span>
                <span>Stock: ${Number(gift.stock || 0)}</span>
                <span style="font-size:10px;font-weight:1000;border-radius:999px;padding:6px 8px;background:${gift.active ? '#ecfdf5' : '#fee2e2'};color:${gift.active ? '#166534' : '#991b1b'};border:1px solid ${gift.active ? '#bbf7d0' : '#fecaca'};">${gift.active ? 'Visible':'Oculto'}</span>
              </div>
            </div>
            <div class="gift-actions-premium" style="display:flex;align-items:center;justify-content:flex-end;gap:7px;flex-wrap:wrap;">
              <button class="premium-action toggle-gift" style="height:38px;border-radius:14px;border:1px solid #e2e8f0;background:#fff;color:#111827;box-shadow:0 9px 18px rgba(15,23,42,.055);padding:0 12px;font-size:12px;font-weight:1000;" data-id="${gift.id}" type="button">${gift.active ? 'Ocultar':'Mostrar'}</button>
              <button class="premium-action arrow move-gift" style="width:38px;height:38px;border-radius:14px;border:1px solid #e2e8f0;background:#fff;color:#111827;box-shadow:0 9px 18px rgba(15,23,42,.055);font-size:15px;font-weight:1000;" data-id="${gift.id}" data-dir="up" type="button" ${index === 0 ? 'disabled' : ''} title="Subir">↑</button>
              <button class="premium-action arrow move-gift" style="width:38px;height:38px;border-radius:14px;border:1px solid #e2e8f0;background:#fff;color:#111827;box-shadow:0 9px 18px rgba(15,23,42,.055);font-size:15px;font-weight:1000;" data-id="${gift.id}" data-dir="down" type="button" ${index === gifts.length - 1 ? 'disabled' : ''} title="Bajar">↓</button>
              <button class="premium-action dark edit-gift" style="height:38px;border-radius:14px;border:1px solid #111827;background:#111827;color:#fff;box-shadow:0 9px 18px rgba(15,23,42,.055);padding:0 12px;font-size:12px;font-weight:1000;" data-id="${gift.id}" type="button">Editar</button>
              <button class="premium-action danger delete-gift" style="height:38px;border-radius:14px;border:1px solid #fecdd3;background:#fff1f2;color:#991b1b;box-shadow:0 9px 18px rgba(15,23,42,.055);padding:0 12px;font-size:12px;font-weight:1000;" data-id="${gift.id}" type="button">Borrar</button>
            </div>
          </article>`).join('');
        document.querySelectorAll('.toggle-gift').forEach((btn)=>btn.addEventListener('click',()=>toggleGift(btn.dataset.id)));
        document.querySelectorAll('.move-gift').forEach((btn)=>btn.addEventListener('click',()=>moveGift(btn.dataset.id, btn.dataset.dir)));
        document.querySelectorAll('.edit-gift').forEach((btn)=>btn.addEventListener('click',()=>editGift(btn.dataset.id)));
        document.querySelectorAll('.delete-gift').forEach((btn)=>btn.addEventListener('click',()=>deleteGift(btn.dataset.id)));
      }
      function resetForm(){ giftForm.reset(); document.getElementById('gift-id').value=''; document.getElementById('gift-active').checked=true; document.getElementById('gift-min').value='0'; document.getElementById('gift-stock').value='0'; formTitle.textContent='Crear regalo'; cancelEditBtn.classList.add('hidden'); }
      function editGift(id){ const gift = gifts.find((item)=>item.id===id); if(!gift) return; document.getElementById('gift-id').value=gift.id; document.getElementById('gift-name').value=gift.name||''; document.getElementById('gift-description').value=gift.description||''; document.getElementById('gift-min').value=Number(gift.min_order_usd||0); document.getElementById('gift-stock').value=Number(gift.stock||0); document.getElementById('gift-active').checked=gift.active!==false; formTitle.textContent='Editar regalo'; cancelEditBtn.classList.remove('hidden'); window.scrollTo({top:0,behavior:'smooth'}); }
      async function saveGift(event){
        event.preventDefault();
        const id = document.getElementById('gift-id').value;
        const fd = new FormData();
        fd.set('name', document.getElementById('gift-name').value.trim());
        fd.set('description', document.getElementById('gift-description').value.trim());
        fd.set('min_order_usd', String(Math.max(0, Number(document.getElementById('gift-min').value || 0))));
        fd.set('stock', String(Math.max(0, Math.floor(Number(document.getElementById('gift-stock').value || 0)))));
        if(!id) fd.set('sort_order', String(nextSortOrder()));
        fd.set('active', document.getElementById('gift-active').checked ? 'true' : 'false');
        const image = document.getElementById('gift-image').files?.[0];
        if(image) fd.append('image', await optimizeGiftImageFile(image));
        fd.set('store', CURRENT_STORE_ID);
        if(id) await api(`/api/collections/gifts/records/${id}`, { method:'PATCH', body:fd });
        else await api('/api/collections/gifts/records', { method:'POST', body:fd });
        resetForm(); await loadGifts(); showAlert('Regalo guardado correctamente.', 'ok');
      }
      function nextSortOrder(){ return gifts.length ? Math.max(...gifts.map((gift)=>Number(gift.sort_order || 0))) + 10 : 10; }
      async function normalizeGiftOrder(){ await Promise.all(gifts.map((gift, index)=>api(`/api/collections/gifts/records/${gift.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:(index + 1) * 10 }) }))); await loadGifts(); }
      async function moveGift(id, direction){ const index = gifts.findIndex((gift)=>gift.id === id); if(index < 0) return; const targetIndex = direction === 'up' ? index - 1 : index + 1; if(targetIndex < 0 || targetIndex >= gifts.length) return; const current = gifts[index]; const target = gifts[targetIndex]; const currentOrder = Number(current.sort_order || 0); const targetOrder = Number(target.sort_order || 0); if(currentOrder === targetOrder){ await normalizeGiftOrder(); return moveGift(id, direction); } await Promise.all([ api(`/api/collections/gifts/records/${current.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:targetOrder }) }), api(`/api/collections/gifts/records/${target.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:currentOrder }) }), ]); await loadGifts(); }
      async function toggleGift(id){ const gift = gifts.find((item)=>item.id === id); if(!gift) return; await api(`/api/collections/gifts/records/${id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ active: !gift.active }) }); await loadGifts(); showAlert(gift.active ? 'Regalo ocultado.' : 'Regalo visible.', 'ok'); }
      async function deleteGift(id){ if(!confirm('¿Seguro que deseas borrar este regalo?')) return; await api(`/api/collections/gifts/records/${id}`, { method:'DELETE' }); await loadGifts(); showAlert('Regalo borrado.', 'ok'); }
      async function saveSettings(){
        if(!settings?.id){ showAlert('No hay settings activo para guardar la categoría pública.', 'error'); return; }
        try {
          saveSettingsBtn.disabled = true;
          saveSettingsBtn.textContent = 'Guardando...';
          const fd = new FormData();
          fd.set('gifts_public_active', document.getElementById('gifts-public-active').checked ? 'true' : 'false');
          fd.set('gifts_public_title', document.getElementById('gifts-public-title').value.trim() || 'Regalos');
          const image = document.getElementById('gifts-public-image').files?.[0];
          if(image) fd.append('gifts_public_image', await optimizeGiftImageFile(image));
          await api(`/api/collections/settings/records/${settings.id}`, { method:'PATCH', body:fd });
          document.getElementById('gifts-public-image').value = '';
          await loadSettings();
          showAlert('Categoría pública de regalos actualizada.', 'ok');
        } catch (error) {
          console.error(error);
          showAlert(error.message || 'No se pudo guardar la categoría pública de regalos.', 'error');
        } finally {
          saveSettingsBtn.disabled = false;
          saveSettingsBtn.textContent = 'Guardar categoría';
        }
      }
      async function boot(){
        if(!POCKETBASE_URL){
          showAlert('Falta PUBLIC_POCKETBASE_URL en .env', 'error');
          return;
        }
        if(!ADMIN_AUTH_TOKEN){
          showAlert('Tu sesión no está disponible. Vuelve a iniciar sesión.', 'error');
          return;
        }
        try{
          await loadSettings();
          await loadGifts();
        } catch(error){
          console.error(error);
          showAlert(error.message || 'No se pudieron cargar los datos de esta tienda.', 'error');
        }
      }
      giftForm?.addEventListener('submit', saveGift);
      cancelEditBtn?.addEventListener('click', resetForm);
      refreshBtn?.addEventListener('click', loadGifts);
      saveSettingsBtn?.addEventListener('click', saveSettings);
      logoutBtn?.addEventListener('click', ()=>{ window.location.href = publicStorePath; });
      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarCloseBtn?.addEventListener('click', closeSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      document.addEventListener('keydown', (event)=>{ if(event.key === 'Escape') closeSidebar(); });
      document.querySelectorAll('#admin-sidebar a').forEach((link)=>link.addEventListener('click', closeSidebar));
      boot();
    </script>
  </body>
</html>
