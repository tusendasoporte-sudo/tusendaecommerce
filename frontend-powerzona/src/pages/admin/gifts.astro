---
import { refreshAuthFromCookie } from '../../lib/auth';
import { getPublicStorePath, getStoreAdminPath } from '../../lib/adminRoutes';
import { requireCurrentStoreForAdmin } from '../../lib/storeContext';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreId = adminContext.storeId;
const adminAuthToken = authPb.authStore.token;
const currentStoreSlug = adminContext.store.slug || '';
const currentStoreName = adminContext.store.name || adminContext.store.title || currentStoreSlug || 'Tienda';
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminCatalogPath = getStoreAdminPath(currentStoreSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const publicStorePath = getPublicStorePath(currentStoreSlug);
const masterSupportWhatsapp = String(import.meta.env.PUBLIC_MASTER_SUPPORT_WHATSAPP || '').replace(/[^0-9]/g, '');
const masterSupportEmail = String(import.meta.env.PUBLIC_MASTER_SUPPORT_EMAIL || '').trim();
const supportMessage = `Hola soporte de Tu Senda 84, necesito ayuda con el admin de regalos de la tienda ${currentStoreName} (${currentStoreSlug || 'sin-slug'}).`;
const masterSupportHref = masterSupportWhatsapp
  ? `https://wa.me/${masterSupportWhatsapp}?text=${encodeURIComponent(supportMessage)}`
  : (masterSupportEmail ? `mailto:${masterSupportEmail}?subject=${encodeURIComponent('Soporte Regalos Tu Senda 84')}&body=${encodeURIComponent(supportMessage)}` : '');
const masterSupportLabel = masterSupportHref ? 'Contactar a soporte' : 'Soporte Tu Senda 84';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Regalos | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --blue: #2563eb;
        --green: #16a34a;
        --red: #dc2626;
        --orange: #f97316;
        --purple: #7c3aed;
        --dark: #0f172a;
        --shadow: 0 18px 45px rgba(15, 23, 42, .08);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, .14), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, .09), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }
      a { color: inherit; text-decoration: none; }
      button, input, textarea, select { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .55; }
      .hidden { display: none !important; }

      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; }
      .sidebar-overlay {
        position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .36);
        opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(3px);
      }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar {
        position: fixed; top: 18px; left: 18px; bottom: 18px; z-index: 90; width: min(286px, calc(100vw - 36px));
        border-radius: 30px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        color: #0f172a; border: 1px solid rgba(226, 232, 240, .95);
        box-shadow: 0 28px 80px rgba(15, 23, 42, .22), inset 0 1px 0 rgba(255,255,255,.95);
        overflow: hidden auto; transform: translateX(calc(-100% - 36px)); transition: transform .24s ease;
      }
      body.sidebar-open .sidebar { transform: translateX(0); }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100%; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo {
        width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #0f172a, #020617); color: #fff; font-size: 12px; font-weight: 1000;
        box-shadow: 0 14px 26px rgba(15,23,42,.18);
      }
      .brand-title { margin: 0; font-size: 22px; font-weight: 1000; letter-spacing: -.035em; line-height: 1.1; }
      .brand-subtitle { margin: 4px 0 0; color: #334155; font-size: 12px; font-weight: 850; line-height: 1.2; }
      .sidebar-close {
        margin-left: auto; width: 42px; height: 42px; min-width: 42px; border-radius: 16px; border: 1px solid #e2e8f0;
        background: #fff; color: #0f172a; font-size: 18px; font-weight: 1000; box-shadow: 0 10px 20px rgba(15,23,42,.06);
      }
      .sidebar-label { margin: 18px 9px 9px; color: #475569; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .14em; }
      .nav-list { display: grid; gap: 6px; }
      .nav-item {
        min-height: 50px; display: flex; align-items: center; gap: 11px; width: 100%; padding: 8px 10px; border-radius: 16px;
        background: transparent; color: #0f172a; border: 1px solid transparent; font-size: 15px; font-weight: 1000; line-height: 1.18;
      }
      .nav-item:hover { transform: translateX(2px); background: #f8fafc; color: #020617; border-color: #e2e8f0; box-shadow: 0 12px 26px rgba(15,23,42,.07); }
      .nav-item.active { background: linear-gradient(135deg, #0f172a, #020617); color: #fff; border-color: rgba(15,23,42,.95); box-shadow: 0 16px 32px rgba(15,23,42,.18); }
      .nav-icon {
        width: 34px; height: 34px; min-width: 34px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center;
        background: #fff; color: #0f172a; border: 1px solid #e2e8f0; box-shadow: 0 9px 18px rgba(15,23,42,.06);
      }
      .nav-icon svg { width: 18px; height: 18px; display: block; fill: currentColor; }
      .nav-item.active .nav-icon, .nav-item:hover .nav-icon { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.20); box-shadow: inset 0 1px 0 rgba(255,255,255,.12); }
      .nav-item:hover:not(.active) .nav-icon { background: #020617; color: #fff; }
      .sidebar-utility { display: grid; gap: 8px; margin-top: auto; padding-top: 14px; }
      .sidebar-utility .nav-item { border: 0; text-align: left; }
      .sidebar-utility .nav-item.danger { color: #991b1b; background: #fff7f7; border-color: #fecaca; }
      .sidebar-footer { margin-top: 14px; padding: 14px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .sidebar-footer strong { display: block; font-size: 12px; margin-bottom: 5px; color: #0f172a; }
      .sidebar-footer span { display: block; color: #475569; font-size: 11px; line-height: 1.45; font-weight: 750; }

      .admin-main { min-width: 0; padding-bottom: 92px; }
      .mobile-topbar { display: grid; grid-template-columns: 42px minmax(0, 1fr) 42px; align-items: center; gap: 8px; margin-bottom: 14px; }
      .mobile-topbar strong { text-align: center; font-size: 16px; font-weight: 1000; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .menu-btn, .notifications-btn, .icon-btn {
        border: 1px solid rgba(226,232,240,.95); border-radius: 16px; background: rgba(255,255,255,.94); color: #0f172a;
        box-shadow: 0 12px 26px rgba(15,23,42,.07); display: inline-flex; align-items: center; justify-content: center; font-weight: 1000;
      }
      .menu-btn, .notifications-btn { width: 42px; height: 42px; padding: 0; }
      .notifications-btn { position: relative; }
      .notifications-btn svg, .icon-btn svg { width: 19px; height: 19px; fill: none; stroke: currentColor; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
      .notifications-dot { position: absolute; top: 9px; right: 10px; width: 8px; height: 8px; border-radius: 999px; background: #ef4444; border: 2px solid #fff; }
      .page-header {
        display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 18px; align-items: center;
        padding: 22px 24px; margin-bottom: 18px; background: rgba(255,255,255,.92); border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px; box-shadow: var(--shadow); backdrop-filter: blur(10px);
      }
      .page-title { margin: 0; font-size: clamp(28px, 4vw, 42px); line-height: 1.02; letter-spacing: -.045em; font-weight: 1000; }
      .page-subtitle { margin: 8px 0 0; color: var(--muted); font-size: 15px; font-weight: 760; line-height: 1.45; }
      .header-actions { display: flex; align-items: center; gap: 10px; }
      .btn {
        border: 1px solid transparent; border-radius: 16px; min-height: 44px; padding: 12px 16px; display: inline-flex; align-items: center; justify-content: center; gap: 9px;
        font-size: 13px; font-weight: 1000; transition: transform .16s ease, box-shadow .16s ease, background .16s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn-primary { background: #2563eb; color: #fff; box-shadow: 0 14px 28px rgba(37,99,235,.18); }
      .btn-dark { background: #0f172a; color: #fff; box-shadow: 0 14px 28px rgba(15,23,42,.18); }
      .btn-soft { background: #fff; color: #0f172a; border-color: #e2e8f0; box-shadow: 0 10px 22px rgba(15,23,42,.06); }
      .btn-danger { background: #fff1f2; color: #991b1b; border-color: #fecdd3; }
      .btn.full { width: 100%; }

      .stats-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
      .stat-card { background: #fff; border: 1px solid rgba(226,232,240,.96); border-radius: 22px; padding: 16px; box-shadow: 0 14px 32px rgba(15,23,42,.07); display: flex; align-items: center; gap: 12px; min-width: 0; }
      .stat-icon { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 1000; flex: 0 0 auto; }
      .stat-icon.blue { background: #eff6ff; color: #1d4ed8; }
      .stat-icon.green { background: #ecfdf5; color: #166534; }
      .stat-icon.orange { background: #fff7ed; color: #c2410c; }
      .stat-icon.purple { background: #f5f3ff; color: #6d28d9; }
      .stat-label { margin: 0; color: #64748b; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .05em; }
      .stat-value { margin: 4px 0 0; color: #0f172a; font-size: 24px; font-weight: 1000; line-height: 1; }

      .filter-card { margin-bottom: 18px; background: #fff; border: 1px solid rgba(226,232,240,.96); border-radius: 22px; padding: 14px; box-shadow: 0 14px 32px rgba(15,23,42,.06); display: grid; grid-template-columns: minmax(260px, 1fr) 220px; gap: 12px; align-items: end; }
      .content-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: 18px; align-items: start; }
      .main-column { display: grid; gap: 18px; min-width: 0; }
      .panel-card {
        background: rgba(255,255,255,.94); border: 1px solid rgba(226,232,240,.96); border-radius: 24px; box-shadow: var(--shadow);
        backdrop-filter: blur(10px); overflow: visible;
      }
      .panel-pad { padding: 22px; }
      .panel-head { display: flex; justify-content: space-between; gap: 14px; align-items: flex-start; margin-bottom: 18px; }
      .panel-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -.025em; }
      .panel-subtitle { margin: 7px 0 0; color: #64748b; font-size: 13px; font-weight: 760; line-height: 1.45; }
      .info-note { margin: 14px 0 0; border-radius: 18px; padding: 12px 14px; background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; font-size: 12px; font-weight: 900; line-height: 1.45; }
      .alert { margin-bottom: 14px; border-radius: 16px; padding: 12px 14px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-ok { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

      .form-layout { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 320px); gap: 18px; align-items: start; }
      .form-grid { display: grid; gap: 13px; }
      .form-two { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .04em; }
      .field input, .field textarea, .field select {
        width: 100%; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; color: #0f172a;
        padding: 12px 13px; outline: none; font-weight: 820; box-shadow: inset 0 1px 0 rgba(15,23,42,.02);
      }
      .field textarea { resize: vertical; min-height: 100px; line-height: 1.45; }
      .field input:focus, .field textarea:focus, .field select:focus { border-color: #93c5fd; box-shadow: 0 0 0 4px rgba(37,99,235,.12); }
      .image-panel { border: 1px solid #e2e8f0; border-radius: 22px; padding: 12px; background: #f8fafc; display: grid; gap: 12px; }
      .image-preview { aspect-ratio: 16 / 9; width: 100%; border-radius: 18px; background: #fff; border: 1px dashed #cbd5e1; display: grid; place-items: center; overflow: hidden; color: #94a3b8; font-size: 32px; font-weight: 1000; }
      .image-preview img { width: 100%; height: 100%; object-fit: contain; display: none; }
      .image-preview.has-image img { display: block; }
      .image-preview.has-image span { display: none; }
      .image-help { margin: 0; color: #64748b; font-size: 11px; line-height: 1.45; font-weight: 800; }
      .file-input { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
      .toggle-line { display: flex; align-items: center; gap: 12px; padding: 12px 13px; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; font-weight: 950; color: #334155; }
      .toggle-line input { position: absolute; opacity: 0; pointer-events: none; }
      .switch { width: 46px; height: 26px; border-radius: 999px; background: #cbd5e1; padding: 3px; transition: background .18s ease; flex: 0 0 auto; }
      .switch::before { content: ''; display: block; width: 20px; height: 20px; border-radius: 999px; background: #fff; box-shadow: 0 4px 10px rgba(15,23,42,.18); transition: transform .18s ease; }
      .toggle-line input:checked + .switch { background: #16a34a; }
      .toggle-line input:checked + .switch::before { transform: translateX(20px); }
      .form-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }

      body.gift-modal-open { overflow: hidden; }
      .gift-modal {
        position: fixed; inset: 0; z-index: 130; display: grid; place-items: center; padding: 24px;
        background: rgba(15, 23, 42, .46); backdrop-filter: blur(8px);
      }
      .gift-modal.hidden { display: none !important; }
      .gift-modal-card {
        width: min(1120px, 100%); max-height: calc(100vh - 48px); overflow: hidden; border-radius: 28px;
        background: rgba(255,255,255,.96); border: 1px solid rgba(226,232,240,.95);
        box-shadow: 0 34px 90px rgba(15,23,42,.28); display: flex; flex-direction: column;
      }
      .gift-modal-head {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 20px 22px;
        border-bottom: 1px solid #e2e8f0; background: linear-gradient(180deg, rgba(248,250,252,.92), rgba(255,255,255,.72));
      }
      .gift-modal-close {
        width: 42px; height: 42px; min-width: 42px; border-radius: 16px; border: 1px solid #e2e8f0;
        background: #fff; color: #0f172a; font-size: 18px; font-weight: 1000; box-shadow: 0 10px 20px rgba(15,23,42,.07);
        display: inline-flex; align-items: center; justify-content: center;
      }
      .gift-modal-body { overflow: auto; padding: 22px; }
      .gift-modal-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(285px, 340px); gap: 18px; align-items: start; }
      .gift-modal-main, .gift-modal-rail { min-width: 0; display: grid; gap: 18px; }

      .preview-card { overflow: hidden; }
      .preview-image { aspect-ratio: 16 / 9; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: grid; place-items: center; color: #94a3b8; font-size: 34px; font-weight: 1000; }
      .preview-image img { width: 100%; height: 100%; object-fit: contain; display: none; }
      .preview-image.has-image img { display: block; }
      .preview-image.has-image span { display: none; }
      .preview-body { padding: 16px; display: grid; gap: 9px; }
      .preview-title { margin: 0; font-size: 18px; font-weight: 1000; letter-spacing: -.02em; line-height: 1.15; }
      .preview-meta { margin: 0; color: #64748b; font-size: 13px; font-weight: 900; }
      .summary-list { display: grid; gap: 10px; }
      .summary-row { display: flex; justify-content: space-between; gap: 12px; padding: 11px 0; border-bottom: 1px solid #eef2f7; font-size: 13px; font-weight: 900; }
      .summary-row:last-child { border-bottom: 0; }
      .summary-row span:first-child { color: #64748b; }
      .badge { display: inline-flex; align-items: center; width: max-content; max-width: 100%; border-radius: 999px; padding: 7px 10px; font-size: 11px; font-weight: 1000; border: 1px solid transparent; white-space: nowrap; }
      .badge.visible { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .badge.hidden-badge { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .badge.soft { background: #f1f5f9; color: #334155; border-color: #e2e8f0; }

      .category-compact-card {
        display: grid; grid-template-columns: minmax(0, 1fr) auto auto; gap: 14px; align-items: center;
        padding: 18px 20px; background: rgba(255,255,255,.94); border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px; box-shadow: var(--shadow); backdrop-filter: blur(10px);
      }
      .category-compact-card .panel-subtitle { margin-top: 5px; }
      .category-inline-card {
        margin-top: -4px; background: rgba(255,255,255,.94); border: 1px solid rgba(226,232,240,.96);
        border-radius: 24px; box-shadow: var(--shadow); backdrop-filter: blur(10px); overflow: hidden;
      }
      .category-inline-card.hidden { display: none !important; }
      .category-inline-head {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; padding: 20px 22px;
        border-bottom: 1px solid #e2e8f0; background: linear-gradient(180deg, rgba(248,250,252,.86), rgba(255,255,255,.62));
      }
      .category-inline-close {
        width: 42px; height: 42px; min-width: 42px; border-radius: 16px; border: 1px solid #e2e8f0;
        background: #fff; color: #0f172a; font-size: 18px; font-weight: 1000; box-shadow: 0 10px 20px rgba(15,23,42,.07);
        display: inline-flex; align-items: center; justify-content: center;
      }
      .category-inline-body { padding: 22px; }
      .category-inline-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 330px); gap: 16px; align-items: start; }
      .category-inline-actions { display: flex; justify-content: flex-start; gap: 10px; margin-top: 16px; }
      .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: end; }
      .category-preview { display: flex; gap: 12px; align-items: center; margin-top: 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 18px; padding: 10px; }
      .category-preview img { width: 90px; height: 58px; border-radius: 14px; object-fit: contain; background: #fff; border: 1px solid #e2e8f0; display: block; flex: 0 0 auto; }
      .category-preview span { font-size: 12px; font-weight: 900; color: #64748b; }

      .list-card { overflow: visible; }
      .list-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; padding: 20px 22px; border-bottom: 1px solid #e2e8f0; flex-wrap: wrap; background: linear-gradient(180deg, rgba(248,250,252,.86), rgba(255,255,255,.6)); border-radius: 24px 24px 0 0; }
      .list-title { margin: 0; font-size: 20px; font-weight: 1000; letter-spacing: -.025em; }
      .list-subtitle { margin: 6px 0 0; color: #64748b; font-size: 13px; font-weight: 760; }
      .list-card { --gifts-table-grid: minmax(260px, 1.35fr) minmax(150px, .75fr) 90px 130px minmax(250px, auto); }
      .gift-table-head, .gift-row {
        display: grid; grid-template-columns: var(--gifts-table-grid);
        column-gap: 24px; align-items: center;
      }
      .gift-table-head { padding: 13px 22px; color: #64748b; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #eef2f7; }
      .gift-table-head span:nth-child(1),
      .gift-row > :nth-child(1) { text-align: left; justify-self: start; }
      .gift-table-head span:nth-child(2),
      .gift-row > :nth-child(2) { text-align: left; justify-self: start; }
      .gift-table-head span:nth-child(3),
      .gift-row > :nth-child(3) { text-align: center; justify-self: center; }
      .gift-table-head span:nth-child(4),
      .gift-row > :nth-child(4) { text-align: center; justify-self: center; }
      .gift-table-head span:nth-child(5) { text-align: right; justify-self: end; }
      #gifts-list { display: grid; }
      .gifts-pagination {
        display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap;
        padding: 16px 22px; border-top: 1px solid #eef2f7; background: #fff; border-radius: 0 0 24px 24px;
      }
      .gifts-pagination.hidden { display: none !important; }
      .pagination-text { color: #475569; font-size: 13px; font-weight: 950; }
      .pagination-pages { display: flex; align-items: center; justify-content: center; gap: 6px; flex-wrap: wrap; }
      .pagination-page.active { background: #0f172a; color: #fff; border-color: #0f172a; }
      .gift-row { min-height: 92px; padding: 16px 22px; border-bottom: 1px solid #eef2f7; background: #fff; position: relative; }
      .gift-row:last-child { border-bottom: 0; border-radius: 0 0 24px 24px; }
      .gift-main { display: flex; align-items: center; gap: 12px; min-width: 0; }
      .gift-thumb { width: 58px; height: 58px; min-width: 58px; border-radius: 15px; object-fit: contain; background: #f8fafc; border: 1px solid #e2e8f0; display: block; }
      .gift-name { margin: 0; font-size: 15px; font-weight: 1000; color: #0f172a; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .gift-desc { margin: 5px 0 0; color: #64748b; font-size: 12px; font-weight: 800; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .gift-cell { color: #334155; font-size: 13px; font-weight: 950; }
      .gift-actions { display: flex; align-items: center; justify-content: flex-end; justify-self: end; gap: 8px; flex-wrap: nowrap; min-width: 0; }
      .mini-btn {
        min-width: 38px; min-height: 38px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a;
        box-shadow: 0 9px 18px rgba(15,23,42,.055); padding: 0 11px; display: inline-flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 1000;
      }
      .mini-btn.dark { background: #0f172a; color: #fff; border-color: #0f172a; }
      .mini-btn svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }
      .gift-menu-wrap { position: relative; }
      .gift-menu {
        position: absolute; right: 0; top: calc(100% + 8px); z-index: 40; min-width: 160px; padding: 7px; border-radius: 16px;
        background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 20px 44px rgba(15,23,42,.16); display: none;
      }
      .gift-menu.open { display: grid; gap: 4px; }
      .gift-menu button { border: 0; border-radius: 12px; background: transparent; color: #0f172a; padding: 10px 11px; text-align: left; font-size: 13px; font-weight: 950; }
      .gift-menu button:hover { background: #f8fafc; }
      .gift-menu button.danger { color: #991b1b; }
      .empty { margin: 22px; padding: 34px; text-align: center; color: #64748b; font-weight: 850; border: 1px dashed #cbd5e1; border-radius: 24px; background: #fff; display: grid; justify-items: center; gap: 12px; }
      .empty strong { color: #0f172a; font-size: 18px; font-weight: 1000; }

      @media (min-width: 1024px) {
        .sidebar { transform: translateX(0); width: 278px; }
        .sidebar-close, .sidebar-overlay { display: none !important; }
        .admin-main { padding-left: 298px; }
        .mobile-topbar, .mobile-new-btn { display: none !important; }
      }
      @media (max-width: 1120px) {
        .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .gift-table-head { display: none; }
        .gift-row { grid-template-columns: minmax(0, 1fr) auto; align-items: start; }
        .gift-row .gift-cell, .gift-row .badge { grid-column: 1 / -1; }
        .gift-actions { grid-column: 1 / -1; justify-content: flex-start; justify-self: stretch; flex-wrap: wrap; }
      }
      @media (max-width: 720px) {
        .app-shell { padding: 14px; }
        .sidebar { top: 12px; left: 12px; bottom: 12px; width: calc(100vw - 24px); }
        .page-header { display: none; }
        .mobile-new-btn { margin-bottom: 12px; }
        .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
        .stat-card { padding: 12px; border-radius: 18px; }
        .stat-icon { width: 36px; height: 36px; border-radius: 14px; }
        .stat-value { font-size: 21px; }
        .filter-card, .form-layout, .form-two, .settings-grid, .category-compact-card, .category-inline-grid, .gift-modal-grid { grid-template-columns: 1fr; }
        .panel-pad { padding: 17px; }
        .panel-card, .page-header { border-radius: 22px; }
        .list-head { padding: 17px; border-radius: 22px 22px 0 0; }
        .gift-modal { padding: 12px; align-items: center; }
        .gift-modal-card { max-height: calc(100vh - 24px); border-radius: 24px; }
        .gift-modal-head { padding: 16px; }
        .gift-modal-body { padding: 16px; }
        .gift-modal-main .form-actions { position: sticky; bottom: -16px; z-index: 4; padding: 12px 0 0; background: linear-gradient(180deg, rgba(255,255,255,0), #fff 28%); }
        .gift-row { padding: 14px; grid-template-columns: 1fr; }
        .gift-main { align-items: flex-start; }
        .gift-thumb { width: 52px; height: 52px; min-width: 52px; border-radius: 14px; }
        .gift-actions { gap: 7px; }
        .mini-btn { min-height: 36px; min-width: 36px; padding: 0 10px; }
        .form-actions .btn { width: 100%; }
        .gifts-pagination { padding: 14px; align-items: stretch; }
        .gifts-pagination .mini-btn { flex: 1 1 120px; }
        .category-inline-head { padding: 16px; }
        .category-inline-body { padding: 16px; }
        .category-inline-actions .btn { width: 100%; }
      }

      .sidebar-plan-meta {
        margin-top: 10px;
        display: grid;
        gap: 4px;
        padding: 9px 10px;
        border-radius: 14px;
        background: rgba(37, 99, 235, .06);
        border: 1px solid rgba(37, 99, 235, .10);
      }
      .sidebar-plan-meta p {
        margin: 0;
        color: #475569;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 800;
      }
      .sidebar-plan-meta strong {
        color: #0f172a;
        font-weight: 1000;
      }
    </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell">
      <AdminSidebar storeSlug={currentStoreSlug} storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'} activeSection="gifts" />

      <main class="admin-main">
        <div class="mobile-topbar">
          <button id="sidebar-open" class="menu-btn" type="button" aria-controls="admin-sidebar" aria-expanded="false" aria-label="Abrir menú">☰</button>
          <strong>Regalos</strong>
          <button class="notifications-btn" type="button" aria-label="Notificaciones del admin">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 9a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Z"></path><path d="M10 21a2 2 0 0 0 4 0"></path></svg>
            <span class="notifications-dot" aria-hidden="true"></span>
          </button>
        </div>

        <button class="btn btn-primary full mobile-new-btn js-new-gift" type="button">+ Nuevo regalo</button>

        <header class="page-header">
          <div>
            <h1 class="page-title">Regalos</h1>
            <p class="page-subtitle">Gestiona los regalos promocionales de tu tienda.</p>
          </div>
          <div class="header-actions">
            <button class="notifications-btn" type="button" aria-label="Notificaciones del admin">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 9a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Z"></path><path d="M10 21a2 2 0 0 0 4 0"></path></svg>
              <span class="notifications-dot" aria-hidden="true"></span>
            </button>
            <button class="btn btn-primary js-new-gift" type="button">+ Nuevo regalo</button>
          </div>
        </header>

        <div id="alert" class="alert alert-info hidden"></div>

        <section class="stats-grid" aria-label="Resumen de regalos">
          <article class="stat-card"><span class="stat-icon blue">#</span><div><p class="stat-label">Total regalos</p><p id="stat-total" class="stat-value">0</p></div></article>
          <article class="stat-card"><span class="stat-icon green">✓</span><div><p class="stat-label">Activos</p><p id="stat-active" class="stat-value">0</p></div></article>
          <article class="stat-card"><span class="stat-icon orange">!</span><div><p class="stat-label">Sin stock</p><p id="stat-stockout" class="stat-value">0</p></div></article>
          <article class="stat-card"><span class="stat-icon purple">$</span><div><p class="stat-label">Reglas por monto</p><p id="stat-rules" class="stat-value">0</p></div></article>
        </section>

        <section class="filter-card" aria-label="Filtros de regalos">
          <div class="field">
            <label for="gift-search">Buscar regalo...</label>
            <input id="gift-search" type="search" placeholder="Buscar por nombre o descripción" />
          </div>
          <div class="field">
            <label for="gift-status-filter">Estado</label>
            <select id="gift-status-filter">
              <option value="all">Todos</option>
              <option value="active">Activos</option>
              <option value="hidden">Ocultos</option>
              <option value="stockout">Sin stock</option>
            </select>
          </div>
        </section>

        <section class="content-grid">
          <div class="main-column">
            <section class="category-compact-card">
              <div>
                <h2 class="panel-title">Categoría pública de regalos</h2>
                <p class="panel-subtitle">Configura cómo se muestra Regalos en la tienda pública.</p>
              </div>
              <span id="gifts-category-status" class="badge visible">Visible</span>
              <button id="toggle-gifts-category-card-btn" class="btn btn-dark" type="button">Configurar</button>
            </section>

            <section id="gifts-category-inline-card" class="category-inline-card hidden">
              <div class="category-inline-head">
                <div>
                  <h2 class="panel-title">Categoría pública de regalos</h2>
                  <p class="panel-subtitle">Configura cómo se muestra esta categoría en la tienda pública.</p>
                </div>
                <button id="close-gifts-category-inline-btn" class="category-inline-close" type="button" aria-label="Cerrar categoría pública">X</button>
              </div>
              <div class="category-inline-body">
                <div class="category-inline-grid">
                  <div class="form-grid">
                    <label class="toggle-line" for="gifts-public-active">
                      <input id="gifts-public-active" type="checkbox" checked />
                      <span class="switch" aria-hidden="true"></span>
                      <span>Mostrar categoría Regalos</span>
                    </label>
                    <div class="field">
                      <label for="gifts-public-title">Nombre de categoría</label>
                      <input id="gifts-public-title" placeholder="Regalos" />
                    </div>
                    <div class="field">
                      <label for="gifts-public-image">Foto de categoría Regalos</label>
                      <input id="gifts-public-image" type="file" accept="image/*" />
                      <p class="image-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                    </div>
                  </div>
                  <div>
                    <div id="category-preview" class="category-preview hidden"><img id="category-preview-img" alt="Categoría Regalos" /><span>Foto actual de la categoría Regalos</span></div>
                  </div>
                </div>
                <div class="category-inline-actions">
                  <button id="save-settings-btn" class="btn btn-dark" type="button">Guardar categoría</button>
                </div>
              </div>
            </section>

            <section class="panel-card list-card">
              <div class="list-head">
                <div>
                  <h2 class="list-title">Listado de regalos</h2>
                  <p class="list-subtitle">Administra todos los regalos promocionales de tu tienda.</p>
                </div>
                <button id="refresh-btn" class="btn btn-soft" type="button">Actualizar</button>
              </div>
              <div class="gift-table-head" aria-hidden="true">
                <span>Regalo</span>
                <span>Regla de activación</span>
                <span>Stock</span>
                <span>Visibilidad</span>
                <span>Acciones</span>
              </div>
              <div id="gifts-list"></div>
              <div id="gifts-pagination" class="gifts-pagination hidden"></div>
            </section>
          </div>
        </section>
      </main>
    </div>

    <div id="gift-modal" class="gift-modal hidden" role="dialog" aria-modal="true" aria-hidden="true">
      <section id="gift-form-card" class="gift-modal-card" aria-labelledby="form-title">
        <div class="gift-modal-head">
          <div>
            <h2 class="panel-title" id="form-title">Nuevo regalo</h2>
            <p class="panel-subtitle">Configura el regalo visible en tu tienda.</p>
          </div>
          <button id="close-gift-modal-btn" class="gift-modal-close" type="button" aria-label="Cerrar formulario">X</button>
        </div>

        <div class="gift-modal-body">
          <div class="gift-modal-grid">
            <div class="gift-modal-main">
              <form id="gift-form">
                <input id="gift-id" type="hidden" />
                <div class="form-layout">
                  <div class="form-grid">
                    <div class="field">
                      <label for="gift-name">Nombre del regalo *</label>
                      <input id="gift-name" required placeholder="Ej: Vitamina E de 30 tabletas" />
                    </div>
                    <div class="field">
                      <label for="gift-description">Descripción</label>
                      <textarea id="gift-description" placeholder="Texto corto para la tarjeta pública"></textarea>
                    </div>
                    <div class="form-two">
                      <div class="field">
                        <label for="gift-stock">Stock *</label>
                        <input id="gift-stock" type="number" min="0" step="1" value="0" required />
                      </div>
                      <div class="field">
                        <label for="gift-min">Se activa desde *</label>
                        <input id="gift-min" type="number" min="0" step="0.01" value="0" required />
                      </div>
                    </div>
                    <label class="toggle-line" for="gift-active">
                      <input id="gift-active" type="checkbox" checked />
                      <span class="switch" aria-hidden="true"></span>
                      <span>Visible en tienda</span>
                    </label>
                    <p class="info-note">Este regalo no tiene precio y se asigna automáticamente cuando el pedido cumple con la condición configurada.</p>
                  </div>

                  <div class="image-panel">
                    <div id="gift-image-preview" class="image-preview"><img id="gift-image-preview-img" alt="Vista previa del regalo" /><span>Regalo</span></div>
                    <input id="gift-image" class="file-input" type="file" accept="image/*" />
                    <button id="change-gift-image-btn" class="btn btn-soft full" type="button">Cambiar imagen</button>
                    <p class="image-help">PNG, JPG o WEBP. Máx. 2MB.<br />Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                  </div>
                </div>
                <div class="form-actions">
                  <button class="btn btn-primary" type="submit">Guardar regalo</button>
                  <button id="cancel-edit-btn" class="btn btn-soft hidden" type="button">Cancelar</button>
                </div>
              </form>
            </div>

            <aside class="gift-modal-rail">
              <section class="panel-card preview-card">
                <div class="list-head">
                  <div>
                    <h2 class="list-title">Vista previa</h2>
                  </div>
                </div>
                <div id="preview-image" class="preview-image"><img id="preview-img" alt="Vista previa del regalo" /><span>Regalo</span></div>
                <div class="preview-body">
                  <h3 id="preview-name" class="preview-title">Nuevo regalo</h3>
                  <p id="preview-min" class="preview-meta">Desde 0.00 USD</p>
                  <span id="preview-active" class="badge visible">Visible</span>
                </div>
              </section>

              <section class="panel-card panel-pad">
                <h2 class="panel-title">Estado y resumen</h2>
                <div class="summary-list" style="margin-top:12px;">
                  <div class="summary-row"><span>Visibilidad</span><strong id="summary-visible">Visible</strong></div>
                  <div class="summary-row"><span>Stock</span><strong id="summary-stock">0 unidades</strong></div>
                  <div class="summary-row"><span>Regla de activación</span><strong id="summary-rule">Desde 0.00 USD</strong></div>
                  <div class="summary-row"><span>Total regalos activos</span><strong id="summary-active-total">0</strong></div>
                </div>
              </section>
            </aside>
          </div>
        </div>
      </section>
    </div>

    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      function quotePb(value) { return String(value || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"'); }
      const STORE_FILTER = CURRENT_STORE_ID ? `store="${quotePb(CURRENT_STORE_ID)}"` : '';
      const ACTIVE_STORE_FILTER = CURRENT_STORE_ID ? `active=true && ${STORE_FILTER}` : 'active=true';
      const giftModal = document.getElementById('gift-modal');
      const giftForm = document.getElementById('gift-form');
      const giftsList = document.getElementById('gifts-list');
      const alertBox = document.getElementById('alert');
      const logoutBtn = document.getElementById('logout-btn');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const sidebar = document.getElementById('admin-sidebar');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarCloseBtn = document.getElementById('sidebar-close');
      const refreshBtn = document.getElementById('refresh-btn');
      const saveSettingsBtn = document.getElementById('save-settings-btn');
      const giftsCategoryInlineCard = document.getElementById('gifts-category-inline-card');
      const toggleGiftsCategoryCardBtn = document.getElementById('toggle-gifts-category-card-btn');
      const closeGiftsCategoryInlineBtn = document.getElementById('close-gifts-category-inline-btn');
      const giftsCategoryStatus = document.getElementById('gifts-category-status');
      const giftsPagination = document.getElementById('gifts-pagination');
      const formTitle = document.getElementById('form-title');
      const cancelEditBtn = document.getElementById('cancel-edit-btn');
      const categoryPreview = document.getElementById('category-preview');
      const categoryPreviewImg = document.getElementById('category-preview-img');
      const giftSearch = document.getElementById('gift-search');
      const giftStatusFilter = document.getElementById('gift-status-filter');
      const giftImageInput = document.getElementById('gift-image');
      const giftImagePreview = document.getElementById('gift-image-preview');
      const giftImagePreviewImg = document.getElementById('gift-image-preview-img');
      const giftSubmitBtn = giftForm?.querySelector('button[type="submit"]');
      const giftNameInput = document.getElementById('gift-name');
      const giftDescriptionInput = document.getElementById('gift-description');
      const giftStockInput = document.getElementById('gift-stock');
      const giftMinInput = document.getElementById('gift-min');
      const giftActiveInput = document.getElementById('gift-active');
      const changeGiftImageBtn = document.getElementById('change-gift-image-btn');
      const giftsPublicActiveInput = document.getElementById('gifts-public-active');
      const giftsPublicTitleInput = document.getElementById('gifts-public-title');
      const giftsPublicImageInput = document.getElementById('gifts-public-image');
      const previewImage = document.getElementById('preview-image');
      const previewImg = document.getElementById('preview-img');
      const previewName = document.getElementById('preview-name');
      const previewMin = document.getElementById('preview-min');
      const previewActive = document.getElementById('preview-active');
      const summaryVisible = document.getElementById('summary-visible');
      const summaryStock = document.getElementById('summary-stock');
      const summaryRule = document.getElementById('summary-rule');
      const summaryActiveTotal = document.getElementById('summary-active-total');
      const closeGiftModalBtn = document.getElementById('close-gift-modal-btn');
      const GIFTS_PER_PAGE = 10;
      let gifts = [];
      let filteredGifts = [];
      let giftsPage = 1;
      let settings = null;
      let localGiftImageUrl = '';
      let editingGiftImageUrl = '';
      let localGiftsCategoryImageUrl = '';
      let giftAlertTimer = null;
      let giftImageChanged = false;
      let giftSaving = false;
      let giftInitialSnapshot = null;
      let giftsCategoryImageChanged = false;
      let giftsCategorySaving = false;
      let giftsCategoryInitialSnapshot = null;

      const token = () => ADMIN_AUTH_TOKEN;
      function openSidebar(){ document.body.classList.add('sidebar-open'); if(sidebarOverlay) sidebarOverlay.hidden = false; sidebar?.setAttribute('aria-hidden','false'); sidebarOpenBtn?.setAttribute('aria-expanded','true'); }
      function closeSidebar(){ document.body.classList.remove('sidebar-open'); sidebar?.setAttribute('aria-hidden','true'); sidebarOpenBtn?.setAttribute('aria-expanded','false'); setTimeout(()=>{ if(!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true; }, 220); }
      function showAlert(message, type='info'){
        if(!alertBox) return;
        if(giftAlertTimer){
          window.clearTimeout(giftAlertTimer);
          giftAlertTimer = null;
        }
        alertBox.textContent=message || '';
        alertBox.className=`alert alert-${type}`;
        alertBox.classList.toggle('hidden', !message);
        const timeout = type === 'ok' || type === 'success' ? 2800 : type === 'error' ? 4800 : 0;
        if(timeout && message){
          giftAlertTimer = window.setTimeout(()=>{
            alertBox.classList.add('hidden');
            giftAlertTimer = null;
          }, timeout);
        }
      }
      function escapeHtml(value){ return String(value || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;'); }
      function normalizeFile(value){ return Array.isArray(value) ? value[0] : value; }
      function fileUrl(record){ const file = normalizeFile(record?.image); return file ? `${POCKETBASE_URL}/api/files/gifts/${record.id}/${file}` : 'https://placehold.co/640x360?text=Regalo'; }
      function thumbUrl(record){ const file = normalizeFile(record?.image); return file ? `${POCKETBASE_URL}/api/files/gifts/${record.id}/${file}?thumb=120x120` : 'https://placehold.co/120x120?text=Regalo'; }
      function settingsFileUrl(field){ const file = normalizeFile(settings?.[field]); return settings?.id && file ? `${POCKETBASE_URL}/api/files/settings/${settings.id}/${file}?thumb=300x200` : ''; }
      function money(value){ return Number(value || 0).toFixed(2); }
      function activeGiftCount(){ return gifts.filter((gift) => gift.active !== false).length; }

      function giftFormSnapshot(){
        return {
          name: String(giftNameInput?.value || '').trim(),
          description: String(giftDescriptionInput?.value || '').trim(),
          stock: Math.max(0, Math.floor(Number(giftStockInput?.value || 0))),
          min_order_usd: Number(Number(giftMinInput?.value || 0).toFixed(2)),
          active: giftActiveInput?.checked !== false,
          imageChanged: Boolean(giftImageChanged),
        };
      }

      function isGiftFormValid(){
        return Boolean(String(giftNameInput?.value || '').trim());
      }

      function hasGiftChanges(){
        const id = document.getElementById('gift-id')?.value || '';
        if(!id) return isGiftFormValid();
        if(!giftInitialSnapshot) return false;
        const current = giftFormSnapshot();
        return current.name !== giftInitialSnapshot.name
          || current.description !== giftInitialSnapshot.description
          || current.stock !== giftInitialSnapshot.stock
          || current.min_order_usd !== giftInitialSnapshot.min_order_usd
          || current.active !== giftInitialSnapshot.active
          || current.imageChanged;
      }

      function syncGiftSubmitState(){
        if(!giftSubmitBtn) return;
        if(!giftSubmitBtn.dataset.defaultText) giftSubmitBtn.dataset.defaultText = giftSubmitBtn.textContent || 'Guardar regalo';
        giftSubmitBtn.disabled = giftSaving || !isGiftFormValid() || !hasGiftChanges();
        giftSubmitBtn.textContent = giftSaving ? 'Guardando...' : giftSubmitBtn.dataset.defaultText;
      }

      function updateGiftImageButton(){
        if(!changeGiftImageBtn) return;
        changeGiftImageBtn.textContent = localGiftImageUrl || editingGiftImageUrl ? 'Cambiar imagen' : 'Subir nueva foto';
      }

      function setGiftInitialSnapshot(){
        giftInitialSnapshot = giftFormSnapshot();
        giftInitialSnapshot.imageChanged = false;
        syncGiftSubmitState();
      }

      function giftsCategorySnapshot(){
        return {
          active: giftsPublicActiveInput?.checked !== false,
          title: String(giftsPublicTitleInput?.value || '').trim() || 'Regalos',
          imageChanged: Boolean(giftsCategoryImageChanged),
        };
      }

      function hasGiftsCategoryChanges(){
        if(!giftsCategoryInitialSnapshot) return false;
        const current = giftsCategorySnapshot();
        return current.active !== giftsCategoryInitialSnapshot.active
          || current.title !== giftsCategoryInitialSnapshot.title
          || current.imageChanged;
      }

      function syncGiftsCategorySubmitState(){
        if(!saveSettingsBtn) return;
        if(!saveSettingsBtn.dataset.defaultText) saveSettingsBtn.dataset.defaultText = saveSettingsBtn.textContent || 'Guardar categoría';
        saveSettingsBtn.disabled = giftsCategorySaving || !hasGiftsCategoryChanges();
        saveSettingsBtn.textContent = giftsCategorySaving ? 'Guardando...' : saveSettingsBtn.dataset.defaultText;
      }

      function setGiftsCategoryInitialSnapshot(){
        giftsCategoryInitialSnapshot = giftsCategorySnapshot();
        giftsCategoryInitialSnapshot.imageChanged = false;
        syncGiftsCategorySubmitState();
      }

      function clearLocalGiftsCategoryImageUrl(){
        if(localGiftsCategoryImageUrl){
          URL.revokeObjectURL(localGiftsCategoryImageUrl);
          localGiftsCategoryImageUrl = '';
        }
      }

      function renderGiftsCategoryPreview(url = ''){
        categoryPreview?.classList.toggle('hidden', !url);
        if(categoryPreviewImg) categoryPreviewImg.src = url || '';
      }

      async function optimizeGiftImageFile(file) {
        if (!file || !file.type?.startsWith('image/')) return file;
        if (file.type === 'image/gif') return file;
        let objectUrl = '';
        try {
          const image = await new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve(img);
            img.onerror = reject;
            objectUrl = URL.createObjectURL(file);
            img.src = objectUrl;
          });

          const targetWidth = 1200;
          const targetHeight = 675;
          const sourceWidth = image.naturalWidth || image.width;
          const sourceHeight = image.naturalHeight || image.height;
          const scale = Math.min(targetWidth / sourceWidth, targetHeight / sourceHeight, 1);
          const drawWidth = Math.max(1, Math.round(sourceWidth * scale));
          const drawHeight = Math.max(1, Math.round(sourceHeight * scale));
          const dx = Math.round((targetWidth - drawWidth) / 2);
          const dy = Math.round((targetHeight - drawHeight) / 2);

          const canvas = document.createElement('canvas');
          canvas.width = targetWidth;
          canvas.height = targetHeight;
          const ctx = canvas.getContext('2d');
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          ctx.fillStyle = '#f8fbff';
          ctx.fillRect(0, 0, targetWidth, targetHeight);
          ctx.drawImage(image, 0, 0, sourceWidth, sourceHeight, dx, dy, drawWidth, drawHeight);

          const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/webp', 0.82));
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          if (!blob) return file;
          const safeName = String(file.name || 'regalo').replace(/\.[^.]+$/, '').replace(/[^a-z0-9_-]+/gi, '_').toLowerCase();
          return new File([blob], `${safeName}_regalo_1200x675.webp`, { type: 'image/webp', lastModified: Date.now() });
        } catch (error) {
          if (objectUrl) URL.revokeObjectURL(objectUrl);
          console.warn('No se pudo optimizar la imagen de regalos. Se usará la original.', error);
          return file;
        }
      }

      async function api(path, options = {}){
        const headers = { ...(options.headers || {}) };
        if (token()) headers.Authorization = `Bearer ${token()}`;
        const res = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const data = await res.json().catch(() => null);
        if(!res.ok) throw new Error(data?.message || 'Error de comunicación con PocketBase.');
        return data;
      }

      async function createStoreSettings(){
        await api('/api/collections/settings/records', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ active:true, store:CURRENT_STORE_ID, store_name:'PowerZona', gifts_public_active:true, gifts_public_title:'Regalos' }) });
      }

      async function loadSettings(){
        const filter = encodeURIComponent(ACTIVE_STORE_FILTER);
        const result = await api(`/api/collections/settings/records?filter=${filter}&sort=-updated&perPage=1`);
        settings = result.items?.[0] || null;
        if(!settings && CURRENT_STORE_ID){
          await createStoreSettings();
          return loadSettings();
        }
        const publicActive = giftsPublicActiveInput;
        const publicTitle = giftsPublicTitleInput;
        if(publicActive) publicActive.checked = settings?.gifts_public_active !== false;
        if(publicTitle) publicTitle.value = settings?.gifts_public_title || 'Regalos';
        if(giftsCategoryStatus){
          const visible = settings?.gifts_public_active !== false;
          giftsCategoryStatus.textContent = visible ? 'Visible' : 'Oculta';
          giftsCategoryStatus.className = `badge ${visible ? 'visible' : 'hidden-badge'}`;
        }
        const preview = settingsFileUrl('gifts_public_image');
        renderGiftsCategoryPreview(preview);
        giftsCategoryImageChanged = false;
        setGiftsCategoryInitialSnapshot();
      }

      async function loadGifts(){
        if(giftsList) giftsList.innerHTML = '<div class="empty"><strong>Cargando regalos...</strong></div>';
        const result = await api(`/api/collections/gifts/records?filter=${encodeURIComponent(STORE_FILTER)}&sort=sort_order,name&perPage=200`);
        gifts = result.items || [];
        renderStats();
        applyGiftFilters(false);
        renderPreview();
      }

      function renderStats(){
        const setText = (id, value) => { const el = document.getElementById(id); if(el) el.textContent = String(value); };
        setText('stat-total', gifts.length);
        setText('stat-active', activeGiftCount());
        setText('stat-stockout', gifts.filter((gift) => Number(gift.stock || 0) <= 0).length);
        setText('stat-rules', gifts.filter((gift) => Number(gift.min_order_usd || 0) > 0).length);
        if(summaryActiveTotal) summaryActiveTotal.textContent = String(activeGiftCount());
      }

      function applyGiftFilters(resetPage = true){
        const query = String(giftSearch?.value || '').trim().toLowerCase();
        const status = giftStatusFilter?.value || 'all';
        filteredGifts = gifts.filter((gift) => {
          const matchesQuery = !query || String(`${gift.name || ''} ${gift.description || ''}`).toLowerCase().includes(query);
          const isActive = gift.active !== false;
          const isStockout = Number(gift.stock || 0) <= 0;
          const matchesStatus = status === 'all' || (status === 'active' && isActive) || (status === 'hidden' && !isActive) || (status === 'stockout' && isStockout);
          return matchesQuery && matchesStatus;
        });
        if(resetPage) giftsPage = 1;
        renderGifts();
      }

      function renderGifts(){
        if(!giftsList) return;
        closeGiftMenu();
        if(giftsPagination) giftsPagination.classList.add('hidden');
        if(!gifts.length){
          giftsList.innerHTML = '<div class="empty"><strong>Aún no tienes regalos creados.</strong><span>Crea tu primer regalo para que aparezca cuando el pedido cumpla la condición configurada.</span><button class="btn btn-primary js-empty-new-gift" type="button">Nuevo regalo</button></div>';
          document.querySelector('.js-empty-new-gift')?.addEventListener('click', openNewGiftModal);
          return;
        }
        if(!filteredGifts.length){
          giftsList.innerHTML = '<div class="empty"><strong>No hay regalos con esos filtros.</strong><span>Ajusta la búsqueda o el estado para ver más resultados.</span></div>';
          return;
        }
        const totalPages = Math.max(1, Math.ceil(filteredGifts.length / GIFTS_PER_PAGE));
        if(giftsPage > totalPages) giftsPage = totalPages;
        if(giftsPage < 1) giftsPage = 1;
        const pageStart = (giftsPage - 1) * GIFTS_PER_PAGE;
        const visibleGifts = filteredGifts.slice(pageStart, pageStart + GIFTS_PER_PAGE);
        giftsList.innerHTML = visibleGifts.map((gift) => {
          const orderIndex = gifts.findIndex((item) => item.id === gift.id);
          const description = gift.description || `Desde ${money(gift.min_order_usd)} USD`;
          return `
            <article class="gift-row">
              <div class="gift-main">
                <img class="gift-thumb" src="${escapeHtml(thumbUrl(gift))}" alt="${escapeHtml(gift.name || 'Regalo')}" />
                <div style="min-width:0;">
                  <h3 class="gift-name">${escapeHtml(gift.name || 'Regalo sin nombre')}</h3>
                  <p class="gift-desc">${escapeHtml(description)}</p>
                </div>
              </div>
              <div class="gift-cell">Desde ${money(gift.min_order_usd)} USD</div>
              <div class="gift-cell">${Number(gift.stock || 0)}</div>
              <span class="badge ${gift.active !== false ? 'visible' : 'hidden-badge'}">${gift.active !== false ? 'Visible' : 'Oculto'}</span>
              <div class="gift-actions">
                <button class="mini-btn dark edit-gift" data-id="${gift.id}" type="button">Editar</button>
                <button class="mini-btn toggle-gift" data-id="${gift.id}" type="button">${gift.active !== false ? 'Ocultar' : 'Mostrar'}</button>
                <button class="mini-btn move-gift" data-id="${gift.id}" data-dir="up" type="button" ${orderIndex === 0 ? 'disabled' : ''} title="Subir" aria-label="Subir regalo">↑</button>
                <button class="mini-btn move-gift" data-id="${gift.id}" data-dir="down" type="button" ${orderIndex === gifts.length - 1 ? 'disabled' : ''} title="Bajar" aria-label="Bajar regalo">↓</button>
                <div class="gift-menu-wrap">
                  <button class="mini-btn gift-menu-btn" data-id="${gift.id}" type="button" aria-label="Más acciones">...</button>
                  <div id="gift-menu-${gift.id}" class="gift-menu">
                    <button class="edit-gift" data-id="${gift.id}" type="button">Editar</button>
                    <button class="danger delete-gift" data-id="${gift.id}" type="button">Borrar</button>
                  </div>
                </div>
              </div>
            </article>`;
        }).join('');
        document.querySelectorAll('.toggle-gift').forEach((btn)=>btn.addEventListener('click',()=>toggleGift(btn.dataset.id)));
        document.querySelectorAll('.move-gift').forEach((btn)=>btn.addEventListener('click',()=>moveGift(btn.dataset.id, btn.dataset.dir)));
        document.querySelectorAll('.edit-gift').forEach((btn)=>btn.addEventListener('click',()=>editGift(btn.dataset.id)));
        document.querySelectorAll('.delete-gift').forEach((btn)=>btn.addEventListener('click',()=>deleteGift(btn.dataset.id)));
        document.querySelectorAll('.gift-menu-btn').forEach((btn)=>btn.addEventListener('click',(event)=>{ event.stopPropagation(); openGiftMenu(btn.dataset.id); }));
        renderGiftsPagination(totalPages);
      }

      function renderGiftsPagination(totalPages){
        if(!giftsPagination) return;
        if(totalPages <= 1){
          giftsPagination.classList.add('hidden');
          giftsPagination.innerHTML = '';
          return;
        }
        const pages = totalPages <= 5
          ? Array.from({ length: totalPages }, (_, index) => index + 1)
          : [];
        giftsPagination.classList.remove('hidden');
        giftsPagination.innerHTML = `
          <button class="mini-btn js-gifts-page-prev" type="button" ${giftsPage <= 1 ? 'disabled' : ''}>Anterior</button>
          <span class="pagination-text">Página ${giftsPage} de ${totalPages}</span>
          ${pages.length ? `<span class="pagination-pages">${pages.map((page) => `<button class="mini-btn pagination-page ${page === giftsPage ? 'active' : ''}" data-page="${page}" type="button">${page}</button>`).join('')}</span>` : ''}
          <button class="mini-btn js-gifts-page-next" type="button" ${giftsPage >= totalPages ? 'disabled' : ''}>Siguiente</button>
        `;
        giftsPagination.querySelector('.js-gifts-page-prev')?.addEventListener('click', () => { giftsPage -= 1; renderGifts(); });
        giftsPagination.querySelector('.js-gifts-page-next')?.addEventListener('click', () => { giftsPage += 1; renderGifts(); });
        giftsPagination.querySelectorAll('.pagination-page').forEach((btn) => btn.addEventListener('click', () => {
          giftsPage = Number(btn.dataset.page || 1);
          renderGifts();
        }));
      }

      function setPreviewImage(url){
        const hasImage = Boolean(url);
        giftImagePreview?.classList.toggle('has-image', hasImage);
        previewImage?.classList.toggle('has-image', hasImage);
        if(giftImagePreviewImg) giftImagePreviewImg.src = hasImage ? url : '';
        if(previewImg) previewImg.src = hasImage ? url : '';
      }

      function renderPreview(){
        const name = document.getElementById('gift-name')?.value.trim() || 'Nuevo regalo';
        const min = Number(document.getElementById('gift-min')?.value || 0);
        const stock = Math.max(0, Math.floor(Number(document.getElementById('gift-stock')?.value || 0)));
        const active = document.getElementById('gift-active')?.checked !== false;
        if(previewName) previewName.textContent = name;
        if(previewMin) previewMin.textContent = `Desde ${money(min)} USD`;
        if(previewActive){
          previewActive.textContent = active ? 'Visible' : 'Oculto';
          previewActive.className = `badge ${active ? 'visible' : 'hidden-badge'}`;
        }
        if(summaryVisible) summaryVisible.textContent = active ? 'Visible' : 'Oculto';
        if(summaryStock) summaryStock.textContent = `${stock} unidades`;
        if(summaryRule) summaryRule.textContent = `Desde ${money(min)} USD`;
        if(summaryActiveTotal) summaryActiveTotal.textContent = String(activeGiftCount());
        setPreviewImage(localGiftImageUrl || editingGiftImageUrl);
        updateGiftImageButton();
        syncGiftSubmitState();
      }

      function clearLocalImageUrl(){
        if(localGiftImageUrl){
          URL.revokeObjectURL(localGiftImageUrl);
          localGiftImageUrl = '';
        }
      }

      function focusGiftForm(){
        setTimeout(()=>document.getElementById('gift-name')?.focus(), 80);
      }

      function openGiftModal(){
        closeGiftMenu();
        closeSidebar();
        giftModal?.classList.remove('hidden');
        giftModal?.setAttribute('aria-hidden', 'false');
        document.body.classList.add('gift-modal-open');
        focusGiftForm();
      }

      function closeGiftModal(){
        giftModal?.classList.add('hidden');
        giftModal?.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('gift-modal-open');
      }

      function openGiftsCategoryInlineCard(){
        giftsCategoryInlineCard?.classList.remove('hidden');
        if(toggleGiftsCategoryCardBtn) toggleGiftsCategoryCardBtn.textContent = 'Cerrar';
        setTimeout(()=>giftsCategoryInlineCard?.scrollIntoView({ behavior:'smooth', block:'nearest' }), 80);
      }

      function closeGiftsCategoryInlineCard(){
        giftsCategoryInlineCard?.classList.add('hidden');
        if(toggleGiftsCategoryCardBtn) toggleGiftsCategoryCardBtn.textContent = 'Configurar';
      }

      function toggleGiftsCategoryInlineCard(){
        if(giftsCategoryInlineCard?.classList.contains('hidden')) openGiftsCategoryInlineCard();
        else closeGiftsCategoryInlineCard();
      }

      function resetGiftForm(){
        giftForm?.reset();
        clearLocalImageUrl();
        editingGiftImageUrl = '';
        giftImageChanged = false;
        giftInitialSnapshot = null;
        const idInput = document.getElementById('gift-id');
        if(idInput) idInput.value='';
        const activeInput = document.getElementById('gift-active');
        if(activeInput) activeInput.checked=true;
        const minInput = document.getElementById('gift-min');
        if(minInput) minInput.value='0';
        const stockInput = document.getElementById('gift-stock');
        if(stockInput) stockInput.value='0';
        if(formTitle) formTitle.textContent='Nuevo regalo';
        cancelEditBtn?.classList.add('hidden');
        renderPreview();
      }

      function resetForm(){ resetGiftForm(); }

      function openNewGiftModal(){
        resetGiftForm();
        openGiftModal();
      }

      function editGift(id){
        const gift = gifts.find((item)=>item.id===id);
        if(!gift) return;
        clearLocalImageUrl();
        giftImageChanged = false;
        editingGiftImageUrl = normalizeFile(gift.image) ? fileUrl(gift) : '';
        document.getElementById('gift-id').value=gift.id;
        document.getElementById('gift-name').value=gift.name||'';
        document.getElementById('gift-description').value=gift.description||'';
        document.getElementById('gift-min').value=Number(gift.min_order_usd||0);
        document.getElementById('gift-stock').value=Number(gift.stock||0);
        document.getElementById('gift-active').checked=gift.active!==false;
        if(giftImageInput) giftImageInput.value = '';
        if(formTitle) formTitle.textContent='Editar regalo';
        cancelEditBtn?.classList.remove('hidden');
        renderPreview();
        setGiftInitialSnapshot();
        openGiftModal();
      }

      async function saveGift(event){
        event.preventDefault();
        if(giftSaving) return;
        if(!isGiftFormValid()){
          showAlert('Escribe el nombre del regalo.', 'error');
          syncGiftSubmitState();
          return;
        }
        if(!hasGiftChanges()){
          syncGiftSubmitState();
          return;
        }
        giftSaving = true;
        syncGiftSubmitState();
        try {
          const id = document.getElementById('gift-id').value;
          const fd = new FormData();
          fd.set('name', giftNameInput.value.trim());
          fd.set('description', giftDescriptionInput.value.trim());
          fd.set('min_order_usd', String(Math.max(0, Number(giftMinInput.value || 0))));
          fd.set('stock', String(Math.max(0, Math.floor(Number(giftStockInput.value || 0)))));
          if(!id) fd.set('sort_order', String(nextSortOrder()));
          fd.set('active', giftActiveInput.checked ? 'true' : 'false');
          const image = giftImageInput?.files?.[0];
          if(image) fd.append('image', await optimizeGiftImageFile(image));
          fd.set('store', CURRENT_STORE_ID);
          if(id) await api(`/api/collections/gifts/records/${id}`, { method:'PATCH', body:fd });
          else await api('/api/collections/gifts/records', { method:'POST', body:fd });
          if(giftImageInput) giftImageInput.value = '';
          clearLocalImageUrl();
          giftImageChanged = false;
          closeGiftModal();
          resetGiftForm();
          await loadGifts();
          showAlert('Regalo guardado correctamente', 'ok');
        } catch (error) {
          console.error(error);
          showAlert(error.message || 'No se pudo guardar el regalo', 'error');
        } finally {
          giftSaving = false;
          syncGiftSubmitState();
        }
      }

      function nextSortOrder(){ return gifts.length ? Math.max(...gifts.map((gift)=>Number(gift.sort_order || 0))) + 10 : 10; }
      async function normalizeGiftOrder(){ await Promise.all(gifts.map((gift, index)=>api(`/api/collections/gifts/records/${gift.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:(index + 1) * 10 }) }))); await loadGifts(); }
      async function moveGift(id, direction){ const index = gifts.findIndex((gift)=>gift.id === id); if(index < 0) return; const targetIndex = direction === 'up' ? index - 1 : index + 1; if(targetIndex < 0 || targetIndex >= gifts.length) return; const current = gifts[index]; const target = gifts[targetIndex]; const currentOrder = Number(current.sort_order || 0); const targetOrder = Number(target.sort_order || 0); if(currentOrder === targetOrder){ await normalizeGiftOrder(); return moveGift(id, direction); } await Promise.all([ api(`/api/collections/gifts/records/${current.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:targetOrder }) }), api(`/api/collections/gifts/records/${target.id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sort_order:currentOrder }) }), ]); await loadGifts(); }
      async function toggleGift(id){ const gift = gifts.find((item)=>item.id === id); if(!gift) return; await api(`/api/collections/gifts/records/${id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ active: gift.active === false }) }); await loadGifts(); showAlert(gift.active !== false ? 'Regalo ocultado.' : 'Regalo visible.', 'ok'); }
      async function deleteGift(id){ if(!confirm('¿Seguro que deseas borrar este regalo?')) return; await api(`/api/collections/gifts/records/${id}`, { method:'DELETE' }); await loadGifts(); showAlert('Regalo borrado.', 'ok'); }

      async function saveSettings(){
        if(!settings?.id){ showAlert('No hay settings activo para guardar la categoría pública.', 'error'); return; }
        try {
          if(saveSettingsBtn) { saveSettingsBtn.disabled = true; saveSettingsBtn.textContent = 'Guardando...'; }
          const fd = new FormData();
          fd.set('gifts_public_active', document.getElementById('gifts-public-active').checked ? 'true' : 'false');
          fd.set('gifts_public_title', document.getElementById('gifts-public-title').value.trim() || 'Regalos');
          const image = document.getElementById('gifts-public-image').files?.[0];
          if(image) fd.append('gifts_public_image', await optimizeGiftImageFile(image));
          await api(`/api/collections/settings/records/${settings.id}`, { method:'PATCH', body:fd });
          document.getElementById('gifts-public-image').value = '';
          await loadSettings();
          closeGiftsCategoryInlineCard();
          showAlert('Categoría pública de regalos actualizada.', 'ok');
        } catch (error) {
          console.error(error);
          showAlert(error.message || 'No se pudo guardar la categoría pública de regalos.', 'error');
        } finally {
          if(saveSettingsBtn) { saveSettingsBtn.disabled = false; saveSettingsBtn.textContent = 'Guardar categoría'; }
        }
      }

      async function saveSettingsSmart(){
        if(!settings?.id){ showAlert('No se pudo guardar la categoria de regalos', 'error'); return; }
        if(giftsCategorySaving) return;
        if(!hasGiftsCategoryChanges()){
          syncGiftsCategorySubmitState();
          return;
        }
        giftsCategorySaving = true;
        syncGiftsCategorySubmitState();
        try {
          const fd = new FormData();
          fd.set('gifts_public_active', giftsPublicActiveInput.checked ? 'true' : 'false');
          fd.set('gifts_public_title', giftsPublicTitleInput.value.trim() || 'Regalos');
          const image = giftsPublicImageInput?.files?.[0];
          if(image) fd.append('gifts_public_image', await optimizeGiftImageFile(image));
          await api(`/api/collections/settings/records/${settings.id}`, { method:'PATCH', body:fd });
          if(giftsPublicImageInput) giftsPublicImageInput.value = '';
          clearLocalGiftsCategoryImageUrl();
          giftsCategoryImageChanged = false;
          await loadSettings();
          closeGiftsCategoryInlineCard();
          showAlert('Categoria de regalos actualizada correctamente', 'ok');
        } catch (error) {
          console.error(error);
          showAlert(error.message || 'No se pudo guardar la categoria de regalos', 'error');
        } finally {
          giftsCategorySaving = false;
          syncGiftsCategorySubmitState();
        }
      }

      function openGiftMenu(id){
        document.querySelectorAll('.gift-menu').forEach((menu)=>menu.classList.toggle('open', menu.id === `gift-menu-${id}` && !menu.classList.contains('open')));
      }
      function closeGiftMenu(){ document.querySelectorAll('.gift-menu.open').forEach((menu)=>menu.classList.remove('open')); }

      async function boot(){
        if(!POCKETBASE_URL){ showAlert('Falta PUBLIC_POCKETBASE_URL en .env', 'error'); return; }
        if(!ADMIN_AUTH_TOKEN){ showAlert('Tu sesión no está disponible. Vuelve a iniciar sesión.', 'error'); return; }
        try{
          await loadSettings();
          await loadGifts();
        } catch(error){
          console.error(error);
          showAlert(error.message || 'No se pudieron cargar los datos de esta tienda.', 'error');
        }
      }

      giftForm?.addEventListener('submit', saveGift);
      cancelEditBtn?.addEventListener('click', closeGiftModal);
      closeGiftModalBtn?.addEventListener('click', closeGiftModal);
      giftModal?.addEventListener('click', (event) => {
        if(event.target === giftModal) closeGiftModal();
      });
      toggleGiftsCategoryCardBtn?.addEventListener('click', toggleGiftsCategoryInlineCard);
      closeGiftsCategoryInlineBtn?.addEventListener('click', closeGiftsCategoryInlineCard);
      refreshBtn?.addEventListener('click', loadGifts);
      saveSettingsBtn?.addEventListener('click', saveSettingsSmart);
      logoutBtn?.addEventListener('click', ()=>{ window.location.href = publicStorePath; });
      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarCloseBtn?.addEventListener('click', closeSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      giftSearch?.addEventListener('input', () => applyGiftFilters(true));
      giftStatusFilter?.addEventListener('change', () => applyGiftFilters(true));
      document.querySelectorAll('.js-new-gift').forEach((btn)=>btn.addEventListener('click', openNewGiftModal));
      document.getElementById('change-gift-image-btn')?.addEventListener('click', ()=>giftImageInput?.click());
      giftImageInput?.addEventListener('change', () => {
        clearLocalImageUrl();
        const file = giftImageInput.files?.[0];
        giftImageChanged = Boolean(file);
        if(file) localGiftImageUrl = URL.createObjectURL(file);
        renderPreview();
      });
      ['gift-name', 'gift-description', 'gift-min', 'gift-stock', 'gift-active'].forEach((id)=>document.getElementById(id)?.addEventListener('input', renderPreview));
      document.getElementById('gift-active')?.addEventListener('change', renderPreview);
      giftsPublicActiveInput?.addEventListener('change', syncGiftsCategorySubmitState);
      giftsPublicTitleInput?.addEventListener('input', syncGiftsCategorySubmitState);
      giftsPublicImageInput?.addEventListener('change', () => {
        clearLocalGiftsCategoryImageUrl();
        const file = giftsPublicImageInput.files?.[0];
        giftsCategoryImageChanged = Boolean(file);
        if(file){
          localGiftsCategoryImageUrl = URL.createObjectURL(file);
          renderGiftsCategoryPreview(localGiftsCategoryImageUrl);
        } else {
          renderGiftsCategoryPreview(settingsFileUrl('gifts_public_image'));
        }
        syncGiftsCategorySubmitState();
      });
      syncGiftSubmitState();
      syncGiftsCategorySubmitState();
      document.addEventListener('click', closeGiftMenu);
      document.addEventListener('keydown', (event)=>{
        if(event.key !== 'Escape') return;
        if(!giftModal?.classList.contains('hidden')) closeGiftModal();
        closeGiftMenu();
        closeSidebar();
      });
      sidebar?.querySelectorAll('a').forEach((link)=>link.addEventListener('click', closeSidebar));
      boot();
    </script>
  </body>
</html>
