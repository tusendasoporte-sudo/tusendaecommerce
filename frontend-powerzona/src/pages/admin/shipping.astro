---
const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Envíos | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page:#eef3f9; --surface:#fff; --soft:#f8fafc; --text:#0f172a; --muted:#64748b; --border:#e2e8f0;
        --blue:#2563eb; --green:#16a34a; --red:#dc2626; --orange:#f97316; --shadow:0 18px 45px rgba(15,23,42,.08);
      }
      *{box-sizing:border-box} html,body{margin:0;min-height:100%} body{color:var(--text);background:radial-gradient(circle at 14% 0%,rgba(37,99,235,.16),transparent 30%),radial-gradient(circle at 85% 8%,rgba(22,163,74,.10),transparent 25%),linear-gradient(180deg,#f8fbff 0%,var(--page) 48%,#e8eef7 100%)}
      a{color:inherit;text-decoration:none} button,input,select,textarea{font:inherit} button{cursor:pointer} button:disabled{cursor:not-allowed;opacity:.65}.hidden{display:none!important}
      .app-shell{width:min(1480px,100%);margin:0 auto;padding:24px}.sidebar-overlay{position:fixed;inset:0;z-index:80;background:rgba(15,23,42,.36);opacity:0;pointer-events:none;transition:opacity .22s ease;backdrop-filter:blur(2px)}body.sidebar-open .sidebar-overlay{opacity:1;pointer-events:auto}.sidebar{position:fixed;top:18px;left:18px;bottom:18px;z-index:90;width:min(286px,calc(100vw - 36px));border-radius:30px;padding:18px;background:linear-gradient(180deg,#fff 0%,#f8fafc 100%);border:1px solid rgba(226,232,240,.95);box-shadow:0 28px 80px rgba(15,23,42,.22);overflow:hidden auto;transform:translateX(calc(-100% - 36px));transition:transform .24s ease}body.sidebar-open .sidebar{transform:translateX(0)}.sidebar-inner{display:flex;flex-direction:column;min-height:100%}.brand{display:flex;align-items:center;gap:11px;padding:8px 8px 18px;border-bottom:1px solid #e2e8f0;margin-bottom:14px}.brand-logo{width:42px;height:42px;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;background:#0f172a;color:#fff;font-weight:1000;box-shadow:0 14px 30px rgba(15,23,42,.18)}.brand-title{margin:0;font-size:15px;font-weight:1000;letter-spacing:-.02em}.brand-subtitle{margin:2px 0 0;color:#64748b;font-size:11px;font-weight:850}.sidebar-close{margin-left:auto;width:36px;height:36px;border-radius:14px;border:1px solid #e2e8f0;background:#fff;color:#0f172a;font-weight:1000}.sidebar-label{margin:18px 9px 9px;color:#64748b;font-size:10px;font-weight:1000;text-transform:uppercase;letter-spacing:.12em}.nav-list{display:grid;gap:8px}.nav-item{display:flex;align-items:center;gap:11px;padding:11px 12px;border-radius:18px;color:#334155;font-size:13px;font-weight:950;border:1px solid transparent}.nav-item:hover{background:#f1f5f9;border-color:#e2e8f0;color:#0f172a}.nav-item.active{background:#0f172a;border-color:#0f172a;color:#fff;box-shadow:0 12px 26px rgba(15,23,42,.16)}.nav-icon{width:34px;height:34px;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:#f8fafc;color:#0f172a;border:1px solid #e2e8f0;flex:0 0 auto}.nav-icon svg{width:18px;height:18px;display:block;fill:currentColor}.nav-item.active .nav-icon{background:rgba(255,255,255,.12);color:#fff;border-color:rgba(255,255,255,.20)}
      .main-wrap{min-width:0;padding:2px 0 28px}.topbar{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:18px;flex-wrap:wrap}.menu-btn,.action-btn,.mini-btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;border-radius:16px;padding:11px 14px;background:rgba(255,255,255,.92);border:1px solid rgba(226,232,240,.95);box-shadow:0 12px 26px rgba(15,23,42,.07);font-weight:950}.menu-btn,.mini-btn.primary,.action-btn.dark{background:#0f172a;color:#fff;border-color:#0f172a}.mini-btn.danger,.action-btn.danger{background:#fee2e2;color:#991b1b;border-color:#fecaca}.mini-btn.green{background:#dcfce7;color:#166534;border-color:#bbf7d0}.hero-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end}.hero-card,.panel-card,.list-card{background:rgba(255,255,255,.92);border:1px solid rgba(226,232,240,.96);border-radius:30px;box-shadow:var(--shadow);backdrop-filter:blur(10px)}.hero-card{padding:26px;margin-bottom:18px;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:18px;align-items:center;position:relative;overflow:hidden}.badge{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:8px 12px;background:#dcfce7;color:#166534;font-size:13px;font-weight:1000}.page-title{font-size:clamp(25px,3vw,40px);font-weight:1000;letter-spacing:-.045em;line-height:1.05;margin:14px 0 0}.page-title span{color:#334155;font-weight:800}.page-subtitle{margin:9px 0 0;font-size:15px;color:var(--muted);line-height:1.55;max-width:820px}.panel-card{padding:22px;margin-bottom:18px}.login-card{max-width:520px;margin:28px auto}.section-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:16px;flex-wrap:wrap}.section-title{margin:0;font-size:21px;font-weight:1000;letter-spacing:-.03em}.section-subtitle{margin:5px 0 0;color:#64748b;font-size:13px;font-weight:750;line-height:1.45}.stats-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-bottom:18px}.stat-card{background:rgba(255,255,255,.92);border:1px solid #e2e8f0;border-radius:26px;padding:18px;box-shadow:0 12px 28px rgba(15,23,42,.06)}.stat-label{margin:0;color:#64748b;font-size:12px;font-weight:950;text-transform:uppercase;letter-spacing:.04em}.stat-value{margin:7px 0 0;font-size:28px;font-weight:1000;letter-spacing:-.04em}.form-grid{display:grid;gap:12px}.shipping-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.full{grid-column:1/-1}.field{display:grid;gap:7px}.field label{color:#334155;font-size:12px;font-weight:950;text-transform:uppercase;letter-spacing:.04em}.field input,.field select,.field textarea{width:100%;border:1px solid var(--border);border-radius:16px;background:#fff;color:var(--text);padding:12px 13px;outline:none;font-weight:800}.field textarea{min-height:92px;resize:vertical;line-height:1.45}.check-row{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:900;color:#334155}.check-row input{width:auto}.form-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;margin-top:4px}.alert{margin-top:12px;border-radius:16px;padding:11px 12px;font-size:13px;font-weight:850;line-height:1.45}.alert-info{background:#eff6ff;color:#1e40af;border:1px solid #bfdbfe}.alert-success{background:#dcfce7;color:#166534;border:1px solid #bbf7d0}.alert-error{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}.filter-row{display:grid;grid-template-columns:minmax(0,1fr) 190px auto;gap:12px;align-items:end;margin-bottom:16px}.municipality-group{border:1px solid #e2e8f0;border-radius:24px;background:#fff;overflow:visible;margin-bottom:14px;position:relative}.municipality-group.menu-open-card{z-index:10010}.municipality-head{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:15px 16px;background:#f8fafc;border-radius:24px;transition:background .18s ease}.municipality-group.expanded .municipality-head{border-bottom:1px solid #e2e8f0;border-radius:24px 24px 0 0}.municipality-toggle{width:100%;border:0;background:transparent;color:inherit;padding:0;display:flex;align-items:center;justify-content:space-between;gap:12px;text-align:left;cursor:pointer}.municipality-main{display:flex;align-items:center;gap:12px;min-width:0}.municipality-chevron{width:34px;height:34px;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #e2e8f0;color:#0f172a;font-weight:1000;flex:0 0 auto;transition:transform .18s ease}.municipality-group.expanded .municipality-chevron{transform:rotate(180deg)}.municipality-name{font-weight:1000;letter-spacing:-.02em}.municipality-count{font-size:12px;font-weight:950;color:#64748b}.municipality-actions{display:none;gap:10px;justify-content:flex-end;flex-wrap:wrap}.municipality-group.expanded .municipality-actions{display:flex}.zone-list{display:none;gap:0}.municipality-group.expanded .zone-list{display:grid}.zone-row{display:grid;grid-template-columns:minmax(0,1.2fr) 130px 100px auto;gap:12px;align-items:center;padding:14px 16px;border-bottom:1px solid #f1f5f9;position:relative}.zone-row.menu-open{z-index:10020}.zone-row:last-child{border-bottom:0}.zone-title{font-weight:1000;color:#0f172a}.zone-note{margin:3px 0 0;color:#64748b;font-size:12px;font-weight:750}.price-pill{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:8px 10px;background:#eff6ff;color:#1d4ed8;font-size:13px;font-weight:1000}.status-pill{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:8px 10px;font-size:12px;font-weight:1000}.status-pill.active{background:#dcfce7;color:#166534}.status-pill.inactive{background:#fee2e2;color:#991b1b}.row-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}.zone-menu-wrap{position:relative;display:flex;justify-content:flex-end;z-index:2}.zone-menu-wrap.open{z-index:10030}.kebab-btn{width:42px;height:42px;border-radius:16px;border:1px solid #e2e8f0;background:#fff;color:#0f172a;box-shadow:0 10px 22px rgba(15,23,42,.07);font-size:20px;font-weight:1000;line-height:1;display:inline-flex;align-items:center;justify-content:center}.kebab-btn:hover{background:#f8fafc}.floating-menu{position:absolute;right:0;top:calc(100% + 8px);z-index:10040;min-width:176px;border-radius:18px;padding:7px;background:#fff;border:1px solid #e2e8f0;box-shadow:0 24px 60px rgba(15,23,42,.18);display:none}.floating-menu.drop-up{top:auto;bottom:calc(100% + 8px)}.zone-menu-wrap.open .floating-menu{display:grid;gap:5px}.menu-action{width:100%;border:0;background:transparent;color:#334155;border-radius:13px;padding:10px 11px;text-align:left;font-size:13px;font-weight:950;display:flex;align-items:center;gap:8px}.menu-action:hover{background:#f8fafc;color:#0f172a}.menu-action.danger{color:#991b1b}.menu-action.danger:hover{background:#fee2e2}.menu-action.green{color:#166534}.menu-action.green:hover{background:#dcfce7}.empty-state{padding:26px;border-radius:24px;background:#f8fafc;border:1px dashed #cbd5e1;color:#64748b;font-weight:850;text-align:center}.muted{color:#64748b}.hide-mobile{display:inline}.show-mobile{display:none}.shipping-modal{position:fixed;inset:0;z-index:12000;display:flex;align-items:center;justify-content:center;padding:18px;background:rgba(15,23,42,.42);backdrop-filter:blur(4px)}.shipping-modal.hidden{display:none!important}.modal-card{width:min(560px,100%);max-height:calc(100vh - 36px);overflow:auto;background:#fff;border:1px solid #e2e8f0;border-radius:28px;box-shadow:0 32px 90px rgba(15,23,42,.28);padding:22px}.modal-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:16px}.modal-title{margin:0;font-size:21px;font-weight:1000;letter-spacing:-.03em}.modal-subtitle{margin:5px 0 0;color:#64748b;font-size:13px;font-weight:750;line-height:1.45}.modal-close{width:40px;height:40px;border-radius:15px;border:1px solid #e2e8f0;background:#fff;color:#0f172a;font-weight:1000}.collapsed-panel.hidden{display:none!important}
      @media (max-width:900px){.hero-card{grid-template-columns:1fr}.stats-grid{grid-template-columns:1fr 1fr}.filter-row{grid-template-columns:1fr}.zone-row{grid-template-columns:1fr;gap:9px}.row-actions,.zone-menu-wrap{justify-content:flex-start}.floating-menu{left:0;right:auto}.hide-mobile{display:none}.show-mobile{display:inline}}
      @media (max-width:620px){.app-shell{padding:14px}.sidebar{top:12px;left:12px;bottom:12px;width:calc(100vw - 24px);border-radius:26px}.hero-card,.panel-card{border-radius:24px;padding:18px}.stats-grid,.shipping-form-grid{grid-template-columns:1fr}.topbar{align-items:stretch}.menu-btn,.action-btn{width:100%}.hero-actions{width:100%;justify-content:stretch}.hero-actions>*{flex:1}.page-title{font-size:28px}.municipality-head{align-items:stretch;flex-direction:column}.municipality-toggle{align-items:flex-start}.municipality-actions{justify-content:stretch}.municipality-actions .mini-btn{width:100%}.zone-row{padding:14px}.form-actions{justify-content:stretch}.form-actions button{width:100%}}
    </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay"></div>
    <div class="app-shell">
      <aside id="admin-sidebar" class="sidebar" aria-label="Panel lateral de administración" aria-hidden="true">
        <div class="sidebar-inner">
          <div class="brand">
            <span class="brand-logo">PZ</span>
            <div><p class="brand-title">PowerZona</p><p class="brand-subtitle">Panel administrativo</p></div>
            <button id="sidebar-close" class="sidebar-close" type="button" aria-label="Cerrar menú">×</button>
          </div>
          <p class="sidebar-label">Principal</p>
          <nav class="nav-list">
            <a class="nav-item" href="/admin"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"/></svg></span><span>Resumen</span></a>
            <a class="nav-item" href="/admin/orders"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Zm3 5h6V6H9v2Zm0 4h6v-2H9v2Zm0 4h4v-2H9v2Z"/></svg></span><span>Pedidos</span></a>
            <a class="nav-item" href="/admin/catalog"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3V6Zm0 5h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7Z"/></svg></span><span>Categorías</span></a>
            <a class="nav-item" href="/admin/products"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 7.5 12 3 3 7.5l9 4.5 9-4.5ZM5 10.7V17l6 3v-6.3l-6-3Zm8 9.3 6-3v-6.3l-6 3V20Z"/></svg></span><span>Productos</span></a>
            <a class="nav-item" href="/admin/gifts"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Regalos</span></a>
            <a class="nav-item active" href="/admin/shipping"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Zm2 0v7.17A3 3 0 0 1 8.83 16H13V7H5Zm12 6h2v1h-2v-1ZM6 17a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/></svg></span><span>Envíos</span></a>
            <a class="nav-item" href="/admin/store-settings"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a8 8 0 0 0-2.6-1.5L14 2h-4l-.4 3a8 8 0 0 0-2.6 1.5l-2.4-1-2 3.5 2 1.5A9 9 0 0 0 4.5 12c0 .5 0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a8 8 0 0 0 2.6 1.5l.4 3h4l.4-3a8 8 0 0 0 2.6-1.5l2.4 1 2-3.5-2-1.5ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z"/></svg></span><span>Ajustes de tienda</span></a>
          </nav>
          <p class="sidebar-label">Divisiones</p>
          <nav class="nav-list">
            <a class="nav-item" href="/admin/promos"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7M3 8h18v4H3V8ZM12 21V8M12 8H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm0 0h3.5A2.5 2.5 0 1 0 13 5.5L12 8Z"/></svg></span><span>Crear Producto/Promo</span></a>
            <a class="nav-item" href="/admin/organization"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v4H5V4Zm0 6h9v4H5v-4Zm0 6h14v4H5v-4Z"/></svg></span><span>Organización Visual</span></a>
          </nav>
        </div>
      </aside>
      <main class="main-wrap">
        <header class="topbar">
          <button id="sidebar-open" class="menu-btn" type="button" aria-controls="admin-sidebar" aria-expanded="false">☰ Menú</button>
          <div class="hero-actions">
            <a class="action-btn" href="/admin/orders">Pedidos</a>
            <a class="action-btn" href="/checkout">Ver checkout</a>
            <button id="logout-btn" class="action-btn danger hidden" type="button">Cerrar sesión</button>
          </div>
        </header>
        <section class="hero-card">
          <div>
            <span class="badge">🚚 Envíos</span>
            <h1 class="page-title">Municipios y zonas <span>de entrega</span></h1>
            <p class="page-subtitle">Administra municipios, zonas y un precio único de envío por zona para usarlo en el checkout.</p>
          </div>
          <div class="hero-actions"><button id="new-zone-top-btn" class="action-btn dark" type="button" aria-expanded="false">Agregar envío</button></div>
        </section>
        <section id="login-view" class="panel-card login-card hidden">
          <h2 class="section-title">Entrar como admin</h2>
          <p class="section-subtitle">Usa el mismo usuario administrador de PocketBase para administrar envíos.</p>
          <form id="login-form" class="form-grid" style="margin-top:18px;">
            <div class="field"><label for="admin-email">Email</label><input id="admin-email" type="email" autocomplete="username" required /></div>
            <div class="field"><label for="admin-password">Contraseña</label><input id="admin-password" type="password" autocomplete="current-password" required /></div>
            <button class="mini-btn primary" type="submit">Entrar al panel</button>
            <div id="login-alert" class="alert alert-error hidden"></div>
          </form>
        </section>
        <section id="admin-view" class="hidden">
          <div class="stats-grid">
            <article class="stat-card"><p class="stat-label">Municipios</p><p id="stat-municipalities" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Zonas activas</p><p id="stat-active-zones" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Costo promedio</p><p id="stat-average-price" class="stat-value">$0.00</p></article>
          </div>
          <section class="panel-card collapsed-panel hidden" id="form-panel">
            <div class="section-head">
              <div><h2 id="form-title" class="section-title">Agregar envío</h2><p id="form-subtitle" class="section-subtitle">Crea un municipio y su zona inicial con precio único de entrega en USD.</p></div>
              <button id="cancel-edit-btn" class="mini-btn hidden" type="button">Cancelar edición</button>
            </div>
            <form id="shipping-form" class="shipping-form-grid">
              <div class="field"><label for="municipality-input">Municipio</label><input id="municipality-input" type="text" placeholder="Nombre del municipio" required /></div>
              <div class="field"><label for="zone-input">Zona</label><input id="zone-input" type="text" placeholder="Nombre de la zona" /></div>
              <div class="field"><label for="price-input">Precio único USD</label><input id="price-input" type="text" inputmode="decimal" placeholder="Ej: 3" required /></div>
              <div class="field"><label for="active-input">Estado</label><label class="check-row"><input id="active-input" type="checkbox" checked /> Activo en checkout</label></div>
              <div class="field full"><label for="note-input">Nota interna opcional</label><textarea id="note-input" placeholder="Detalles internos para el administrador"></textarea></div>
              <div class="form-actions full"><button id="save-zone-btn" class="mini-btn primary" type="submit">Guardar zona</button></div>
            </form>
            <div id="form-alert" class="alert alert-info hidden"></div>
          </section>
          <section class="panel-card">
            <div class="section-head">
              <div><h2 class="section-title">Zonas configuradas</h2><p class="section-subtitle">Las zonas activas aparecen en el checkout público. Las ocultas quedan guardadas para uso futuro.</p></div>
              <button id="refresh-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <div class="filter-row">
              <div class="field"><label for="search-input">Buscar</label><input id="search-input" type="search" placeholder="Municipio, zona o nota" /></div>
              <div class="field"><label for="status-filter">Estado</label><select id="status-filter"><option value="all">Todas</option><option value="active">Activas</option><option value="inactive">Ocultas</option></select></div>
              <button id="clear-filters-btn" class="mini-btn" type="button">Limpiar</button>
            </div>
            <div id="zones-list"></div>
            <div id="list-alert" class="alert alert-info hidden"></div>
          </section>
          <section id="zone-modal" class="shipping-modal hidden" aria-hidden="true">
            <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="zone-modal-title">
              <div class="modal-head">
                <div>
                  <h2 id="zone-modal-title" class="modal-title">Agregar zona</h2>
                  <p id="zone-modal-subtitle" class="modal-subtitle">Nueva zona para el municipio seleccionado.</p>
                </div>
                <button id="zone-modal-close" class="modal-close" type="button" aria-label="Cerrar">×</button>
              </div>
              <form id="zone-modal-form" class="form-grid">
                <input id="zone-modal-municipality" type="hidden" />
                <div class="field"><label for="zone-modal-zone">Zona</label><input id="zone-modal-zone" type="text" placeholder="Nombre de la zona" required /></div>
                <div class="field"><label for="zone-modal-price">Precio único USD</label><input id="zone-modal-price" type="text" inputmode="decimal" placeholder="Ej: 3" required /></div>
                <label class="check-row"><input id="zone-modal-active" type="checkbox" checked /> Activo en checkout</label>
                <div class="field"><label for="zone-modal-note">Nota interna opcional</label><textarea id="zone-modal-note" placeholder="Detalles internos para el administrador"></textarea></div>
                <div class="form-actions">
                  <button id="zone-modal-cancel" class="mini-btn" type="button">Cancelar</button>
                  <button class="mini-btn primary" type="submit">Guardar zona</button>
                </div>
                <div id="zone-modal-alert" class="alert alert-info hidden"></div>
              </form>
            </div>
          </section>
        </section>
      </main>
    </div>
    <script define:vars={{ pocketbaseUrl }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const AUTH_TOKEN_KEY = 'powerzona_admin_token';
      const AUTH_MODEL_KEY = 'powerzona_admin_model';
      const sidebarOpen = document.getElementById('sidebar-open');
      const sidebarClose = document.getElementById('sidebar-close');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const logoutBtn = document.getElementById('logout-btn');
      const loginView = document.getElementById('login-view');
      const adminView = document.getElementById('admin-view');
      const loginForm = document.getElementById('login-form');
      const loginAlert = document.getElementById('login-alert');
      const form = document.getElementById('shipping-form');
      const formTitle = document.getElementById('form-title');
      const formSubtitle = document.getElementById('form-subtitle');
      const formAlert = document.getElementById('form-alert');
      const listAlert = document.getElementById('list-alert');
      const zonesList = document.getElementById('zones-list');
      const refreshBtn = document.getElementById('refresh-btn');
      const cancelEditBtn = document.getElementById('cancel-edit-btn');
      const newZoneTopBtn = document.getElementById('new-zone-top-btn');
      const searchInput = document.getElementById('search-input');
      const statusFilter = document.getElementById('status-filter');
      const clearFiltersBtn = document.getElementById('clear-filters-btn');
      const zoneModal = document.getElementById('zone-modal');
      const zoneModalForm = document.getElementById('zone-modal-form');
      const zoneModalClose = document.getElementById('zone-modal-close');
      const zoneModalCancel = document.getElementById('zone-modal-cancel');
      const zoneModalSubtitle = document.getElementById('zone-modal-subtitle');
      const zoneModalAlert = document.getElementById('zone-modal-alert');
      const zoneModalFields = {
        municipality: document.getElementById('zone-modal-municipality'),
        zone: document.getElementById('zone-modal-zone'),
        price: document.getElementById('zone-modal-price'),
        active: document.getElementById('zone-modal-active'),
        note: document.getElementById('zone-modal-note'),
      };
      const fields = {
        municipality: document.getElementById('municipality-input'),
        zone: document.getElementById('zone-input'),
        price: document.getElementById('price-input'),
        active: document.getElementById('active-input'),
        note: document.getElementById('note-input'),
      };
      let shippingZones = [];
      let editingId = '';
      const expandedMunicipalities = new Set();
      function token(){return localStorage.getItem(AUTH_TOKEN_KEY)||'';}
      function showAlert(element,message='',type='info'){
        if(!element)return;
        if(!message){element.className='alert alert-info hidden';element.textContent='';return;}
        element.className='alert alert-'+type;element.textContent=message;
      }
      function escapeHtml(value){return String(value||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');}
      function formatUSD(value){return '$'+Number(value||0).toFixed(2)+' USD';}
      function openSidebar(){document.body.classList.add('sidebar-open');sidebarOpen?.setAttribute('aria-expanded','true');}
      function closeSidebar(){document.body.classList.remove('sidebar-open');sidebarOpen?.setAttribute('aria-expanded','false');}
      sidebarOpen?.addEventListener('click',openSidebar);sidebarClose?.addEventListener('click',closeSidebar);sidebarOverlay?.addEventListener('click',closeSidebar);document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){closeSidebar();closeZoneModal();}});
      async function api(path,options={}){
        if(!POCKETBASE_URL)throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el frontend.');
        const headers=Object.assign({},options.headers||{});
        if(token())headers.Authorization='Bearer '+token();
        const response=await fetch(POCKETBASE_URL+path,Object.assign({},options,{headers}));
        const result=await response.json().catch(()=>null);
        if(!response.ok)throw new Error((result&&result.message)||'Error de comunicación con PocketBase.');
        return result;
      }
      async function loginAsAdmin(email,password){
        const payload={identity:email,password};
        try{
          const result=await api('/api/collections/_superusers/auth-with-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          localStorage.setItem(AUTH_TOKEN_KEY,result.token);localStorage.setItem(AUTH_MODEL_KEY,JSON.stringify(result.record||{}));return;
        }catch(error){
          const result=await api('/api/admins/auth-with-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          localStorage.setItem(AUTH_TOKEN_KEY,result.token);localStorage.setItem(AUTH_MODEL_KEY,JSON.stringify(result.admin||{}));
        }
      }
      function showAdmin(){loginView.classList.add('hidden');adminView.classList.remove('hidden');logoutBtn.classList.remove('hidden');loadZones().catch((error)=>showAlert(listAlert,error.message||'No se pudieron cargar los envíos.','error'));}
      function showLogin(){adminView.classList.add('hidden');loginView.classList.remove('hidden');logoutBtn.classList.add('hidden');}
      function getPayload(){
        const municipality=fields.municipality.value.trim();
        const zone=fields.zone.value.trim();
        const priceRaw=String(fields.price.value||'').replace(',', '.').trim();
        const price=Number(priceRaw||0);
        if(municipality.length<2)throw new Error('Escribe el municipio.');
        if(!Number.isFinite(price)||price<0)throw new Error('Escribe un precio único USD válido.');
        return {municipality,zone,price_usd:price,active:fields.active.checked,note:fields.note.value.trim()};
      }
      function showMainForm(){document.getElementById('form-panel').classList.remove('hidden');newZoneTopBtn?.setAttribute('aria-expanded','true');if(newZoneTopBtn)newZoneTopBtn.textContent='Cerrar panel';}
      function hideMainForm(){document.getElementById('form-panel').classList.add('hidden');newZoneTopBtn?.setAttribute('aria-expanded','false');if(newZoneTopBtn)newZoneTopBtn.textContent='Agregar envío';}
      function resetForm(){editingId='';form.reset();fields.active.checked=true;formTitle.textContent='Agregar envío';formSubtitle.textContent='Crea un municipio y su zona inicial con precio único de entrega en USD.';cancelEditBtn.classList.add('hidden');document.getElementById('save-zone-btn').textContent='Guardar envío';showAlert(formAlert,'');}
      function fillForm(zone){editingId=zone.id;showMainForm();fields.municipality.value=zone.municipality||'';fields.zone.value=zone.zone||'';fields.price.value=Number(zone.price_usd||0).toString();fields.active.checked=zone.active!==false;fields.note.value=zone.note||'';formTitle.textContent='Editar zona de envío';formSubtitle.textContent='Modifica municipio, zona, precio único o estado.';cancelEditBtn.classList.remove('hidden');document.getElementById('save-zone-btn').textContent='Guardar cambios';document.getElementById('form-panel').scrollIntoView({behavior:'smooth',block:'start'});}
      function openZoneModal(municipality){closeZoneMenus();zoneModalForm.reset();zoneModalFields.active.checked=true;zoneModalFields.municipality.value=municipality||'';zoneModalSubtitle.textContent='Nueva zona para '+(municipality||'el municipio seleccionado')+'.';showAlert(zoneModalAlert,'');zoneModal.classList.remove('hidden');zoneModal.setAttribute('aria-hidden','false');setTimeout(()=>zoneModalFields.zone.focus(),60);}
      function closeZoneModal(){zoneModal.classList.add('hidden');zoneModal.setAttribute('aria-hidden','true');showAlert(zoneModalAlert,'');}
      function getZoneModalPayload(){const municipality=zoneModalFields.municipality.value.trim();const zone=zoneModalFields.zone.value.trim();const priceRaw=String(zoneModalFields.price.value||'').replace(',', '.').trim();const price=Number(priceRaw||0);if(municipality.length<2)throw new Error('Falta el municipio.');if(zone.length<2)throw new Error('Escribe el nombre de la zona.');if(!Number.isFinite(price)||price<0)throw new Error('Escribe un precio único USD válido.');return {municipality,zone,price_usd:price,active:zoneModalFields.active.checked,note:zoneModalFields.note.value.trim()};}
      async function saveZoneFromModal(event){event.preventDefault();showAlert(zoneModalAlert,'');const payload=getZoneModalPayload();await api('/api/collections/shipping_zones/records',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});showAlert(zoneModalAlert,'Zona agregada correctamente.','success');closeZoneModal();await loadZones();}
      async function saveZone(event){
        event.preventDefault();showAlert(formAlert,'');
        const payload=getPayload();
        if(editingId){
          await api('/api/collections/shipping_zones/records/'+editingId,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          showAlert(formAlert,'Zona actualizada correctamente.','success');
        }else{
          await api('/api/collections/shipping_zones/records',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          showAlert(formAlert,'Envío agregado correctamente.','success');
        }
        resetForm();hideMainForm();await loadZones();
      }
      async function loadZones(){
        showAlert(listAlert,'');
        const result=await api('/api/collections/shipping_zones/records?sort=municipality,zone&perPage=500');
        shippingZones=result.items||[];renderStats();renderZones();
      }
      function renderStats(){
        const municipalities=new Set(shippingZones.map((zone)=>String(zone.municipality||'').trim()).filter(Boolean));
        const active=shippingZones.filter((zone)=>zone.active!==false);
        const avg=active.length?active.reduce((sum,zone)=>sum+Number(zone.price_usd||0),0)/active.length:0;
        document.getElementById('stat-municipalities').textContent=String(municipalities.size);
        document.getElementById('stat-active-zones').textContent=String(active.length);
        document.getElementById('stat-average-price').textContent=formatUSD(avg).replace(' USD','');
      }
      function filteredZones(){
        const q=String(searchInput.value||'').trim().toLowerCase();
        const status=statusFilter.value;
        return shippingZones.filter((zone)=>{
          const isActive=zone.active!==false;
          if(status==='active'&&!isActive)return false;
          if(status==='inactive'&&isActive)return false;
          if(!q)return true;
          return [zone.municipality,zone.zone,zone.note].some((value)=>String(value||'').toLowerCase().includes(q));
        });
      }
      function groupByMunicipality(items){
        return items.reduce((groups,zone)=>{const key=zone.municipality||'Sin municipio';if(!groups[key])groups[key]=[];groups[key].push(zone);return groups;},{});
      }
      function renderZones(){
        const items=filteredZones();
        if(!items.length){zonesList.innerHTML='<div class="empty-state">No hay zonas de envío con esos filtros.</div>';return;}
        const groups=groupByMunicipality(items);
        zonesList.innerHTML=Object.keys(groups).sort((a,b)=>a.localeCompare(b)).map((municipality)=>{
          const zones=groups[municipality];
          const activeCount=zones.filter((zone)=>zone.active!==false).length;
          const isExpanded=expandedMunicipalities.has(municipality);
          return `<section class="municipality-group ${isExpanded?'expanded':''}" data-municipality="${escapeHtml(municipality)}"><div class="municipality-head"><button class="municipality-toggle js-toggle-municipality" type="button" aria-expanded="${isExpanded?'true':'false'}"><span class="municipality-main"><span class="municipality-chevron">⌄</span><span><span class="municipality-name">${escapeHtml(municipality)}</span><span class="municipality-count">${zones.length} zona${zones.length===1?'':'s'} · ${activeCount} activa${activeCount===1?'':'s'}</span></span></span></button><div class="municipality-actions"><button class="mini-btn js-add-same" data-municipality="${escapeHtml(municipality)}" type="button">Agregar nueva zona</button></div></div><div class="zone-list">${zones.map(renderZoneRow).join('')}</div></section>`;
        }).join('');
      }
      function renderZoneRow(zone){
        const isActive=zone.active!==false;
        return `<article class="zone-row" data-zone-id="${zone.id}"><div><div class="zone-title">${escapeHtml(zone.zone||zone.municipality||'Zona general')}</div>${zone.note?`<p class="zone-note">${escapeHtml(zone.note)}</p>`:''}</div><div><span class="price-pill">${formatUSD(zone.price_usd)}</span></div><div><span class="status-pill ${isActive?'active':'inactive'}">${isActive?'Activa':'Oculta'}</span></div><div class="zone-menu-wrap"><button class="kebab-btn js-menu" type="button" aria-label="Abrir opciones" aria-expanded="false">⋯</button><div class="floating-menu" role="menu"><button class="menu-action js-edit" type="button" role="menuitem">✏️ Editar</button><button class="menu-action ${isActive?'danger':'green'} js-toggle" type="button" role="menuitem">${isActive?'🙈 Ocultar':'✅ Activar'}</button><button class="menu-action danger js-delete" type="button" role="menuitem">🗑️ Borrar</button></div></div></article>`;
      }
      function closeZoneMenus(except=null){
        zonesList.querySelectorAll('.zone-menu-wrap.open').forEach((menu)=>{
          if(menu===except)return;
          menu.classList.remove('open');
          menu.closest('.zone-row')?.classList.remove('menu-open');
          menu.closest('.municipality-group')?.classList.remove('menu-open-card');
          menu.querySelector('.floating-menu')?.classList.remove('drop-up');
          menu.querySelector('.js-menu')?.setAttribute('aria-expanded','false');
        });
      }
      function positionZoneMenu(menuWrap){
        if(!menuWrap)return;
        const floatingMenu=menuWrap.querySelector('.floating-menu');
        const trigger=menuWrap.querySelector('.js-menu');
        if(!floatingMenu||!trigger)return;
        floatingMenu.classList.remove('drop-up');
        requestAnimationFrame(()=>{
          const menuHeight=floatingMenu.offsetHeight||150;
          const triggerRect=trigger.getBoundingClientRect();
          const availableBelow=window.innerHeight-triggerRect.bottom;
          const availableAbove=triggerRect.top;
          if(availableBelow<menuHeight+18&&availableAbove>menuHeight+18){
            floatingMenu.classList.add('drop-up');
          }
        });
      }
      function toggleZoneMenu(menuWrap){
        if(!menuWrap)return;
        const willOpen=!menuWrap.classList.contains('open');
        closeZoneMenus(menuWrap);
        menuWrap.classList.toggle('open',willOpen);
        menuWrap.closest('.zone-row')?.classList.toggle('menu-open',willOpen);
        menuWrap.closest('.municipality-group')?.classList.toggle('menu-open-card',willOpen);
        menuWrap.querySelector('.js-menu')?.setAttribute('aria-expanded',willOpen?'true':'false');
        if(willOpen)positionZoneMenu(menuWrap);
      }
      zonesList.addEventListener('click',(event)=>{
        const municipalityToggle=event.target.closest('.js-toggle-municipality');
        if(municipalityToggle){
          const group=municipalityToggle.closest('.municipality-group');
          const municipality=group?.dataset.municipality||'';
          const willOpen=!group?.classList.contains('expanded');
          if(willOpen)expandedMunicipalities.add(municipality);else expandedMunicipalities.delete(municipality);
          group?.classList.toggle('expanded',willOpen);
          municipalityToggle.setAttribute('aria-expanded',willOpen?'true':'false');
          closeZoneMenus();
          return;
        }
        const menuBtn=event.target.closest('.js-menu');
        if(menuBtn){
          toggleZoneMenu(menuBtn.closest('.zone-menu-wrap'));
          return;
        }
        const addBtn=event.target.closest('.js-add-same');
        if(addBtn){openZoneModal(addBtn.dataset.municipality||'');return;}
        const row=event.target.closest('[data-zone-id]');
        if(!row)return;
        const zone=shippingZones.find((item)=>item.id===row.dataset.zoneId);
        if(!zone)return;
        if(event.target.closest('.js-edit')){closeZoneMenus();fillForm(zone);return;}
        if(event.target.closest('.js-toggle')){
          closeZoneMenus();
          api('/api/collections/shipping_zones/records/'+zone.id,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({active:zone.active===false})})
            .then(loadZones).catch((error)=>showAlert(listAlert,error.message||'No se pudo cambiar el estado.','error'));
          return;
        }
        if(event.target.closest('.js-delete')){
          closeZoneMenus();
          const ok=window.confirm('¿Borrar esta zona de envío?');
          if(!ok)return;
          api('/api/collections/shipping_zones/records/'+zone.id,{method:'DELETE'})
            .then(()=>{if(editingId===zone.id)resetForm();return loadZones();})
            .catch((error)=>showAlert(listAlert,error.message||'No se pudo borrar la zona.','error'));
        }
      });
      document.addEventListener('click',(event)=>{if(!event.target.closest('.zone-menu-wrap'))closeZoneMenus();});
      form.addEventListener('submit',(event)=>saveZone(event).catch((error)=>showAlert(formAlert,error.message||'No se pudo guardar la zona.','error')));
      cancelEditBtn.addEventListener('click',()=>{resetForm();hideMainForm();});
      newZoneTopBtn.addEventListener('click',()=>{const panel=document.getElementById('form-panel');const willOpen=panel.classList.contains('hidden');resetForm();if(willOpen){showMainForm();panel.scrollIntoView({behavior:'smooth',block:'start'});}else{hideMainForm();}});
      zoneModalForm.addEventListener('submit',(event)=>saveZoneFromModal(event).catch((error)=>showAlert(zoneModalAlert,error.message||'No se pudo guardar la zona.','error')));
      zoneModalClose.addEventListener('click',closeZoneModal);
      zoneModalCancel.addEventListener('click',closeZoneModal);
      zoneModal.addEventListener('click',(event)=>{if(event.target===zoneModal)closeZoneModal();});
      refreshBtn.addEventListener('click',()=>loadZones().catch((error)=>showAlert(listAlert,error.message||'No se pudieron cargar los envíos.','error')));
      searchInput.addEventListener('input',renderZones);statusFilter.addEventListener('change',renderZones);clearFiltersBtn.addEventListener('click',()=>{searchInput.value='';statusFilter.value='all';renderZones();});
      loginForm.addEventListener('submit',async(event)=>{event.preventDefault();showAlert(loginAlert,'');try{await loginAsAdmin(document.getElementById('admin-email').value.trim(),document.getElementById('admin-password').value);showAdmin();}catch(error){showAlert(loginAlert,error.message||'No se pudo iniciar sesión.','error');}});
      logoutBtn.addEventListener('click',()=>{localStorage.removeItem(AUTH_TOKEN_KEY);localStorage.removeItem(AUTH_MODEL_KEY);showLogin();});
      if(token())showAdmin();else showLogin();
    </script>
  </body>
</html>
