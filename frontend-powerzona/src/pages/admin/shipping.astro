---
import { refreshAuthFromCookie } from '../../lib/auth';
import { getPublicStorePath, getStoreAdminPath } from '../../lib/adminRoutes';
import { requireCurrentStoreForAdmin } from '../../lib/storeContext';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const authPb = await refreshAuthFromCookie(Astro.request.headers.get('cookie') || '');
const adminContext = await requireCurrentStoreForAdmin(authPb);
const currentStoreId = adminContext.storeId;
const adminAuthToken = authPb.authStore.token;
const currentStoreSlug = adminContext.store.slug || '';
const currentStoreName = adminContext.store.name || adminContext.store.title || currentStoreSlug || 'Tienda';
const adminBasePath = getStoreAdminPath(currentStoreSlug);
const adminCatalogPath = getStoreAdminPath(currentStoreSlug, 'catalog');
const adminProductsPath = getStoreAdminPath(currentStoreSlug, 'products');
const adminOrdersPath = getStoreAdminPath(currentStoreSlug, 'orders');
const adminStoreSettingsPath = getStoreAdminPath(currentStoreSlug, 'store-settings');
const adminGiftsPath = getStoreAdminPath(currentStoreSlug, 'gifts');
const adminShippingPath = getStoreAdminPath(currentStoreSlug, 'shipping');
const adminPromosPath = getStoreAdminPath(currentStoreSlug, 'promos');
const adminOrganizationPath = getStoreAdminPath(currentStoreSlug, 'organization');
const publicStorePath = getPublicStorePath(currentStoreSlug);
const masterSupportWhatsapp = String(import.meta.env.PUBLIC_MASTER_SUPPORT_WHATSAPP || '').replace(/[^0-9]/g, '');
const masterSupportEmail = String(import.meta.env.PUBLIC_MASTER_SUPPORT_EMAIL || '').trim();
const supportMessage = `Hola soporte de Tu Senda 84, necesito ayuda con el admin de envios de la tienda ${currentStoreName} (${currentStoreSlug || 'sin-slug'}).`;
const masterSupportHref = masterSupportWhatsapp
  ? `https://wa.me/${masterSupportWhatsapp}?text=${encodeURIComponent(supportMessage)}`
  : (masterSupportEmail ? `mailto:${masterSupportEmail}?subject=${encodeURIComponent('Soporte Envios Tu Senda 84')}&body=${encodeURIComponent(supportMessage)}` : '');
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Env&iacute;os | PowerZona</title>
    <link rel="icon" href="/favicon.ico?v=2" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --blue: #2563eb;
        --green: #16a34a;
        --orange: #f97316;
        --red: #dc2626;
        --shadow: 0 18px 45px rgba(15, 23, 42, .08);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, .16), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, .10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }

      a { color: inherit; text-decoration: none; }
      button, input, select, textarea { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .62; }
      .hidden { display: none !important; }

      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .nav-list { display: grid; gap: 8px; }
      .support-card { padding: 14px; border-radius: 20px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .support-title { display: block; margin: 0 0 12px; font-size: 12px; font-weight: 900; color: #0f172a; }
      .support-text { display: block; margin: 0 0 12px; color: #334155; font-size: 12px; font-weight: 850; }
      .support-btn { width: 100%; min-height: 40px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border-radius: 16px; border: 1px solid #dbeafe; background: #fff; color: #2563eb; font-size: 12px; font-weight: 1000; }

      .main-wrap { min-width: 0; padding: 2px 0 96px; }
      .mobile-topbar { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
      .mobile-topbar-title { margin: 0; font-size: 24px; font-weight: 1000; letter-spacing: -.03em; flex: 1; }
      .icon-btn, .menu-btn, .mini-btn, .primary-blue-btn, .notification-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        border-radius: 16px;
        border: 1px solid rgba(226, 232, 240, .95);
        background: rgba(255, 255, 255, .92);
        color: #0f172a;
        box-shadow: 0 12px 26px rgba(15, 23, 42, .07);
        font-weight: 950;
      }
      .icon-btn { width: 46px; height: 46px; padding: 0; box-shadow: none; }
      .icon-btn svg, .mini-btn svg, .primary-blue-btn svg, .notification-btn svg, .bottom-nav svg { width: 18px; height: 18px; fill: currentColor; }
      .mini-btn { min-height: 42px; padding: 10px 14px; }
      .mini-btn.primary, .primary-blue-btn {
        min-height: 48px;
        padding: 12px 18px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff;
        border-color: rgba(37, 99, 235, .88);
        box-shadow: 0 14px 28px rgba(37, 99, 235, .22);
      }
      .mini-btn.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
      .mini-btn.green { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
      .notification-btn { width: 48px; height: 48px; position: relative; }
      .notification-btn::after { content: ''; position: absolute; top: 12px; right: 12px; width: 7px; height: 7px; border-radius: 999px; background: #f97316; box-shadow: 0 0 0 3px #fff; }
      .hero-card, .panel-card, .list-card {
        background: rgba(255, 255, 255, .92);
        border: 1px solid rgba(226, 232, 240, .96);
        border-radius: 30px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }
      .hero-card { padding: 26px 28px; margin-bottom: 18px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 18px; align-items: center; }
      .hero-eyebrow { margin: 0 0 8px; color: #2563eb; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .page-title { margin: 0; font-size: clamp(30px, 3.3vw, 46px); font-weight: 1000; letter-spacing: -.045em; line-height: 1.03; }
      .page-subtitle { margin: 9px 0 0; color: var(--muted); font-size: 15px; line-height: 1.55; max-width: 790px; font-weight: 700; }
      .hero-actions { display: flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }

      .mobile-intro { display: none; }
      .section-title { margin: 0; font-size: 21px; font-weight: 1000; letter-spacing: -.03em; }
      .section-subtitle { margin: 7px 0 0; color: #64748b; font-size: 14px; line-height: 1.5; font-weight: 750; }
      .stats-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; margin-bottom: 18px; }
      .stat-card { min-height: 112px; display: grid; align-content: center; gap: 8px; background: rgba(255, 255, 255, .92); border: 1px solid #e2e8f0; border-radius: 26px; padding: 18px 20px; box-shadow: 0 12px 28px rgba(15, 23, 42, .06); }
      .stat-top { display: flex; align-items: center; gap: 14px; }
      .stat-icon { width: 48px; height: 48px; border-radius: 17px; display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; }
      .stat-icon svg { width: 22px; height: 22px; fill: currentColor; }
      .stat-icon.blue { background: #dbeafe; color: #2563eb; }
      .stat-icon.green { background: #dcfce7; color: #16a34a; }
      .stat-icon.purple { background: #ede9fe; color: #7c3aed; }
      .stat-icon.orange { background: #ffedd5; color: #f97316; }
      .stat-label { margin: 0; color: #475569; font-size: 13px; font-weight: 950; }
      .stat-value { margin: 0; color: #0f172a; font-size: 28px; font-weight: 1000; letter-spacing: -.04em; }

      .panel-card { padding: 22px; margin-bottom: 18px; }
      .login-card { max-width: 520px; margin: 28px auto; }
      .section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
      .form-grid { display: grid; gap: 12px; }
      .shipping-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      .full { grid-column: 1 / -1; }
      .field { display: grid; gap: 7px; }
      .field label { color: #334155; font-size: 12px; font-weight: 950; }
      .field input, .field select, .field textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: #fff;
        color: var(--text);
        padding: 12px 13px;
        outline: none;
        font-weight: 800;
        box-shadow: inset 0 1px 0 rgba(15, 23, 42, .02);
      }
      .field input:focus, .field select:focus, .field textarea:focus { border-color: #93c5fd; box-shadow: 0 0 0 4px rgba(37, 99, 235, .12); }
      .field textarea { min-height: 92px; resize: vertical; line-height: 1.45; }
      .check-row { display: flex; align-items: center; gap: 9px; min-height: 46px; font-size: 13px; font-weight: 900; color: #334155; }
      .check-row input { width: 18px; height: 18px; accent-color: #16a34a; }
      .form-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; margin-top: 4px; }
      .alert { margin-top: 12px; border-radius: 16px; padding: 11px 12px; font-size: 13px; font-weight: 850; line-height: 1.45; }
      .alert-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
      .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
      .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

      .filters-card { padding: 22px; }
      .filters-grid { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(170px, .5fr) minmax(170px, .5fr) auto; gap: 18px; align-items: end; }
      .filter-button { min-width: 132px; }
      .zones-shell { padding: 0; overflow: visible; }
      .zones-list { display: grid; gap: 10px; padding: 0; }
      .municipality-group { border: 1px solid #e2e8f0; border-radius: 24px; background: rgba(255, 255, 255, .94); overflow: visible; position: relative; box-shadow: 0 12px 28px rgba(15, 23, 42, .055); }
      .municipality-group.menu-open-card { z-index: 10010; }
      .municipality-head { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 14px; padding: 16px 18px; border-radius: 24px; }
      .municipality-group.expanded .municipality-head { border-bottom: 1px solid #e2e8f0; border-radius: 24px 24px 0 0; }
      .municipality-toggle { min-width: 0; border: 0; background: transparent; color: inherit; padding: 0; display: flex; align-items: center; gap: 14px; text-align: left; cursor: pointer; }
      .municipality-icon { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; background: #f8fafc; border: 1px solid #eef2f7; color: #0f172a; flex: 0 0 auto; }
      .municipality-icon svg { width: 21px; height: 21px; fill: currentColor; }
      .municipality-name { display: block; font-size: 18px; font-weight: 1000; letter-spacing: -.025em; }
      .municipality-count { display: block; margin-top: 4px; color: #64748b; font-size: 12px; font-weight: 850; }
      .municipality-chevron { width: 38px; height: 38px; border-radius: 15px; display: inline-flex; align-items: center; justify-content: center; background: transparent; color: #0f172a; border: 0; transition: transform .18s ease; }
      .municipality-chevron svg { width: 18px; height: 18px; fill: currentColor; }
      .municipality-group.expanded .municipality-chevron { transform: rotate(180deg); }
      .zone-list { display: none; }
      .municipality-group.expanded .zone-list { display: block; }
      .zone-table-head, .zone-row { display: grid; grid-template-columns: minmax(0, 1.05fr) 150px 140px minmax(170px, .8fr) 132px; gap: 14px; align-items: center; }
      .zone-table-head { padding: 14px 20px; color: #475569; background: rgba(248, 250, 252, .72); border-bottom: 1px solid #eef2f7; font-size: 11px; font-weight: 1000; text-transform: uppercase; letter-spacing: .05em; }
      .zone-row { padding: 14px 20px; border-bottom: 1px solid #eef2f7; position: relative; }
      .zone-row:last-child { border-bottom: 0; border-radius: 0 0 24px 24px; }
      .zone-row.menu-open { z-index: 10020; }
      .zone-title { font-weight: 950; color: #0f172a; }
      .zone-note { color: #334155; font-size: 13px; font-weight: 850; }
      .price-pill { color: #0f172a; font-size: 13px; font-weight: 950; }
      .status-pill { display: inline-flex; align-items: center; justify-content: center; width: max-content; border-radius: 999px; padding: 7px 10px; font-size: 12px; font-weight: 1000; }
      .status-pill.active { background: #dcfce7; color: #166534; }
      .status-pill.inactive { background: #ffedd5; color: #ea580c; }
      .zone-menu-wrap { position: relative; display: flex; justify-content: flex-end; z-index: 2; }
      .zone-menu-wrap.open { z-index: 10030; }
      .kebab-btn { width: 40px; height: 40px; border-radius: 15px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; box-shadow: 0 8px 18px rgba(15, 23, 42, .06); display: inline-flex; align-items: center; justify-content: center; }
      .kebab-btn svg { width: 18px; height: 18px; fill: currentColor; }
      .floating-menu { position: absolute; right: 0; top: calc(100% + 8px); z-index: 10040; min-width: 176px; border-radius: 18px; padding: 7px; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 24px 60px rgba(15, 23, 42, .18); display: none; }
      .floating-menu.drop-up { top: auto; bottom: calc(100% + 8px); }
      .zone-menu-wrap.open .floating-menu { display: grid; gap: 5px; }
      .menu-action { width: 100%; border: 0; background: transparent; color: #334155; border-radius: 13px; padding: 10px 11px; text-align: left; font-size: 13px; font-weight: 950; display: flex; align-items: center; gap: 8px; }
      .menu-action:hover { background: #f8fafc; color: #0f172a; }
      .menu-action.danger { color: #991b1b; }
      .menu-action.danger:hover { background: #fee2e2; }
      .menu-action.green { color: #166534; }
      .menu-action.green:hover { background: #dcfce7; }
      .empty-state { padding: 26px; border-radius: 24px; background: #f8fafc; border: 1px dashed #cbd5e1; color: #64748b; font-weight: 850; text-align: center; }
      .pagination-row { display: flex; align-items: center; justify-content: space-between; gap: 18px; margin-top: 14px; padding: 14px 2px 0; color: #475569; font-size: 14px; font-weight: 850; }
      .pager { display: flex; align-items: center; gap: 10px; }
      .pager-btn { width: 44px; height: 44px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; color: #334155; display: inline-flex; align-items: center; justify-content: center; font-weight: 1000; }
      .pager-btn.active { background: #0f172a; border-color: #0f172a; color: #fff; }
      .pager-btn svg { width: 18px; height: 18px; fill: currentColor; }

      .shipping-modal { position: fixed; inset: 0; z-index: 12000; display: flex; align-items: center; justify-content: center; padding: 18px; background: rgba(15, 23, 42, .42); backdrop-filter: blur(4px); }
      .shipping-modal.hidden { display: none !important; }
      .modal-card { width: min(560px, 100%); max-height: calc(100vh - 36px); overflow: auto; background: #fff; border: 1px solid #e2e8f0; border-radius: 28px; box-shadow: 0 32px 90px rgba(15, 23, 42, .28); padding: 22px; }
      .modal-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; margin-bottom: 16px; }
      .modal-title { margin: 0; font-size: 21px; font-weight: 1000; letter-spacing: -.03em; }
      .modal-subtitle { margin: 5px 0 0; color: #64748b; font-size: 13px; font-weight: 750; line-height: 1.45; }
      .modal-close { width: 40px; height: 40px; border-radius: 15px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-weight: 1000; }
      .collapsed-panel.hidden { display: none !important; }
            .shipping-main-form-panel {
        position: relative;
        scroll-margin-top: 118px;
        border: 1px solid #bfdbfe !important;
        background:
          linear-gradient(180deg, rgba(239, 246, 255, .72), rgba(255, 255, 255, .98)) !important;
        box-shadow:
          0 22px 55px rgba(37, 99, 235, .14),
          0 10px 28px rgba(15, 23, 42, .08) !important;
      }
      .shipping-main-form-panel::before {
        content: '';
        position: absolute;
        inset: 0 auto 0 0;
        width: 5px;
        border-radius: 24px 0 0 24px;
        background: linear-gradient(180deg, #2563eb, #60a5fa);
      }
      .shipping-main-form-panel.is-attention { animation: pzShippingFormAttention .72s ease both; }
      @keyframes pzShippingFormAttention {
        0% { transform: translateY(-6px); box-shadow: 0 0 0 0 rgba(37, 99, 235, .22), 0 22px 55px rgba(37, 99, 235, .14); }
        55% { transform: translateY(0); box-shadow: 0 0 0 6px rgba(37, 99, 235, .10), 0 24px 58px rgba(37, 99, 235, .18); }
        100% { transform: translateY(0); box-shadow: 0 22px 55px rgba(37, 99, 235, .14), 0 10px 28px rgba(15, 23, 42, .08); }
      }
      .shipping-main-form-head { align-items: flex-start; }
      .shipping-form-eyebrow {
        margin: 0 0 6px;
        color: #2563eb;
        font-size: 12px;
        line-height: 1;
        font-weight: 1000;
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .shipping-main-form-actions { display: inline-flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }
      .shipping-close-form-btn { border-color: #bfdbfe !important; color: #2563eb !important; background: #eff6ff !important; }

      .bottom-nav {
        position: fixed;
        left: 14px;
        right: 14px;
        bottom: 12px;
        z-index: 70;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 6px;
        padding: 10px;
        background: rgba(255, 255, 255, .94);
        border: 1px solid rgba(226, 232, 240, .96);
        border-radius: 22px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, .12);
        backdrop-filter: blur(12px);
      }
      .bottom-nav a { min-height: 58px; border-radius: 16px; display: grid; place-items: center; gap: 3px; color: #475569; font-size: 11px; font-weight: 850; }
      .bottom-nav a.active { background: #dbeafe; color: #2563eb; }

      @media (min-width: 1024px) {
        .app-shell { width: auto; max-width: none; }
        .main-wrap { padding-bottom: 28px; }
      }

      @media (max-width: 980px) {
        .hero-card { display: none; }
        .mobile-intro { display: block; margin: 8px 4px 18px; }
        .mobile-intro .section-title { font-size: 20px; }
        .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
        .stat-card { min-height: 132px; align-content: start; }
        .stat-top { display: grid; gap: 12px; }
        .filters-card { padding: 18px; }
        .filters-grid { grid-template-columns: 1fr 1fr auto; gap: 12px; }
        .filters-grid .search-field { grid-column: 1 / -1; }
        .filter-button { min-width: 112px; }
        .zone-table-head { display: none; }
        .zone-row { grid-template-columns: minmax(0, 1fr) auto; gap: 8px 12px; padding: 16px 20px; }
        .zone-row > div:nth-child(1) { grid-column: 1 / -1; }
        .zone-note::before { content: 'Observacion privada: '; color: #64748b; }
        .price-pill::before { content: 'Precio (USD): '; color: #64748b; font-weight: 850; }
        .zone-menu-wrap { justify-content: flex-end; }
      }

      @media (max-width: 620px) {
        .app-shell { padding: 10px 14px 100px; }
        .mobile-topbar { gap: 10px; }
        .mobile-topbar-title { font-size: 23px; }
        .primary-blue-btn { min-height: 46px; padding: 10px 13px; border-radius: 15px; font-size: 13px; white-space: nowrap; }
        .notification-btn, .icon-btn { width: 44px; height: 44px; border-radius: 15px; }
        .panel-card { border-radius: 24px; padding: 18px; }
        .stats-grid { gap: 10px; }
        .stat-card { border-radius: 20px; padding: 16px; min-height: 132px; }
        .stat-icon { width: 46px; height: 46px; }
        .stat-label { font-size: 12px; }
        .stat-value { font-size: 25px; }
        .filters-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
        .filter-button { grid-column: 1 / -1; width: 100%; }
        .municipality-head { grid-template-columns: minmax(0, 1fr) auto; gap: 10px; padding: 16px; }
        .municipality-head .mini-btn { grid-column: 1 / 2; width: 100%; justify-self: stretch; }
        .municipality-chevron { grid-row: 1 / 2; grid-column: 2 / 3; }
        .shipping-form-grid { grid-template-columns: 1fr; }
        .form-actions, .form-actions button { width: 100%; justify-content: stretch; }
        .form-actions button { justify-content: center; }
        .floating-menu { right: 0; }
        .pagination-row { align-items: flex-start; flex-direction: column; }
        .pager { align-self: flex-end; }
        .shipping-main-form-panel {
          scroll-margin-top: 154px;
          border-radius: 24px !important;
          padding: 18px !important;
        }
        .shipping-main-form-head {
          display: grid !important;
          gap: 14px !important;
        }
        .shipping-main-form-actions {
          width: 100%;
          justify-content: stretch;
        }
        .shipping-main-form-actions .mini-btn {
          flex: 1 1 auto;
          min-height: 44px;
        }
      }</style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay"></div>
    <div class="app-shell pz-admin-content">
      <AdminSidebar
        storeSlug={currentStoreSlug}
        storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'}
        activeSection="shipping"
        mobileTitle="Envíos"
        mobileActionLabel="Nuevo Municipio"
        mobileActionTarget="#new-zone-top-btn"
      />
      <main class="main-wrap pz-admin-content-inner">
        <header class="mobile-topbar">
          <button id="sidebar-open" class="icon-btn" type="button" aria-controls="pz-admin-sidebar" aria-expanded="false" aria-label="Abrir men&uacute;"><svg viewBox="0 0 24 24"><path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z"/></svg></button>
          <h1 class="mobile-topbar-title">Env&iacute;os</h1>
          <button id="new-zone-mobile-btn" class="primary-blue-btn" type="button"><svg viewBox="0 0 24 24"><path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z"/></svg>Nuevo Municipio</button>
          <button class="notification-btn" type="button" aria-label="Notificaciones"><svg viewBox="0 0 24 24"><path d="M12 22a2.8 2.8 0 0 0 2.7-2h-5.4a2.8 2.8 0 0 0 2.7 2Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/></svg></button>
        </header>
        <section class="hero-card">
          <div>
            <p class="hero-eyebrow">Env&iacute;os</p>
            <h1 class="page-title">Env&iacute;os</h1>
            <p class="page-subtitle">Configura municipios y zonas de entrega para el checkout de tu tienda.</p>
          </div>
          <div class="hero-actions">
            <button class="notification-btn" type="button" aria-label="Notificaciones"><svg viewBox="0 0 24 24"><path d="M12 22a2.8 2.8 0 0 0 2.7-2h-5.4a2.8 2.8 0 0 0 2.7 2Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/></svg></button>
            <button id="new-zone-top-btn" class="primary-blue-btn" type="button" aria-expanded="false"><svg viewBox="0 0 24 24"><path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z"/></svg>Nuevo Municipio</button>
          </div>
        </section>
        <section id="login-view" class="panel-card login-card hidden">
          <h2 class="section-title">Entrar como admin</h2>
          <p class="section-subtitle">Usa tu usuario administrador para gestionar env&iacute;os.</p>
          <form id="login-form" class="form-grid" style="margin-top:18px;">
            <div class="field"><label for="admin-email">Email</label><input id="admin-email" type="email" autocomplete="username" required /></div>
            <div class="field"><label for="admin-password">Contrase&ntilde;a</label><input id="admin-password" type="password" autocomplete="current-password" required /></div>
            <button class="mini-btn primary" type="submit">Entrar al panel</button>
            <div id="login-alert" class="alert alert-error hidden"></div>
          </form>
        </section>
        <section id="admin-view" class="hidden">
          <div class="mobile-intro">
            <h2 class="section-title">Municipios y zonas de entrega</h2>
            <p class="section-subtitle">Administra los precios de env&iacute;o por municipio y zona que ver&aacute; el cliente en el checkout.</p>
          </div>
          <div class="stats-grid">
            <article class="stat-card"><div class="stat-top"><span class="stat-icon blue"><svg viewBox="0 0 24 24"><path d="M12 2 4 6v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V6l-8-4Zm0 3 5 2.5V12c0 3.3-2 5.8-5 6.8-3-1-5-3.5-5-6.8V7.5L12 5Zm-1 4h2v4h3v2h-5V9Z"/></svg></span><p class="stat-label">Municipios</p></div><p id="stat-municipalities" class="stat-value">0</p></article>
            <article class="stat-card"><div class="stat-top"><span class="stat-icon green"><svg viewBox="0 0 24 24"><path d="M12 2 3 6v14l9-4 9 4V6l-9-4Zm-1 12.3-6 2.7V7.3l6-2.7v9.7Zm2 0V4.6l6 2.7V17l-6-2.7Z"/></svg></span><p class="stat-label">Zonas activas</p></div><p id="stat-active-zones" class="stat-value">0</p></article>
            <article class="stat-card"><div class="stat-top"><span class="stat-icon purple"><svg viewBox="0 0 24 24"><path d="m2.8 4.2 1.4-1.4 17 17-1.4 1.4-3-3A10.8 10.8 0 0 1 12 19c-5 0-9-5.2-9-7 0-.9 1-2.7 2.8-4.2l-3-3.6ZM12 5c5 0 9 5.2 9 7 0 .7-.7 2.1-2 3.4l-3-3A4 4 0 0 0 11.6 8l-2-2A9.6 9.6 0 0 1 12 5Zm0 11.5c.7 0 1.3-.2 1.8-.5L8 10.2A4 4 0 0 0 12 16.5Z"/></svg></span><p class="stat-label">Zonas ocultas</p></div><p id="stat-hidden-zones" class="stat-value">0</p></article>
            <article class="stat-card"><div class="stat-top"><span class="stat-icon orange"><svg viewBox="0 0 24 24"><path d="M13 3v2.1c2.3.4 4 1.8 4 3.9h-3c0-.8-.8-1.3-2-1.3s-2 .5-2 1.2c0 .8.7 1.1 2.8 1.6 2.8.7 4.7 1.7 4.7 4.3 0 2.1-1.7 3.7-4.5 4.1V21h-2v-2.1c-2.7-.4-4.6-2-4.7-4.4h3c.1 1 1 1.7 2.5 1.7s2.4-.6 2.4-1.4c0-.9-.8-1.2-3-1.8-2.7-.7-4.4-1.7-4.4-4 0-2 1.6-3.5 4.2-3.9V3h2Z"/></svg></span><p class="stat-label">Promedio</p></div><p id="stat-average-price" class="stat-value">$0.00</p></article>
          </div>
          <section class="panel-card shipping-main-form-panel collapsed-panel hidden" id="form-panel" aria-live="polite">
            <div class="section-head shipping-main-form-head">
              <div>
                <p class="shipping-form-eyebrow">Municipio</p>
                <h2 id="form-title" class="section-title">Nuevo municipio</h2>
                <p id="form-subtitle" class="section-subtitle">
                  Crea un municipio y su zona inicial con precio &uacute;nico de entrega en USD.
                </p>
              </div>
              <div class="shipping-main-form-actions">
                <button id="cancel-edit-btn" class="mini-btn hidden" type="button">
                  Cancelar edici&oacute;n
                </button>
                <button
                  id="close-main-form-btn"
                  class="mini-btn ghost shipping-close-form-btn"
                  type="button"
                  aria-label="Cerrar formulario de municipio"
                >
                  Cerrar
                </button>
              </div>
            </div>
            <form id="shipping-form" class="shipping-form-grid">
              <div class="field"><label for="municipality-input">Municipio</label><input id="municipality-input" type="text" placeholder="Nombre del municipio" required /></div>
              <div class="field"><label for="zone-input">Zona</label><input id="zone-input" type="text" placeholder="Nombre de la zona" /></div>
              <div class="field"><label for="price-input">Precio &uacute;nico USD</label><input id="price-input" type="text" inputmode="decimal" placeholder="Ej: 3" required /></div>
              <div class="field"><label for="active-input">Estado</label><label class="check-row"><input id="active-input" type="checkbox" checked /> Activo en checkout</label></div>
              <div class="field full"><label for="note-input">Observacion privada opcional</label><textarea id="note-input" placeholder="Detalles visibles solo para administracion"></textarea></div>
              <div class="form-actions full"><button id="save-zone-btn" class="mini-btn primary" type="submit">Guardar municipio</button></div>
            </form>
            <div id="form-alert" class="alert alert-info hidden"></div>
          </section>
          <section class="panel-card filters-card">
            <div class="filters-grid">
              <div class="field search-field"><label for="search-input">Buscar zona</label><input id="search-input" type="search" placeholder="Buscar zona o municipio..." /></div>
              <div class="field"><label for="status-filter">Estado</label><select id="status-filter"><option value="all">Todos</option><option value="active">Activas</option><option value="inactive">Ocultas</option></select></div>
              <div class="field"><label for="municipality-filter">Municipio</label><select id="municipality-filter"><option value="all">Todos</option></select></div>
              <button id="filters-btn" class="mini-btn filter-button" type="button"><svg viewBox="0 0 24 24"><path d="M4 7h10a3 3 0 1 0 0-2H4v2Zm16 10H10a3 3 0 1 0 0 2h10v-2ZM8 11H4v2h4a3 3 0 1 0 0-2Zm8 2h4v-2h-4a3 3 0 0 0 0 2Z"/></svg>Filtros</button>
            </div>
          </section>
          <section class="zones-shell">
            <div id="zones-list" class="zones-list"></div>
            <div class="pagination-row">
              <span id="pagination-summary">Mostrando 0 a 0 de 0 municipios</span>
              <div class="pager" aria-label="Paginacion">
                <button class="pager-btn" type="button" disabled aria-label="Pagina anterior"><svg viewBox="0 0 24 24"><path d="m15.4 7.4-1.4-1.4L8 12l6 6 1.4-1.4L10.8 12l4.6-4.6Z"/></svg></button>
                <button class="pager-btn active" type="button">1</button>
                <button class="pager-btn" type="button" disabled aria-label="Pagina siguiente"><svg viewBox="0 0 24 24"><path d="m8.6 16.6 1.4 1.4 6-6-6-6-1.4 1.4 4.6 4.6-4.6 4.6Z"/></svg></button>
              </div>
            </div>
            <div id="list-alert" class="alert alert-info hidden"></div>
          </section>
          <section id="zone-modal" class="shipping-modal hidden" aria-hidden="true">
            <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="zone-modal-title">
              <div class="modal-head">
                <div>
                  <h2 id="zone-modal-title" class="modal-title">Nueva zona</h2>
                  <p id="zone-modal-subtitle" class="modal-subtitle">Nueva zona para el municipio seleccionado.</p>
                </div>
                <button id="zone-modal-close" class="modal-close" type="button" aria-label="Cerrar">x</button>
              </div>
              <form id="zone-modal-form" class="form-grid">
                <input id="zone-modal-municipality" type="hidden" />
                <div class="field"><label for="zone-modal-zone">Zona</label><input id="zone-modal-zone" type="text" placeholder="Nombre de la zona" required /></div>
                <div class="field"><label for="zone-modal-price">Precio &uacute;nico USD</label><input id="zone-modal-price" type="text" inputmode="decimal" placeholder="Ej: 3" required /></div>
                <label class="check-row"><input id="zone-modal-active" type="checkbox" checked /> Activo en checkout</label>
                <div class="field"><label for="zone-modal-note">Observacion privada opcional</label><textarea id="zone-modal-note" placeholder="Detalles visibles solo para administracion"></textarea></div>
                <div class="form-actions">
                  <button id="zone-modal-cancel" class="mini-btn" type="button">Cancelar</button>
                  <button id="zone-modal-save-btn" class="mini-btn primary" type="submit">Guardar zona</button>
                </div>
                <div id="zone-modal-alert" class="alert alert-info hidden"></div>
              </form>
            </div>
          </section>
        </section>
      </main>
    </div>
    <nav class="bottom-nav" aria-label="Navegacion inferior">
      <a href={adminBasePath}><svg viewBox="0 0 24 24"><path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"/></svg><span>Resumen</span></a>
      <a href={adminOrdersPath}><svg viewBox="0 0 24 24"><path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Z"/></svg><span>Pedidos</span></a>
      <a class="active" href={adminShippingPath}><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Z"/></svg><span>Env&iacute;os</span></a>
      <a href={adminStoreSettingsPath}><svg viewBox="0 0 24 24"><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a8 8 0 0 0-2.6-1.5L14 2h-4l-.4 3a8 8 0 0 0-2.6 1.5l-2.4-1-2 3.5 2 1.5A9 9 0 0 0 4.5 12c0 .5 0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a8 8 0 0 0 2.6 1.5l.4 3h4l.4-3a8 8 0 0 0 2.6-1.5l2.4 1 2-3.5-2-1.5Z"/></svg><span>Ajustes</span></a>
    </nav>
    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken, publicStorePath }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\"')}"`;
      const sidebarOpen = document.getElementById('sidebar-open');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const logoutBtn = document.getElementById('logout-btn');
      const loginView = document.getElementById('login-view');
      const adminView = document.getElementById('admin-view');
      const loginForm = document.getElementById('login-form');
      const loginAlert = document.getElementById('login-alert');
      const form = document.getElementById('shipping-form');
      const formPanel = document.getElementById('form-panel');
      const formTitle = document.getElementById('form-title');
      const formSubtitle = document.getElementById('form-subtitle');
      const formAlert = document.getElementById('form-alert');
      const saveZoneBtn = document.getElementById('save-zone-btn');
      const listAlert = document.getElementById('list-alert');
      const zonesList = document.getElementById('zones-list');
      const paginationSummary = document.getElementById('pagination-summary');
      const cancelEditBtn = document.getElementById('cancel-edit-btn');
      const closeMainFormBtn = document.getElementById('close-main-form-btn');
      const newZoneTopBtn = document.getElementById('new-zone-top-btn');
      const newZoneMobileBtn = document.getElementById('new-zone-mobile-btn');
      const searchInput = document.getElementById('search-input');
      const statusFilter = document.getElementById('status-filter');
      const municipalityFilter = document.getElementById('municipality-filter');
      const filtersBtn = document.getElementById('filters-btn');
      const zoneModal = document.getElementById('zone-modal');
      const zoneModalForm = document.getElementById('zone-modal-form');
      const zoneModalClose = document.getElementById('zone-modal-close');
      const zoneModalCancel = document.getElementById('zone-modal-cancel');
      const zoneModalSaveBtn = document.getElementById('zone-modal-save-btn');
      const zoneModalSubtitle = document.getElementById('zone-modal-subtitle');
      const zoneModalAlert = document.getElementById('zone-modal-alert');
      const zoneModalFields = {
        municipality: document.getElementById('zone-modal-municipality'),
        zone: document.getElementById('zone-modal-zone'),
        price: document.getElementById('zone-modal-price'),
        active: document.getElementById('zone-modal-active'),
        note: document.getElementById('zone-modal-note'),
      };
      const fields = {
        municipality: document.getElementById('municipality-input'),
        zone: document.getElementById('zone-input'),
        price: document.getElementById('price-input'),
        active: document.getElementById('active-input'),
        note: document.getElementById('note-input'),
      };
      let shippingZones = [];
      let editingId = '';
      let formInitialSnapshot = '';
      let modalInitialSnapshot = '';
      const noticeTimers = { form: null, modal: null, list: null };
      let isSavingZone = false;
      let isSavingModalZone = false;
      const expandedMunicipalities = new Set();
      function token(){return ADMIN_AUTH_TOKEN;}
      function showAlert(element,message='',type='info'){
        if(!element)return;
        if(!message){element.className='alert alert-info hidden';element.textContent='';return;}
        element.className='alert alert-'+type;element.textContent=message;
      }
      function showTimedAlert(element,message='',type='info',timerName='form'){
        const key=noticeTimers[timerName]===undefined?'form':timerName;
        if(noticeTimers[key]){window.clearTimeout(noticeTimers[key]);noticeTimers[key]=null;}
        showAlert(element,message,type);
        const timeout=type==='success'?2800:type==='error'?4800:0;
        if(message&&timeout){
          noticeTimers[key]=window.setTimeout(()=>{showAlert(element,'');noticeTimers[key]=null;},timeout);
        }
      }
      function escapeHtml(value){return String(value||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');}
      function formatMoney(value){return '$'+Number(value||0).toFixed(2);}
      function openSidebar(){document.body.classList.add('sidebar-open');sidebarOpen?.setAttribute('aria-expanded','true');}
      function closeSidebar(){document.body.classList.remove('sidebar-open');sidebarOpen?.setAttribute('aria-expanded','false');}
      sidebarOpen?.addEventListener('click',openSidebar);
      sidebarOverlay?.addEventListener('click',closeSidebar);
      document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){closeSidebar();closeZoneModal();closeZoneMenus();}});
      async function api(path,options={}){
        if(!POCKETBASE_URL)throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el frontend.');
        const headers=Object.assign({},options.headers||{});
        if(token())headers.Authorization='Bearer '+token();
        const response=await fetch(POCKETBASE_URL+path,Object.assign({},options,{headers}));
        const result=await response.json().catch(()=>null);
        if(!response.ok)throw new Error((result&&result.message)||'Error de comunicacion con la plataforma.');
        return result;
      }
      function showAdmin(){loginView.classList.add('hidden');adminView.classList.remove('hidden');loadZones().catch((error)=>showAlert(listAlert,error.message||'No se pudieron cargar los envios.','error'));}
      function showLogin(){adminView.classList.add('hidden');loginView.classList.remove('hidden');}
      function collectFormPayload(){
        const priceRaw=String(fields.price.value||'').replace(',', '.').trim();
        return {municipality:fields.municipality.value.trim(),zone:fields.zone.value.trim(),price_usd:priceRaw===''?'':Number(priceRaw),active:fields.active.checked,note:fields.note.value.trim(),store:CURRENT_STORE_ID};
      }
      function collectModalPayload(){
        const priceRaw=String(zoneModalFields.price.value||'').replace(',', '.').trim();
        return {municipality:zoneModalFields.municipality.value.trim(),zone:zoneModalFields.zone.value.trim(),price_usd:priceRaw===''?'':Number(priceRaw),active:zoneModalFields.active.checked,note:zoneModalFields.note.value.trim(),store:CURRENT_STORE_ID};
      }
      function validateZonePayload(payload,{requireZone=false}={}){
        if(String(payload.municipality||'').length<2)return 'Selecciona un municipio.';
        if(requireZone&&String(payload.zone||'').length<2)return 'Completa el nombre de la zona.';
        if(payload.price_usd==='')return 'Completa el precio de envío.';
        if(!Number.isFinite(Number(payload.price_usd))||Number(payload.price_usd)<0)return 'Completa un precio de envío válido.';
        return '';
      }
      function getPayload(){
        const payload=collectFormPayload();
        const error=validateZonePayload(payload);
        if(error)throw new Error(error);
        payload.price_usd=Number(payload.price_usd);
        return payload;
      }
      function formSnapshot(){return JSON.stringify(collectFormPayload());}
      function modalSnapshot(){return JSON.stringify(collectModalPayload());}
      function hasFormChanges(){return Boolean(formInitialSnapshot)&&formSnapshot()!==formInitialSnapshot;}
      function hasModalChanges(){return Boolean(modalInitialSnapshot)&&modalSnapshot()!==modalInitialSnapshot;}
      function syncFormState(){
        if(!saveZoneBtn)return;
        const canSave=!validateZonePayload(collectFormPayload())&&hasFormChanges()&&!isSavingZone;
        saveZoneBtn.disabled=!canSave;
        saveZoneBtn.textContent=isSavingZone?'Guardando...':(editingId?'Guardar cambios':'Guardar municipio');
      }
      function syncModalState(){
        if(!zoneModalSaveBtn)return;
        const canSave=!validateZonePayload(collectModalPayload(),{requireZone:true})&&hasModalChanges()&&!isSavingModalZone;
        zoneModalSaveBtn.disabled=!canSave;
        zoneModalSaveBtn.textContent=isSavingModalZone?'Guardando...':'Guardar zona';
      }
      function setFormSnapshot(){formInitialSnapshot=formSnapshot();syncFormState();}
      function setModalSnapshot(){modalInitialSnapshot=modalSnapshot();syncModalState();}
      function setNewZoneButtonText(text){
        if(newZoneTopBtn&&newZoneTopBtn.lastChild)newZoneTopBtn.lastChild.textContent=text;
        if(newZoneMobileBtn&&newZoneMobileBtn.lastChild)newZoneMobileBtn.lastChild.textContent=text==='Cerrar panel'?'Cerrar':'Nuevo Municipio';
      }
      function showMainForm(){
        formPanel?.classList.remove('hidden');
        formPanel?.classList.add('is-attention');
        newZoneTopBtn?.setAttribute('aria-expanded','true');
        newZoneMobileBtn?.setAttribute('aria-expanded','true');
        setNewZoneButtonText('Cerrar panel');
        window.setTimeout(()=>{formPanel?.classList.remove('is-attention');},850);
      }
      function hideMainForm(){
        formPanel?.classList.add('hidden');
        formPanel?.classList.remove('is-attention');
        newZoneTopBtn?.setAttribute('aria-expanded','false');
        newZoneMobileBtn?.setAttribute('aria-expanded','false');
        setNewZoneButtonText('Nuevo Municipio');
      }
      function resetForm(){
        editingId='';
        form.reset();
        isSavingZone=false;
        fields.active.checked=true;
        formTitle.textContent='Nuevo municipio';
        formSubtitle.textContent='Crea un municipio y su zona inicial con precio único de entrega en USD.';
        if(saveZoneBtn)saveZoneBtn.textContent='Guardar municipio';
        cancelEditBtn.classList.add('hidden');
        showTimedAlert(formAlert,'','info','form');
        setFormSnapshot();
      }
      function fillForm(zone){editingId=zone.id;showMainForm();fields.municipality.value=zone.municipality||'';fields.zone.value=zone.zone||'';fields.price.value=Number(zone.price_usd||0).toString();fields.active.checked=zone.active!==false;fields.note.value=zone.note||'';formTitle.textContent='Editar zona de envio';formSubtitle.textContent='Modifica municipio, zona, precio unico o estado.';if(saveZoneBtn)saveZoneBtn.textContent='Guardar cambios';cancelEditBtn.classList.remove('hidden');setFormSnapshot();formPanel?.scrollIntoView({behavior:'smooth',block:'start'});}
      function openZoneModal(municipality){closeZoneMenus();zoneModalForm.reset();isSavingModalZone=false;zoneModalFields.active.checked=true;zoneModalFields.municipality.value=municipality||'';zoneModalSubtitle.textContent='Nueva zona para '+(municipality||'el municipio seleccionado')+'.';showTimedAlert(zoneModalAlert,'','info','modal');setModalSnapshot();zoneModal.classList.remove('hidden');zoneModal.setAttribute('aria-hidden','false');setTimeout(()=>zoneModalFields.zone.focus(),60);}
      function closeZoneModal(){zoneModal.classList.add('hidden');zoneModal.setAttribute('aria-hidden','true');showTimedAlert(zoneModalAlert,'','info','modal');}
      function getZoneModalPayload(){const payload=collectModalPayload();const error=validateZonePayload(payload,{requireZone:true});if(error)throw new Error(error);payload.price_usd=Number(payload.price_usd);return payload;}
      async function saveZoneFromModal(event){event.preventDefault();if(isSavingModalZone)return;showTimedAlert(zoneModalAlert,'','info','modal');const payload=getZoneModalPayload();if(!hasModalChanges()){syncModalState();return;}isSavingModalZone=true;syncModalState();showTimedAlert(zoneModalAlert,'Guardando cambios...','info','modal');try{await api('/api/collections/shipping_zones/records',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});if(payload.municipality)expandedMunicipalities.add(payload.municipality);closeZoneModal();await loadZones();showTimedAlert(listAlert,'Zona de envío creada correctamente','success','list');}catch(error){showTimedAlert(zoneModalAlert,'No se pudieron guardar los cambios','error','modal');}finally{isSavingModalZone=false;syncModalState();}}
      async function saveZone(event){
        event.preventDefault();
        if(isSavingZone)return;
        showTimedAlert(formAlert,'','info','form');
        const payload=getPayload();
        if(!hasFormChanges()){syncFormState();return;}
        const savedMunicipality=payload.municipality;
        const isEditing=Boolean(editingId);
        isSavingZone=true;syncFormState();showTimedAlert(formAlert,'Guardando cambios...','info','form');
        try{
          if(isEditing){
            await api('/api/collections/shipping_zones/records/'+editingId,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          }else{
            await api('/api/collections/shipping_zones/records',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
          }
          if(savedMunicipality)expandedMunicipalities.add(savedMunicipality);
          resetForm();hideMainForm();await loadZones();
          showTimedAlert(listAlert,isEditing?'Envío actualizado correctamente':'Municipio creado correctamente','success','list');
        }catch(error){
          showTimedAlert(formAlert,'No se pudieron guardar los cambios','error','form');
        }finally{
          isSavingZone=false;syncFormState();
        }
      }
      async function loadZones(){
        showAlert(listAlert,'');
        const result=await api(`/api/collections/shipping_zones/records?filter=${encodeURIComponent(STORE_FILTER)}&sort=municipality,zone&perPage=500`);
        shippingZones=result.items||[];
        renderStats();
        populateMunicipalityFilter();
        renderZones();
      }
      function renderStats(){
        const municipalities=new Set(shippingZones.map((zone)=>String(zone.municipality||'').trim()).filter(Boolean));
        const active=shippingZones.filter((zone)=>zone.active!==false);
        const hidden=shippingZones.filter((zone)=>zone.active===false);
        const avg=active.length?active.reduce((sum,zone)=>sum+Number(zone.price_usd||0),0)/active.length:0;
        document.getElementById('stat-municipalities').textContent=String(municipalities.size);
        document.getElementById('stat-active-zones').textContent=String(active.length);
        document.getElementById('stat-hidden-zones').textContent=String(hidden.length);
        document.getElementById('stat-average-price').textContent=formatMoney(avg);
      }
      function populateMunicipalityFilter(){
        const selected=municipalityFilter.value||'all';
        const municipalities=[...new Set(shippingZones.map((zone)=>String(zone.municipality||'').trim()).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
        municipalityFilter.innerHTML='<option value="all">Todos</option>'+municipalities.map((municipality)=>`<option value="${escapeHtml(municipality)}">${escapeHtml(municipality)}</option>`).join('');
        municipalityFilter.value=municipalities.includes(selected)?selected:'all';
      }
      function filteredZones(){
        const q=String(searchInput.value||'').trim().toLowerCase();
        const status=statusFilter.value;
        const municipality=municipalityFilter.value;
        return shippingZones.filter((zone)=>{
          const isActive=zone.active!==false;
          if(status==='active'&&!isActive)return false;
          if(status==='inactive'&&isActive)return false;
          if(municipality!=='all'&&String(zone.municipality||'')!==municipality)return false;
          if(!q)return true;
          return [zone.municipality,zone.zone,zone.note].some((value)=>String(value||'').toLowerCase().includes(q));
        });
      }
      function groupByMunicipality(items){
        return items.reduce((groups,zone)=>{const key=zone.municipality||'Sin municipio';if(!groups[key])groups[key]=[];groups[key].push(zone);return groups;},{});
      }
      function updatePaginationSummary(total){
        const end=total?total:0;
        paginationSummary.textContent=`Mostrando ${total?1:0} a ${end} de ${total} municipios`;
      }
      function renderZones(){
        const items=filteredZones();
        const groups=groupByMunicipality(items);
        const municipalities=Object.keys(groups).sort((a,b)=>a.localeCompare(b));
        updatePaginationSummary(municipalities.length);
        if(!items.length){zonesList.innerHTML='<div class="empty-state">No hay zonas de envio con esos filtros.</div>';return;}
        if(expandedMunicipalities.size===0&&municipalities[0])expandedMunicipalities.add(municipalities[0]);
        zonesList.innerHTML=municipalities.map((municipality)=>{
          const zones=groups[municipality];
          const activeCount=zones.filter((zone)=>zone.active!==false).length;
          const isExpanded=expandedMunicipalities.has(municipality);
          return `<section class="municipality-group ${isExpanded?'expanded':''}" data-municipality="${escapeHtml(municipality)}"><div class="municipality-head"><button class="municipality-toggle js-toggle-municipality" type="button" aria-expanded="${isExpanded?'true':'false'}"><span class="municipality-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 21V9l8-6 8 6v12h-6v-7h-4v7H4Zm3-3h2v-6h6v6h2V10.5l-5-3.8-5 3.8V18Z"/></svg></span><span><span class="municipality-name">${escapeHtml(municipality)}</span><span class="municipality-count">${zones.length} zona${zones.length===1?'':'s'} · ${activeCount} activa${activeCount===1?'':'s'}</span></span></button><button class="mini-btn js-add-same" data-municipality="${escapeHtml(municipality)}" type="button"><svg viewBox="0 0 24 24"><path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z"/></svg>Nueva zona</button><button class="municipality-chevron js-toggle-municipality" type="button" aria-label="Alternar municipio" aria-expanded="${isExpanded?'true':'false'}"><svg viewBox="0 0 24 24"><path d="m7.4 8.6 4.6 4.6 4.6-4.6L18 10l-6 6-6-6 1.4-1.4Z"/></svg></button></div><div class="zone-list"><div class="zone-table-head"><span>Zona</span><span>Precio (USD)</span><span>Estado</span><span>Observacion privada</span><span>Acciones</span></div>${zones.map(renderZoneRow).join('')}</div></section>`;
        }).join('');
      }
      function renderZoneRow(zone){
        const isActive=zone.active!==false;
        return `<article class="zone-row" data-zone-id="${zone.id}"><div><div class="zone-title">${escapeHtml(zone.zone||zone.municipality||'Zona general')}</div></div><div><span class="price-pill">${formatMoney(zone.price_usd)}</span></div><div><span class="status-pill ${isActive?'active':'inactive'}">${isActive?'Activa':'Oculta'}</span></div><div class="zone-note">${zone.note?escapeHtml(zone.note):'--'}</div><div class="zone-menu-wrap"><button class="kebab-btn js-menu" type="button" aria-label="Abrir opciones" aria-expanded="false"><svg viewBox="0 0 24 24"><path d="M12 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg></button><div class="floating-menu" role="menu"><button class="menu-action js-edit" type="button" role="menuitem">Editar</button><button class="menu-action ${isActive?'danger':'green'} js-toggle" type="button" role="menuitem">${isActive?'Ocultar':'Activar'}</button><button class="menu-action danger js-delete" type="button" role="menuitem">Borrar</button></div></div></article>`;
      }
      function closeZoneMenus(except=null){
        zonesList.querySelectorAll('.zone-menu-wrap.open').forEach((menu)=>{
          if(menu===except)return;
          menu.classList.remove('open');
          menu.closest('.zone-row')?.classList.remove('menu-open');
          menu.closest('.municipality-group')?.classList.remove('menu-open-card');
          menu.querySelector('.floating-menu')?.classList.remove('drop-up');
          menu.querySelector('.js-menu')?.setAttribute('aria-expanded','false');
        });
      }
      function positionZoneMenu(menuWrap){
        if(!menuWrap)return;
        const floatingMenu=menuWrap.querySelector('.floating-menu');
        const trigger=menuWrap.querySelector('.js-menu');
        if(!floatingMenu||!trigger)return;
        floatingMenu.classList.remove('drop-up');
        requestAnimationFrame(()=>{
          const menuHeight=floatingMenu.offsetHeight||150;
          const triggerRect=trigger.getBoundingClientRect();
          const availableBelow=window.innerHeight-triggerRect.bottom;
          const availableAbove=triggerRect.top;
          if(availableBelow<menuHeight+18&&availableAbove>menuHeight+18){
            floatingMenu.classList.add('drop-up');
          }
        });
      }
      function toggleZoneMenu(menuWrap){
        if(!menuWrap)return;
        const willOpen=!menuWrap.classList.contains('open');
        closeZoneMenus(menuWrap);
        menuWrap.classList.toggle('open',willOpen);
        menuWrap.closest('.zone-row')?.classList.toggle('menu-open',willOpen);
        menuWrap.closest('.municipality-group')?.classList.toggle('menu-open-card',willOpen);
        menuWrap.querySelector('.js-menu')?.setAttribute('aria-expanded',willOpen?'true':'false');
        if(willOpen)positionZoneMenu(menuWrap);
      }
      zonesList.addEventListener('click',async (event)=>{
        const municipalityToggle=event.target.closest('.js-toggle-municipality');
        if(municipalityToggle){
          const group=municipalityToggle.closest('.municipality-group');
          const municipality=group?.dataset.municipality||'';
          const willOpen=!group?.classList.contains('expanded');
          if(willOpen)expandedMunicipalities.add(municipality);else expandedMunicipalities.delete(municipality);
          group?.classList.toggle('expanded',willOpen);
          group?.querySelectorAll('.js-toggle-municipality').forEach((button)=>button.setAttribute('aria-expanded',willOpen?'true':'false'));
          closeZoneMenus();
          return;
        }
        const menuBtn=event.target.closest('.js-menu');
        if(menuBtn){toggleZoneMenu(menuBtn.closest('.zone-menu-wrap'));return;}
        const addBtn=event.target.closest('.js-add-same');
        if(addBtn){openZoneModal(addBtn.dataset.municipality||'');return;}
        const row=event.target.closest('[data-zone-id]');
        if(!row)return;
        const zone=shippingZones.find((item)=>item.id===row.dataset.zoneId);
        if(!zone)return;
        if(event.target.closest('.js-edit')){closeZoneMenus();fillForm(zone);return;}
        if(event.target.closest('.js-toggle')){
          closeZoneMenus();
          api('/api/collections/shipping_zones/records/'+zone.id,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({active:zone.active===false})})
            .then(()=>loadZones()).then(()=>showTimedAlert(listAlert,'Envío actualizado correctamente','success','list')).catch(()=>showTimedAlert(listAlert,'No se pudieron guardar los cambios','error','list'));
          return;
        }
        if(event.target.closest('.js-delete')){
          closeZoneMenus();
          const ok=await window.adminConfirm({
            title:'Eliminar zona de envío',
            message:'¿Seguro que deseas eliminar esta zona de envío? Esta acción no se puede deshacer.',
            confirmText:'Eliminar',
            cancelText:'Cancelar',
            tone:'danger'
          });
          if(!ok)return;
          api('/api/collections/shipping_zones/records/'+zone.id,{method:'DELETE'})
            .then(()=>{if(editingId===zone.id)resetForm();return loadZones();})
            .then(()=>showTimedAlert(listAlert,'Zona de envío eliminada correctamente','success','list'))
            .catch(()=>showTimedAlert(listAlert,'No se pudieron guardar los cambios','error','list'));
        }
      });
      document.addEventListener('click',(event)=>{if(!event.target.closest('.zone-menu-wrap'))closeZoneMenus();});
      form.addEventListener('input',syncFormState);
      form.addEventListener('change',syncFormState);
      form.addEventListener('submit',(event)=>saveZone(event).catch((error)=>{isSavingZone=false;syncFormState();showTimedAlert(formAlert,error.message||'No se pudieron guardar los cambios','error','form');}));
      cancelEditBtn.addEventListener('click',()=>{resetForm();hideMainForm();});
      closeMainFormBtn?.addEventListener('click',()=>{resetForm();hideMainForm();});
      function toggleMainForm(){
        const willOpen=formPanel?.classList.contains('hidden');
        resetForm();
        if(willOpen){
          showMainForm();
          window.setTimeout(()=>{
            formPanel?.scrollIntoView({behavior:'smooth',block:'start'});
            fields.municipality?.focus();
          },80);
        }else{
          hideMainForm();
        }
      }
      newZoneTopBtn.addEventListener('click',toggleMainForm);
      newZoneMobileBtn.addEventListener('click',toggleMainForm);
      zoneModalForm.addEventListener('input',syncModalState);
      zoneModalForm.addEventListener('change',syncModalState);
      zoneModalForm.addEventListener('submit',(event)=>saveZoneFromModal(event).catch((error)=>{isSavingModalZone=false;syncModalState();showTimedAlert(zoneModalAlert,error.message||'No se pudieron guardar los cambios','error','modal');}));
      zoneModalClose.addEventListener('click',closeZoneModal);
      zoneModalCancel.addEventListener('click',closeZoneModal);
      zoneModal.addEventListener('click',(event)=>{if(event.target===zoneModal)closeZoneModal();});
      searchInput.addEventListener('input',renderZones);
      statusFilter.addEventListener('change',renderZones);
      municipalityFilter.addEventListener('change',renderZones);
      filtersBtn.addEventListener('click',()=>closeZoneMenus());
      showAdmin();
    </script>
  </body>
</html>
