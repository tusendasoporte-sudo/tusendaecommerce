      }
      .nav-link > span:last-child:not(.nav-left):not(.nav-pill),
      .nav-link > .arrow,
      .nav-item > .arrow,
      .nav-arrow { display: none !important; }
      .nav-pill {
        margin-left: auto !important;
        background: #f1f5f9 !important;
        color: #64748b !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 999px !important;
        padding: 5px 9px !important;
        font-size: 11px !important;
        font-weight: 1000 !important;
      }
      .nav-link.active .nav-pill,
      .nav-item.active .nav-pill { background: rgba(255,255,255,.14) !important; color: #fff !important; border-color: rgba(255,255,255,.25) !important; }
      .sidebar-footer {
        margin-top: auto !important;
        padding: 14px !important;
        border-radius: 22px !important;
        background: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
      }
      .sidebar-footer strong { display: block !important; font-size: 12px !important; margin-bottom: 5px !important; color: #0f172a !important; }
      .sidebar-footer span { display: block !important; color: #475569 !important; font-size: 11px !important; line-height: 1.45 !important; font-weight: 750 !important; }
      @media (max-width: 620px) {
        .sidebar,
        #admin-sidebar { top: 12px !important; left: 12px !important; bottom: 12px !important; width: calc(100vw - 24px) !important; }
      }

      /* V25J: oculta notas internas del menú lateral para clientes finales */
      .sidebar-footer,
      .admin-sidebar-footer,
      .sidebar-note {
        display: none !important;
      }

      </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell">
      <aside id="admin-sidebar" class="sidebar" aria-label="Panel lateral de administración" aria-hidden="true">
        <div class="sidebar-inner">
          <div class="brand">
            <span class="brand-logo">PZ</span>
            <div>
              <p class="brand-title">PowerZona</p>
              <p class="brand-subtitle">Panel administrativo</p>
            </div>
            <button id="sidebar-close" class="sidebar-close" type="button" aria-label="Cerrar menú">×</button>
          </div>

          <p class="sidebar-label">Principal</p>
          <nav class="nav-list">
            <a class="nav-item" href={adminBasePath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 19V9h4v10H4Zm6 0V5h4v14h-4Zm6 0v-7h4v7h-4Z"/></svg></span><span>Resumen</span></a>
            <a class="nav-item" href={adminOrdersPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h12a1 1 0 0 1 1 1v17l-3-2-2 2-2-2-2 2-2-2-3 2V4a1 1 0 0 1 1-1Zm3 5h6V6H9v2Zm0 4h6v-2H9v2Zm0 4h4v-2H9v2Z"/></svg></span><span>Pedidos</span></a>
            <a class="nav-item" href={adminCatalogPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3V6Zm0 5h18v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7Z"/></svg></span><span>Categorías</span></a>
            <a class="nav-item" href={adminProductsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 7.5 12 3 3 7.5l9 4.5 9-4.5ZM5 10.7V17l6 3v-6.3l-6-3Zm8 9.3 6-3v-6.3l-6 3V20Z"/></svg></span><span>Productos</span></a>
            <a class="nav-item" href={adminGiftsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Regalos</span></a>
            <a class="nav-item" href={adminShippingPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h10v9h2.2l1.5-3H21v5h-2a3 3 0 0 1-6 0H9a3 3 0 0 1-6 0H2V9a2 2 0 0 1 1-1.73V7Zm2 0v7.17A3 3 0 0 1 8.83 16H13V7H5Zm12 6h2v1h-2v-1ZM6 17a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm10 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/></svg></span><span>Envíos</span></a>
            <a class="nav-item active" href={adminStoreSettingsPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7H3V8h18v4h-1ZM5 10h14V9H5v1Zm1 2v7h12v-7H6Zm6-4H8.5A2.5 2.5 0 1 1 11 5.5L12 8Zm1 0h2.5A2.5 2.5 0 1 0 13 5.5L12 8h1Z"/></svg></span><span>Ajustes de tienda</span></a>
          </nav>

          <p class="sidebar-label">Divisiones</p>
          <nav class="nav-list">
            <a class="nav-item" href={adminPromosPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a8 8 0 0 0-2.6-1.5L14 2h-4l-.4 3a8 8 0 0 0-2.6 1.5l-2.4-1-2 3.5 2 1.5A9 9 0 0 0 4.5 12c0 .5 0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a8 8 0 0 0 2.6 1.5l.4 3h4l.4-3a8 8 0 0 0 2.6-1.5l2.4 1 2-3.5-2-1.5ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z"/></svg></span><span>Marketing</span></a>
            <a class="nav-item" href={adminOrganizationPath}><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v4H5V4Zm0 6h9v4H5v-4Zm0 6h14v4H5v-4Z"/></svg></span><span>Organización Visual</span></a>
          </nav>

        </div>
      </aside>

      <main class="main-wrap">
        <header class="topbar">
          <button id="sidebar-open" class="menu-btn" type="button" aria-controls="admin-sidebar" aria-expanded="false">☰ Menú</button>
          <div class="hero-actions">
            <a class="action-btn" href={adminProductsPath}>Productos</a>
            <a class="action-btn" href={publicStorePath}>Ver tienda pública</a>
            <button id="logout-btn" class="action-btn danger hidden" type="button">Cerrar sesión</button>
          </div>
        </header>

        <section class="hero-card">
          <div>
            <span class="badge">⚙️ Ajustes de la tienda</span>
            <h1 class="page-title">Ajustes generales <span>de la tienda</span></h1>
            <p id="admin-subtitle" class="page-subtitle">Configura los datos generales de la tienda, el footer público y las monedas activas.</p>
          </div>
          <div class="hero-actions">
            
          </div>
        </section>
        <section id="admin-view">
          <div class="tabs">
            <button class="tab-btn active" data-tab="generales" type="button">Ajustes generales</button>
            <button class="tab-btn" data-tab="footer" type="button">Footer público</button>
            <button class="tab-btn" data-tab="monedas" type="button">Monedas</button>
            <button class="tab-btn" data-tab="horario" type="button">Horario</button>
          </div>

          <div class="stats-grid hidden">
            <article class="stat-card"><p class="stat-label">Productos destacados</p><p id="stat-featured" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Promos visuales</p><p id="stat-promos" class="stat-value">0</p></article>
            <article class="stat-card"><p class="stat-label">Accesos rápidos</p><p id="stat-shortcuts" class="stat-value">0</p></article>
          </div>

          <section id="tab-generales" class="panel-card tab-panel">
            <div class="section-head">
              <div>
                <h2 class="section-title">Ajustes generales públicos</h2>
                <p class="section-subtitle">Edita los datos principales que verá el cliente en la tienda pública.</p>
              </div>
              <button id="settings-refresh-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <form id="settings-form" class="visual-form-grid">
              <div class="field"><label for="settings-store-name">Nombre p&uacute;blico de la tienda</label><input id="settings-store-name" type="text" placeholder="Ej: PowerZona" required /></div>
              <div class="field"><label for="settings-order-prefix">Prefijo de &oacute;rdenes</label><input id="settings-order-prefix" type="text" placeholder="Ej: PP" maxlength="3" pattern="[A-Za-z]{0,3}" autocomplete="off" /></div>
              <div class="field"><label for="settings-whatsapp-number">WhatsApp principal</label><input id="settings-whatsapp-number" type="text" placeholder="Ej: +53 5 000 0000" required /></div>
              <div class="field"><label for="settings-cover-mode">Tipo de portada</label><select id="settings-cover-mode"><option value="single">Foto &uacute;nica</option><option value="carousel">Carrusel de fotos</option></select></div>
              <h3 class="settings-section-title">Im&aacute;genes</h3>
              <div class="settings-image-grid">
                <article class="settings-image-card">
                  <div class="settings-image-head"><h3 class="settings-image-title">Logo</h3></div>
                  <div id="settings-logo-preview" class="settings-thumb logo">Logo</div>
                  <div class="settings-upload-actions">
                    <div class="field settings-file-control"><label for="settings-logo-image">Subir logo</label><input id="settings-logo-image" type="file" accept="image/*" /></div>
                  </div>
                  <p class="form-help">Recomendado: imagen cuadrada, m&iacute;nimo 512 x 512 px.</p>
                </article>
                <article class="settings-image-card">
                  <div class="settings-image-head"><h3 class="settings-image-title">Portada</h3></div>
                  <div id="settings-cover-single-wrap">
                    <div id="settings-cover-preview" class="settings-thumb cover">Portada</div>
                    <div class="settings-upload-actions" style="margin-top:12px;">
                      <div class="field settings-file-control"><label for="settings-cover-image">Subir portada</label><input id="settings-cover-image" type="file" accept="image/*" /></div>
                    </div>
                  </div>
                  <div id="settings-cover-carousel-wrap" class="hidden">
                    <div id="settings-cover-gallery-preview" class="settings-gallery-grid"></div>
                  </div>
                  <p class="form-help">Recomendado: imagen horizontal 16:9, m&iacute;nimo 1600 x 900 px.</p>
                  <p class="form-help">La portada se optimiza autom&aacute;ticamente con calidad alta para cargar r&aacute;pido sin perder brillo.</p>
                </article>
              </div>
              <div class="field full"><label for="settings-store-description">Descripci&oacute;n de la tienda</label><textarea id="settings-store-description" placeholder="Descripci&oacute;n m&aacute;s completa para Bazar, ficha de tienda o SEO."></textarea><p class="form-help">Descripci&oacute;n m&aacute;s completa para uso futuro en Bazar, ficha de tienda, SEO o presentaci&oacute;n general.</p></div>
              <div class="field full"><label for="settings-welcome-text">Texto corto de bienvenida</label><textarea id="settings-welcome-text" placeholder="Ej: Suplementos, vitaminas y ofertas seleccionadas para ti."></textarea></div>
              <div class="field"><label for="settings-public-category-columns">Vista de categor&iacute;as</label><select id="settings-public-category-columns"><option value="2">2 por fila</option><option value="1">1 por fila</option></select></div>
              <div class="field full">
                <label>Tipo de negocio</label>
                <div class="business-type-picker">
                  <button id="business-type-trigger" class="mini-btn business-type-trigger" type="button" aria-expanded="false">Seleccionar tipos de negocio <span aria-hidden="true">&#8964;</span></button>
                  <div id="business-type-chips" class="chip-list"></div>
                  <div id="business-type-panel" class="business-type-panel hidden">
                    <input id="business-type-search" type="search" placeholder="Buscar tipo de negocio..." />
                    <div id="business-type-options"></div>
                  </div>
                </div>
                <p id="business-type-help" class="form-help">Puedes seleccionar hasta 3 tipos de negocio.</p>
              </div>
              <div class="field full"><label>Direcci&oacute;n</label></div>
              <div class="field"><label for="settings-province">Provincia</label><select id="settings-province"><option value="">Selecciona provincia</option></select></div>
              <div class="field"><label for="settings-municipality">Municipio</label><select id="settings-municipality" disabled><option value="">Primero selecciona provincia</option></select></div>
              <div class="field full"><label for="settings-address-detail">Direcci&oacute;n exacta / Referencia</label><textarea id="settings-address-detail" placeholder="Calle, n&uacute;mero, reparto, barrio o referencia"></textarea></div>
              <textarea id="settings-address" class="hidden" aria-hidden="true"></textarea>
              <textarea id="settings-public-services-text" class="hidden" aria-hidden="true"></textarea>
              <div class="field full"><label for="settings-reviews-text">Rese&ntilde;a / texto de confianza</label><textarea id="settings-reviews-text" placeholder="Ej: Gracias por elegir PowerZona. Atenci&oacute;n personalizada y productos seleccionados."></textarea></div>
              <div id="settings-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full"><button class="submit-btn" type="submit">Guardar ajustes generales</button></div>
            </form>
          </section>

          <section id="tab-footer" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Footer público</h2>
                <p class="section-subtitle">Agrega la información inferior que saldrá en portada, categoría, subcategoría y producto.</p>
              </div>
            </div>
            <form id="footer-settings-form" class="visual-form-grid">
              <div class="field"><label for="settings-footer-title">Título del footer</label><input id="settings-footer-title" type="text" placeholder="Ej: PowerZona" /></div>
              <div class="field"><label for="settings-footer-contact-text">Texto de contacto</label><textarea id="settings-footer-contact-text" placeholder="Ej: Escríbenos para confirmar disponibilidad, combos o entregas."></textarea></div>
              <div class="field full"><label for="settings-footer-text">Descripción del footer</label><textarea id="settings-footer-text" placeholder="Texto corto para cerrar la tienda pública."></textarea></div>
              <div class="field full"><label for="settings-footer-extra-text">Información extra</label><textarea id="settings-footer-extra-text" placeholder="Ej: Políticas, garantía, nota de confianza o información adicional."></textarea></div>
              <div class="field"><label for="settings-footer-link-1-label">Botón / enlace 1</label><input id="settings-footer-link-1-label" type="text" placeholder="Ej: Grupo de WhatsApp" /></div>
              <div class="field"><label for="settings-footer-link-1-url">URL enlace 1</label><input id="settings-footer-link-1-url" type="url" placeholder="https://..." /></div>
              <div class="field"><label for="settings-footer-link-2-label">Botón / enlace 2</label><input id="settings-footer-link-2-label" type="text" placeholder="Ej: Instagram" /></div>
              <div class="field"><label for="settings-footer-link-2-url">URL enlace 2</label><input id="settings-footer-link-2-url" type="url" placeholder="https://..." /></div>
              <div id="footer-settings-alert" class="alert alert-info hidden full"></div>
              <div class="full hero-actions" style="justify-content:flex-start">
                <button class="submit-btn" type="submit">Guardar footer público</button>
                <button id="footer-settings-refresh-btn" class="mini-btn" type="button">Actualizar</button>
              </div>
            </form>
          </section>


          <section id="tab-horario" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Horario</h2>
                <p class="section-subtitle">Configura cuándo tu tienda aparece como disponible. Aunque esté fuera de horario, los clientes pueden dejar su pedido para ser atendidos luego.</p>
              </div>
              <button id="business-hours-refresh-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <form id="business-hours-form" class="visual-form-grid">
              <div class="field full">
                <label>Disponibilidad</label>
                <div class="option-grid">
                  <label class="option-card">
                    <input type="radio" name="business_hours_mode" value="always_available" checked />
                    <span class="option-title">Siempre disponible</span>
                    <span class="option-text">La tienda se muestra como disponible y no se muestra aviso de cerrado.</span>
                  </label>
                  <label class="option-card">
                    <input type="radio" name="business_hours_mode" value="custom" />
                    <span class="option-title">Horario personalizado</span>
                    <span class="option-text">Configura días y horas. Fuera de horario se muestra un aviso.</span>
                  </label>
                  <label class="option-card">
                    <input type="radio" name="business_hours_mode" value="temporarily_closed" />
                    <span class="option-title">Cerrado temporalmente</span>
                    <span class="option-text">Para pausas, vacaciones o mantenimiento con aviso visible.</span>
                  </label>
                </div>
              </div>

              <div id="business-hours-days" class="field full">
                <label>Días y horas</label>
                <div class="hours-grid" id="business-hours-days-grid"></div>
              </div>

              <div class="field full">
                <label for="closed-message">Mensaje fuera de horario</label>
                <textarea id="closed-message" placeholder="Estamos fuera de horario, pero puedes realizar tu pedido. Lo atenderemos en horario laboral."></textarea>
              </div>
              <div class="field full">
                <label for="temporarily-closed-message">Mensaje cerrado temporalmente</label>
                <textarea id="temporarily-closed-message" placeholder="Estamos cerrados temporalmente. Puedes realizar tu pedido y te responderemos pronto."></textarea>
              </div>
              <div class="field full">
                <label class="toggle-row"><input id="allow-orders-when-closed" type="checkbox" checked /> Permitir pedidos fuera de horario</label>
                <p class="form-help">Si lo desactivas, el checkout bloqueará el botón de realizar pedido cuando la tienda esté cerrada.</p>
              </div>
              <div id="business-hours-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full"><button class="submit-btn" type="submit">Guardar horario</button></div>
            </form>
