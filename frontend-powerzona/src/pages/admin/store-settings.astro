<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ajustes generales de la tienda | PowerZona</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --page: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --green: #16a34a;
        --blue: #2563eb;
        --red: #dc2626;
        --orange: #f97316;
        --purple: #7c3aed;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        color: var(--text);
        background:
          radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.16), transparent 30%),
          radial-gradient(circle at 85% 8%, rgba(22, 163, 74, 0.10), transparent 25%),
          linear-gradient(180deg, #f8fbff 0%, var(--page) 48%, #e8eef7 100%);
      }
      a { color: inherit; text-decoration: none; }
      button, input, select, textarea { font: inherit; }
      button { cursor: pointer; }
      button:disabled { cursor: not-allowed; opacity: .65; }
      .hidden { display: none !important; }

      .app-shell { width: min(1480px, 100%); margin: 0 auto; padding: 24px; display: block; }
      .sidebar-overlay { position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .36); opacity: 0; pointer-events: none; transition: opacity .22s ease; backdrop-filter: blur(2px); }
      body.sidebar-open .sidebar-overlay { opacity: 1; pointer-events: auto; }
      .sidebar { position: fixed; top: 18px; left: 18px; bottom: 18px; z-index: 90; width: min(286px, calc(100vw - 36px)); border-radius: 30px; padding: 18px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); color: #0f172a; border: 1px solid rgba(226, 232, 240, .95); box-shadow: 0 28px 80px rgba(15, 23, 42, .22); overflow: hidden; transform: translateX(calc(-100% - 28px)); transition: transform .24s ease; }
      body.sidebar-open .sidebar { transform: translateX(0); }
      .sidebar::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 18% 0%, rgba(15,23,42,.06), transparent 32%); pointer-events: none; }
      .sidebar-inner { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; }
      .brand { display: flex; align-items: center; gap: 11px; padding: 8px 8px 18px; border-bottom: 1px solid #e2e8f0; margin-bottom: 14px; }
      .brand-logo { width: 42px; height: 42px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; background: #0f172a; color: #fff; box-shadow: 0 14px 30px rgba(15, 23, 42, .18); font-weight: 1000; }
      .brand-title { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.02em; }
      .brand-subtitle { margin: 2px 0 0; color: #64748b; font-size: 11px; font-weight: 850; }
      .sidebar-label { margin: 18px 9px 9px; color: #64748b; font-size: 10px; font-weight: 1000; text-transform: uppercase; letter-spacing: .12em; }
      .nav-list { display: grid; gap: 8px; }
      .nav-item { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: 18px; color: #334155; font-size: 13px; font-weight: 950; border: 1px solid transparent; }
      .nav-item:hover { background: #f1f5f9; border-color: #e2e8f0; color: #0f172a; }
      .nav-item.active { background: #0f172a; border-color: #0f172a; color: #fff; box-shadow: 0 12px 26px rgba(15,23,42,.16); }
      .nav-icon { width: 34px; height: 34px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; background: #f8fafc; color: #0f172a; border: 1px solid #e2e8f0; flex: 0 0 auto; }
      .nav-icon svg { width: 18px; height: 18px; display: block; fill: currentColor; }
      .nav-item.active .nav-icon { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.20); }
      .sidebar-footer { margin-top: auto; padding: 14px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
      .sidebar-footer strong { display: block; font-size: 12px; margin-bottom: 5px; color: #0f172a; }
      .sidebar-footer span { display: block; color: #475569; font-size: 11px; line-height: 1.45; font-weight: 750; }
      .sidebar-close { margin-left: auto; width: 36px; height: 36px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; color: #0f172a; font-weight: 1000; box-shadow: 0 8px 18px rgba(15,23,42,.05); }
      .menu-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; border-radius: 18px; padding: 12px 15px; background: #0f172a; color: #fff; border: 1px solid #0f172a; box-shadow: 0 12px 26px rgba(15,23,42,.16); font-weight: 1000; }

