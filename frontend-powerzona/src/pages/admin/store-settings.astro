            <div id="currency-alert" class="alert alert-info hidden"></div>
            <form id="currency-create-form" class="visual-form-grid" style="margin-top:14px;">
              <div class="field"><label for="currency-code">Código</label><input id="currency-code" type="text" placeholder="Ej: CUP" maxlength="8" /></div>
              <div class="field"><label for="currency-name">Nombre</label><input id="currency-name" type="text" placeholder="Ej: Peso Cubano" /></div>
              <div class="field"><label for="currency-symbol">Símbolo</label><input id="currency-symbol" type="text" placeholder="Ej: CUP" /></div>
