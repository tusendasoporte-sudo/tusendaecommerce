      async function swapVisualOrder(itemId, direction) {
        const currentItem = visualItems.find((item) => item.id === itemId);
        if (!currentItem) return;
        const sameTypeItems = getVisualItemsSorted(currentItem.type);
        const currentIndex = sameTypeItems.findIndex((item) => item.id === itemId);
        const targetIndex = direction === 'up' ? currentIndex - 1 : currentIndex + 1;
        if (currentIndex < 0 || targetIndex < 0 || targetIndex >= sameTypeItems.length) return;
        const current = sameTypeItems[currentIndex];
        const target = sameTypeItems[targetIndex];
        const currentOrder = Number(current.sort_order || currentIndex + 1);
        const targetOrder = Number(target.sort_order || targetIndex + 1);
        const currentData = new FormData();
        const targetData = new FormData();
        currentData.append('sort_order', String(targetOrder));
        targetData.append('sort_order', String(currentOrder));
        await Promise.all([
          apiRequest(`/api/collections/store_visual_items/records/${current.id}`, { method: 'PATCH', body: currentData }),
          apiRequest(`/api/collections/store_visual_items/records/${target.id}`, { method: 'PATCH', body: targetData }),
