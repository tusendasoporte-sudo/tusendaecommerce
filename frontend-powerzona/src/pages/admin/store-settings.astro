            <div id="visual-list" class="items-list" style="margin-top:16px;"><div class="empty-state">Cargando promos y accesos...</div></div>
          </section>

          <section id="tab-organizacion" class="panel-card tab-panel hidden">
            <div class="section-head" id="organizacion">
              <div>
                <h2 class="section-title">Organización Visual</h2>
                <p class="section-subtitle">Ordena lo que ve el cliente en la tienda pública. En este paso puedes mover productos destacados, promos visuales y accesos rápidos.</p>
              </div>
              <button id="refresh-org-btn" class="mini-btn" type="button">Actualizar</button>
            </div>
            <div id="organization-alert" class="alert alert-info hidden"></div>
            <div class="organization-grid">
              <article class="organization-card">
                <h3 class="organization-title">Productos destacados</h3>
                <p class="organization-help">Cambia el orden de la sección “Productos destacados”. Si quieres ocultar uno solo de destacados, usa “Quitar destacado” para no ocultar el producto completo de la tienda.</p>
                <div id="organization-featured-list" class="items-list"><div class="empty-state">Cargando destacados...</div></div>
              </article>
              <article class="organization-card">
                <h3 class="organization-title">Promos visuales</h3>
                <p class="organization-help">Ordena y activa/desactiva las tarjetas de promociones que aparecen en la portada pública.</p>
                <div id="organization-promos-list" class="items-list"><div class="empty-state">Cargando promos...</div></div>
              </article>
              <article class="organization-card">
                <h3 class="organization-title">Accesos rápidos</h3>
                <p class="organization-help">Ordena y activa/desactiva botones o tarjetas rápidas como WhatsApp, enlaces, categorías o archivos.</p>
                <div id="organization-shortcuts-list" class="items-list"><div class="empty-state">Cargando accesos rápidos...</div></div>
              </article>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script define:vars={{ pocketbaseUrl, currentStoreId, adminProductsPath, adminAuthToken }}>
      const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
      const CURRENT_STORE_ID = String(currentStoreId || '');
      const ADMIN_PRODUCTS_PATH = String(adminProductsPath || '/admin/products');
      const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
      const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
      let products = [];
      let categories = [];
      let visualItems = [];
      let activeTab = 'generales';

      const sidebar = document.getElementById('admin-sidebar');
      const sidebarOpenBtn = document.getElementById('sidebar-open');
      const sidebarCloseBtn = document.getElementById('sidebar-close');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      const adminView = document.getElementById('admin-view');
      const logoutBtn = document.getElementById('logout-btn');
      const featuredProductSelect = document.getElementById('featured-product-select');
      const markFeaturedBtn = document.getElementById('mark-featured-btn');
      const featuredList = document.getElementById('featured-list');
      const featuredAlert = document.getElementById('featured-alert');
      const visualForm = document.getElementById('visual-form');
      const visualList = document.getElementById('visual-list');
      const visualAlert = document.getElementById('visual-alert');
      const newVisualBtn = document.getElementById('new-visual-btn');
      const openVisualFormBtn = document.getElementById('open-visual-form-btn');
      const refreshBtn = document.getElementById('refresh-btn');
      const refreshOrgBtn = document.getElementById('refresh-org-btn');
      const organizationAlert = document.getElementById('organization-alert');
      const organizationFeaturedList = document.getElementById('organization-featured-list');
      const organizationPromosList = document.getElementById('organization-promos-list');
      const organizationShortcutsList = document.getElementById('organization-shortcuts-list');
      const visualId = document.getElementById('visual-id');
      const visualType = document.getElementById('visual-type');
      const visualTitle = document.getElementById('visual-title');
      const visualDescription = document.getElementById('visual-description');
      const visualImage = document.getElementById('visual-image');
      const visualCurrentImage = document.getElementById('visual-current-image');
      const visualButtonText = document.getElementById('visual-button-text');
      const visualActionType = document.getElementById('visual-action-type');
      const visualOrder = document.getElementById('visual-order');
      const visualUrl = document.getElementById('visual-url');
      const visualWhatsappMessage = document.getElementById('visual-whatsapp-message');
      const visualCategory = document.getElementById('visual-category');
      const visualAttachment = document.getElementById('visual-attachment');
      const visualCurrentAttachment = document.getElementById('visual-current-attachment');
      const visualActive = document.getElementById('visual-active');
      const visualCancelBtn = document.getElementById('visual-cancel-btn');
      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function clearAdminToken() { document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax'; }
      function showAlert(el, message = '', type = 'info') {
        if (!el) return;
        if (!message) { el.className = 'alert alert-info hidden'; el.textContent = ''; return; }
        el.className = `alert alert-${type}`;
        el.textContent = message;
      }
      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
      }
      function pocketBaseErrorMessage(result, fallback = 'Error de comunicacion con la plataforma.') {
        const base = result?.message || fallback;
        const fieldErrors = result?.data && typeof result.data === 'object'
          ? Object.entries(result.data).map(([field, info]) => {
              const message = info?.message || (Array.isArray(info) ? info.map((item) => item?.message).filter(Boolean).join(', ') : '');
              return message ? `${field}: ${message}` : field;
            }).filter(Boolean)
          : [];
        return fieldErrors.length ? `${base} ${fieldErrors.join(' · ')}` : base;
      }
      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(pocketBaseErrorMessage(result));
        return result;
      }
      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${params}${separator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }

      function withStoreFilter(params = '') {
        const query = new URLSearchParams(params || '');
        const existing = query.get('filter');
        if (existing) query.set('filter', `(${existing}) && ${STORE_FILTER}`);
        else query.set('filter', STORE_FILTER);
        return query.toString();
      }

      function isCurrentStoreRecord(record) {
        const value = record?.store;
        return Array.isArray(value) ? value.includes(CURRENT_STORE_ID) : String(value || '') === CURRENT_STORE_ID;
      }
      function parseProductImageOrder(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let stored = [];
        try {
          stored = Array.isArray(JSON.parse(product?.image_order || '[]')) ? JSON.parse(product?.image_order || '[]') : [];
        } catch (_) {
          stored = [];
        }
        const ordered = stored.filter((name) => images.includes(name));
        images.forEach((name) => { if (!ordered.includes(name)) ordered.push(name); });
        return ordered;
      }
      function productImageUrl(product) {
        const images = parseProductImageOrder(product);
        const firstImage = images[0] || '';
        if (!product?.id || !firstImage) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }
      function visualImageUrl(item) {
        const image = Array.isArray(item?.image) ? item.image[0] : item?.image;
        if (!item?.id || !image) return '';
        return `${POCKETBASE_URL}/api/files/store_visual_items/${encodeURIComponent(item.id)}/${encodeURIComponent(image)}?thumb=300x200`;
      }
      function visualAttachmentName(item) {
        const attachment = Array.isArray(item?.attachment) ? item.attachment[0] : item?.attachment;
        return attachment || '';
      }
      function thumbMarkup(url, fallback = '📦') {
        if (!url) return `<span class="thumb placeholder">${fallback}</span>`;
        return `<img class="thumb" src="${url}" alt="" loading="lazy" />`;
      }
      function formatUsd(value) { return `$${Number(value || 0).toFixed(2)} USD`; }
      function renderStats() {
        document.getElementById('stat-featured').textContent = String(products.filter((p) => p.featured === true).length);
        document.getElementById('stat-promos').textContent = String(visualItems.filter((item) => item.type === 'promo_visual').length);
        document.getElementById('stat-shortcuts').textContent = String(visualItems.filter((item) => item.type === 'acceso_rapido').length);
      }
      function renderProductSelect() {
        const available = products.filter((product) => product.active !== false && product.featured !== true);
        featuredProductSelect.innerHTML = '<option value="">Selecciona un producto</option>' + available
          .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
          .map((product) => `<option value="${product.id}">${escapeHtml(product.name || 'Sin nombre')} · ${formatUsd(product.base_price_usd)}</option>`).join('');
      }
      function getFeaturedProductsSorted() {
        return products
          .filter((product) => product.featured === true)
          .sort((a, b) => (Number(a.featured_order || 0) - Number(b.featured_order || 0)) || String(a.name || '').localeCompare(String(b.name || '')));
      }
      function getVisualItemsSorted(type) {
        return visualItems
          .filter((item) => item.type === type)
          .sort((a, b) => (Number(a.sort_order || 0) - Number(b.sort_order || 0)) || String(a.title || '').localeCompare(String(b.title || '')));
      }
      function renderFeaturedList() {
        const featured = getFeaturedProductsSorted();
        if (!featured.length) {
          featuredList.innerHTML = '<div class="empty-state">Todavía no hay productos marcados como destacados.</div>';
          return;
        }
        featuredList.innerHTML = featured.map((product) => `
          <article class="item-row" data-product-id="${product.id}">
            <div class="item-main">
              ${thumbMarkup(productImageUrl(product), '📦')}
              <div>
                <p class="item-title">${escapeHtml(product.name || 'Sin nombre')}</p>
                <p class="item-meta">${formatUsd(product.base_price_usd)} · Stock ${Number(product.stock || 0)} · Orden destacado ${Number(product.featured_order || 0)} · ${product.active === false ? 'Oculto' : 'Visible'}</p>
              </div>
            </div>
            <div class="item-actions">
              <span class="pill pill-visible">Destacado</span>
              <a class="mini-btn" href="${ADMIN_PRODUCTS_PATH}?product=${encodeURIComponent(product.id)}">Editar producto</a>
              <button class="mini-btn danger js-unfeature" type="button">Quitar</button>
            </div>
          </article>
        `).join('');
      }
      function renderVisualList() {
        if (!visualItems.length) {
          visualList.innerHTML = '<div class="empty-state">Todavía no hay promos visuales ni accesos rápidos.</div>';
          return;
        }
        visualList.innerHTML = [...visualItems]
          .sort((a, b) => (Number(a.sort_order || 0) - Number(b.sort_order || 0)) || String(a.title || '').localeCompare(String(b.title || '')))
          .map((item) => {
            const typeLabel = item.type === 'promo_visual' ? 'Promo visual' : 'Acceso rápido';
            const actionLabel = item.action_type ? `Acción: ${item.action_type}` : 'Sin acción';
            const attachment = visualAttachmentName(item);
            return `
              <article class="item-row" data-visual-id="${item.id}">
                <div class="item-main">
                  ${thumbMarkup(visualImageUrl(item), item.type === 'promo_visual' ? '🏷️' : '⚡')}
                  <div>
                    <p class="item-title">${escapeHtml(item.title || 'Sin título')}</p>
                    <p class="item-meta">${escapeHtml(typeLabel)} · ${escapeHtml(actionLabel)} · Orden ${Number(item.sort_order || 0)}${attachment ? ` · Archivo: ${escapeHtml(attachment)}` : ''}</p>
                  </div>
                </div>
                <div class="item-actions">
                  <span class="pill pill-type">${escapeHtml(typeLabel)}</span>
                  <span class="pill ${item.active !== false ? 'pill-visible' : 'pill-hidden'}">${item.active !== false ? 'Visible' : 'Oculto'}</span>
                  <button class="mini-btn js-visual-edit" type="button">Editar</button>
                  <button class="mini-btn danger js-visual-delete" type="button">Borrar</button>
                </div>
              </article>
            `;
          }).join('');
      }
      function renderOrganizationFeaturedList() {
        const featured = getFeaturedProductsSorted();
        if (!featured.length) {
          organizationFeaturedList.innerHTML = '<div class="empty-state">Todavía no hay productos destacados para ordenar.</div>';
          return;
        }
        organizationFeaturedList.innerHTML = featured.map((product, index) => `
          <article class="item-row" data-org-product-id="${product.id}">
            <div class="item-main">
              ${thumbMarkup(productImageUrl(product), '📦')}
              <div>
                <p class="item-title">${escapeHtml(product.name || 'Sin nombre')}</p>
                <p class="item-meta">Orden ${Number(product.featured_order || 0)} · ${formatUsd(product.base_price_usd)} · ${product.active === false ? 'Producto oculto' : 'Producto visible'}</p>
              </div>
            </div>
            <div class="item-actions">
              <button class="mini-btn order-btn js-featured-move" data-direction="up" type="button" ${index === 0 ? 'disabled' : ''}>↑</button>
              <button class="mini-btn order-btn js-featured-move" data-direction="down" type="button" ${index === featured.length - 1 ? 'disabled' : ''}>↓</button>
              <button class="mini-btn warning js-featured-org-remove" type="button">Quitar destacado</button>
            </div>
          </article>
        `).join('');
      }
      function organizationVisualRow(item, index, total) {
        const typeLabel = item.type === 'promo_visual' ? 'Promo visual' : 'Acceso rápido';
        return `
          <article class="item-row" data-org-visual-id="${item.id}">
            <div class="item-main">
              ${thumbMarkup(visualImageUrl(item), item.type === 'promo_visual' ? '🏷️' : '⚡')}
              <div>
                <p class="item-title">${escapeHtml(item.title || 'Sin título')}</p>
                <p class="item-meta">${escapeHtml(typeLabel)} · Orden ${Number(item.sort_order || 0)} · ${item.active !== false ? 'Visible' : 'Oculto'}</p>
              </div>
            </div>
            <div class="item-actions">
              <button class="mini-btn order-btn js-visual-move" data-direction="up" type="button" ${index === 0 ? 'disabled' : ''}>↑</button>
              <button class="mini-btn order-btn js-visual-move" data-direction="down" type="button" ${index === total - 1 ? 'disabled' : ''}>↓</button>
              <button class="mini-btn ${item.active !== false ? 'warning' : 'success'} js-visual-toggle" type="button">${item.active !== false ? 'Ocultar' : 'Mostrar'}</button>
              <button class="mini-btn js-visual-org-edit" type="button">Editar</button>
            </div>
          </article>
        `;
      }
      function renderOrganizationVisualLists() {
        const promos = getVisualItemsSorted('promo_visual');
        const shortcuts = getVisualItemsSorted('acceso_rapido');
        organizationPromosList.innerHTML = promos.length
          ? promos.map((item, index) => organizationVisualRow(item, index, promos.length)).join('')
          : '<div class="empty-state">Todavía no hay promos visuales para ordenar.</div>';
        organizationShortcutsList.innerHTML = shortcuts.length
          ? shortcuts.map((item, index) => organizationVisualRow(item, index, shortcuts.length)).join('')
          : '<div class="empty-state">Todavía no hay accesos rápidos para ordenar.</div>';
      }
      function renderOrganization() {
        renderOrganizationFeaturedList();
        renderOrganizationVisualLists();
      }
      function renderAll() {
        renderStats();
        renderProductSelect();
        renderFeaturedList();
        renderVisualList();
        renderCategoryOptions();
        renderOrganization();
      }
      function renderCategoryOptions() {
        visualCategory.innerHTML = '<option value="">Selecciona categoría</option>' + categories
          .filter((item) => item.active !== false)
          .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
          .map((item) => `<option value="${item.id}">${escapeHtml(item.name || 'Sin nombre')}</option>`).join('');
      }
      async function loadData() {
        products = await loadAllRecords('products', withStoreFilter('sort=featured_order,name'));
        categories = await loadAllRecords('categories', withStoreFilter('sort=order,name'));
        try {
          visualItems = await loadAllRecords('store_visual_items', withStoreFilter('sort=sort_order,title'));
        } catch (error) {
          visualItems = [];
          showAlert(visualAlert, 'No existe todavía la colección store_visual_items. Reinicia la plataforma para aplicar la migración nueva.', 'error');
        }
        renderAll();
      }
      async function markFeatured() {
        const productId = featuredProductSelect.value;
        if (!productId) return showAlert(featuredAlert, 'Selecciona un producto primero.', 'error');
        const formData = new FormData();
        formData.append('featured', 'true');
        formData.append('featured_order', String(nextFeaturedOrder()));
        await apiRequest(`/api/collections/products/records/${productId}`, { method: 'PATCH', body: formData });
        showAlert(featuredAlert, 'Producto marcado como destacado.', 'success');
        await loadData();
      }
      async function unfeatureProduct(productId) {
        const formData = new FormData();
        formData.append('featured', 'false');
        await apiRequest(`/api/collections/products/records/${productId}`, { method: 'PATCH', body: formData });
        showAlert(featuredAlert, 'Producto quitado de destacados.', 'success');
        await loadData();
      }
      function nextFeaturedOrder() {
        return products
          .filter((product) => product.featured === true)
          .reduce((max, item) => Math.max(max, Number(item.featured_order || 0)), 0) + 1;
      }
      function nextVisualOrder() {
