          const fieldName = slot.dataset.galleryField || 'cover_gallery';
          const sourceField = slot.dataset.gallerySourceField || fieldName;
          if (target?.closest('.js-delete-gallery-image')) {
            if (slot.dataset.pendingFile === 'true') {
              const input = slot.querySelector('.js-cover-gallery-file');
              const thumb = slot.querySelector('.settings-thumb.cover');
              const index = Number(slot.dataset.galleryIndex || 0);
              const previewUrl = galleryPreviewUrls.get(fieldName);
              if (previewUrl) URL.revokeObjectURL(previewUrl);
              galleryPreviewUrls.delete(fieldName);
              if (input) input.value = '';
              delete slot.dataset.pendingFile;
              thumb.innerHTML = filename
                ? `<img src="${escapeHtml(fileUrlFor(filename, '700x260'))}" alt="Foto ${index + 1}" /><button class="settings-thumb-delete js-delete-gallery-image" type="button" aria-label="Borrar foto ${index + 1}">&#128465;</button>`
