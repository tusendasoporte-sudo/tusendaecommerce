          grid-template-columns: minmax(0, 1fr) auto;
          gap: 14px;
          align-items: center;
        }
        .currency-search-box {
          min-height: 54px;
          display: flex;
          align-items: center;
          gap: 10px;
          padding: 0 16px;
          border-radius: 16px;
          border: 1px solid #e2e8f0;
          background: #fff;
          color: #64748b;
          box-shadow: 0 12px 26px rgba(15,23,42,.04);
        }
        .currency-search-box svg {
          width: 22px;
          height: 22px;
          fill: currentColor;
          flex: 0 0 auto;
        }
        .currency-search-box input {
          width: 100%;
          border: 0;
          outline: none;
          background: transparent;
          color: #0f172a;
          font-size: 16px;
          font-weight: 750;
        }
        .currency-search-box input::placeholder {
          color: #64748b;
        }
        .currency-mobile-toolbar .mini-btn.primary {
          min-height: 54px;
          border-radius: 16px;
          padding: 0 20px;
          background: #2563eb;
          color: #fff;
          border-color: #2563eb;
          box-shadow: 0 14px 28px rgba(37,99,235,.24);
          font-size: 15px;
        }
        .currency-panel {
          padding: 0;
          border-radius: 18px;
          background: #fff;
          border: 1px solid #e2e8f0;
          overflow: hidden;
        }
        .currency-panel-head {
          display: none;
        }
        .currency-table-head {
          display: none;
        }
        .currency-row {
          display: block;
          border-radius: 0;
          border: 0;
          border-bottom: 1px solid #e2e8f0;
          margin: 0;
          padding: 18px 20px;
        }
        .currency-row > :not(.currency-mobile-row) {
          display: none !important;
        }
        .currency-mobile-row {
          display: grid;
          grid-template-columns: 58px minmax(0, 1fr) auto;
          gap: 14px;
          align-items: center;
          width: 100%;
          min-width: 0;
        }
        .currency-mobile-body {
          min-width: 0;
          display: grid;
          gap: 6px;
        }
        .currency-mobile-title {
          display: flex;
          align-items: center;
          gap: 9px;
          min-width: 0;
        }
        .currency-mobile-code {
          color: #0f172a;
          font-size: 20px;
          line-height: 1.1;
          font-weight: 1000;
        }
        .currency-mobile-name {
          color: #243b63;
          font-size: 14px;
          font-weight: 750;
          line-height: 1.25;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
        .currency-mobile-meta {
          display: flex;
          align-items: center;
          gap: 8px;
          flex-wrap: wrap;
          color: #0f172a;
          font-size: 15px;
          font-weight: 850;
        }
        .currency-mobile-control-line {
          display: grid;
          grid-template-columns: minmax(0, 1fr) auto auto;
          align-items: center;
          column-gap: 10px;
          row-gap: 6px;
          margin-top: 2px;
          min-width: 0;
        }
        .currency-mobile-rate {
          color: #0f172a;
          font-size: 15px;
          font-weight: 900;
          min-width: fit-content;
        }
        .currency-mobile-default {
          display: flex;
          align-items: center;
          min-height: 28px;
        }
        .currency-mobile-actions {
          display: flex;
          align-items: center;
          gap: 8px;
          justify-content: flex-end;
          margin-left: auto;
          min-width: max-content;
        }
        .currency-table {
          border: 0;
          background: #fff;
          overflow: visible;
        }
        .currency-avatar {
          width: 54px;
          height: 54px;
        }
        .currency-system-badge,
        .currency-custom-badge,
        .currency-base-badge,
        .currency-default-badge {
          font-size: 12px;
        }
        .currency-switch-text {
          min-width: auto;
          border-radius: 999px;
          padding: 6px 10px;
          background: #dcfce7;
          color: #15803d;
        }
        .currency-switch input:not(:checked) ~ .currency-switch-text {
          background: #f1f5f9;
          color: #334155;
        }
        .currency-visible-control {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          min-width: 0;
          cursor: pointer;
        }
        .currency-mobile-control-line .currency-visible-control {
          flex-wrap: wrap;
        }
        .currency-mobile-control-line .currency-switch-text {
          line-height: 1.15;
          white-space: normal;
        }
        .currency-mobile-meta .currency-switch-track {
          display: inline-flex;
          flex: 0 0 auto;
        }
        .currency-mobile-actions .currency-action-btn {
          width: 38px;
          min-height: 38px;
          padding: 0;
          font-size: 0;
          border: 0;
          background: transparent;
          color: #1e293b;
        }
        .currency-mobile-actions .currency-action-btn::before {
          content: '';
          width: 22px;
          height: 22px;
          display: block;
          background: currentColor;
          -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 17.5V20h2.5L17.8 8.7l-2.5-2.5L4 17.5Zm15.6-10.6c.4-.4.4-1 0-1.4l-1.1-1.1c-.4-.4-1-.4-1.4 0l-.9.9 2.5 2.5.9-.9Z'/%3E%3C/svg%3E") center / contain no-repeat;
          mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 17.5V20h2.5L17.8 8.7l-2.5-2.5L4 17.5Zm15.6-10.6c.4-.4.4-1 0-1.4l-1.1-1.1c-.4-.4-1-.4-1.4 0l-.9.9 2.5 2.5.9-.9Z'/%3E%3C/svg%3E") center / contain no-repeat;
        }
        .currency-mobile-actions .currency-action-btn.save {
          width: auto;
          min-height: 34px;
          padding: 7px 10px;
          font-size: 12px;
        }
        .currency-mobile-actions .currency-action-btn.save::before {
          display: none;
        }
        .currency-mobile-actions .currency-delete-btn {
          border: 0;
          background: transparent;
        }
        .currency-base-action {
          white-space: nowrap;
        }
        .currency-create-grid {
          grid-template-columns: 1fr;
        }
        .currency-info-card {
          border-radius: 18px;
          padding: 18px 20px;
        }
      }


      .sidebar-plan-meta {
        margin-top: 10px;
        display: grid;
        gap: 4px;
        padding: 9px 10px;
        border-radius: 14px;
        background: rgba(37, 99, 235, .06);
        border: 1px solid rgba(37, 99, 235, .10);
      }
      .sidebar-plan-meta p {
        margin: 0;
        color: #475569;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 800;
      }
      .sidebar-plan-meta strong {
        color: #0f172a;
        font-weight: 1000;
      }
    </style>
  </head>
