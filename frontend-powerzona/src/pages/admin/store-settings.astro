            <div class="product-picker">
              <div class="field">
                <label for="featured-product-select">Producto existente</label>
                <select id="featured-product-select"><option value="">Selecciona un producto</option></select>
                <p class="form-help">No crea un producto nuevo. Solo marca uno existente como destacado.</p>
