        }
        function reviewSourceLabel(source) {
          return {
            public_store: 'Publica de tienda',
            public_product: 'Publica de producto',
            order_review_link: 'Link de orden',
            admin_created: 'Creada por admin',
          }[source] || source || 'Sin fuente';
        }
        function reviewDate(value) {
          if (!value) return 'Sin fecha';
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return String(value);
          return date.toLocaleString('es-ES', { dateStyle: 'medium', timeStyle: 'short' });
        }
        function reviewProductName(review) {
          return review.expand?.product?.name || review.product || '';
        }
        function reviewOrderLabel(review) {
          const order = review.expand?.order;
          if (!order && !review.order) return '';
          return order?.order_number || review.order || '';
        }
        function reviewStars(value) {
          const rating = Math.max(0, Math.min(5, Math.round(Number(value || 0))));
          return '<span class="rating-stars" aria-label="' + rating + ' de 5">' + '\u2605'.repeat(rating) + '\u2606'.repeat(5 - rating) + '</span>';
        }
        function renderReviewAnalytics() {
          const approvedStoreReviews = reviews.filter((review) => review.status === 'approved' && review.type === 'store');
          const approvedRatingTotal = approvedStoreReviews.reduce((sum, review) => sum + Number(review.rating || 0), 0);
          const average = approvedStoreReviews.length ? (approvedRatingTotal / approvedStoreReviews.length).toFixed(1) : '0.0';
          if (analyticsFields.average) analyticsFields.average.textContent = average;
          if (analyticsFields.approved) analyticsFields.approved.textContent = String(reviews.filter((review) => review.status === 'approved').length);
          if (analyticsFields.pending) analyticsFields.pending.textContent = String(reviews.filter((review) => review.status === 'pending').length);
          if (analyticsFields.verified) analyticsFields.verified.textContent = String(reviews.filter((review) => review.verified_purchase === true).length);
          if (analyticsFields.public) analyticsFields.public.textContent = String(reviews.filter((review) => review.source === 'public_store' || review.source === 'public_product').length);
          if (analyticsFields.products) analyticsFields.products.textContent = String(reviews.filter((review) => review.type === 'product').length);
          if (analyticsFields.store) analyticsFields.store.textContent = String(reviews.filter((review) => review.type === 'store').length);
        }
        function reviewMatchesFilter(review) {
          if (activeReviewFilter === 'all') return true;
          if (['pending', 'approved', 'rejected', 'hidden'].includes(activeReviewFilter)) return review.status === activeReviewFilter;
          if (activeReviewFilter === 'store') return review.type === 'store';
          if (activeReviewFilter === 'product') return review.type === 'product';
          if (activeReviewFilter === 'verified') return review.verified_purchase === true;
          if (activeReviewFilter === 'public') return review.source === 'public_store' || review.source === 'public_product';
          return true;
        }
        function reviewProductOrType(review) {
          const productName = reviewProductName(review);
          return productName || reviewTypeLabel(review.type);
        }
        function reviewStatusPill(review) {
          const status = String(review.status || 'pending');
          return `<span class="rating-status-pill ${escapeHtml(status)}">${escapeHtml(reviewStatusLabel(status))}</span>`;
        }
        function reviewActionsMarkup(review) {
          const canApprove = review.status !== 'approved';
          const canReject = review.status !== 'rejected';
          const canHide = review.status !== 'hidden';
          return `
            <div class="rating-row-actions">
              <button class="rating-row-menu-btn" type="button" data-rating-menu-trigger aria-label="Abrir acciones">\u22EE</button>
              <div class="rating-floating-menu hidden" data-rating-menu>
                ${canApprove ? '<button class="js-review-action" data-action="approve" type="button">Aprobar</button>' : ''}
                ${canReject ? '<button class="js-review-action" data-action="reject" type="button">Rechazar</button>' : ''}
                ${canHide ? '<button class="js-review-action" data-action="hide" type="button">Ocultar</button>' : ''}
                <button class="danger js-review-action" data-action="delete" type="button">Eliminar</button>
              </div>
            </div>
          `;
        }
        function readyOrderActionsMarkup() {
          return `
            <div class="rating-row-actions">
              <button class="rating-row-menu-btn" type="button" data-rating-menu-trigger aria-label="Abrir acciones">\u22EE</button>
              <div class="rating-floating-menu hidden" data-rating-menu>
                <button class="js-ready-order-action" data-action="whatsapp" type="button">Pedir rese\u00f1a por WhatsApp</button>
                <button class="js-ready-order-action" data-action="skip" type="button">Ignorar</button>
              </div>
            </div>
          `;
        }
        function pendingReviewCompactRow(review) {
          return `
            <article class="rating-compact-row" data-review-id="${escapeHtml(review.id)}">
              <div>
                <p class="rating-compact-title">${escapeHtml(review.customer_name || 'Cliente')} \u00b7 \u2605 ${escapeHtml(Number(review.rating || 0).toFixed(1))}</p>
                <p class="rating-compact-meta">${escapeHtml(review.comment || 'Sin comentario')}</p>
              </div>
              ${reviewActionsMarkup(review)}
            </article>
          `;
        }
        function readyOrderCompactRow(order) {
          return `
            <article class="rating-compact-row" data-ready-order-id="${escapeHtml(order.id)}">
              <div>
                <p class="rating-compact-title">${escapeHtml(order.order_number || 'Orden')} \u00b7 ${escapeHtml(order.customer_name || 'Cliente sin nombre')}</p>
                <p class="rating-compact-meta">Entregada ${escapeHtml(timeAgoFrom(order.delivered_at))}</p>
              </div>
              ${readyOrderActionsMarkup()}
            </article>
          `;
        }
        function reviewCard(review, mode = 'all') {
          const productName = reviewProductName(review);
          const orderLabel = reviewOrderLabel(review);
          const canApprove = review.status !== 'approved';
          const canReject = review.status !== 'rejected';
          const canHide = review.status !== 'hidden';
          return `
            <article class="item-row" data-review-id="${escapeHtml(review.id)}">
              <div class="item-main" style="align-items:flex-start;">
                <div class="thumb placeholder" aria-hidden="true">${reviewStars(review.rating)}</div>
                <div>
                  <p class="item-title">${escapeHtml(review.customer_name || 'Cliente')} \u00b7 ${escapeHtml(reviewTypeLabel(review.type))}</p>
                  <p class="item-meta">${escapeHtml(review.comment || 'Sin comentario')}</p>
                  <p class="item-meta">
                    Estado: ${escapeHtml(reviewStatusLabel(review.status))}
                    \u00b7 Fuente: ${escapeHtml(reviewSourceLabel(review.source))}
                    \u00b7 Compra verificada: ${review.verified_purchase === true ? 'Si' : 'No'}
                    \u00b7 Fecha: ${escapeHtml(reviewDate(review.created))}
                    ${productName ? ' \u00b7 Producto: ' + escapeHtml(productName) : ''}
                    ${orderLabel ? ' \u00b7 Orden: ' + escapeHtml(orderLabel) : ''}
                  </p>
                </div>
              </div>
              ${reviewActionsMarkup(review)}
            </article>
          `;
        }
        function renderPendingReviews() {
          if (!pendingList) return;
          if (pendingReviewsCount) pendingReviewsCount.textContent = `${pendingReviews.length} pendiente${pendingReviews.length === 1 ? '' : 's'} >`;
          pendingList.innerHTML = pendingReviews.length
            ? pendingReviews.slice(0, 3).map(pendingReviewCompactRow).join('')
            : '<div class="empty-state">No hay rese&ntilde;as pendientes.</div>';
        }
        function renderAllReviews() {
          if (!allList) return;
          const items = reviews.filter(reviewMatchesFilter);
          const totalPages = Math.max(1, Math.ceil(items.length / RATING_REVIEWS_PAGE_SIZE));
          ratingAllReviewsPage = Math.min(Math.max(1, ratingAllReviewsPage), totalPages);
          const start = (ratingAllReviewsPage - 1) * RATING_REVIEWS_PAGE_SIZE;
          const pageItems = items.slice(start, start + RATING_REVIEWS_PAGE_SIZE);
          const end = Math.min(start + RATING_REVIEWS_PAGE_SIZE, items.length);
          if (!items.length) {
            allList.innerHTML = '<div class="empty-state">Todav&iacute;a no hay rese&ntilde;as.<br><span>Las rese&ntilde;as aparecer&aacute;n aqu&iacute; cuando tus clientes empiecen a dejar sus opiniones.</span></div>';
            allPagination?.classList.add('hidden');
            return;
          }
          allList.innerHTML = `
            <div class="rating-reviews-table-wrap">
              <table class="rating-reviews-table">
                <thead>
                  <tr>
                    <th>Cliente</th>
                    <th>Producto / Tipo</th>
                    <th>Rating</th>
                    <th>Rese&ntilde;a</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Acci&oacute;n</th>
                  </tr>
                </thead>
                <tbody>
                  ${pageItems.map((review) => `
                    <tr data-review-id="${escapeHtml(review.id)}">
                      <td><span class="rating-review-client">${escapeHtml(review.customer_name || 'Cliente')}</span><span class="rating-review-muted">${review.verified_purchase === true ? 'Compra verificada' : escapeHtml(reviewSourceLabel(review.source))}</span></td>
                      <td>${escapeHtml(reviewProductOrType(review))}</td>
                      <td>${reviewStars(review.rating)}</td>
                      <td><span class="rating-review-comment">${escapeHtml(review.comment || 'Sin comentario')}</span></td>
                      <td>${reviewStatusPill(review)}</td>
                      <td>${escapeHtml(reviewDate(review.created))}</td>
                      <td>${reviewActionsMarkup(review)}</td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
            <div class="rating-reviews-mobile-list">
              ${pageItems.map((review) => `
                <article class="rating-review-row-mobile" data-review-id="${escapeHtml(review.id)}">
                  <div class="rating-review-row-head">
                    <span class="rating-review-row-title">${escapeHtml(review.customer_name || 'Cliente')}</span>
                    <span class="rating-stars">\u2605 ${escapeHtml(Number(review.rating || 0).toFixed(1))}</span>
                    ${reviewStatusPill(review)}
                    ${reviewActionsMarkup(review)}
                  </div>
                  <div class="rating-review-product">${escapeHtml(reviewProductOrType(review))}</div>
                  <div class="rating-review-comment">${escapeHtml(review.comment || 'Sin comentario')}</div>
                  <div class="rating-review-date">${escapeHtml(reviewDate(review.created))}</div>
                </article>
              `).join('')}
            </div>
          `;
          if (allPaginationSummary) allPaginationSummary.textContent = `Mostrando ${start + 1}-${end} de ${items.length} rese\u00f1as`;
          if (allPageLabel) allPageLabel.textContent = `P\u00e1gina ${ratingAllReviewsPage} de ${totalPages}`;
          if (allPrevPageBtn) allPrevPageBtn.disabled = ratingAllReviewsPage <= 1;
          if (allNextPageBtn) allNextPageBtn.disabled = ratingAllReviewsPage >= totalPages;
          allPagination?.classList.toggle('hidden', items.length <= RATING_REVIEWS_PAGE_SIZE);
        }
        function readyOrderCard(order) {
          return `
            <article class="item-row" data-ready-order-id="${escapeHtml(order.id)}">
              <div class="item-main" style="align-items:flex-start;">
                <div class="thumb placeholder" aria-hidden="true">\u2605</div>
                <div>
                  <p class="item-title">${escapeHtml(order.order_number || 'Orden')} \u00b7 ${escapeHtml(order.customer_name || 'Cliente sin nombre')}</p>
                  <p class="item-meta">
                    Tel\u00e9fono: ${escapeHtml(order.customer_phone || 'Sin tel\u00e9fono')}
                    \u00b7 Entregada: ${escapeHtml(formatDateTime(order.delivered_at))}
                    \u00b7 ${escapeHtml(timeAgoFrom(order.delivered_at))}
                    \u00b7 Total: ${escapeHtml(formatUsd(order.total ?? order.total_usd))}
                  </p>
                </div>
              </div>
              ${readyOrderActionsMarkup()}
            </article>
          `;
        }
        function renderReadyReviewOrders() {
          if (!readyOrdersList) return;
          if (readyOrdersCount) readyOrdersCount.textContent = `${readyReviewOrders.length} pendiente${readyReviewOrders.length === 1 ? '' : 's'} >`;
          readyOrdersList.innerHTML = readyReviewOrders.length
            ? readyReviewOrders.slice(0, 3).map(readyOrderCompactRow).join('')
            : '<div class="empty-state">No hay &oacute;rdenes listas para pedir rese&ntilde;a.</div>';
        }
        function reviewRequestMessage(order, reviewLink) {
          const template = settingsRecord?.review_whatsapp_message || fields.reviewWhatsappMessage?.value || DEFAULT_REVIEW_WHATSAPP_MESSAGE;
          return String(template)
            .replace(/\{cliente\}/g, order.customer_name || 'cliente')
            .replace(/\{tienda\}/g, settingsRecord?.store_name || settingsRecord?.stored_name || 'PowerZona')
            .replace(/\{link_rese\u00f1a\}/g, reviewLink)
            .replace(/\{link_rese\u00f1a\}/g, reviewLink)
            .replace(/\{numero_orden\}/g, order.order_number || '');
        }
        async function patchOrder(orderId, payload) {
          return api('/api/collections/orders/records/' + encodeURIComponent(orderId), {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
        }
        async function requestReviewByWhatsApp(orderId) {
          const order = readyReviewOrders.find((item) => item.id === orderId);
          if (!order) return;
          const reviewToken = hasValue(order.review_token) ? String(order.review_token) : generateReviewToken();
          if (!hasValue(order.review_token)) {
            await patchOrder(order.id, { review_token: reviewToken });
            order.review_token = reviewToken;
          }
          const reviewLink = `${window.location.origin}${PUBLIC_STORE_PATH}/review/order/${encodeURIComponent(reviewToken)}`;
          const message = reviewRequestMessage(order, reviewLink);
          const phone = cleanWhatsAppPhone(order.customer_phone);
          const url = phone ? `https://wa.me/${phone}?text=${encodeURIComponent(message)}` : `https://wa.me/?text=${encodeURIComponent(message)}`;
          window.open(url, '_blank', 'noopener');
          await patchOrder(order.id, {
            review_requested_at: new Date().toISOString(),
            review_request_count: Number(order.review_request_count || 0) + 1,
          });
          showMessage(readyOrdersAlertBox, 'Solicitud de rese\u00f1a preparada correctamente.', 'success');
          await loadReadyReviewOrders();
        }
        async function skipReviewRequest(orderId) {
          await patchOrder(orderId, { review_skipped_at: new Date().toISOString() });
          showMessage(readyOrdersAlertBox, 'Orden ignorada para solicitud de rese\u00f1a.', 'success');
          await loadReadyReviewOrders();
        }
        function handleReadyOrderClick(event) {
          if (handleRatingMenuTrigger(event)) return;
          const target = event.target instanceof Element ? event.target : null;
          const button = target?.closest('.js-ready-order-action');
          if (!button) return;
          const orderId = button.closest('[data-ready-order-id]')?.dataset.readyOrderId;
          const action = button.dataset.action;
          if (!orderId || !action) return;
          closeRatingMenus();
          const task = action === 'whatsapp' ? requestReviewByWhatsApp(orderId) : skipReviewRequest(orderId);
          task.catch((error) => showMessage(readyOrdersAlertBox, humanizeRatingError(error, 'No se pudo procesar la orden para pedir rese\u00f1a.'), 'error'));
        }
        function closeRatingMenus(except = null) {
          document.querySelectorAll('[data-rating-menu]').forEach((menu) => {
            if (menu === except) return;
            menu.classList.add('hidden');
          });
        }
        function handleRatingMenuTrigger(event) {
          const target = event.target instanceof Element ? event.target : null;
          const trigger = target?.closest('[data-rating-menu-trigger]');
          if (!trigger) return false;
          event.preventDefault();
          event.stopPropagation();
          const menu = trigger.parentElement?.querySelector('[data-rating-menu]');
          const willOpen = menu?.classList.contains('hidden');
          closeRatingMenus(menu);
          menu?.classList.toggle('hidden', !willOpen);
          return true;
        }
        async function updateReviewStatus(reviewId, status) {
          const payload = { status };
          if (status === 'approved') payload.approved_at = new Date().toISOString();
          await api('/api/collections/reviews/records/' + encodeURIComponent(reviewId), {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          showMessage(allAlertBox, 'Rese\u00f1a actualizada correctamente.', 'success');
          await loadReviews();
        }
        async function deleteReview(reviewId) {
          if (!confirm('\u00bfEliminar esta rese\u00f1a?')) return;
          await api('/api/collections/reviews/records/' + encodeURIComponent(reviewId), { method: 'DELETE' });
          showMessage(allAlertBox, 'Rese\u00f1a eliminada correctamente.', 'success');
          await loadReviews();
        }
        function handleReviewClick(event) {
          if (handleRatingMenuTrigger(event)) return;
          const target = event.target instanceof Element ? event.target : null;
          const button = target?.closest('.js-review-action');
          if (!button) return;
          const reviewId = button.closest('[data-review-id]')?.dataset.reviewId;
          const action = button.dataset.action;
          if (!reviewId || !action) return;
          closeRatingMenus();
          const task = action === 'approve'
            ? updateReviewStatus(reviewId, 'approved')
            : action === 'reject'
              ? updateReviewStatus(reviewId, 'rejected')
              : action === 'hide'
                ? updateReviewStatus(reviewId, 'hidden')
                : deleteReview(reviewId);
          task.catch((error) => {
            showMessage(allAlertBox, humanizeRatingError(error, 'No se pudo actualizar la rese\u00f1a. Verifica permisos de administrador.'), 'error');
          });
        }
        async function saveRatingSettings({ silent = false } = {}) {
          normalizeDelayInput();
          updateSettingsSummary();
          if (silent) setSaveStatus('Guardando...', 'saving');
          if (!settingsRecord?.id) settingsRecord = await createSettingsRecord();
          const payload = {
            reviews_enabled: boolValue(fields.reviewsEnabled),
            store_reviews_enabled: boolValue(fields.storeReviewsEnabled),
            product_reviews_enabled: boolValue(fields.productReviewsEnabled),
            verified_order_reviews_enabled: boolValue(fields.verifiedOrderReviewsEnabled),
            reviews_require_approval: true,
            show_store_rating: boolValue(fields.showStoreRating),
            show_product_rating: boolValue(fields.showProductRating),
            show_verified_badge: boolValue(fields.showVerifiedBadge),
            review_request_delay_hours: delayHoursValue(),
            review_whatsapp_message: fields.reviewWhatsappMessage?.value?.trim() || DEFAULT_REVIEW_WHATSAPP_MESSAGE,
            store: CURRENT_STORE_ID,
          };
          await api('/api/collections/settings/records/' + settingsRecord.id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
          settingsRecord = Object.assign({}, settingsRecord, payload);
          if (silent) setSaveStatus('Guardado autom\u00e1ticamente');
          else show('Configuraci\u00f3n de rating guardada correctamente.', 'success');
          await loadSettings();
          await loadReviews();
          await loadReadyReviewOrders();
        }
        async function save(event) {
          event.preventDefault();
          await saveRatingSettings({ silent: false });
        }
        function scheduleRatingSave(delay = 450) {
          if (isRenderingSettings) return;
          updateSettingsSummary();
          setSaveStatus('Guardando...', 'saving');
          window.clearTimeout(autoSaveTimer);
          autoSaveTimer = window.setTimeout(() => {
            saveRatingSettings({ silent: true }).catch((error) => {
              setSaveStatus('No se pudo guardar', 'error');
              show(humanizeRatingError(error, 'No se pudo guardar la configuraci\u00f3n de rating.'), 'error');
            });
          }, delay);
        }
        async function loadRatingTab() {
          await loadSettings();
          await loadReviews();
          await loadReadyReviewOrders();
        }

        form?.addEventListener('submit', (event) => save(event).catch((error) => {
          setSaveStatus('No se pudo guardar', 'error');
          show(humanizeRatingError(error, 'No se pudo guardar la configuraci\u00f3n de rating.'), 'error');
        }));
        form?.querySelectorAll('input[type="checkbox"], input[type="number"], select').forEach((input) => {
          input.addEventListener('change', () => {
            if (input === fields.reviewRequestDelayHours) normalizeDelayInput();
            scheduleRatingSave(250);
          });
        });
        fields.reviewWhatsappMessage?.addEventListener('input', () => scheduleRatingSave(850));
        configToggleBtn?.addEventListener('click', () => setConfigOpen(configPanel?.classList.contains('hidden') === true));
        restoreMessageBtn?.addEventListener('click', () => {
          if (fields.reviewWhatsappMessage) fields.reviewWhatsappMessage.value = DEFAULT_REVIEW_WHATSAPP_MESSAGE;
          scheduleRatingSave(150);
        });
        readyOrdersRetryBtn?.addEventListener('click', () => loadReadyReviewOrders().catch((error) => showMessage(readyOrdersAlertBox, humanizeRatingError(error, 'No se pudieron cargar las \u00f3rdenes listas para pedir rese\u00f1a. Intenta nuevamente.'), 'error')));
        document.querySelectorAll('[data-tab="rating"]').forEach((tabButton) => tabButton.addEventListener('click', () => loadRatingTab().catch((error) => show(humanizeRatingError(error, 'No se pudo cargar la configuraci\u00f3n de rating.'), 'error'))));
        pendingList?.addEventListener('click', handleReviewClick);
        allList?.addEventListener('click', handleReviewClick);
        readyOrdersList?.addEventListener('click', handleReadyOrderClick);
        reviewFilterSelect?.addEventListener('change', () => {
          activeReviewFilter = reviewFilterSelect.value || 'all';
          ratingAllReviewsPage = 1;
          renderAllReviews();
        });
        allPrevPageBtn?.addEventListener('click', () => {
          ratingAllReviewsPage -= 1;
          renderAllReviews();
        });
        allNextPageBtn?.addEventListener('click', () => {
          ratingAllReviewsPage += 1;
          renderAllReviews();
        });
        pendingReviewsShortcut?.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (target?.closest('.rating-row-actions')) return;
          if (reviewFilterSelect) {
            reviewFilterSelect.value = 'pending';
            reviewFilterSelect.dispatchEvent(new Event('change', { bubbles: true }));
          }
          ratingAllReviewsPage = 1;
          renderAllReviews();
          allReviewsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          allReviewsSection?.classList.add('rating-section-highlight');
          window.setTimeout(() => allReviewsSection?.classList.remove('rating-section-highlight'), 1800);
        });
        pendingReviewsShortcut?.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          pendingReviewsShortcut.click();
        });
        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target?.closest('.rating-row-actions')) closeRatingMenus();
        });
        setConfigOpen(false);
        renderSettings();
        renderReviewAnalytics();
        renderReadyReviewOrders();
        if (token()) loadRatingTab().catch(() => {});
      })();
    </script>

    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken }}>
      (() => {
        const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
        const CURRENT_STORE_ID = String(currentStoreId || '');
        const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
        const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
        const CLOSED_MESSAGE_DEFAULT = 'Estamos fuera de horario, pero puedes realizar tu pedido. Lo atenderemos en horario laboral.';
        const TEMPORARILY_CLOSED_MESSAGE_DEFAULT = 'Estamos cerrados temporalmente. Vuelve pronto.';
        const DAYS = [
          ['monday', 'Lunes'],
          ['tuesday', 'Martes'],
          ['wednesday', 'Miércoles'],
          ['thursday', 'Jueves'],
          ['friday', 'Viernes'],
          ['saturday', 'Sábado'],
          ['sunday', 'Domingo'],
        ];
        const DEFAULT_HOURS = Object.fromEntries(DAYS.map(([key]) => [key, { enabled: false, open: '09:00', close: '18:00' }]));
        const form = document.getElementById('business-hours-form');
        const alertBox = document.getElementById('business-hours-alert');
        const refreshBtn = document.getElementById('business-hours-refresh-btn');
        const saveBtn = document.getElementById('business-hours-save-btn');
        const daysBox = document.getElementById('business-hours-days');
        const daysGrid = document.getElementById('business-hours-days-grid');
        const closedMessage = document.getElementById('closed-message');
        const temporarilyClosedMessage = document.getElementById('temporarily-closed-message');
        const allowOrders = document.getElementById('allow-orders-when-closed');
        const hoursAdvancedToggle = document.getElementById('hours-advanced-toggle');
        const hoursAdvancedContent = document.getElementById('hours-advanced-content');
        const hoursModePanel = document.querySelector('.hours-mode-panel');
        const hoursMessageGrid = document.querySelector('.hours-message-grid');
        const hoursOrdersPanel = document.querySelector('.hours-orders-panel');
        const hoursAlwaysAvailableCard = document.getElementById('hours-always-available-card');
