                  <div class="currency-mobile-body">
                    <div class="currency-mobile-title"><strong class="currency-mobile-code">${escapeHtml(code)}</strong>${systemBadge}</div>
                    <div class="currency-mobile-name">${escapeHtml(currency.name || (isBase ? 'Dolar Americano' : code))}</div>
                    ${isBase ? `<div class="currency-mobile-meta">${mobileMeta}</div>` : `<div class="currency-mobile-control-line">${mobileVisibilityControl}<span class="currency-mobile-rate">${formatRate(rate)}</span><div class="currency-mobile-actions">${mobileActionsMarkup}</div></div>`}
                    ${mobileDefaultMarkup ? `<div class="currency-mobile-default">${mobileDefaultMarkup}</div>` : ''}
                  </div>
                  ${isBase ? `<div class="currency-mobile-actions">${mobileActionsMarkup}</div>` : ''}
                </div>
                <div class="currency-main-cell">
                  ${currencyIconMarkup(currency)}
                  <div>
                    <p class="currency-code">${escapeHtml(code)} ${systemBadge}</p>
                    ${isBase ? `<p class="currency-name">${escapeHtml(currency.name || 'Dolar Americano')}</p><p class="currency-name">Moneda base del sistema</p>` : `<input class="currency-inline-input js-currency-name" type="text" value="${escapeHtml(currency.name || code)}" />`}
                  </div>
                </div>
                <span>${isBase ? '<span class="currency-base-badge">Base</span>' : '<span class="currency-muted">-</span>'}</span>
                ${isBase ? '<span class="currency-readonly-value">$</span>' : `<input class="currency-inline-input js-currency-symbol" type="text" value="${escapeHtml(currency.symbol || code)}" />`}
                ${isBase ? '<span class="currency-rate-cell">1 <span class="currency-base-badge">Base</span></span>' : `<input class="currency-inline-input js-currency-rate" type="number" min="0" step="0.0001" value="${formatRate(rate)}" />`}
                ${isBase ? '<span class="currency-base-badge">Siempre visible</span>' : `<label class="currency-switch"><input class="js-currency-active" type="checkbox" ${isVisible ? 'checked' : ''} /><span class="currency-switch-track"><span class="currency-switch-thumb"></span></span><span class="currency-switch-text">${isVisible ? 'Visible' : 'No se muestra en tienda'}</span></label>`}
                ${defaultMarkup}
                <div class="currency-actions">
                  ${actionsMarkup}
                </div>
              </div>
            `;
          }).join('');
        }
        async function enforceCurrencyState() {
          if (!token() || !CURRENT_STORE_ID) return false;
          const usd = usdCurrency();
          if (!usd) {
            show('Falta la moneda USD en esta tienda. USD es requerida como moneda base.', 'error');
            return false;
          }
          let changed = false;
          if (usd.is_base !== true || usd.active !== true || Number(usd.exchange_rate || 0) !== 1) {
            await api('/api/collections/currencies/records/' + usd.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_base: true, active: true, exchange_rate: 1 }),
            });
            changed = true;
          }
          const wrongBase = state.currencies.filter((currency) => currency.id !== usd.id && currency.is_base === true);
          for (const currency of wrongBase) {
            await api('/api/collections/currencies/records/' + currency.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_base: false }),
            });
            changed = true;
          }
          const visible = visibleCurrencies();
          let selectedDefault = visible.find((currency) => currency.id === defaultId()) || visible.find((currency) => currency.is_default === true) || visible[0] || null;
          if (!selectedDefault && usd) {
            await api('/api/collections/currencies/records/' + usd.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ active: true }),
            });
            selectedDefault = usd;
            changed = true;
          }
          if (!selectedDefault) return changed;
          for (const currency of state.currencies) {
            const shouldBeDefault = currency.id === selectedDefault.id;
            if (currency.is_default !== shouldBeDefault) {
              await api('/api/collections/currencies/records/' + currency.id, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ is_default: shouldBeDefault }),
              });
              changed = true;
            }
          }
          if (state.settingsRecord?.id && defaultId() !== selectedDefault.id) {
            await api('/api/collections/settings/records/' + state.settingsRecord.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ default_currency: selectedDefault.id }),
            });
            changed = true;
          }
          return changed;
        }
        async function loadCurrencies(shouldEnforce = true) {
          if (!token()) return;
          const [currencyResult, settingsResult] = await Promise.all([
            api('/api/collections/currencies/records?' + withStoreFilter('sort=code&perPage=100')),
            api('/api/collections/settings/records?' + withStoreFilter('filter=active%3Dtrue&sort=-updated&page=1&perPage=1')),
          ]);
          state.currencies = sortCurrencies(currencyResult.items || []);
          state.settingsRecord = (settingsResult.items || [])[0] || null;
          if (shouldEnforce && await enforceCurrencyState()) return loadCurrencies(false);
          renderSummary();
          renderCurrencies();
        }
        async function saveCurrency(row) {
          const id = row?.dataset?.currencyId;
          const currency = state.currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          const code = normalizeCode(currency.code);
          const isBase = code === 'USD' || currency.is_base === true;
          const activeInput = row.querySelector('.js-currency-active');
          const wantsVisible = isBase || activeInput?.checked === true;
          const isDefault = currency.id === defaultId() || currency.is_default === true;
          if (!wantsVisible && isDefault) {
            if (activeInput) activeInput.checked = true;
            return show('No puedes ocultar la moneda predeterminada. Selecciona otra moneda visible como predeterminada primero.', 'error');
          }
          if (!wantsVisible && visibleCurrencies().filter((item) => item.id !== id).length === 0) {
            if (activeInput) activeInput.checked = true;
            return show('La tienda debe tener al menos una moneda visible.', 'error');
          }
          const payload = isBase
            ? {
                exchange_rate: 1,
                active: true,
                is_default: isDefault,
                is_base: true,
              }
            : {
                name: row.querySelector('.js-currency-name')?.value?.trim() || code,
                symbol: row.querySelector('.js-currency-symbol')?.value?.trim() || code,
                exchange_rate: Math.max(0, Number(row.querySelector('.js-currency-rate')?.value || 0)),
                active: wantsVisible,
                is_default: isDefault,
                is_base: false,
              };
          await api('/api/collections/currencies/records/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (isDefault && state.settingsRecord?.id && defaultId() !== id) {
            await api('/api/collections/settings/records/' + state.settingsRecord.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ default_currency: id }),
            });
          }
          show('Moneda guardada correctamente.', 'success');
          await loadCurrencies();
        }
        async function setDefaultCurrencyById(id) {
          const currency = state.currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          if (normalizeCode(currency.code) !== 'USD' && currency.active === false) return show('Para usar esta moneda como predeterminada, primero debes marcarla como visible.', 'error');
          for (const item of state.currencies) {
            if (item.is_default === (item.id === id)) continue;
            await api('/api/collections/currencies/records/' + item.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_default: item.id === id }),
            });
          }
          if (state.settingsRecord?.id && defaultId() !== id) {
            await api('/api/collections/settings/records/' + state.settingsRecord.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ default_currency: id }),
            });
          }
        }
        async function setDefaultCurrency(row) {
          const id = row?.dataset?.currencyId;
          await setDefaultCurrencyById(id);
          show('Moneda predeterminada actualizada.', 'success');
          await loadCurrencies();
        }
        async function saveEditedCurrency(event) {
          event.preventDefault();
          const id = state.editingId;
          const currency = state.currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          const code = normalizeCode(currency.code);
          if (code === 'USD' || currency.is_base === true) return;
          const isSystem = isSystemCurrency(currency);
          const nextCode = normalizeCode(byId('currency-edit-code')?.value || code);
          if (!isSystem) {
            if (!nextCode) return show('Escribe el codigo de la moneda.', 'error');
            if (!/^[A-Z0-9]{2,12}$/.test(nextCode)) return show('El codigo debe tener de 2 a 12 letras o numeros, sin espacios.', 'error');
            const duplicated = state.currencies.some((item) => item.id !== id && normalizeCode(item.code) === nextCode);
            if (duplicated) return show('Ya existe una moneda con ese codigo en esta tienda.', 'error');
          }
          const payload = isSystem
            ? { exchange_rate: Math.max(0, Number(byId('currency-edit-rate')?.value || 0)), is_base: false }
            : {
                code: nextCode,
                name: byId('currency-edit-name')?.value?.trim() || nextCode,
                symbol: byId('currency-edit-symbol')?.value?.trim() || nextCode,
                exchange_rate: Math.max(0, Number(byId('currency-edit-rate')?.value || 0)),
                active: currency.active !== false,
                is_default: currency.id === defaultId() || currency.is_default === true,
                is_base: false,
              };
          await api('/api/collections/currencies/records/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          closeEditModal();
          show('Moneda guardada correctamente.', 'success');
          await loadCurrencies();
        }
        async function createCurrency(event) {
          event.preventDefault();
          const codeInput = byId('currency-code');
          const nameInput = byId('currency-name');
          const symbolInput = byId('currency-symbol');
          const rateInput = byId('currency-rate');
          const code = normalizeCode(codeInput?.value || '');
          if (!code) return show('Escribe el codigo de la moneda.', 'error');
          if (!/^[A-Z0-9]{2,12}$/.test(code)) return show('El codigo debe tener de 2 a 12 letras o numeros, sin espacios.', 'error');
          if (state.currencies.some((currency) => normalizeCode(currency.code) === code)) return show('Ya existe una moneda con ese codigo en esta tienda.', 'error');
          const payload = {
            store: CURRENT_STORE_ID,
            code,
            name: nameInput?.value?.trim() || code,
            symbol: symbolInput?.value?.trim() || code,
            exchange_rate: code === 'USD' ? 1 : Math.max(0, Number(rateInput?.value || 0)),
            active: true,
            is_default: false,
            is_system: false,
            is_base: false,
          };
          await api('/api/collections/currencies/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          clearCreateForm();
          closeCurrencyModal();
          show('Moneda agregada correctamente.', 'success');
          await loadCurrencies();
        }
        async function deleteCurrency(row) {
          const id = row?.dataset?.currencyId;
          const currency = state.currencies.find((item) => item.id === id);
          if (!id || !currency) return;
          if (isSystemCurrency(currency)) return show('No puedes borrar una moneda fija del sistema.', 'error');
          if (currency.id === defaultId() || currency.is_default === true) return show('No puedes borrar la moneda predeterminada. Selecciona otra moneda visible como predeterminada primero.', 'error');
          if (currency.store && currency.store !== CURRENT_STORE_ID) return show('No puedes borrar monedas de otra tienda.', 'error');
          if (!confirm('Deseas borrar esta moneda? Esta accion no afecta ordenes existentes.')) return;
          await api('/api/collections/currencies/records/' + id, { method: 'DELETE' });
          show('Moneda borrada correctamente.', 'success');
          await loadCurrencies();
        }
        byId('currency-list')?.addEventListener('click', (event) => {
          const target = event.target;
          const row = target?.closest?.('[data-currency-id]');
          if (!row) return;
          if (target.closest('.js-currency-edit')) {
            openEditModal(row);
            return;
          }
          if (target.closest('.js-currency-set-default')) {
            setDefaultCurrency(row).catch((error) => show(error.message || 'No se pudo seleccionar la moneda predeterminada.', 'error'));
            return;
          }
          if (target.closest('.js-currency-delete')) {
            deleteCurrency(row).catch((error) => show(error.message || 'No se pudo borrar la moneda.', 'error'));
          }
        });
        byId('currency-list')?.addEventListener('change', (event) => {
          const target = event.target;
          const row = target?.closest?.('[data-currency-id]');
          if (!row) return;
          if (target.classList?.contains('js-currency-active') && !target.checked) {
            const id = row.dataset.currencyId;
            const currency = state.currencies.find((item) => item.id === id);
            const isDefault = currency && (currency.id === defaultId() || currency.is_default === true);
            if (isDefault) {
              target.checked = true;
              show('No puedes ocultar la moneda predeterminada. Selecciona otra moneda visible como predeterminada primero.', 'error');
              return;
            }
            if (visibleCurrencies().filter((item) => item.id !== id).length === 0) {
              target.checked = true;
              show('La tienda debe tener al menos una moneda visible.', 'error');
              return;
            }
          }
          if (target.classList?.contains('js-currency-active')) {
            row.querySelectorAll('.js-currency-active').forEach((input) => {
              input.checked = target.checked;
            });
            row.querySelectorAll('.currency-switch-text').forEach((text) => {
              text.textContent = target.checked ? 'Visible' : 'No se muestra en tienda';
            });
          }
          saveCurrency(row).catch((error) => show(error.message || 'No se pudo guardar la moneda.', 'error'));
        });
        byId('currency-create-form')?.addEventListener('submit', (event) => createCurrency(event).catch((error) => show(error.message || 'No se pudo crear la moneda.', 'error')));
        byId('currency-refresh-btn')?.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error')));
        byId('currency-code')?.addEventListener('input', (event) => { event.target.value = normalizeCode(event.target.value); });
        byId('currency-search')?.addEventListener('input', (event) => {
          state.search = event.target?.value || '';
          renderCurrencies();
        });
        document.querySelectorAll('[data-scroll-currency-create]').forEach((button) => button.addEventListener('click', openCurrencyModal));
        byId('currency-edit-form')?.addEventListener('submit', (event) => saveEditedCurrency(event).catch((error) => show(error.message || 'No se pudo guardar la moneda.', 'error')));
        byId('currency-edit-modal-close')?.addEventListener('click', closeEditModal);
        byId('currency-edit-cancel')?.addEventListener('click', closeEditModal);
        byId('currency-modal-close')?.addEventListener('click', closeCurrencyModal);
        byId('currency-modal-cancel')?.addEventListener('click', closeCurrencyModal);
        byId('currency-create-modal')?.addEventListener('click', (event) => {
          if (event.target === byId('currency-create-modal')) closeCurrencyModal();
        });
        byId('currency-edit-modal')?.addEventListener('click', (event) => {
          if (event.target === byId('currency-edit-modal')) closeEditModal();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !byId('currency-create-modal')?.classList.contains('hidden')) closeCurrencyModal();
          if (event.key === 'Escape' && !byId('currency-edit-modal')?.classList.contains('hidden')) closeEditModal();
        });
        document.querySelectorAll('[data-tab="monedas"]').forEach((tabButton) => tabButton.addEventListener('click', () => loadCurrencies().catch((error) => show(error.message || 'No se pudieron cargar las monedas.', 'error'))));
        if (token()) loadCurrencies().catch(() => {});
      })();
    </script>

  </body>
</html>
