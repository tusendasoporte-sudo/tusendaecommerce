          const index = Number(slot?.dataset?.galleryIndex || 0);
          if (!slot || !thumb) return;
          const key = slot.dataset.galleryField || `cover_image_${index + 1}`;
          const previousUrl = galleryPreviewUrls.get(key);
          if (previousUrl) URL.revokeObjectURL(previousUrl);
          const previewUrl = URL.createObjectURL(target.files[0]);
          galleryPreviewUrls.set(key, previewUrl);
          thumb.innerHTML = `<img src="${escapeHtml(previewUrl)}" alt="Foto ${index + 1} pendiente" /><button class="settings-thumb-delete js-delete-gallery-image" type="button" aria-label="Borrar foto ${index + 1}">&#128465;</button>`;
          slot.dataset.pendingFile = 'true';
