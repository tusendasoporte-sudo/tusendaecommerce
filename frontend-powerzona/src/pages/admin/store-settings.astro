      async function swapProductFeaturedOrder(productId, direction) {
        const featured = getFeaturedProductsSorted();
        const currentIndex = featured.findIndex((item) => item.id === productId);
        const targetIndex = direction === 'up' ? currentIndex - 1 : currentIndex + 1;
        if (currentIndex < 0 || targetIndex < 0 || targetIndex >= featured.length) return;
        const current = featured[currentIndex];
        const target = featured[targetIndex];
        const currentOrder = Number(current.featured_order || currentIndex + 1);
        const targetOrder = Number(target.featured_order || targetIndex + 1);
        const currentData = new FormData();
        const targetData = new FormData();
        currentData.append('featured_order', String(targetOrder));
        targetData.append('featured_order', String(currentOrder));
        await Promise.all([
          apiRequest(`/api/collections/products/records/${current.id}`, { method: 'PATCH', body: currentData }),
          apiRequest(`/api/collections/products/records/${target.id}`, { method: 'PATCH', body: targetData }),
        ]);
        showAlert(organizationAlert, 'Orden de destacados actualizado.', 'success');
        await loadData();
