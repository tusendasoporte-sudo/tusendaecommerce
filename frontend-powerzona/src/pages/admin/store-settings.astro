              </div>
              <div id="visual-alert" class="alert alert-info hidden full"></div>
              <div class="editor-actions full">
                <button id="visual-cancel-btn" class="mini-btn" type="button">Cancelar</button>
                <button id="visual-save-btn" class="submit-btn" type="submit">Guardar</button>
              </div>
