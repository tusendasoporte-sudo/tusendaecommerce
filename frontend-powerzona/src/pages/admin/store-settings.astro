            tips: ['Las reseñas verificadas generan más confianza.', 'Mantén la moderación activa para cuidar la tienda pública.']
          }
        };

        const modal = document.getElementById('settings-help-modal');
        const titleEl = document.getElementById('settings-help-title');
        const introEl = document.getElementById('settings-help-intro');
        const stepsEl = document.getElementById('settings-help-steps');
        const tipsEl = document.getElementById('settings-help-tips');

        const renderList = (target, items) => {
          if (!target) return;
          target.replaceChildren(...items.map((item) => {
            const li = document.createElement('li');
            li.textContent = item;
            return li;
          }));
        };

        const closeSettingsHelp = () => {
          if (!modal) return;
          modal.classList.add('hidden');
          document.body.classList.remove('settings-help-open');
        };

        const openSettingsHelp = (key) => {
          const content = SETTINGS_HELP_CONTENT[key];
          if (!modal || !content) return;
          titleEl.textContent = content.title;
          introEl.textContent = content.intro;
          renderList(stepsEl, content.steps || []);
          renderList(tipsEl, content.tips || []);
          modal.classList.remove('hidden');
          document.body.classList.add('settings-help-open');
          modal.querySelector('.settings-help-close')?.focus();
        };

        document.querySelectorAll('.settings-help-btn').forEach((button) => {
          button.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            openSettingsHelp(button.dataset.helpKey);
          });
        });

        document.querySelectorAll('[data-help-close]').forEach((button) => {
          button.addEventListener('click', closeSettingsHelp);
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
            closeSettingsHelp();
          }
        });
      })();
    </script>

