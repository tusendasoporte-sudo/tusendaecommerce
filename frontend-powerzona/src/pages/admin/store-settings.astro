          <section id="tab-destacados" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Productos destacados</h2>
                <p class="section-subtitle">Marca productos existentes para que salgan en la sección pública “Productos destacados”. Aquí ves el resumen de todos los marcados.</p>
              </div>
              <button id="refresh-btn" class="mini-btn" type="button">Actualizar</button>
