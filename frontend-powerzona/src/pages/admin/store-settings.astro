          <section id="tab-visuales" class="panel-card tab-panel hidden">
            <div class="section-head">
              <div>
                <h2 class="section-title">Promo visual / Acceso rápido</h2>
                <p class="section-subtitle">Crea tarjetas visuales para ofertas o accesos a WhatsApp, enlaces, categorías o archivos.</p>
              </div>
              <button id="open-visual-form-btn" class="mini-btn primary" type="button">+ Crear</button>
            </div>

            <form id="visual-form" class="visual-form-grid hidden">
              <input id="visual-id" type="hidden" />
              <div class="field">
                <label for="visual-type">Tipo</label>
                <select id="visual-type" required>
                  <option value="promo_visual">Promo visual</option>
                  <option value="acceso_rapido">Acceso rápido</option>
                </select>
              </div>
              <div class="field">
                <label for="visual-title">Título</label>
                <input id="visual-title" type="text" placeholder="Ej: Combo especial" required />
              </div>
              <div class="field full">
                <label for="visual-description">Descripción corta</label>
                <textarea id="visual-description" placeholder="Texto corto para mostrar en la tienda pública"></textarea>
              </div>
              <div class="field">
                <label for="visual-image">Imagen</label>
                <input id="visual-image" type="file" accept="image/*" />
                <p class="form-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                <p id="visual-current-image" class="form-help"></p>
              </div>
              <div class="field">
                <label for="visual-button-text">Texto del botón</label>
                <input id="visual-button-text" type="text" placeholder="Ej: Contactar por WhatsApp" />
              </div>
              <div class="field">
                <label for="visual-action-type">Acción</label>
                <select id="visual-action-type">
                  <option value="whatsapp">WhatsApp</option>
                  <option value="url">Enlace externo</option>
                  <option value="categoria">Categoría</option>
                  <option value="archivo">Archivo</option>
                </select>
              </div>
              <div class="field">
                <label for="visual-order">Orden visual</label>
                <input id="visual-order" type="number" min="0" step="1" placeholder="0" />
              </div>
              <div class="field full" id="visual-url-field">
                <label for="visual-url">URL / enlace</label>
                <input id="visual-url" type="url" placeholder="https://..." />
              </div>
              <div class="field full" id="visual-whatsapp-field">
                <label for="visual-whatsapp-message">Mensaje de WhatsApp</label>
                <textarea id="visual-whatsapp-message" placeholder="Hola PowerZona, quiero información sobre..."></textarea>
              </div>
              <div class="field" id="visual-category-field">
                <label for="visual-category">Categoría</label>
                <select id="visual-category"><option value="">Selecciona categoría</option></select>
              </div>
              <div class="field" id="visual-attachment-field">
                <label for="visual-attachment">Archivo</label>
                <input id="visual-attachment" type="file" accept="application/pdf,image/*" />
                <p id="visual-current-attachment" class="form-help"></p>
