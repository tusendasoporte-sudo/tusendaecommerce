    <script define:vars={{ pocketbaseUrl, currentStoreId, adminAuthToken }}>
      (() => {
        const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
        const CURRENT_STORE_ID = String(currentStoreId || '');
        const ADMIN_AUTH_TOKEN = String(adminAuthToken || '');
        const STORE_FILTER = `store="${CURRENT_STORE_ID.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
        const CLOSED_MESSAGE_DEFAULT = 'Estamos fuera de horario, pero puedes realizar tu pedido. Lo atenderemos en horario laboral.';
        const TEMPORARILY_CLOSED_MESSAGE_DEFAULT = 'Estamos cerrados temporalmente. Puedes realizar tu pedido y te responderemos pronto.';
        const DAYS = [
          ['monday', 'Lunes'],
          ['tuesday', 'Martes'],
          ['wednesday', 'Miércoles'],
          ['thursday', 'Jueves'],
          ['friday', 'Viernes'],
          ['saturday', 'Sábado'],
          ['sunday', 'Domingo'],
        ];
        const DEFAULT_HOURS = Object.fromEntries(DAYS.map(([key]) => [key, { enabled: false, open: '09:00', close: '18:00' }]));
        const form = document.getElementById('business-hours-form');
        const alertBox = document.getElementById('business-hours-alert');
        const refreshBtn = document.getElementById('business-hours-refresh-btn');
        const daysBox = document.getElementById('business-hours-days');
        const daysGrid = document.getElementById('business-hours-days-grid');
        const closedMessage = document.getElementById('closed-message');
        const temporarilyClosedMessage = document.getElementById('temporarily-closed-message');
        const allowOrders = document.getElementById('allow-orders-when-closed');
        let settingsRecord = null;

        function token() { return ADMIN_AUTH_TOKEN; }
        function show(message = '', type = 'info') {
          if (!alertBox) return;
          if (!message) { alertBox.className = 'alert alert-info hidden'; alertBox.textContent = ''; return; }
          alertBox.className = 'alert alert-' + type;
          alertBox.textContent = message;
        }
        async function api(path, options = {}) {
          const headers = Object.assign({}, options.headers || {});
          if (token()) headers.Authorization = 'Bearer ' + token();
          const response = await fetch(POCKETBASE_URL + path, Object.assign({}, options, { headers }));
          const result = await response.json().catch(() => null);
          if (!response.ok) throw new Error((result && result.message) || 'Error de comunicacion con la plataforma.');
          return result;
        }
        function withStoreFilter(params = '') {
          const query = new URLSearchParams(params || '');
          const existing = query.get('filter');
          if (existing) query.set('filter', `(${existing}) && ${STORE_FILTER}`);
          else query.set('filter', STORE_FILTER);
          return query.toString();
        }
        function parseHours(value) {
          if (!value) return { ...DEFAULT_HOURS };
          if (typeof value === 'string') {
            try {
              const parsed = JSON.parse(value);
              return parsed && typeof parsed === 'object' ? mergeHours(parsed) : { ...DEFAULT_HOURS };
            } catch (_) {
              return { ...DEFAULT_HOURS };
            }
          }
          return mergeHours(value);
        }
        function mergeHours(value) {
          const next = {};
          DAYS.forEach(([key]) => {
            const day = value?.[key] || {};
            next[key] = {
              enabled: day.enabled === true,
              open: /^\d{2}:\d{2}$/.test(String(day.open || '')) ? day.open : '09:00',
              close: /^\d{2}:\d{2}$/.test(String(day.close || '')) ? day.close : '18:00',
            };
          });
          return next;
        }
        function selectedMode() {
          return document.querySelector('input[name="business_hours_mode"]:checked')?.value || 'always_available';
        }
        function setMode(mode) {
          const input = document.querySelector(`input[name="business_hours_mode"][value="${mode || 'always_available'}"]`);
          if (input) input.checked = true;
          updateModeUI();
        }
        function updateModeUI() {
          if (daysBox) daysBox.classList.toggle('hidden', selectedMode() !== 'custom');
        }
        function renderDays(hours = DEFAULT_HOURS) {
          if (!daysGrid) return;
          daysGrid.innerHTML = DAYS.map(([key, label]) => {
            const day = hours[key] || DEFAULT_HOURS[key];
            return `
              <article class="day-card" data-day="${key}">
                <div class="day-card-head">
                  <p class="day-name">${label}</p>
                  <label class="day-toggle"><input class="js-day-enabled" type="checkbox" ${day.enabled ? 'checked' : ''} /> Activo</label>
                </div>
                <div class="day-times">
                  <div class="field"><label>Apertura</label><input class="js-day-open" type="time" value="${day.open || '09:00'}" /></div>
                  <div class="field"><label>Cierre</label><input class="js-day-close" type="time" value="${day.close || '18:00'}" /></div>
                </div>
              </article>
            `;
          }).join('');
        }
        function readDays() {
          const next = {};
          document.querySelectorAll('[data-day]').forEach((row) => {
            const key = row.dataset.day;
            next[key] = {
              enabled: row.querySelector('.js-day-enabled')?.checked === true,
              open: row.querySelector('.js-day-open')?.value || '09:00',
              close: row.querySelector('.js-day-close')?.value || '18:00',
            };
          });
          return mergeHours(next);
        }
        async function findDefaultCurrencyId() {
          const result = await api('/api/collections/currencies/records?filter=active%3Dtrue&sort=code&page=1&perPage=1');
          return (result.items || [])[0]?.id || '';
        }
        async function createSettingsRecord() {
          const payload = {
            stored_name: 'PowerZona',
            store_name: 'PowerZona',
            active: true,
            store: CURRENT_STORE_ID,
            business_hours_mode: selectedMode(),
            business_hours: JSON.stringify(readDays()),
            closed_message: closedMessage?.value?.trim() || CLOSED_MESSAGE_DEFAULT,
            temporarily_closed_message: temporarilyClosedMessage?.value?.trim() || TEMPORARILY_CLOSED_MESSAGE_DEFAULT,
            allow_orders_when_closed: allowOrders?.checked !== false,
          };
          const defaultCurrencyId = await findDefaultCurrencyId();
          if (defaultCurrencyId) payload.default_currency = defaultCurrencyId;
          return api('/api/collections/settings/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
        }
        async function loadSettings() {
          const result = await api('/api/collections/settings/records?' + withStoreFilter('filter=active%3Dtrue&sort=-updated&page=1&perPage=1'));
          settingsRecord = (result.items || [])[0] || null;
          const record = settingsRecord || {};
          setMode(record.business_hours_mode || 'always_available');
          renderDays(parseHours(record.business_hours));
          if (closedMessage) closedMessage.value = record.closed_message || CLOSED_MESSAGE_DEFAULT;
          if (temporarilyClosedMessage) temporarilyClosedMessage.value = record.temporarily_closed_message || TEMPORARILY_CLOSED_MESSAGE_DEFAULT;
          if (allowOrders) allowOrders.checked = record.allow_orders_when_closed !== false;
        }
        async function save(event) {
          event.preventDefault();
          if (!settingsRecord?.id) settingsRecord = await createSettingsRecord();
          const payload = {
            business_hours_mode: selectedMode(),
            business_hours: JSON.stringify(readDays()),
            closed_message: closedMessage?.value?.trim() || CLOSED_MESSAGE_DEFAULT,
            temporarily_closed_message: temporarilyClosedMessage?.value?.trim() || TEMPORARILY_CLOSED_MESSAGE_DEFAULT,
            allow_orders_when_closed: allowOrders?.checked !== false,
            store: CURRENT_STORE_ID,
          };
          await api('/api/collections/settings/records/' + settingsRecord.id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          show('Horario guardado correctamente.', 'success');
          await loadSettings();
        }

        document.querySelectorAll('input[name="business_hours_mode"]').forEach((input) => input.addEventListener('change', updateModeUI));
        form?.addEventListener('submit', (event) => save(event).catch((error) => show(error.message || 'No se pudo guardar el horario.', 'error')));
        refreshBtn?.addEventListener('click', () => loadSettings().catch((error) => show(error.message || 'No se pudo cargar el horario.', 'error')));
        document.querySelector('[data-tab="horario"]')?.addEventListener('click', () => loadSettings().catch((error) => show(error.message || 'No se pudo cargar el horario.', 'error')));
        renderDays(DEFAULT_HOURS);
        updateModeUI();
        if (token()) loadSettings().catch(() => {});
      })();
    </script>


