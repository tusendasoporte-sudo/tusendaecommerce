        async function save(event) {
          event.preventDefault();
          if (settingsSaving) return;
          if (!hasSettingsChanges()) {
            syncSettingsSubmitState();
            return;
          }
          settingsSaving = true;
          syncSettingsSubmitState();
          show('Guardando ajustes...', 'info');
          if (!settingsRecord || !settingsRecord.id) {
            try {
              settingsRecord = await createSettingsRecord();
            } catch (error) {
              settingsSaving = false;
              syncSettingsSubmitState();
              show(error.message || 'No se pudieron guardar los cambios', 'error');
              return;
            }
          }
          try {
            const data = new FormData();
            data.append('store_name', fields.storeName.value.trim() || 'PowerZona');
            data.append('stored_name', fields.storeName.value.trim() || 'PowerZona');
            data.append('order_prefix', normalizeOrderPrefix(fields.orderPrefix.value));
            data.append('whatsapp_number', composeWhatsappNumber());
            data.append('store_description', fields.storeDescription.value.trim());
            data.append('welcome_text', fields.welcome.value.trim());
            data.append('public_category_columns', fields.categoryColumns.value || '2');
            data.append('cover_mode', fields.coverMode.value || 'single');
            data.append('business_types', JSON.stringify(selectedBusinessTypes));
            data.append('province', fields.province?.value || '');
            data.append('municipality', fields.municipality?.value || '');
            data.append('address_detail', fields.addressDetail?.value?.trim() || '');
            data.append('address', composeAddress());
            data.append('public_services_text', selectedBusinessTypes.map(businessTypeLabel).join(', '));
            data.append('reviews_text', fields.reviews.value.trim());
            data.append('store', CURRENT_STORE_ID_PUBLIC_SETTINGS);
            if (fields.logo.files && fields.logo.files[0]) data.append('logo_image', fields.logo.files[0]);
            if (fields.cover.files && fields.cover.files[0]) data.append('cover_image', await optimizeCoverImageFile(fields.cover.files[0]));
            const galleryInputs = Array.from(document.querySelectorAll('.js-cover-gallery-file'));
            const selectedGalleryInputs = galleryInputs.filter((input) => input.files && input.files[0]);
            for (const input of selectedGalleryInputs) {
              const slot = input.closest('[data-gallery-field]');
              const fieldName = slot?.dataset?.galleryField || '';
              const sourceField = slot?.dataset?.gallerySourceField || fieldName;
              const currentFile = input.dataset.currentFile || '';
              if (!/^cover_image_[1-4]$/.test(fieldName)) continue;
              if (currentFile) data.append(sourceField + '-', currentFile);
              data.append(fieldName, await optimizeCoverImageFile(input.files[0]));
            }
            await api('/api/collections/settings/records/' + settingsRecord.id, { method: 'PATCH', body: data });
            fields.logo.value = '';
            fields.cover.value = '';
            galleryInputs.forEach((input) => { input.value = ''; });
            show('Cambios guardados correctamente', 'success');
            await loadSettings();
          } catch (error) {
            console.error(error);
            show(error.message || 'No se pudieron guardar los cambios', 'error');
          } finally {
            settingsSaving = false;
            syncSettingsSubmitState();
          }
        }
