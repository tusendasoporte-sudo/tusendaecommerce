      async function moveVariation(variationId, direction) {
        const sorted = getSortedVariations();
        const currentIndex = sorted.findIndex((item) => item.id === variationId);
        const targetIndex = direction === 'up' ? currentIndex - 1 : currentIndex + 1;
        if (currentIndex < 0 || targetIndex < 0 || targetIndex >= sorted.length) return;
        const current = sorted[currentIndex];
        const target = sorted[targetIndex];
        const currentOrder = Number(current.sort_order || currentIndex + 1);
        const targetOrder = Number(target.sort_order || targetIndex + 1);
        const currentData = new FormData();
        const targetData = new FormData();
        currentData.append('sort_order', String(targetOrder));
        targetData.append('sort_order', String(currentOrder));
        await apiRequest(`/api/collections/product_variations/records/${current.id}`, { method: 'PATCH', body: currentData });
