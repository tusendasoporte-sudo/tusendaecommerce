        }
        .price {
          margin-top: 2px !important;
          color: #111827 !important;
        }
        .stock {
          color: #6b7280 !important;
        }
        .price-offer-admin {
          flex-direction: row !important;
          align-items: center !important;
          gap: 5px !important;
        }
        .pill {
          justify-self: start !important;
          padding: 4px 7px !important;
          font-size: 9px !important;
        }
        .row-actions {
          grid-column: 3 !important;
          grid-row: 1 / span 4 !important;
          align-self: center !important;
          justify-self: end !important;
        }
        .row-actions .js-product-toggle {
          display: none !important;
        }
        .actions-trigger {
          width: 36px !important;
          height: 36px !important;
          min-width: 36px !important;
          padding: 0 !important;
          border-radius: 12px !important;
        }
        .actions-menu {
          right: 0 !important;
          width: 196px !important;
        }
        .product-delete-confirm {
          grid-column: 1 / -1 !important;
          margin: 8px 0 0 !important;
        }
        .pagination-bar {
          justify-content: center !important;
          padding: 12px !important;
        }
        .pagination-summary {
          width: 100% !important;
          text-align: center !important;
        }
      }


      .sidebar-plan-meta {
        margin-top: 10px;
        display: grid;
        gap: 4px;
        padding: 9px 10px;
        border-radius: 14px;
        background: rgba(37, 99, 235, .06);
        border: 1px solid rgba(37, 99, 235, .10);
      }
      .sidebar-plan-meta p {
        margin: 0;
        color: #475569;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 800;
      }
      .sidebar-plan-meta strong {
        color: #0f172a;
        font-weight: 1000;
      }
    </style>
  </head>
  <body>
    <div id="sidebar-overlay" class="sidebar-overlay" hidden></div>
    <div class="app-shell pz-admin-content">
      <AdminSidebar storeSlug={currentStoreSlug} storeName={adminContext.store.name || adminContext.store.title || currentStoreSlug || 'PowerZona'} activeSection="products" />

      <main class="admin-main pz-admin-content-inner">
        <header class="topbar mobile-topbar">
          <button id="sidebar-open" class="menu-btn" type="button" aria-controls="pz-admin-sidebar" aria-expanded="false">☰</button>
          <strong id="mobile-topbar-title">Productos</strong>
          <span class="mobile-topbar-slot" aria-hidden="true"></span>
        </header>

        <section class="hero-card products-page-header">
          <div>
            <span class="badge">Catálogo</span>
            <h1 class="page-title">Productos</h1>
            <p id="admin-subtitle" class="page-subtitle">Gestiona y organiza todos los productos de tu tienda.</p>
          </div>
          <div class="hero-actions">
            <button id="admin-notifications-btn" class="notifications-btn" type="button" aria-label="Notificaciones del admin">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18 9a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9Z"></path>
                <path d="M10 21a2 2 0 0 0 4 0"></path>
              </svg>
              <span class="notifications-badge" aria-hidden="true"></span>
            </button>
            <button id="new-product-btn" class="action-btn dark" type="button">+ Nuevo producto</button>
          </div>
        </section>
        <section id="admin-view">

          <section id="product-editor" class="panel-card editor-card hidden">
            <div class="editor-head">
              <div>
                <h2 id="editor-title" class="editor-title">Nuevo producto</h2>
                <p id="editor-subtitle" class="editor-subtitle">Completa los datos principales. La subcategoría es opcional: si la dejas vacía, será producto directo de la categoría.</p>
              </div>
              <button id="editor-close-btn" class="mini-btn" type="button">← Volver a productos</button>
            </div>
            <div class="editor-body">
              <form id="product-form">
                <input id="product-id" type="hidden" />
                <input id="product-slug" type="hidden" />
                <div class="admin-product-editor-page">
                  <div class="editor-main-column">
                <div class="product-form-grid">
                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Producto</p>
                    <h3>Información básica</h3>
                    <span>Completa la información para publicar este producto en tu tienda.</span>
                  </div>
                  <div class="field full">
                    <label for="product-name">Nombre del producto</label>
                    <input id="product-name" type="text" placeholder="Ej: Nombre del producto" required />
                    <p class="form-help">El slug se genera automáticamente desde este nombre.</p>
                  </div>
                  <div class="field">
                    <label for="product-internal-ref">SKU / Ref interna</label>
                    <input id="product-internal-ref" type="text" placeholder="Ej: BF-WHEY-5LB" />
                  </div>
                  <div class="field">
                    <label for="product-delivery-mode">Método disponible</label>
                    <select id="product-delivery-mode" required>
                      <option value="both">Envío o recogida</option>
                      <option value="delivery">Solo envío</option>
                      <option value="pickup">Solo recogida</option>
                    </select>
                  </div>
                  <div class="field full">
                    <label for="product-description">Descripción</label>
                    <textarea id="product-description" placeholder="Descripción visible en la ficha del producto"></textarea>
                  </div>

                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Organización</p>
                    <h3>Categoría y organización</h3>
                    <span>Ubica este producto dentro del catálogo y crea categorías rápidas si hace falta.</span>
                  </div>
                  <div class="field">
                    <label for="product-category">Categoría</label>
                    <select id="product-category"><option value="">Sin categoría / página principal</option></select>
                    <div id="quick-category-panel" class="quick-create-panel hidden" role="dialog" aria-modal="true" aria-labelledby="quick-category-title">
                      <div class="quick-create-head">
                        <div>
                          <p class="quick-create-kicker">Nueva categoría</p>
                          <h3 id="quick-category-title" class="quick-create-title">Crear nueva categoría</h3>
                          <p class="quick-create-subtitle">Agrega una categoría sin salir del producto. La foto es opcional y luego puedes cambiarla desde Gestión de catálogo.</p>
                        </div>
                        <button id="quick-category-x" class="quick-create-close" type="button" aria-label="Cerrar">×</button>
                      </div>
                      <div class="quick-create-body">
                        <div class="quick-create-grid">
                          <div class="field">
                            <label for="quick-category-name">Nombre</label>
                            <input id="quick-category-name" type="text" placeholder="Ej. Proteínas" />
                          </div>
                          <div class="field">
                            <label for="quick-category-image">Foto opcional</label>
                            <input id="quick-category-image" type="file" accept="image/*" />
                            <p class="form-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                          </div>
                        </div>
                        <div id="quick-category-alert" class="alert alert-info hidden"></div>
                        <div class="quick-create-actions">
                          <button id="quick-category-cancel" class="mini-btn" type="button">Cancelar</button>
                          <button id="quick-category-save" class="submit-btn" type="button">Crear categoría</button>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="field">
                    <label for="product-subcategory">Subcategoría</label>
                    <select id="product-subcategory"><option value="">Producto directo de la categoría</option></select>
                    <div id="quick-subcategory-panel" class="quick-create-panel hidden" role="dialog" aria-modal="true" aria-labelledby="quick-subcategory-title">
                      <div class="quick-create-head">
                        <div>
                          <p class="quick-create-kicker">Nueva subcategoría</p>
                          <h3 id="quick-subcategory-title" class="quick-create-title">Crear nueva subcategoría</h3>
                          <p class="quick-create-subtitle">Se guardará dentro de la categoría seleccionada y quedará lista para este producto.</p>
                        </div>
                        <button id="quick-subcategory-x" class="quick-create-close" type="button" aria-label="Cerrar">×</button>
                      </div>
                      <div class="quick-create-body">
                        <div class="quick-create-grid">
                          <div class="field">
                            <label for="quick-subcategory-name">Nombre</label>
                            <input id="quick-subcategory-name" type="text" placeholder="Ej. Whey Protein" />
                          </div>
                          <div class="field">
                            <label for="quick-subcategory-image">Foto opcional</label>
                            <input id="quick-subcategory-image" type="file" accept="image/*" />
                            <p class="form-help">Recomendado: imagen horizontal 16:9, mínimo 1200 x 675 px.</p>
                          </div>
                        </div>
                        <p class="form-help">Se creará dentro de la categoría seleccionada.</p>
                        <div id="quick-subcategory-alert" class="alert alert-info hidden"></div>
                        <div class="quick-create-actions">
                          <button id="quick-subcategory-cancel" class="mini-btn" type="button">Cancelar</button>
                          <button id="quick-subcategory-save" class="submit-btn" type="button">Crear subcategoría</button>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="field price-offer-card">
                    <div class="price-offer-card-head">
                      <div>
                        <p class="price-offer-card-title">Precio y oferta</p>
                        <p class="price-offer-card-subtitle">Activa la oferta para mostrar un precio promocional en tu tienda.</p>
                      </div>
                    </div>
                    <div class="price-offer-grid">
                      <div class="field">
                        <label for="product-price">Precio USD</label>
                        <input id="product-price" type="number" min="0" step="0.01" placeholder="0.00" required />
                      </div>
                      <div class="field offer-field">
                        <label class="check-card switch-card"><input id="product-is-offer" type="checkbox" /> Este producto tiene oferta</label>
                        <label for="product-offer-price" style="margin-top:10px;">Precio oferta USD</label>
                        <input id="product-offer-price" type="number" min="0" step="0.01" placeholder="0.00" disabled />
                        <p id="product-offer-help" class="offer-hint">Activa la oferta y escribe un precio menor al precio normal.</p>
                      </div>
                    </div>
                  </div>
                  <div class="field">
                    <label for="product-cost">Costo USD</label>
                    <input id="product-cost" type="number" min="0" step="0.01" placeholder="0.00" />
                  </div>
                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Disponibilidad</p>
                    <h3>Inventario</h3>
                    <span>Controla la disponibilidad del producto en tu tienda.</span>
                  </div>
                  <div id="product-stock-field" class="field">
                    <label for="product-stock">Stock</label>
                    <input id="product-stock" type="number" min="0" step="1" placeholder="0" />
                    <p id="product-stock-help" class="form-help">Si el producto usa variaciones, el stock real de venta saldrá de las variaciones.</p>
                  </div>
                  <div class="field">
                    <label for="product-expiration-date">Fecha de vencimiento</label>
                    <input id="product-expiration-date" type="date" />
                  </div>

                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Contenido</p>
                    <h3>Información adicional</h3>
                    <span>Agrega detalles, especificaciones o instrucciones para este producto.</span>
                  </div>
                  <div class="field full">
                    <label>Información adicional</label>
                    <p class="form-help">Agrega hasta 3 datos editables por producto. Ej: Marca, Presentación, Beneficio, Sabor, Tamaño o Servicio.</p>
                    <div class="product-extra-panel">
                      <div id="product-extra-list" class="product-extra-list"></div>
                      <button id="product-extra-add-btn" class="product-extra-add" type="button">＋ Añadir información</button>
                      <div id="product-extra-editor" class="product-extra-editor hidden">
                        <div class="product-extra-editor-head">
                          <div>
                            <p id="product-extra-editor-title" class="product-extra-editor-title">Nueva información</p>
                            <p class="product-extra-editor-help">El admin puede editar el nombre del dato y su valor para cada producto.</p>
                          </div>
                          <button id="product-extra-close-btn" class="mini-btn" type="button">×</button>
                        </div>
                        <div class="product-extra-editor-grid">
                          <div class="field">
                            <label for="product-extra-label">Nombre del dato</label>
                            <input id="product-extra-label" type="text" placeholder="Ej: Marca" maxlength="40" />
                          </div>
                          <div class="field">
                            <label for="product-extra-value">Valor</label>
                            <input id="product-extra-value" type="text" placeholder="Ej: Spring Valley" maxlength="80" />
                          </div>
                        </div>
                        <div class="product-extra-editor-actions">
                          <button id="product-extra-cancel-btn" class="mini-btn" type="button">Cancelar</button>
                          <button id="product-extra-save-btn" class="submit-btn" type="button">Guardar información</button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Sugerencias</p>
                    <h3>Productos relacionados</h3>
                    <span>Selecciona productos para mostrarlos al final de la ficha pública.</span>
                  </div>
                  <div class="field full">
                    <label>Productos relacionados</label>
                    <p class="form-help">Selecciona hasta 4 productos sugeridos para mostrar al final de la ficha pública.</p>
                    <div class="related-products-panel">
                      <div class="related-products-head">
                        <div>
                          <p class="related-products-title">Productos relacionados</p>
                          <p class="related-products-subtitle">Artículos sugeridos junto a este producto.</p>
                        </div>
                        <button id="related-products-open-btn" class="mini-btn" type="button">＋ Añadir productos</button>
                      </div>
                      <div id="related-products-list" class="related-products-list"></div>
                    </div>
                  </div>

                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Galería</p>
                    <h3>Imágenes del producto</h3>
                    <span>Arrastra imágenes aquí o selecciona archivos para preparar la galería.</span>
                  </div>
                  <div class="field full">
                    <label>Imágenes del producto</label>
                    <div class="product-upload-dropzone">
                      <strong>Arrastra imágenes aquí o selecciona archivos</strong>
                      <span>Usa hasta 4 espacios; la primera foto es la portada.</span>
                      <em>Seleccionar archivos desde las miniaturas</em>
                    </div>
                    <p class="form-help">Recomendado: imagen cuadrada o vertical limpia, mínimo 1000 x 1000 px.</p>
                    <div id="product-image-slots" class="product-image-slots"></div>
                  </div>

                  <div class="editor-section-heading full">
                    <p class="editor-section-kicker">Estado</p>
                    <h3>Estado del producto</h3>
                    <span>Define visibilidad, stock descontable y opciones públicas.</span>
                  </div>
                  <div class="field full">
                    <label>Opciones</label>
                    <div class="check-grid">
                      <label class="check-card"><input id="product-active" type="checkbox" checked /> Visible en tienda</label>
                      <label class="check-card"><input id="product-featured" type="checkbox" /> Destacado</label>
                      <label class="check-card"><input id="product-only-usd" type="checkbox" /> Solo USD</label>
                      <label class="check-card"><input id="product-allow-preorder" type="checkbox" /> Preorder si está agotado</label>
                      <label class="check-card"><input id="product-track-stock" type="checkbox" checked /> Descontar stock en órdenes</label>
                      <label id="product-has-variations-option" class="check-card hidden"><input id="product-has-variations" type="checkbox" /> Usa variaciones</label>
                    </div>
                    <p class="form-help">Si activas “Descontar stock”, las órdenes descontarán inventario. Si el producto usa variaciones, el stock del producto padre será la suma de las variaciones.</p>
                  </div>
                  <div id="product-variation-view-field" class="field full hidden">
                    <label for="product-variation-view">Vista de variaciones en tienda</label>
                    <select id="product-variation-view">
                      <option value="buttons">Botones</option>
                      <option value="dropdown">Desplegable</option>
                      <option value="checkbox">Checkbox fijo</option>
                    </select>
                    <p class="form-help">Botones para pocas opciones, desplegable para muchas opciones y checkbox fijo para mostrar todas las variaciones visibles.</p>
