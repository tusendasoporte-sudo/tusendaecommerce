            <button class="related-product-remove" type="button" data-related-remove="${product.id}">Quitar</button>
          </div>
        `).join('');
        relatedProductsList.querySelectorAll('[data-related-remove]').forEach((button) => {
          button.addEventListener('click', () => {
            selectedRelatedProductIds = selectedRelatedProductIds.filter((id) => id !== button.dataset.relatedRemove);
