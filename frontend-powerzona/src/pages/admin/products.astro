      async function deleteProductWithVariations(productId) {
        if (!productId) return;
        const filter = encodeURIComponent(`product="${productId}"`);
        const variations = await loadAllRecords('product_variations', `filter=${filter}`);
        for (const variation of variations) {
          await apiRequest(`/api/collections/product_variations/records/${variation.id}`, { method: 'DELETE' });
        }
        await apiRequest(`/api/collections/products/records/${productId}`, { method: 'DELETE' });
      }

      function pocketBaseErrorMessage(result, fallback = 'Error de comunicacion con la plataforma.') {
        const base = result?.message || fallback;
        const fieldErrors = result?.data && typeof result.data === 'object'
          ? Object.entries(result.data).map(([field, info]) => {
              const message = info?.message || (Array.isArray(info) ? info.map((item) => item?.message).filter(Boolean).join(', ') : '');
              return message ? `${field}: ${message}` : field;
            }).filter(Boolean)
          : [];
        return fieldErrors.length ? `${base} ${fieldErrors.join(' · ')}` : base;
      }
      async function apiRequest(path, options = {}) {
        const headers = { ...(options.headers || {}) };
        const token = getAdminToken();
        if (token) headers.Authorization = `Bearer ${token}`;
        const response = await fetch(`${POCKETBASE_URL}${path}`, { ...options, headers });
        const result = await response.json().catch(() => null);
        if (!response.ok) throw new Error(pocketBaseErrorMessage(result));
        return result;
      }
      async function loadAllRecords(collection, params = '') {
        let page = 1;
        const perPage = 200;
        let items = [];
        let totalPages = 1;
        do {
          const separator = params ? '&' : '';
          const result = await apiRequest(`/api/collections/${collection}/records?${params}${separator}page=${page}&perPage=${perPage}`);
          items = items.concat(result.items || []);
          totalPages = result.totalPages || 1;
          page += 1;
        } while (page <= totalPages);
        return items;
      }

      function withStoreFilter(params = '') {
        const query = new URLSearchParams(params || '');
        const existing = query.get('filter');
        if (existing) query.set('filter', `(${existing}) && ${STORE_FILTER}`);
        else query.set('filter', STORE_FILTER);
        return query.toString();
      }

      function isCurrentStoreRecord(record) {
        const value = record?.store;
        return Array.isArray(value) ? value.includes(CURRENT_STORE_ID) : String(value || '') === CURRENT_STORE_ID;
      }

      function productImageUrl(product) {
        const images = normalizeProductImages(product);
        const firstImage = images[0] || '';
        if (!product?.id || !firstImage || !POCKETBASE_URL) return '';
        return `${POCKETBASE_URL}/api/files/products/${encodeURIComponent(product.id)}/${encodeURIComponent(firstImage)}?thumb=160x160`;
      }
      function productImageMarkup(product) {
        const name = product?.name || 'Producto';
        const url = productImageUrl(product);
        if (!url) return '<span class="product-thumb placeholder js-product-open" role="button" tabindex="0" title="Editar producto">📦</span>';
        return `<img class="product-thumb js-product-open" src="${url}" alt="${escapeHtml(name)}" loading="lazy" title="Editar producto" />`;
      }
      function normalizeRelatedProductsValue(value) {
        if (Array.isArray(value)) return value.filter(Boolean).slice(0, 4);
        if (typeof value === 'string' && value.trim()) return [value.trim()].slice(0, 4);
        return [];
      }
      function relatedProductThumbMarkup(product) {
        const url = productImageUrl(product);
        const name = escapeHtml(product?.name || 'Producto');
        if (!url) return '<span class="related-product-thumb placeholder">📦</span>';
        return `<img class="related-product-thumb" src="${url}" alt="${name}" loading="lazy" />`;
      }
      function relatedProductPriceText(product) {
        const activePrice = Number(product?.base_price_usd || 0);
        const regularPrice = Number(product?.regular_price_usd || activePrice || 0);
        const hasOffer = Boolean(product?.is_offer) && regularPrice > activePrice && activePrice > 0;
        return hasOffer ? `Oferta · ${formatUsd(activePrice)}` : `${formatUsd(activePrice)}`;
      }
      function getRelatedProductCandidates() {
        const currentId = productIdInput?.value || '';
        return products.filter((product) => product?.id && product.id !== currentId);
      }
      function getSelectedRelatedProducts() {
        return selectedRelatedProductIds
          .map((id) => products.find((product) => product.id === id))
          .filter(Boolean)
          .slice(0, 4);
      }
      function renderSelectedRelatedProducts() {
        if (!relatedProductsList) return;
        const selectedProducts = getSelectedRelatedProducts();
        if (!selectedProducts.length) {
          relatedProductsList.innerHTML = '<div class="related-modal-empty">No hay productos relacionados seleccionados.</div>';
          return;
        }
        relatedProductsList.innerHTML = selectedProducts.map((product) => `
          <div class="related-product-row">
