        const savedImages = Array.isArray(savedProduct.images) ? savedProduct.images.filter(Boolean) : [];
        const existingKept = productImageSlotExisting.filter(Boolean).filter((name) => savedImages.includes(name));
        const newNames = savedImages.filter((name) => !existingKept.includes(name));
        let newIndex = 0;
        const ordered = [];
        for (let index = 0; index < PRODUCT_IMAGE_SLOT_COUNT; index += 1) {
          if (productImageSlotFiles[index]) {
            const uploadedName = newNames[newIndex];
            newIndex += 1;
            if (uploadedName && savedImages.includes(uploadedName)) ordered.push(uploadedName);
          } else {
            const existing = productImageSlotExisting[index] || '';
            if (existing && savedImages.includes(existing)) ordered.push(existing);
          }
        }
        const finalOrder = ordered.concat(savedImages.filter((name) => !ordered.includes(name))).slice(0, PRODUCT_IMAGE_SLOT_COUNT);
        if (!finalOrder.length) return savedProduct;
        const orderData = new FormData();
        orderData.set('image_order', JSON.stringify(finalOrder));
        try {
          return await apiRequest(`/api/collections/products/records/${savedProduct.id}`, { method: 'PATCH', body: orderData });
