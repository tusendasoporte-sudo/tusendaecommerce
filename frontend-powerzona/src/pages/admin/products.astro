      function findDuplicateProduct({ excludeId = '', name = '', slug = '', internalRef = '' } = {}) {
        const cleanName = normalizeDuplicateText(name);
        const cleanSlug = normalizeDuplicateText(slug);
        const cleanRef = normalizeDuplicateText(internalRef);
        return products.find((item) => {
          if (!item || item.id === excludeId) return false;
          const itemName = normalizeDuplicateText(item.name);
          const itemSlug = normalizeDuplicateText(item.slug);
          const itemRef = normalizeDuplicateText(item.internal_ref);
          if (cleanSlug && itemSlug && cleanSlug === itemSlug) return true;
          if (cleanName && itemName && cleanName === itemName) return true;
          if (cleanRef && itemRef && cleanRef === itemRef) return true;
