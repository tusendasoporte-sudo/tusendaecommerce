      let editingExtraInfoIndex = -1;
      function normalizeProductImages(product) {
        const images = Array.isArray(product?.images) ? product.images.filter(Boolean) : [];
        let order = [];
        try {
          order = product?.image_order ? JSON.parse(product.image_order) : [];
        } catch (_) {
          order = [];
        }
        const ordered = Array.isArray(order) ? order.filter((name) => images.includes(name)) : [];
        return ordered.concat(images.filter((name) => !ordered.includes(name))).slice(0, PRODUCT_IMAGE_SLOT_COUNT);
      }
      const variationAlert = document.getElementById('variation-alert');
      const variationCancelBtn = document.getElementById('variation-cancel-btn');
      const variationDeleteBtn = document.getElementById('variation-delete-btn');
      const variationSaveBtn = document.getElementById('variation-save-btn');

      function openSidebar() {
        document.body.classList.add('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'false');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'true');
        if (sidebarOverlay) sidebarOverlay.hidden = false;
      }
      function closeSidebar() {
        document.body.classList.remove('sidebar-open');
        sidebar?.setAttribute('aria-hidden', 'true');
        sidebarOpenBtn?.setAttribute('aria-expanded', 'false');
        window.setTimeout(() => {
          if (!document.body.classList.contains('sidebar-open') && sidebarOverlay) sidebarOverlay.hidden = true;
        }, 230);
      }
      sidebarOpenBtn?.addEventListener('click', openSidebar);
      sidebarCloseBtn?.addEventListener('click', closeSidebar);
      sidebarOverlay?.addEventListener('click', closeSidebar);
      sidebar?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeSidebar));
      if (window.matchMedia('(min-width: 1121px)').matches) sidebar?.setAttribute('aria-hidden', 'false');
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && document.body.classList.contains('sidebar-open')) closeSidebar();
      });
      filtersToggleBtn?.addEventListener('click', () => {
        const isOpen = catalogOverview?.classList.toggle('filters-open');
        filtersToggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
      }
      function formatUsd(value) {
        return `${Number(value || 0).toFixed(2)} USD`;
      }
      function getAdminToken() { return ADMIN_AUTH_TOKEN; }
      function clearAdminToken() { document.cookie = 'pb_auth=; Path=/; Max-Age=0; SameSite=Lax'; }
      function showAdmin() { adminView.classList.remove('hidden'); logoutBtn.classList.remove('hidden'); }
      function setAlert(element, message) {
        element.textContent = message || '';
        element.classList.toggle('hidden', !message);
      }

      function slugify(value) {
        return String(value || '')
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '')
          .slice(0, 80);
      }
      function dateForInput(value) {
        if (!value) return '';
        return String(value).slice(0, 10);
      }
      function setFormAlert(message, type = 'info') {
        showProductNotice(message, type);
      }

      function showTimedNotice(element, timerName, message, type = 'info') {
        if (!element) return null;
        window.clearTimeout(timerName === 'product' ? productNoticeTimer : variationNoticeTimer);
        element.textContent = message || '';
        element.className = `alert alert-${type} ${message ? '' : 'hidden'}`;
        if (!message || type === 'info') return null;
        const delay = type === 'error' ? 4600 : 2800;
        return window.setTimeout(() => {
          element.textContent = '';
          element.className = `alert alert-${type} hidden`;
        }, delay);
      }

      function showProductNotice(message, type = 'info') {
        productNoticeTimer = showTimedNotice(productFormAlert, 'product', message, type);
      }

      function showVariationNotice(message, type = 'info') {
        variationNoticeTimer = showTimedNotice(variationAlert, 'variation', message, type);
      }

      function showDuplicateProductToast(detail = '') {
        if (!duplicateProductToast) return;
        if (duplicateProductToastDetail) {
          duplicateProductToastDetail.textContent = detail || 'Ya existe un producto con ese nombre o ref interna.';
        }
        duplicateProductToast.classList.remove('hidden');
        window.clearTimeout(duplicateProductToastTimer);
        duplicateProductToastTimer = window.setTimeout(() => {
          duplicateProductToast?.classList.add('hidden');
        }, 4200);
