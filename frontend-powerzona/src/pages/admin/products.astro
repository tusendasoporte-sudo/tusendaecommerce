        if (category && !categories.some((item) => item.id === category && isCurrentStoreRecord(item))) {
          throw new Error('La categoria seleccionada no pertenece a esta tienda.');
        }
        if (subcategory && !subcategories.some((item) => item.id === subcategory && item.category === category && isCurrentStoreRecord(item))) {
          throw new Error('La subcategoria seleccionada no pertenece a esta tienda.');
        }
        if (!name) throw new Error('Escribe el nombre del producto.');
        if (!slug) throw new Error('Escribe un nombre válido para generar el slug del producto.');
        const duplicate = findDuplicateProduct({
          excludeId: productIdInput.value || '',
          name,
          slug,
          internalRef: productInternalRefInput.value.trim(),
        });
        if (duplicate) {
          const duplicateName = duplicate.name || 'Producto existente';
          const detail = `Ya existe: ${duplicateName}. Edita ese producto o cambia el nombre/ref interna.`;
          showDuplicateProductToast(detail);
          throw new Error(detail);
        }
        const trackStock = productTracksStock();
        const isEditing = Boolean(productIdInput.value);
        const shouldUseVariations = forceHasVariations !== null
          ? Boolean(forceHasVariations)
          : (isEditing && (productHasVariationsInput.checked || productVariations.length > 0));
        if (trackStock && !shouldUseVariations && productStockInput.value === '') throw new Error('Este producto descuenta stock. Escribe un stock válido.');
        formData.append('name', name);
        formData.append('slug', slug);
        formData.append('store', CURRENT_STORE_ID);
        if (isEditing || category) formData.append('category', category);
        if (isEditing || subcategory) formData.append('subcategory', subcategory);
        const offerState = getValidOfferState();
        if (offerState.enabled && !offerState.valid) throw new Error('El precio de oferta debe ser mayor que 0 y menor que el Precio USD bloqueado.');
        const regularPriceUsd = offerState.enabled ? offerState.regularPrice : readRegularPriceInput();
