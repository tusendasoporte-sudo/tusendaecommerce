        formData.append('cost_usd', String(Math.max(0, Number(productCostInput.value || 0))));
        formData.append('internal_ref', productInternalRefInput.value.trim());
        const finalStock = trackStock && !shouldUseVariations ? Math.max(0, Math.floor(Number(productStockInput.value || 0))) : (shouldUseVariations ? getVariationStockSum() : 0);
        const safeStock = Number.isFinite(Number(finalStock)) ? Math.max(0, Math.floor(Number(finalStock))) : 0;
        formData.set('stock', String(safeStock));
        formData.append('delivery_mode', productDeliveryModeInput.value || 'both');
        formData.append('description', productDescriptionInput.value.trim());
        formData.append('extra_info', JSON.stringify(normalizeProductExtraInfo(productExtraInfoItems)));
        formData.append('active', productActiveInput.checked ? 'true' : 'false');
        formData.append('featured', productFeaturedInput.checked ? 'true' : 'false');
        formData.append('only_usd', productOnlyUsdInput.checked ? 'true' : 'false');
        formData.append('allow_preorder', productAllowPreorderInput.checked ? 'true' : 'false');
        formData.append(TRACK_STOCK_FIELD, trackStock ? 'true' : 'false');
        formData.append('has_variations', shouldUseVariations ? 'true' : 'false');
        formData.append('variation_view', shouldUseVariations ? (productVariationViewInput?.value || 'buttons') : 'buttons');
        if (isEditing) formData.append('expiration_date', productExpirationDateInput.value || '');
        else appendOptionalFormValue(formData, 'expiration_date', productExpirationDateInput.value || '');
        const relatedIds = selectedRelatedProductIds.slice(0, 4).filter(Boolean);
        if (relatedIds.length) relatedIds.forEach((id) => formData.append('related_products', id));
        else formData.append('related_products', '');
        await appendProductImageFiles(formData, { appendMode: isEditing });
        return formData;
      }
