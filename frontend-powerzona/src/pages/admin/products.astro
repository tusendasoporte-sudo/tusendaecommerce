      function renderRelatedProductsModal() {
        if (!relatedProductsModalList) return;
        const term = normalizeDuplicateText(relatedProductsSearchInput?.value || '');
        const candidates = getRelatedProductCandidates().filter((product) => {
          if (!term) return true;
          return normalizeDuplicateText(`${product.name || ''} ${product.internal_ref || ''} ${product.slug || ''}`).includes(term);
        });
        if (!candidates.length) {
          relatedProductsModalList.innerHTML = '<div class="related-modal-empty">No se encontraron productos.</div>';
          return;
        }
        relatedProductsModalList.innerHTML = candidates.map((product) => {
          const isSelected = modalRelatedProductIds.includes(product.id);
          const limitReached = modalRelatedProductIds.length >= 4 && !isSelected;
          const activeLabel = product.active ? 'Activo' : 'Inactivo';
          const disabledClass = limitReached ? ' is-disabled' : '';
          const selectedClass = isSelected ? ' is-selected' : '';
          return `
            <label class="related-modal-item${disabledClass}${selectedClass}" data-related-option="${product.id}">
              <div class="related-product-info">
                ${relatedProductThumbMarkup(product)}
                <div style="min-width:0;">
                  <p class="related-product-name">${escapeHtml(product.name || 'Producto')}</p>
                  <p class="related-product-meta">${escapeHtml(activeLabel)} · ${escapeHtml(relatedProductPriceText(product))}</p>
                </div>
              </div>
              <input type="checkbox" value="${product.id}" ${isSelected ? 'checked' : ''} ${limitReached ? 'disabled' : ''} />
            </label>
          `;
        }).join('');
        relatedProductsModalList.querySelectorAll('[data-related-option]').forEach((row) => {
          row.addEventListener('click', (event) => {
            event.preventDefault();
            const id = row.dataset.relatedOption || '';
            if (!id) return;
            const isSelected = modalRelatedProductIds.includes(id);
            if (!isSelected && modalRelatedProductIds.length >= 4) return;
            modalRelatedProductIds = isSelected
              ? modalRelatedProductIds.filter((item) => item !== id)
              : modalRelatedProductIds.concat(id).slice(0, 4);
            renderRelatedProductsModal();
          });
        });
      }
      function openRelatedProductsModal() {
        if (!relatedProductsModal) return;
        modalRelatedProductIds = selectedRelatedProductIds.slice(0, 4);
        if (relatedProductsModalSubtitle) {
          const productName = productNameInput?.value?.trim() || 'este producto';
          relatedProductsModalSubtitle.textContent = `Selecciona productos relacionados con: ${productName}. Máximo 4.`;
        }
        if (relatedProductsSearchInput) relatedProductsSearchInput.value = '';
        relatedProductsModal.classList.remove('hidden');
        document.body.classList.add('quick-modal-open');
        renderRelatedProductsModal();
        setTimeout(() => relatedProductsSearchInput?.focus(), 40);
      }
      function closeRelatedProductsModal() {
        relatedProductsModal?.classList.add('hidden');
        document.body.classList.remove('quick-modal-open');
      }
      function applyRelatedProductsModal() {
        selectedRelatedProductIds = modalRelatedProductIds.slice(0, 4);
        renderSelectedRelatedProducts();
        closeRelatedProductsModal();
        updateProductFormState();
      }
      function getCategory(id) { return categories.find((item) => item.id === id) || null; }
      function getSubcategory(id) { return subcategories.find((item) => item.id === id) || null; }
      function productIsPublicVisible(product) {
        const category = product.category ? getCategory(product.category) : null;
        const subcategory = product.subcategory ? getSubcategory(product.subcategory) : null;
        if (!product.active) return false;
        if (product.category && !category?.active) return false;
        if (subcategory && !subcategory.active) return false;
        return true;
      }

      function syncFiltersFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const categoryId = params.get('category') || '';
        const subcategoryId = params.get('subcategory') || '';
        if (categoryId) categoryFilter.value = categoryId;
        updateSubcategoryOptions();
        if (subcategoryId) subcategoryFilter.value = subcategoryId;
      }

      function openEditorFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const editProductId = params.get('product') || '';
        const shouldCreate = params.get('new') === '1';
        const categoryId = params.get('category') || '';
        const subcategoryId = params.get('subcategory') || '';
        if (editProductId) {
          openEditProductEditor(editProductId);
          return;
        }
        if (shouldCreate) {
          openNewProductEditor();
          if (categoryId && categories.some((item) => item.id === categoryId)) {
            productCategoryInput.value = categoryId;
            renderProductSubcategoryOptions(subcategoryId);
          }
        }
      }
      function updateSubcategoryOptions() {
        const selectedCategory = categoryFilter.value;
        const items = subcategories.filter((item) => !selectedCategory || item.category === selectedCategory);
        subcategoryFilter.innerHTML = '<option value="">Todas</option>' + items.map((item) => `<option value="${item.id}">${escapeHtml(item.name || 'Sin nombre')}</option>`).join('');
      }
      function renderFilters() {
        categoryFilter.innerHTML = '<option value="">Todas</option>' + categories.map((item) => `<option value="${item.id}">${escapeHtml(item.name || 'Sin nombre')}</option>`).join('');
        updateSubcategoryOptions();
      }
      function resetProductPage() {
        currentProductPage = 1;
      }
      function productHasActiveOffer(product) {
        const activePriceUsd = Number(product.base_price_usd || 0);
        const regularPriceUsd = Number(product.regular_price_usd || 0);
        return Boolean(product.is_offer) && regularPriceUsd > activePriceUsd && activePriceUsd > 0;
      }
      function renderStats(sourceProducts = products) {
        document.getElementById('stat-total').textContent = String(sourceProducts.length);
        document.getElementById('stat-visible').textContent = String(sourceProducts.filter(productIsPublicVisible).length);
        document.getElementById('stat-hidden').textContent = String(sourceProducts.filter((item) => !productIsPublicVisible(item)).length);
        document.getElementById('stat-stockout').textContent = String(sourceProducts.filter((item) => productTracksStock(item) && Number(item.stock || 0) <= 0).length);
      }
      function getFilteredProducts() {
        const term = searchInput.value.trim().toLowerCase();
        const categoryId = categoryFilter.value;
        const subcategoryId = subcategoryFilter.value;
        const status = statusFilter?.value || '';
        const stockStatus = stockFilter?.value || '';
        return products.filter((product) => {
          const category = getCategory(product.category);
          const subcategory = getSubcategory(product.subcategory);
          const searchable = [product.name, product.internal_ref, product.slug, category?.name, subcategory?.name].filter(Boolean).join(' ').toLowerCase();
          if (term && !searchable.includes(term)) return false;
          if (categoryId && product.category !== categoryId) return false;
          if (subcategoryId && product.subcategory !== subcategoryId) return false;
          if (status === 'active' && !productIsPublicVisible(product)) return false;
          if (status === 'hidden' && productIsPublicVisible(product)) return false;
          if (status === 'offer' && !productHasActiveOffer(product)) return false;
          if (status === 'variations' && !product.has_variations) return false;
          if (stockStatus === 'in-stock' && productTracksStock(product) && Number(product.stock || 0) <= 0) return false;
          if (stockStatus === 'out-stock' && (!productTracksStock(product) || Number(product.stock || 0) > 0)) return false;
          return true;
        });
      }
      function closeProductActionMenus(exceptMenu = null) {
        productsList?.querySelectorAll('.actions-menu').forEach((menu) => {
          if (exceptMenu && menu === exceptMenu) return;
          menu.classList.add('hidden');
          menu.classList.remove('open-up');
          const trigger = menu.closest('.actions-wrap')?.querySelector('.js-actions-trigger');
          trigger?.setAttribute('aria-expanded', 'false');
        });
      }
      function positionProductActionsMenu(menu, trigger) {
        if (!menu || !trigger) return;

        menu.classList.remove('open-up');
        const margin = 18;
        const triggerRect = trigger.getBoundingClientRect();
        const menuHeight = menu.offsetHeight || 150;
        const availableBelow = window.innerHeight - triggerRect.bottom;
        const availableAbove = triggerRect.top;

        if (availableBelow < menuHeight + margin && availableAbove > menuHeight + margin) {
          menu.classList.add('open-up');
        }
      }
      function renderProductPagination(totalItems, fromItem, toItem, totalPages) {
        if (!productsPagination) return;
        if (!totalItems) {
          productsPagination.classList.add('hidden');
          productsPagination.innerHTML = '';
          return;
        }
        const pageButtons = Array.from({ length: totalPages }, (_, index) => {
          const page = index + 1;
          return `<button class="page-btn ${page === currentProductPage ? 'is-active' : ''}" type="button" data-page="${page}" aria-label="Ir a pagina ${page}">${page}</button>`;
        }).join('');
        productsPagination.classList.remove('hidden');
        productsPagination.innerHTML = `
          <p class="pagination-summary">Mostrando ${fromItem} a ${toItem} de ${totalItems} productos</p>
          <div class="pagination-actions">
            <button class="page-btn" type="button" data-page="prev" ${currentProductPage <= 1 ? 'disabled' : ''}>Anterior</button>
            ${pageButtons}
            <button class="page-btn" type="button" data-page="next" ${currentProductPage >= totalPages ? 'disabled' : ''}>Siguiente</button>
          </div>
        `;
      }
      function renderProducts() {
        closeProductActionMenus();
        const filtered = getFilteredProducts();
        renderStats(products);
        const totalPages = Math.max(1, Math.ceil(filtered.length / PRODUCT_PAGE_SIZE));
        currentProductPage = Math.min(Math.max(1, currentProductPage), totalPages);
        const startIndex = (currentProductPage - 1) * PRODUCT_PAGE_SIZE;
        const visibleProducts = filtered.slice(startIndex, startIndex + PRODUCT_PAGE_SIZE);
        if (!filtered.length) {
          productsList.innerHTML = '<div class="empty-state">No hay productos para este filtro.</div>';
          renderProductPagination(0, 0, 0, totalPages);
          return;
        }
        productsList.innerHTML = visibleProducts.map((product) => {
          const category = getCategory(product.category);
          const subcategory = getSubcategory(product.subcategory);
          const visible = productIsPublicVisible(product);
          const stockNumber = Number(product.stock || 0);
          const allowPreorder = Boolean(product.allow_preorder);
          const isOutOfStock = stockNumber <= 0;
          const categoryText = category?.name || 'Sin categoria';
          const subcategoryText = subcategory?.name || (category ? 'Producto directo' : 'Pagina principal');
          const refText = product.internal_ref ? `Ref: ${product.internal_ref}` : '';
          const trackStock = productTracksStock(product);
          const activePriceUsd = Number(product.base_price_usd || 0);
          const regularPriceUsd = Number(product.regular_price_usd || 0);
          const hasActiveOffer = productHasActiveOffer(product);
          return `
            <article class="product-row" data-product-id="${product.id}">
              <div class="product-main">
                  ${productImageMarkup(product)}
                <div>
                  <p class="product-title js-product-open" role="button" tabindex="0" title="Editar producto">${escapeHtml(product.name || 'Producto sin nombre')}</p>
                  <p class="product-meta">${escapeHtml([product.slug, refText].filter(Boolean).join(' · '))}</p>
                  <div class="product-badges">
                    ${product.featured ? '<span class="mini-pill featured">Destacado</span>' : ''}
                    ${hasActiveOffer ? '<span class="mini-pill danger">Oferta</span>' : ''}
                    ${product.only_usd ? '<span class="mini-pill usd">Solo USD</span>' : ''}
                    ${product.has_variations ? '<span class="mini-pill featured">Variaciones</span>' : ''}
                    <span class="mini-pill delivery">${escapeHtml(deliveryLabel(product.delivery_mode))}</span>
                    ${isOutOfStock && allowPreorder ? '<span class="mini-pill featured">Preorder</span>' : ''}
                  </div>
                </div>
              </div>
              <span class="category-cell"><span class="category-name">${escapeHtml(categoryText)}</span><span class="category-sub">${escapeHtml(subcategoryText)}</span></span>
              <span class="price">${hasActiveOffer ? `<span class="price-offer-admin"><span class="old">${escapeHtml(formatUsd(regularPriceUsd))}</span><span class="new">${escapeHtml(formatUsd(activePriceUsd))}</span></span>` : escapeHtml(formatUsd(activePriceUsd))}</span>
              <span class="stock">${trackStock ? `Stock: ${stockNumber}${isOutOfStock ? (allowPreorder ? ' · Preorder' : ' · Agotado') : ''}` : 'Sin stock descontable'}</span>
              <span class="pill ${visible ? 'pill-visible' : 'pill-hidden'}">${visible ? 'Visible' : 'Oculto'}</span>
              <div class="row-actions">
                <button class="mini-btn js-product-toggle" type="button">${product.active ? 'Ocultar' : 'Activar'}</button>
                <div class="actions-wrap">
                  <button class="mini-btn actions-trigger js-actions-trigger" type="button" aria-haspopup="menu" aria-expanded="false" title="Más acciones">⋯</button>
                  <div class="actions-menu hidden" role="menu">
                    <button class="js-product-edit" type="button" role="menuitem">Editar <span>✏️</span></button>
                    <button class="danger-action js-product-soldout" type="button" role="menuitem" ${isOutOfStock ? 'disabled' : ''}>${isOutOfStock ? 'Ya está agotado' : 'Marcar agotado'} <span>⚠️</span></button>
                    <button class="danger-action js-product-delete" type="button" role="menuitem">Borrar <span>🗑️</span></button>
                  </div>
                </div>
              </div>
              ${pendingDeleteProductId === product.id ? `
                <div class="inline-floating-card danger product-delete-confirm">
                  <p class="inline-floating-title">Borrar producto</p>
                  <p class="inline-floating-text">¿Seguro que quieres borrar “${escapeHtml(product.name || 'Producto sin nombre')}”? Si tiene variaciones de prueba, se borrarán primero. Si solo quieres quitarlo de la tienda, usa Ocultar.</p>
                  <div class="inline-floating-actions">
                    <button class="mini-btn js-product-delete-cancel" type="button">Cancelar</button>
                    <button class="mini-btn danger js-product-delete-confirm" type="button">Sí, borrar</button>
                  </div>
                </div>
              ` : ''}
              ${pendingSoldoutProductId === product.id ? `
                <div class="inline-floating-card danger product-delete-confirm">
                  <p class="inline-floating-title">Marcar agotado</p>
                  <p class="inline-floating-text">¿Seguro que quieres marcar “${escapeHtml(product.name || 'Producto sin nombre')}” como agotado? Esto pondrá el stock en 0. El producto puede seguir visible, pero no se podrá pedir salvo que tenga preorder activo.</p>
                  <div class="inline-floating-actions">
                    <button class="mini-btn js-product-soldout-cancel" type="button">Cancelar</button>
                    <button class="mini-btn danger js-product-soldout-confirm" type="button">Sí, marcar agotado</button>
                  </div>
                </div>
              ` : ''}
            </article>
          `;
        }).join('');
        renderProductPagination(filtered.length, startIndex + 1, Math.min(startIndex + visibleProducts.length, filtered.length), totalPages);
      }
      async function loadProducts({ openFromUrl = false } = {}) {
        if (refreshBtn) refreshBtn.disabled = true;
        productsList.innerHTML = '<div class="empty-state">Cargando productos...</div>';
        try {
          const [categoryRecords, subcategoryRecords, productRecords] = await Promise.all([
            loadAllRecords('categories', withStoreFilter('sort=order,name')),
            loadAllRecords('subcategories', withStoreFilter('sort=order,name')),
            loadAllRecords('products', withStoreFilter('sort=name')),
          ]);
          categories = categoryRecords;
          subcategories = subcategoryRecords;
          products = productRecords;
          renderProductSelectOptions();
          renderFilters();
          syncFiltersFromUrl();
          renderProducts();
          if (openFromUrl) openEditorFromUrl();
        } catch (error) {
          console.error(error);
          productsList.innerHTML = '<div class="empty-state">No se pudieron cargar los productos. Revisa tu sesión admin.</div>';
        } finally {
          if (refreshBtn) refreshBtn.disabled = false;
        }
      }
      logoutBtn?.addEventListener('click', () => {
        clearAdminToken();
        window.location.assign('/login');
      });
      refreshBtn?.addEventListener('click', loadProducts);
      relatedProductsOpenBtn?.addEventListener('click', openRelatedProductsModal);
      relatedProductsCloseBtn?.addEventListener('click', closeRelatedProductsModal);
      relatedProductsCancelBtn?.addEventListener('click', closeRelatedProductsModal);
      relatedProductsApplyBtn?.addEventListener('click', applyRelatedProductsModal);
      relatedProductsSearchInput?.addEventListener('input', renderRelatedProductsModal);
      relatedProductsModal?.addEventListener('click', (event) => {
        if (event.target === relatedProductsModal) closeRelatedProductsModal();
      });
      searchInput?.addEventListener('input', () => {
        resetProductPage();
        renderProducts();
      });
      categoryFilter?.addEventListener('change', () => {
        updateSubcategoryOptions();
        subcategoryFilter.value = '';
        resetProductPage();
        renderProducts();
      });
      subcategoryFilter?.addEventListener('change', () => {
        resetProductPage();
        renderProducts();
      });
      statusFilter?.addEventListener('change', () => {
        resetProductPage();
        renderProducts();
      });
      stockFilter?.addEventListener('change', () => {
        resetProductPage();
        renderProducts();
      });
      productsPagination?.addEventListener('click', (event) => {
        const button = event.target.closest('.page-btn');
        if (!button || button.disabled) return;
        const page = button.dataset.page;
        const filtered = getFilteredProducts();
        const totalPages = Math.max(1, Math.ceil(filtered.length / PRODUCT_PAGE_SIZE));
        if (page === 'prev') currentProductPage -= 1;
        else if (page === 'next') currentProductPage += 1;
        else currentProductPage = Number(page || 1);
        currentProductPage = Math.min(Math.max(1, currentProductPage), totalPages);
        renderProducts();
      });
      newProductBtn?.addEventListener('click', openNewProductEditor);
      editorCloseBtn?.addEventListener('click', closeProductEditor);
      productCancelBtn?.addEventListener('click', closeProductEditor);
      editorSideSaveBtn?.addEventListener('click', () => productSaveBtn?.click());
      editorSideCancelBtn?.addEventListener('click', closeProductEditor);
      editorSideBackBtn?.addEventListener('click', closeProductEditor);
      productNameInput?.addEventListener('input', () => {
        productSlugInput.value = slugify(productNameInput.value);
        updateProductFormState();
      });
      productPriceInput?.addEventListener('input', () => {
        if (!productIsOfferInput?.checked) lockedRegularPriceUsd = readRegularPriceInput();
        updateProductFormState();
      });
      productIsOfferInput?.addEventListener('change', () => {
        syncLockedRegularPrice({ force: productIsOfferInput.checked });
        updateProductFormState({ showMessage: true });
      });
      productOfferPriceInput?.addEventListener('input', () => updateProductFormState());
      productStockInput?.addEventListener('input', () => updateProductFormState());
      productTrackStockInput?.addEventListener('change', () => updateProductFormState({ showMessage: true }));
      productActiveInput?.addEventListener('change', updateEditorPreview);
      productVariationViewInput?.addEventListener('change', () => updateProductFormState());
      productHasVariationsInput?.addEventListener('change', () => {
        updateProductFormState({ showMessage: true });
        if (productHasVariationsInput.checked && productIdInput.value) {
          setFormAlert('Este producto usará variaciones. El stock padre se calculará con la suma de las variaciones.', 'info');
        }
      });
      productCategoryInput?.addEventListener('change', () => {
        setFormAlert('');
        if (productCategoryInput.value === CREATE_CATEGORY_VALUE) {
          productCategoryInput.value = '';
          renderProductSubcategoryOptions('');
          openQuickCategoryPanel();
          return;
        }
        resetQuickCreatePanels();
        renderProductSubcategoryOptions('');
      });
      productSubcategoryInput?.addEventListener('change', () => {
        setFormAlert('');
        if (productSubcategoryInput.value === CREATE_SUBCATEGORY_VALUE) {
          productSubcategoryInput.value = '';
          openQuickSubcategoryPanel();
          return;
        }
        quickSubcategoryPanel?.classList.add('hidden');
      });
      quickCategoryCancel?.addEventListener('click', closeQuickCreatePanelsAndRestoreSelects);
      quickSubcategoryCancel?.addEventListener('click', closeQuickCreatePanelsAndRestoreSelects);
      quickCategoryX?.addEventListener('click', closeQuickCreatePanelsAndRestoreSelects);
      quickSubcategoryX?.addEventListener('click', closeQuickCreatePanelsAndRestoreSelects);
      quickCategorySave?.addEventListener('click', createQuickCategory);
      quickSubcategorySave?.addEventListener('click', createQuickSubcategory);
      quickCategoryName?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          createQuickCategory();
        }
      });
      quickSubcategoryName?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          createQuickSubcategory();
        }
      });
      productExtraAddBtn?.addEventListener('click', (event) => {
        event.preventDefault();
        openExtraInfoEditor(-1);
      });
      productExtraCloseBtn?.addEventListener('click', closeExtraInfoEditor);
      productExtraCancelBtn?.addEventListener('click', closeExtraInfoEditor);
      productExtraSaveBtn?.addEventListener('click', (event) => {
        event.preventDefault();
        saveExtraInfoEditor();
      });
      productExtraEditor?.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        const tagName = String(event.target?.tagName || '').toLowerCase();
        if (tagName === 'textarea') return;
        event.preventDefault();
        saveExtraInfoEditor();
      });
      document.addEventListener('click', (event) => {
        if (!document.body.classList.contains('quick-modal-open')) return;
        const openPanel = getOpenQuickCreatePanel();
        if (!openPanel) return;
        const clickedInsideModal = openPanel.contains(event.target);
        const clickedCreateSelect = event.target === productCategoryInput || event.target === productSubcategoryInput;
        if (!clickedInsideModal && !clickedCreateSelect) closeQuickCreatePanelsAndRestoreSelects();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !relatedProductsModal?.classList.contains('hidden')) {
          closeRelatedProductsModal();
          return;
        }
        if (event.key === 'Escape' && document.body.classList.contains('quick-modal-open')) {
          closeQuickCreatePanelsAndRestoreSelects();
        }
      });
      variationRefreshBtn?.addEventListener('click', async () => {
        const currentProductId = productIdInput.value;
        if (!currentProductId) return;
        await loadProductVariations(currentProductId);
        setVariationAlert('Variaciones actualizadas.', 'success');
      });
      variationNewBtn?.addEventListener('click', openNewVariationEditor);
      variationCancelBtn?.addEventListener('click', resetVariationEditor);
      variationDeleteBtn?.addEventListener('click', async () => {
        const variationId = variationIdInput.value;
        if (!variationId) return;
        const variation = productVariations.find((item) => item.id === variationId);
        const label = `${variation?.variation_type || 'Variación'}: ${variation?.value || 'Sin valor'}`;
        const confirmed = window.confirm(`¿Seguro que quieres borrar la variación "${label}"?\n\nEsta acción no se puede deshacer.`);
        if (!confirmed) return;
        variationDeleteBtn.disabled = true;
        try {
          await apiRequest(`/api/collections/product_variations/records/${variationId}`, { method: 'DELETE' });
          resetVariationEditor();
          await loadProductVariations(productIdInput.value);
          await syncProductVariationFlag();
          setVariationAlert('Variación borrada correctamente.', 'success');
        } catch (error) {
          setVariationAlert(error.message || 'No se pudo borrar la variación. Revisa si ya fue usada en una orden.', 'error');
        } finally {
          variationDeleteBtn.disabled = false;
        }
      });
      variationSaveBtn?.addEventListener('click', saveVariation);
      [variationTypeInput, variationValueInput, variationPriceInput, variationCostInput, variationStockInput, variationRefInput].forEach((input) => {
        input?.addEventListener('input', updateVariationFormState);
      });
      [variationActiveInput, variationAllowPreorderInput].forEach((input) => {
        input?.addEventListener('change', updateVariationFormState);
      });
      variationImageInput?.addEventListener('change', () => {
        const file = variationImageInput.files?.[0] || null;
        if (variationPreviewObjectUrl) URL.revokeObjectURL(variationPreviewObjectUrl);
        variationPreviewObjectUrl = '';
        if (file) {
          if (!file.type.startsWith('image/')) {
            setVariationAlert('Solo puedes subir imagenes.', 'error');
            variationImageInput.value = '';
          } else {
            variationPreviewObjectUrl = URL.createObjectURL(file);
          }
        }
        renderVariationImageSlot(currentVariationImageUrl);
        updateVariationFormState();
      });
      variationEditor?.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        const tagName = String(event.target?.tagName || '').toLowerCase();
        if (tagName === 'textarea') return;
        event.preventDefault();
        saveVariation();
      });
      variationsList?.addEventListener('click', async (event) => {
        const row = event.target.closest('.variation-row');
        const variationId = row?.dataset?.variationId;
        if (!variationId) return;
        const editBtn = event.target.closest('.js-variation-edit');
        const upBtn = event.target.closest('.js-variation-up');
        const downBtn = event.target.closest('.js-variation-down');
        if (editBtn) {
          openVariationEditor(variationId);
          return;
        }
        if (upBtn || downBtn) {
          const button = upBtn || downBtn;
          button.disabled = true;
          try {
            await moveVariation(variationId, upBtn ? 'up' : 'down');
          } catch (error) {
            setVariationAlert(error.message || 'No se pudo cambiar el orden de la variación.', 'error');
          } finally {
            button.disabled = false;
          }
        }
      });
      productSaveBtn?.addEventListener('click', async (event) => {
        event.preventDefault();
        await saveProduct();
      });
      productForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        await saveProduct();
      });
      productForm?.addEventListener('input', (event) => {
        if (event.target?.type === 'file') return;
        updateProductFormState();
      });
      productForm?.addEventListener('change', (event) => {
        if (event.target?.type === 'file') return;
        updateProductFormState();
      });
      postSaveVariationYesBtn?.addEventListener('click', confirmPostSaveVariationChoice);
      postSaveVariationNoBtn?.addEventListener('click', declinePostSaveVariationChoice);
      productsList?.addEventListener('click', async (event) => {
        const row = event.target.closest('.product-row');
        const productId = row?.dataset?.productId;
        if (!productId) return;
        const editBtn = event.target.closest('.js-product-edit');
        const openClick = event.target.closest('.js-product-open');
        const toggleBtn = event.target.closest('.js-product-toggle');
        const actionsTrigger = event.target.closest('.js-actions-trigger');
        const soldoutBtn = event.target.closest('.js-product-soldout');
        const soldoutConfirmBtn = event.target.closest('.js-product-soldout-confirm');
        const soldoutCancelBtn = event.target.closest('.js-product-soldout-cancel');
        const deleteBtn = event.target.closest('.js-product-delete');
        const deleteConfirmBtn = event.target.closest('.js-product-delete-confirm');
        const deleteCancelBtn = event.target.closest('.js-product-delete-cancel');
        if (deleteCancelBtn) {
          pendingDeleteProductId = '';
          renderProducts();
          return;
        }
        if (soldoutCancelBtn) {
          pendingSoldoutProductId = '';
          renderProducts();
          return;
        }
        if (soldoutConfirmBtn) {
          const product = products.find((item) => item.id === productId);
          if (!product) return;
          soldoutConfirmBtn.disabled = true;
          try {
            const formData = new FormData();
            formData.append('stock', '0');
            await apiRequest(`/api/collections/products/records/${productId}`, { method: 'PATCH', body: formData });
            pendingSoldoutProductId = '';
            await loadProducts();
          } catch (error) {
            alert(error.message || 'No se pudo marcar el producto como agotado.');
            soldoutConfirmBtn.disabled = false;
          }
          return;
        }
        if (deleteConfirmBtn) {
          const product = products.find((item) => item.id === productId);
          if (!product) return;
          deleteConfirmBtn.disabled = true;
          try {
            await deleteProductWithVariations(productId);
            pendingDeleteProductId = '';
            if (productIdInput.value === productId) closeProductEditor();
            await loadProducts();
          } catch (error) {
            alert(error.message || 'No se pudo borrar el producto. Revisa reglas delete de products/product_variations o si otra colección todavía tiene una relación requerida.');
            deleteConfirmBtn.disabled = false;
          }
          return;
        }
        if (actionsTrigger) {
          const menu = actionsTrigger.closest('.actions-wrap')?.querySelector('.actions-menu');
          if (!menu) return;
          const willOpen = menu.classList.contains('hidden');
          closeProductActionMenus(menu);
          menu.classList.toggle('hidden', !willOpen);
          actionsTrigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          if (willOpen) requestAnimationFrame(() => positionProductActionsMenu(menu, actionsTrigger));
          return;
        }
        if (toggleBtn) {
          const product = products.find((item) => item.id === productId);
          if (!product) return;
          toggleBtn.disabled = true;
          try {
            const formData = new FormData();
            formData.append('active', product.active ? 'false' : 'true');
            await apiRequest(`/api/collections/products/records/${productId}`, { method: 'PATCH', body: formData });
            await loadProducts();
          } catch (error) {
            alert(error.message || 'No se pudo cambiar la visibilidad del producto.');
          } finally {
            toggleBtn.disabled = false;
          }
          return;
        }
        if (soldoutBtn) {
          const product = products.find((item) => item.id === productId);
          if (!product || soldoutBtn.disabled) return;
          if (!productTracksStock(product)) {
            alert('Este producto no descuenta stock. No necesita marcarse como agotado.');
            return;
          }
          closeProductActionMenus();
          pendingDeleteProductId = '';
          pendingSoldoutProductId = productId;
          renderProducts();
          return;
        }
        if (deleteBtn) {
          closeProductActionMenus();
          pendingSoldoutProductId = '';
          pendingDeleteProductId = productId;
          renderProducts();
          return;
        }
        if (editBtn || openClick) {
          closeProductActionMenus();
          openEditProductEditor(productId);
          return;
        }
      });

      document.addEventListener('click', (event) => {
        if (!event.target.closest('.actions-wrap')) closeProductActionMenus();
      });

      window.addEventListener('scroll', () => closeProductActionMenus(), true);
      window.addEventListener('resize', () => closeProductActionMenus());

      productsList?.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        const openTarget = event.target.closest('.js-product-open');
        if (!openTarget) return;
        const row = event.target.closest('.product-row');
        const productId = row?.dataset?.productId;
        if (!productId) return;
        event.preventDefault();
        openEditProductEditor(productId);
      });

      if (!POCKETBASE_URL) {
        showAdmin();
        productsList.innerHTML = '<div class="empty-state">Falta PUBLIC_POCKETBASE_URL en el archivo .env del frontend.</div>';
      } else if (getAdminToken()) {
        showAdmin();
        loadProducts({ openFromUrl: true });
      } else {
        showAdmin();
        productsList.innerHTML = '<div class="empty-state">No se pudo validar la sesion administrativa.</div>';
      }
    </script>
  </body>
</html>
