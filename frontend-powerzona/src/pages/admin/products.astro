      async function saveProduct() {
        if (isSavingProduct || productSaveBtn.disabled) return;
        const editingId = productIdInput.value;
        const requestedTrackStock = productTracksStock();
        const requestedStock = Math.max(0, Math.floor(Number(productStockInput.value || 0)));
        let formData;
        try {
          if (!requestedTrackStock || (editingId && productHasVariationsInput?.checked)) productStockInput.value = '0';
          formData = await buildProductFormData({ forceHasVariations: editingId ? null : false });
        } catch (error) {
          setFormAlert('No se pudo guardar el producto', 'error');
          updateProductFormState();
          return;
        }
        isSavingProduct = true;
        updateProductFormState();
        setFormAlert(editingId ? 'Guardando cambios...' : 'Creando producto...', 'info');
        try {
          if (editingId) {
            const updatedProduct = await apiRequest(`/api/collections/products/records/${editingId}`, { method: 'PATCH', body: formData });
            const savedProduct = await syncProductImageOrder(updatedProduct);
            await loadProducts();
            const freshProduct = products.find((item) => item.id === editingId) || savedProduct || updatedProduct;
            renderCurrentImages(freshProduct);
            setProductSnapshotFromCurrent();
            setFormAlert('Cambios guardados correctamente', 'success');
          } else {
            let created;

            if (requestedTrackStock) {
              // PZ-PRODUCTS-V33-CREATE-TRACK-STOCK-SAFE-20260602
              // Evita el bloqueo al crear producto nuevo con stock descontable.
              // Creamos primero igual que el flujo que ya funciona manualmente: sin stock descontable.
              const createData = new FormData();
              formData.forEach((value, key) => {
                if (value instanceof File) return;
                createData.append(key, value);
              });
              createData.set(TRACK_STOCK_FIELD, 'false');
              createData.set('stock', '0');
              createData.set('has_variations', 'false');
              createData.set('variation_view', 'buttons');
              await appendProductImageFiles(createData);

              created = await apiRequest('/api/collections/products/records', { method: 'POST', body: createData });

              const stockPatchData = new FormData();
              stockPatchData.set(TRACK_STOCK_FIELD, 'true');
              stockPatchData.set('stock', String(requestedStock));
              stockPatchData.set('has_variations', 'false');
              stockPatchData.set('variation_view', 'buttons');
              await apiRequest(`/api/collections/products/records/${created.id}`, { method: 'PATCH', body: stockPatchData });
            } else {
              created = await apiRequest('/api/collections/products/records', { method: 'POST', body: formData });
            }

            await loadProducts();
            productIdInput.value = created.id;
            const freshCreatedProduct = products.find((item) => item.id === created.id) || created;
            renderCurrentImages(freshCreatedProduct);
            editorTitle.textContent = 'Producto creado';
            editorSubtitle.textContent = `Producto guardado: ${created.name || productNameInput.value.trim()}`;
            productHasVariationsInput.checked = false;
            if (requestedTrackStock) {
              productTrackStockInput.checked = true;
              productStockInput.value = String(requestedStock);
            }
            setProductSnapshotFromCurrent();
            setFormAlert('Producto creado correctamente.', 'success');
            showPostSaveVariationPrompt(created.id);
          }
        } catch (error) {
          setFormAlert('No se pudo guardar el producto', 'error');
        } finally {
          isSavingProduct = false;
          updateProductFormState();
        }
      }


