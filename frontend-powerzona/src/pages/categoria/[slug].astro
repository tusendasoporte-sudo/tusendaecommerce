---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import PublicFooter from '../../components/PublicFooter.astro';
import PublicCategoryActions from '../../components/PublicCategoryActions.astro';
import StoreAnalyticsTracker from '../../components/StoreAnalyticsTracker.astro';
import { getSettings, getCategories, getSubcategories, getProducts, getAutomaticPromotions, getProductAutomaticPromotionText, getProductReviewSummaries } from '../../lib/api';
import { isStoreTemporarilyClosed } from '../../lib/storeAvailability';
import { getCurrentStore, getPublicPath } from '../../lib/stores';

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((category) => ({ params: { slug: category.slug } }));
}

const { slug } = Astro.params;
const currentStore = await getCurrentStore(Astro);
const storeQuery = { storeId: currentStore.id };
const currentPathname = Astro.url.pathname;
const settings = await getSettings(storeQuery);
if (isStoreTemporarilyClosed(settings)) return Astro.redirect(getPublicPath('/', currentStore, currentPathname));
const categories = await getCategories(storeQuery);
const subcategories = await getSubcategories(storeQuery);
const products = await getProducts(storeQuery);
const automaticPromotions = await getAutomaticPromotions(storeQuery);

const category = categories.find((item) => item.slug === slug);
if (!category) return Astro.redirect(getPublicPath('/', currentStore, currentPathname));

const storeName = settings?.store_name || settings?.stored_name || 'PowerZona';
const logoImageUrl = settings?.logoImageUrl || '';
const homePath = getPublicPath('/', currentStore, currentPathname);
const categoryAnchorPath = getPublicPath('/#categorias', currentStore, currentPathname);
const categorySubcategories = subcategories.filter((subcategory) => subcategory.category === category.id);
const directProducts = products.filter((product) => product.category === category.id && !product.subcategory);
const categorySubcategoryIds = new Set(categorySubcategories.map((subcategory) => subcategory.id));
const allCategoryProducts = products.filter((product) => product.category === category.id || categorySubcategoryIds.has(product.subcategory));
const categoryProductCountLabel = `${allCategoryProducts.length} ${allCategoryProducts.length === 1 ? 'producto' : 'productos'}`;
const categorySeoImage =
  category.imageUrl
  || settings?.coverImageUrl
  || settings?.logoImageUrl
  || '/brand/tusenda84-bazzar-logo.webp';
const categorySeoTitle = category.name;
const categorySeoUrl = getPublicPath(`/categoria/${category.slug}`, currentStore, currentPathname);
const showProductRating = settings?.reviews_enabled !== false && settings?.show_product_rating !== false;
const productReviewSummaries = showProductRating
  ? await getProductReviewSummaries(directProducts.map((product) => product.id).filter(Boolean), storeQuery)
  : {};

function productsBySubcategory(subcategoryId: string) {
  return products.filter((product) => product.subcategory === subcategoryId);
}

function subcategoryInitial(name: string) {
  return String(name || 'S').trim()[0]?.toUpperCase() || 'S';
}

function getProductOfferView(product: any) {
  if (product?.has_variations) {
    const price = Number(product.variation_price_min_usd || product.public_price_usd || 0);
    return {
      price,
      regularPrice: price,
      isOffer: false,
      pricePrefix: price > 0 ? 'DESDE:' : '',
    };
  }
  const activePrice = Number(product?.base_price_usd || 0);
  const regularPrice = Number(product?.regular_price_usd || activePrice);
  const isOffer = Boolean(product?.is_offer) && activePrice > 0 && regularPrice > activePrice;
  return {
    price: activePrice,
    regularPrice: isOffer ? regularPrice : activePrice,
    isOffer,
    pricePrefix: '',
  };
}

---

<Layout
  seo={{
    title: categorySeoTitle,
    description: categorySeoTitle,
    image: categorySeoImage,
    canonical: categorySeoUrl,
    type: 'website',
    siteName: storeName,
  }}
>
  <style>
    .category-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
    .brand-link { display: flex; align-items: center; gap: 10px; min-width: 0; color: #111827; }
    .brand-logo { width: 42px; height: 42px; border-radius: 16px; background: #111827; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 1000; overflow: hidden; flex: 0 0 auto; }
    .brand-logo img { width: 100%; height: 100%; object-fit: contain; }
    .brand-name { margin: 0; font-size: 15px; font-weight: 1000; letter-spacing: -.03em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .category-top-actions { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; flex: 0 0 auto; }
    .back-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 16px; padding: 11px 13px; background: #fff; border: 1px solid #e5e7eb; color: #111827; font-size: 13px; font-weight: 1000; box-shadow: 0 10px 24px rgba(15,23,42,.06); }
    .category-copy { display: grid; gap: 12px; margin-bottom: 16px; }
    .category-kicker { margin: 0; color: #16a34a; font-size: 12px; font-weight: 1000; text-transform: uppercase; letter-spacing: .11em; }
    .category-title { margin: 0; font-size: clamp(34px, 8vw, 64px); line-height: .96; font-weight: 1000; letter-spacing: -.065em; color: #111827; }
    .category-description { margin: 0; max-width: 760px; color: #475569; font-size: 15px; line-height: 1.55; font-weight: 800; white-space: pre-line; }
    .category-meta { display: flex; flex-wrap: wrap; gap: 8px; }
    .category-pill { display: inline-flex; border-radius: 999px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 8px 11px; color: #334155; font-size: 12px; font-weight: 950; }
    .category-hero { position: relative; min-height: 260px; aspect-ratio: 16 / 9; border-radius: 34px; overflow: hidden; background: linear-gradient(135deg, #f8fafc, #eef4ff); border: 1px solid rgba(226,232,240,.9); box-shadow: 0 24px 70px rgba(15,23,42,.15); margin-bottom: 24px; }
    .category-hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; object-position: center; opacity: .98; }
    .category-hero-fallback { position: absolute; inset: 0; background: radial-gradient(circle at top left, #334155, #111827); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.45); font-size: 68px; font-weight: 1000; }
    .section-head { margin: 0 0 14px; }
    .section-title { margin: 0; color: #111827; font-size: 22px; font-weight: 1000; letter-spacing: -.04em; }
    .section-subtitle { margin: 3px 0 0; color: #64748b; font-size: 13px; font-weight: 800; }
    .subcategory-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-bottom: 28px; overflow: hidden; }
    .subcategory-card { min-width: 0; display: grid; grid-template-columns: minmax(160px, 42%) minmax(0, 58%); overflow: hidden; border-radius: 18px; border: 1px solid #dbe7f6; background: linear-gradient(100deg, #eaf4ff, #fff); color: #08133f; text-decoration: none; box-shadow: 0 20px 52px rgba(37,99,235,.10); }
    .subcategory-media { position: relative; width: 100%; height: auto; min-height: 0; aspect-ratio: 16 / 9; overflow: hidden; background: #f6f9ff; }
    .subcategory-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; transition: transform .35s ease; }
    .subcategory-card:hover .subcategory-media img { transform: scale(1.04); }
    .subcategory-fallback { position: absolute; inset: 0; display: grid; place-items: center; background: radial-gradient(circle at 50% 34%, #fff 0%, #eaf4ff 52%, #dbeafe 100%); color: #0b63f6; font-size: 54px; font-weight: 1000; }
    .subcategory-copy { min-width: 0; display: flex; flex-direction: column; justify-content: center; gap: 10px; padding: clamp(18px, 3vw, 28px); }
    .subcategory-card strong { display: -webkit-box; color: #08133f; font-size: clamp(20px, 2.2vw, 30px); font-weight: 1000; line-height: 1.08; letter-spacing: 0; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .subcategory-description { display: -webkit-box; margin: 0; color: #33446f; font-size: 13px; line-height: 1.45; font-weight: 780; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .subcategory-count { display: inline-flex; width: max-content; max-width: 100%; border-radius: 999px; border: 1px solid #dbe7f6; background: rgba(255,255,255,.88); color: #33446f; padding: 7px 10px; font-size: 12px; line-height: 1; font-weight: 950; box-shadow: 0 8px 20px rgba(37,99,235,.06); }
    .product-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .empty-box { background: #fff; border: 1px dashed #cbd5e1; border-radius: 24px; padding: 22px; color: #64748b; font-size: 14px; font-weight: 850; text-align: center; }
    @media (min-width: 768px) {
      .product-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 22px; }
    }
    @media (max-width: 640px) {
      .category-hero { border-radius: 28px; min-height: 210px; }
      .back-btn { padding: 10px 11px; }
      .category-top { align-items: flex-start; }
      .category-top-actions { flex-wrap: wrap; }
      .subcategory-grid { grid-template-columns: 1fr; gap: 12px; }
      .subcategory-card { grid-template-columns: 1fr; }
      .subcategory-media { order: 1; aspect-ratio: 16 / 9; }
      .subcategory-copy { order: 2; padding: 16px; }
      .subcategory-card strong { font-size: 20px; }
    }
  </style>

  <div class="category-top">
    <a class="brand-link" href={homePath}>
      <div class="brand-logo">{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : 'PZ'}</div>
      <p class="brand-name">INICIO</p>
    </a>
    <div class="category-top-actions">
      <a class="back-btn" href={categoryAnchorPath}>← Categorías</a>
      <PublicCategoryActions title={category.name} text={`Categoría ${category.name}`} categories={categories} currentCategoryId={category.id} />
    </div>
  </div>

  <div class="category-copy">
    <p class="category-kicker">Categoría</p>
    <h1 class="category-title">{category.name}</h1>
    {category.description && <p class="category-description">{category.description}</p>}
    <div class="category-meta">
      <span class="category-pill">{categoryProductCountLabel}</span>
      {categorySubcategories.length > 0 && <span class="category-pill">{categorySubcategories.length} subcategorías</span>}
    </div>
  </div>

  <section class="category-hero">
    {category.imageUrl ? <img src={category.imageUrl} alt={category.name} /> : <div class="category-hero-fallback">PZ</div>}
  </section>

  {categorySubcategories.length > 0 && (
    <section>
      <div class="section-head">
        <h2 class="section-title">Subcategorías</h2>
      </div>
      <div class="subcategory-grid">
        {categorySubcategories.map((subcategory) => {
          const count = productsBySubcategory(subcategory.id).length;
          return (
            <a href={getPublicPath(`/subcategoria/${subcategory.slug}`, currentStore, currentPathname)} class="subcategory-card" aria-label={`Abrir subcategoría ${subcategory.name}`}>
              <div class="subcategory-media">
                {subcategory.imageUrl ? <img src={subcategory.imageUrl} alt={subcategory.name} loading="lazy" /> : <div class="subcategory-fallback">{subcategoryInitial(subcategory.name)}</div>}
              </div>
              <div class="subcategory-copy">
                <strong>{subcategory.name}</strong>
                {subcategory.description && <p class="subcategory-description">{subcategory.description}</p>}
                <span class="subcategory-count">{count} productos</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {(directProducts.length > 0 || categorySubcategories.length === 0) && (
  <section>
    <div class="section-head">
      <h2 class="section-title">Productos de {category.name}</h2>
    </div>

    {directProducts.length > 0 ? (
      <div class="product-grid">
        {directProducts.map((product) => (
          <a href={getPublicPath(`/producto/${product.slug}`, currentStore, currentPathname)} class="block">
            <ProductCard view="large" title={product.name} price={String(getProductOfferView(product).price)} regularPrice={String(getProductOfferView(product).regularPrice)} isOffer={getProductOfferView(product).isOffer} pricePrefix={getProductOfferView(product).pricePrefix} image={product.imageUrls?.[0] ?? 'https://placehold.co/500x500?text=PowerZona'} stock={product.has_variations ? product.variation_public_stock : product.stock} allowPreorder={product.has_variations ? product.variation_public_allow_preorder : product.allow_preorder} variationAvailable={product.has_variations ? product.variation_public_available : undefined} trackStock={product.track_stock !== false} hasVariations={Boolean(product.has_variations)} onlyUsd={Boolean(product.only_usd)} promoText={getProductAutomaticPromotionText(product, automaticPromotions)} showRating={showProductRating} ratingAverage={productReviewSummaries[product.id]?.average || 0} ratingCount={productReviewSummaries[product.id]?.count || 0} />
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-box">Esta categoría no tiene productos directos visibles. Revisa sus subcategorías.</div>
    )}
  </section>
  )}

  <StoreAnalyticsTracker storeId={currentStore.id} pageType="category" entityType="category" entityId={category.id} />
  <PublicFooter settings={settings} />
</Layout>
