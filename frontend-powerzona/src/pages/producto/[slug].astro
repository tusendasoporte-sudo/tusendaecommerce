---
import Layout from '../../layouts/Layout.astro';
import PublicFooter from '../../components/PublicFooter.astro';
import { getSettings, getProducts, getProductBySlug, getProductVariations } from '../../lib/api';

export async function getStaticPaths() {
	const products = await getProducts();

	return products.map((product) => ({
		params: {
			slug: product.slug,
		},
	}));
}

const { slug } = Astro.params;
const settings = await getSettings();
const product = await getProductBySlug(slug as string);
const variations = product.has_variations ? await getProductVariations(product.id) : [];

const productGalleryImages = product.imageUrls?.length ? product.imageUrls : ['https://placehold.co/800x800?text=PowerZona'];
const mainImage = productGalleryImages[0];
const categoryName = product.expand?.category?.name ?? 'Sin categoría';
const storeName = settings?.store_name || settings?.stored_name || 'PowerZona';
const logoImageUrl = settings?.logoImageUrl || '';
const productBackHref = product.expand?.subcategory?.slug
	? `/subcategoria/${product.expand.subcategory.slug}`
	: product.expand?.category?.slug
		? `/categoria/${product.expand.category.slug}`
		: '/';
const productBackLabel = product.expand?.subcategory?.name
	? `← Volver a ${product.expand.subcategory.name}`
	: product.expand?.category?.name
		? `← Volver a ${product.expand.category.name}`
		: '← Volver al inicio';
const relatedProductIds = Array.isArray(product.related_products)
	? product.related_products.filter(Boolean).slice(0, 4)
	: product.related_products
		? [product.related_products].filter(Boolean).slice(0, 4)
		: [];
const allPublicProducts = relatedProductIds.length ? await getProducts() : [];
const relatedProducts = relatedProductIds
	.map((id: string) => allPublicProducts.find((item: any) => item.id === id))
	.filter((item: any) => item && item.id !== product.id)
	.slice(0, 4);
function getProductCardImage(item: any) {
	return item?.imageUrls?.[0] || 'https://placehold.co/180x180?text=PowerZona';
}
function getProductOfferState(item: any) {
	const activePrice = Number(item?.base_price_usd || 0);
	const regularPrice = Number(item?.regular_price_usd || activePrice || 0);
	const hasOffer = Boolean(item?.is_offer) && activePrice > 0 && regularPrice > activePrice;
	return { activePrice, regularPrice, hasOffer, savings: hasOffer ? regularPrice - activePrice : 0 };
}
function parseExtraInfoValue(value: any) {
	if (!value) return [];
	let current = value;

	// PocketBase puede devolver el campo texto como string JSON. En algunos casos,
	// si el dato se guardó doble-serializado, hay que parsearlo más de una vez.
	for (let index = 0; index < 3 && typeof current === 'string'; index += 1) {
		const cleaned = current.trim();
		if (!cleaned) return [];

		try {
			current = JSON.parse(cleaned);
		} catch (_) {
			// Fallback: permite texto simple tipo "Marca: Spring Valley" por línea.
			return cleaned
				.split('\n')
				.map((line) => {
					const [label, ...rest] = line.split(':');
					return {
						label: String(label || '').trim(),
						value: rest.join(':').trim(),
					};
				})
				.filter((item) => item.label && item.value)
				.slice(0, 3);
		}
	}

	if (current && !Array.isArray(current) && typeof current === 'object') {
		current = current.items || current.data || current.values || [current];
	}

	return Array.isArray(current)
		? current
			.map((item) => ({
				label: String(item?.label || item?.name || item?.title || item?.key || item?.dato || '').trim(),
				value: String(item?.value || item?.description || item?.text || item?.valor || '').trim(),
			}))
			.filter((item) => item.label && item.value)
			.slice(0, 3)
		: [];
}
const extraInfoItems = parseExtraInfoValue(
	product.extra_info ?? product.extraInfo ?? product.additional_info ?? product.product_extra_info ?? []
);
const tracksStock = product.track_stock !== false;
const baseProductPrice = Number(product.base_price_usd || 0);
const regularProductPrice = Number(product.regular_price_usd || baseProductPrice);
const productHasOffer = Boolean(product.is_offer) && baseProductPrice > 0 && regularProductPrice > baseProductPrice;
const effectiveProductPrice = baseProductPrice;
const productSavings = productHasOffer ? regularProductPrice - baseProductPrice : 0;
const hasPublicVariations = variations.length > 0;
const variationView = ['buttons', 'dropdown', 'checkbox'].includes(product.variation_view) ? product.variation_view : 'buttons';
const firstVariation = variations.find((variation) => !tracksStock || Number(variation.stock || 0) > 0 || Boolean(variation.allow_preorder)) ?? variations[0] ?? null;
const initialPrice = hasPublicVariations
	? Number(firstVariation?.price_usd || effectiveProductPrice || 0)
	: Number(effectiveProductPrice || 0);
const initialCost = hasPublicVariations
	? Number(firstVariation?.cost_usd || 0)
	: Number(product.cost_usd || 0);
const initialStock = hasPublicVariations
	? Number(firstVariation?.stock || 0)
	: Number(product.stock || 0);
const initialAllowPreorder = hasPublicVariations
	? Boolean(firstVariation?.allow_preorder)
	: Boolean(product.allow_preorder);
const initialIsOutOfStock = tracksStock && initialStock <= 0;
const initialCanPreorder = tracksStock && initialIsOutOfStock && initialAllowPreorder;
const initialButtonDisabled = initialIsOutOfStock && !initialCanPreorder;
const initialButtonText = initialIsOutOfStock && !initialCanPreorder
	? 'Agotado'
	: `${initialCanPreorder ? 'Preordenar' : 'Añadir'} 1 al pedido · ${initialPrice.toFixed(2)} USD`;
const initialStockText = !tracksStock
	? 'Disponible'
	: initialCanPreorder
		? 'Disponible por preorder'
		: initialStock > 0
			? `${initialStock} disponibles`
			: 'Agotado';
const initialStockClass = !tracksStock
	? 'text-green-700'
	: initialCanPreorder
		? 'text-blue-700'
		: initialIsOutOfStock
			? 'text-red-600'
			: 'text-gray-800';
const variationItems = variations.map((variation) => {
	const variationImage = variation.imageUrls?.[0] ?? mainImage;
	const variationPrice = Number(variation.price_usd || effectiveProductPrice || 0);
	const variationCost = Number(variation.cost_usd || 0);
	const variationStock = Number(variation.stock || 0);
	const variationPreorder = Boolean(variation.allow_preorder);
	const variationOutOfStock = tracksStock && variationStock <= 0;
	const variationCanPreorder = variationOutOfStock && variationPreorder;
	const variationDisabled = variationOutOfStock && !variationCanPreorder;
	const variationLabel = [variation.variation_type, variation.value].filter(Boolean).join(': ') || 'Variación';
	const stockLabel = !tracksStock ? 'Disponible' : variationCanPreorder ? 'Preorder' : variationDisabled ? 'Agotada' : `${variationStock} disponibles`;
	const stockClass = !tracksStock ? 'text-green-700' : variationCanPreorder ? 'text-blue-700' : variationDisabled ? 'text-red-600' : 'text-gray-500';
	return {
		...variation,
		variationImage,
		variationPrice,
		variationCost,
		variationStock,
		variationOutOfStock,
		variationCanPreorder,
		variationDisabled,
		variationLabel,
		stockLabel,
		stockClass,
	};
});

