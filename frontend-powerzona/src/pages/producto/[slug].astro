			width: 1px;
			height: 1px;
			opacity: 0;
			pointer-events: none;
		}

		.product-reviews-list {
			display: grid;
			gap: 14px;
		}

		.product-review-card {
			display: grid;
			grid-template-columns: 290px minmax(0, 1fr) auto;
			gap: 26px;
			align-items: center;
			border: 1px solid #dbe7f6;
			border-radius: 18px;
			background: rgba(255,255,255,.96);
			padding: 22px 24px;
			box-shadow: 0 16px 38px rgba(37,99,235,.07);
		}

		.product-review-person {
			min-width: 0;
			display: grid;
			grid-template-columns: 58px minmax(0, 1fr);
			align-items: center;
			gap: 14px;
			padding-right: 24px;
			border-right: 1px solid #e6eef8;
		}

		.product-review-avatar {
			width: 58px;
			height: 58px;
			display: grid;
			place-items: center;
			border-radius: 999px;
			background: linear-gradient(135deg, #eaf4ff, #dbeafe);
			color: #0b63f6;
			font-size: 18px;
			font-weight: 1000;
		}

		.product-review-name {
			margin: 0;
			color: #08133f;
			font-size: 16px;
			line-height: 1.15;
			font-weight: 1000;
			overflow-wrap: anywhere;
		}

		.product-review-date {
			margin: 6px 0 0;
			color: #52648f;
			font-size: 13px;
			font-weight: 800;
		}

		.product-review-body {
			min-width: 0;
			display: grid;
			gap: 10px;
		}

		.product-review-stars {
			color: #f5a400;
			font-size: 22px;
			letter-spacing: 2px;
			line-height: 1;
		}

		.product-review-comment {
			margin: 0;
			color: #33446f;
			font-size: 15px;
			line-height: 1.55;
			font-weight: 800;
			white-space: pre-line;
			overflow-wrap: anywhere;
		}

		.product-review-badge {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 38px;
			height: 38px;
			border-radius: 999px;
			border: 1px solid #bbf7d0;
			background: #f0fdf4;
			color: #16a34a;
			box-shadow: 0 10px 24px rgba(22,163,74,.08);
		}

		.product-review-badge svg {
			width: 19px;
			height: 19px;
		}

		.product-reviews-pagination {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 14px;
			margin-top: 18px;
			color: #52648f;
			font-size: 13px;
			font-weight: 850;
		}

		.product-reviews-pages {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 8px;
		}

		.product-reviews-page-btn {
			min-width: 42px;
			height: 42px;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			border-radius: 10px;
			border: 1px solid #bfd3ef;
			background: rgba(255,255,255,.92);
			color: #0b63f6;
			font-size: 14px;
			font-weight: 1000;
			cursor: pointer;
		}

		.product-reviews-page-btn.active {
			background: #0b63f6;
			border-color: #0b63f6;
			color: #fff;
			box-shadow: 0 12px 26px rgba(11,99,246,.22);
		}

		.product-reviews-page-btn:disabled {
			opacity: .45;
			cursor: not-allowed;
		}

		@media (max-width: 860px) {
			.product-reviews-head {
				grid-template-columns: 52px minmax(0, 1fr);
				gap: 14px;
			}

			.product-reviews-icon {
				width: 52px;
				height: 52px;
				border-radius: 17px;
			}

			.product-review-form-grid {
				grid-template-columns: 1fr;
			}

			.product-review-card {
				grid-template-columns: 1fr;
				gap: 14px;
			}

			.product-review-person {
				border-right: 0;
				padding-right: 0;
			}

			.product-review-badge {
				justify-self: start;
			}

			.product-reviews-pagination {
				align-items: flex-start;
				flex-direction: column;
			}
		}
		.product-mobile-cta {
			position: fixed;
			left: 50%;
			right: auto;
			bottom: 0;
			z-index: 35;
			display: flex;
			width: min(720px, calc(100vw - 32px));
			padding: 12px 0 calc(16px + env(safe-area-inset-bottom));
			background: linear-gradient(180deg, rgba(248,250,252,0), rgba(248,250,252,.92) 34%, rgba(248,250,252,.98));
			pointer-events: none;
			opacity: 0;
			transform: translate(-50%, 18px);
			transition: opacity .22s ease, transform .22s ease;
		}
		.product-mobile-cta.is-visible {
			opacity: 1;
			transform: translate(-50%, 0);
		}
		.product-mobile-cta button {
			width: 100%;
			min-height: 60px;
			border: 0;
			border-radius: 999px;
			background: #0b63f6;
			color: #fff;
			font-size: 16px;
			font-weight: 1000;
			line-height: 1.2;
			padding: 16px 22px;
			box-shadow: 0 18px 38px rgba(11,99,246,.24), 0 3px 10px rgba(15,23,42,.10);
			pointer-events: auto;
		}
		.product-mobile-cta button:hover { background: #0757dc; }
		.product-mobile-cta button:active { transform: translateY(1px); }
		.product-mobile-cta button.is-disabled {
			background: #e5e7eb;
			color: #6b7280;
			box-shadow: 0 12px 28px rgba(15,23,42,.12);
			cursor: not-allowed;
		}
		@media (max-width: 780px) { .related-grid { grid-template-columns: 1fr; } }
		@media (max-width: 767px) {
			.product-mobile-cta {
				left: 0;
				right: 0;
				width: auto;
				padding: 12px 16px calc(14px + env(safe-area-inset-bottom));
				transform: translateY(18px);
			}
			.product-mobile-cta.is-visible {
				transform: translateY(0);
			}
			.product-mobile-cta button {
				min-height: 58px;
				font-size: 15px;
				padding: 15px 18px;
			}
		}
		@media (prefers-reduced-motion: reduce) {
			.product-mobile-cta,
			.product-mobile-cta button {
				transition: none;
			}
		}
		@media (max-width: 640px) { .product-public-top { align-items: flex-start; flex-wrap: wrap; padding: 0 2px; } .product-public-brand { flex: 1 1 calc(100% - 96px); max-width: calc(100% - 96px); } .product-public-actions { flex: 1 0 100%; width: 100%; justify-content: flex-end; } .product-public-name { max-width: calc(100vw - 168px); } .product-back-btn { order: 1; min-height: 40px; max-width: calc(100% - 104px); margin-right: auto; padding: 10px 11px; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; } .product-top-icon-btn { order: 2; width: 42px; height: 42px; } .product-share-status { right: 2px; } .related-card { grid-template-columns: 82px minmax(0, 1fr); border-radius: 22px; } .related-image { width: 82px; height: 82px; } .related-section-title { font-size: 22px; } }
	</style>

	<div class="product-public-top">
		<a class="product-public-brand" href={homePath} aria-label={`Ir al inicio de ${storeName}`}>
			<div class="product-public-logo">{logoImageUrl ? <img src={logoImageUrl} alt={storeName} /> : 'PZ'}</div>
			<p class="product-public-name">INICIO</p>
		</a>
		<div class="product-public-actions">
			<a href={productBackHref} class="product-back-btn">{productBackLabel}</a>
			<a href={searchPath} class="product-top-icon-btn" aria-label="Buscar productos" title="Buscar productos">
				<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M10.8 18.1a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					<path d="m16 16 4.2 4.2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</a>
			<button
				type="button"
				id="product-share-btn"
				class="product-top-icon-btn"
				aria-label="Compartir producto"
				title="Compartir producto"
				data-share-title={productShareTitle}
				data-share-text={productShareText}
				data-share-url={productShareUrl}
			>
				<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M8.5 12.5 15.5 16.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					<path d="M15.5 7.5 8.5 11.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					<path d="M6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke-width="2"></path>
					<path d="M18 9.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke-width="2"></path>
					<path d="M18 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke-width="2"></path>
				</svg>
			</button>
		</div>
		<p id="product-share-status" class="product-share-status" role="status" aria-live="polite" hidden>Enlace copiado</p>
	</div>

	<section class="product-detail-stack grid grid-cols-1 gap-8">
		<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
			<div id="product-gallery" class="relative bg-white">
				<img
					id="product-main-image"
					src={mainImage}
					alt={product.name}
					class="w-full aspect-square object-contain bg-white p-2 sm:p-4"
				/>

				{productGalleryImages.length > 1 && (
					<>
						<button
							type="button"
							id="gallery-prev-btn"
							class="absolute left-3 top-1/2 -translate-y-1/2 inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 bg-white/95 text-xl font-black text-gray-900 shadow-lg backdrop-blur transition hover:scale-105 hover:bg-white"
							aria-label="Foto anterior"
						>
							‹
						</button>

						<button
							type="button"
							id="gallery-next-btn"
							class="absolute right-3 top-1/2 -translate-y-1/2 inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 bg-white/95 text-xl font-black text-gray-900 shadow-lg backdrop-blur transition hover:scale-105 hover:bg-white"
							aria-label="Foto siguiente"
						>
							›
						</button>
					</>
				)}
			</div>

			{productGalleryImages.length > 1 && (
				<div id="gallery-dots" class="flex items-center justify-center gap-2 px-4 pb-5 pt-1">
					{productGalleryImages.map((imageUrl, index) => (
						<button
							type="button"
							data-gallery-dot
							data-index={index}
							aria-label={`Ver foto ${index + 1}`}
							class={`h-2.5 rounded-full transition-all ${index === 0 ? 'w-5 bg-gray-900' : 'w-2.5 bg-gray-300 hover:bg-gray-400'}`}
						></button>
					))}
				</div>
			)}

			<script type="application/json" id="product-gallery-data" set:html={JSON.stringify(productGalleryImages)}></script>
		</div>

		<div class="product-detail-info">
			<p class="product-detail-category text-sm font-semibold text-blue-600 mb-2">
				{categoryName}
			</p>

			<h1 class="product-detail-title text-3xl font-extrabold text-gray-900 mb-4">
				{product.name}
			</h1>

			<div class="product-detail-price flex flex-wrap items-center gap-3 mb-5">
				{productHasOffer && !hasPublicVariations && (
					<span class="product-offer-badge">Oferta</span>
				)}

				<div class="flex flex-col gap-1">
					{productHasOffer && !hasPublicVariations && (
						<span id="product-regular-price" class="product-regular-price" data-pz-price-usd={regularProductPrice} data-pz-only-usd={product.only_usd ? 'true' : 'false'}>
							{`$${regularProductPrice.toFixed(2)} USD`}
						</span>
					)}
					{hasPublicVariations && (
						<span id="product-regular-price" class={`product-regular-price ${firstVariationHasOffer ? '' : 'hidden'}`} data-pz-price-usd={firstVariationRegularPrice} data-pz-only-usd={product.only_usd ? 'true' : 'false'}>
							{`$${firstVariationRegularPrice.toFixed(2)} USD`}
						</span>
					)}
					<span id="product-price" class={`text-3xl font-black ${productHasOffer && !hasPublicVariations ? 'text-red-600' : 'text-gray-900'}`} data-pz-price-usd={initialPrice} data-pz-only-usd={product.only_usd ? 'true' : 'false'}>
						{hasPublicVariations && !firstVariation ? 'Agotado' : `$${initialPrice.toFixed(2)} USD`}
					</span>
					{productHasOffer && !hasPublicVariations && (
						<span id="product-save-text" class="product-save-text">
							{`Ahorras $${productSavings.toFixed(2)} USD`}
						</span>
					)}
					{hasPublicVariations && (
						<span id="product-save-text" class={`product-save-text ${firstVariationHasOffer ? '' : 'hidden'}`}>
							{`Ahorras $${Math.max(0, firstVariationRegularPrice - firstVariationPrice).toFixed(2)} USD`}
						</span>
					)}
				</div>

				{product.only_usd && (
					<span class="text-xs font-bold bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full">
						Solo USD
					</span>
				)}

				{automaticPromotionText && (
					<span class="text-xs font-black bg-green-50 text-green-700 border border-green-100 px-3 py-2 rounded-2xl">
						Promo · {automaticPromotionText}
					</span>
				)}
			</div>

			{showProductRating && productReviewSummary.count > 0 && (
				<a class="product-rating-link" href="#opiniones-producto" aria-label={`${productReviewSummary.average.toFixed(1)} de 5 con ${reviewCountLabel(productReviewSummary.count)}`}>
					<span>{productReviewSummary.average.toFixed(1)}</span>
					<span class="product-rating-stars" aria-hidden="true">{reviewStars(productReviewSummary.roundedAverage)}</span>
					<span>({reviewCountLabel(productReviewSummary.count)})</span>
				</a>
			)}
			{showProductRating && productReviewSummary.count === 0 && productReviewsEnabled && (
				<a class="product-rating-link" href="#opiniones-producto">Sé el primero en dejar una reseña</a>
			)}

			{hasPublicVariations && (
				<div class="product-detail-variations bg-white rounded-2xl border border-gray-100 p-5 mb-6">
					<div class="flex items-center justify-between gap-3 mb-3">
						<div>
							<h2 class="font-bold text-gray-900">Selecciona una variacion</h2>
							<p class="text-xs text-gray-500 mt-1">El precio, la foto y el stock cambian según la opción.</p>
						</div>
						<span class="text-xs font-black bg-blue-50 text-blue-700 px-3 py-1 rounded-full">
							{variations.length} opciones
						</span>
					</div>

					{variationView === 'dropdown' && (
						<div class="space-y-2">
							<label for="variation-dropdown" class="text-xs font-black text-gray-500 uppercase tracking-wide">Opción disponible</label>
							<select
								id="variation-dropdown"
								class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm font-bold text-gray-900 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
							>
                                <option value="">Selecciona una variacion</option>
								{variationItems.map((variation) => (
										<option value={variation.id} disabled={variation.variationDisabled} selected={firstVariation?.id === variation.id}>
											{variation.variationLabel} · {`$${variation.variationPrice.toFixed(2)} USD`}{tracksStock ? ` · ${variation.stockLabel}` : ''}
										</option>
									))}
							</select>
						</div>
					)}

					{variationView === 'checkbox' && (
						<div id="variation-checkbox-list" class="grid grid-cols-1 gap-3">
							{variationItems.map((variation) => (
									<label
										data-variation-check-card
										data-variation-id={variation.id}
										class={`flex items-center justify-between gap-3 rounded-2xl border p-3 transition border-gray-100 bg-white ${variation.variationDisabled ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer hover:border-blue-200'}`}
									>
										<span class="flex items-center gap-3 min-w-0">
											<input
												type="radio"
												name="variation_fixed_option"
												value={variation.id}
												disabled={variation.variationDisabled}
												checked={firstVariation?.id === variation.id}
												data-variation-radio
												class="h-4 w-4 accent-blue-600"
											/>
											<img src={variation.variationImage} alt={variation.variationLabel} class="w-11 h-11 rounded-xl object-contain bg-white border border-gray-100" />
											<span class="min-w-0">
												<span class="block font-black text-gray-900 text-sm truncate">{variation.variationLabel}</span>
												<span class={`block text-xs font-bold ${variation.stockClass}`}>
													{variation.stockLabel}
												</span>
											</span>
										</span>
										<span class="text-blue-600 font-extrabold text-sm whitespace-nowrap" data-pz-price-usd={variation.variationPrice} data-pz-only-usd={product.only_usd ? 'true' : 'false'}>{`$${variation.variationPrice.toFixed(2)} USD`}</span>
									</label>
								))}
						</div>
					)}

					<div id="variation-options" class={`${variationView === 'buttons' ? 'grid grid-cols-1 sm:grid-cols-2 gap-3' : 'hidden'}`}>
						{variationItems.map((variation) => (
								<button
									type="button"
									data-variation-option
									data-id={variation.id}
									data-label={variation.variationLabel}
									data-price={variation.variationPrice}
									data-regular-price={variation.variationRegularPrice}
									data-is-offer={variation.variationIsOffer ? 'true' : 'false'}
									data-savings-usd={variation.variationSavings}
									data-cost={variation.variationCost}
									data-stock={variation.variationStock}
									data-image={variation.variationImage}
									data-ref={variation.internal_ref || ''}
									data-preorder={variation.variationCanPreorder ? 'true' : 'false'}
									data-out-of-stock={variation.variationOutOfStock ? 'true' : 'false'}
									disabled={variation.variationDisabled}
									class={`variation-option text-left rounded-2xl border p-3 transition border-gray-100 bg-white hover:border-blue-200 ${variation.variationDisabled ? 'opacity-50 cursor-not-allowed' : ''}`}
								>
									<div class="flex items-center gap-3">
										<img src={variation.variationImage} alt={variation.variationLabel} class="w-12 h-12 rounded-xl object-contain bg-white border border-gray-100" />
										<div class="min-w-0">
											<p class="font-black text-gray-900 text-sm truncate">{variation.variationLabel}</p>
											<p class="text-blue-600 font-extrabold text-sm" data-pz-price-usd={variation.variationPrice} data-pz-only-usd={product.only_usd ? 'true' : 'false'}>{`$${variation.variationPrice.toFixed(2)} USD`}</p>
											<p class={`text-xs font-bold ${variation.stockClass}`}>
												{variation.stockLabel}
											</p>
										</div>
									</div>
								</button>
							))}
					</div>
                    <p id="selected-variation-summary" class="mt-3 text-sm font-black text-blue-700">{firstVariation ? `${product.name} — ${[firstVariation.variation_type, firstVariation.value].filter(Boolean).join(': ') || 'variacion'}` : 'No hay variaciones disponibles para comprar.'}</p>
				</div>
			)}

			<div class="product-detail-meta grid grid-cols-2 gap-3 mb-6">
				<div class="bg-white rounded-2xl border border-gray-100 p-4">
					<p class="text-xs text-gray-500">Stock</p>
					<p id="product-stock-text" class={`font-bold ${initialStockClass}`}>
						{initialStockText}
					</p>
				</div>

				<div class="bg-white rounded-2xl border border-gray-100 p-4">
					<p class="text-xs text-gray-500">Entrega</p>
					<p class="font-bold text-gray-800">
						{product.delivery_mode === 'both' && 'Envío o recogida'}
						{product.delivery_mode === 'delivery' && 'Solo envío'}
						{product.delivery_mode === 'pickup' && 'Solo recogida'}
					</p>
				</div>
			</div>


			{extraInfoItems.length > 0 && (
				<section class="product-detail-extra relative overflow-hidden rounded-[2rem] border border-slate-100 bg-white/95 p-5 mb-6 shadow-[0_18px_45px_rgba(15,23,42,0.08)]">
					<div class="absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>

					<h2 class="mb-4 text-xl font-semibold tracking-tight text-slate-950">Información adicional</h2>

					<div class="rounded-[1.6rem] border border-slate-100 bg-slate-50/70 p-2 shadow-inner shadow-slate-200/40">
						{extraInfoItems.map((item) => (
							<div class="flex items-center justify-between gap-4 rounded-2xl bg-white px-4 py-3 text-sm shadow-sm ring-1 ring-slate-100/80 [&:not(:last-child)]:mb-2">
								<span class="min-w-0 text-slate-500 font-medium tracking-wide">{item.label}</span>
								<span class="min-w-0 text-right text-slate-950 font-semibold">{item.value}</span>
							</div>
						))}
					</div>
				</section>
			)}

			<div class="product-detail-description bg-white rounded-2xl border border-gray-100 p-5 mb-6">
				<h2 class="font-bold text-gray-900 mb-3">
					Descripción
				</h2>

				<div class="product-description-text">{product.description || 'Sin descripción disponible.'}</div>
			</div>

			<div id="product-purchase-actions" class="product-detail-purchase">
			<div class="bg-white rounded-3xl border border-gray-100 p-5 mb-4">
				<p class="text-xs font-black text-gray-500 uppercase tracking-wide text-center mb-4">Cantidad</p>
				<div class="flex items-center justify-center gap-6">
					<button
						type="button"
						id="quantity-minus-btn"
						class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-slate-300 text-3xl font-black leading-none text-white shadow-sm transition hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
						aria-label="Disminuir cantidad"
					>
						−
					</button>

					<span id="quantity-display" class="min-w-10 text-center text-3xl font-black text-slate-900">1</span>

					<button
						type="button"
						id="quantity-plus-btn"
						class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-3xl font-black leading-none text-white shadow-lg shadow-blue-500/20 transition hover:scale-105 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
						aria-label="Aumentar cantidad"
					>
						+
					</button>
				</div>
			</div>

			<button
				id="add-to-cart-btn"
				data-id={product.id}
				data-title={product.name}
				data-price={initialPrice}
				data-cost={initialCost}
				data-regular-price={hasPublicVariations ? firstVariationRegularPrice : regularProductPrice}
				data-is-offer={(hasPublicVariations ? firstVariationHasOffer : productHasOffer) && (!hasPublicVariations || Boolean(firstVariation)) ? 'true' : 'false'}
				data-savings-usd={hasPublicVariations && firstVariationHasOffer ? firstVariationRegularPrice - firstVariationPrice : productHasOffer && !hasPublicVariations ? productSavings : 0}
				data-image={firstVariation?.imageUrls?.[0] ?? mainImage}
				data-category={product.category || ''}
				data-subcategory={product.subcategory || ''}
				data-only-usd={product.only_usd}
				data-delivery-mode={product.delivery_mode}
				data-stock={initialStock}
				data-track-stock={tracksStock ? 'true' : 'false'}
				data-out-of-stock={initialIsOutOfStock ? 'true' : 'false'}
				data-preorder={initialCanPreorder ? 'true' : 'false'}
				data-requires-variation={hasPublicVariations ? 'true' : 'false'}
				data-variation-id={firstVariation?.id || ''}
				data-variation-label={firstVariation ? [firstVariation.variation_type, firstVariation.value].filter(Boolean).join(': ') || 'variacion' : ''}
				data-variation-ref={firstVariation?.internal_ref || ''}
				disabled={initialButtonDisabled}
				class={`w-full font-black py-4 rounded-[2rem] shadow-xl transition ${initialButtonDisabled ? 'bg-gray-200 text-gray-500 cursor-not-allowed shadow-none' : 'bg-blue-600 hover:bg-blue-700 text-white shadow-blue-500/20'}`}
			>
				{initialButtonText}
			</button>
			</div>

			<div id="product-mobile-cta" class="product-mobile-cta" aria-hidden="true">
				<button id="mobile-add-to-cart-btn" type="button" disabled={initialButtonDisabled}>
					{initialButtonText}
				</button>
			</div>

			<script>
				const addToCartBtn = document.getElementById('add-to-cart-btn');
				const productShareBtn = document.getElementById('product-share-btn');
				const productShareStatus = document.getElementById('product-share-status');
				const mobileCta = document.getElementById('product-mobile-cta');
				const mobileAddToCartBtn = document.getElementById('mobile-add-to-cart-btn');
				const purchaseActions = document.getElementById('product-purchase-actions');
				const productMainImage = document.getElementById('product-main-image');
				const productPrice = document.getElementById('product-price');
				const productRegularPrice = document.getElementById('product-regular-price');
				const productSaveText = document.getElementById('product-save-text');
				const productStockText = document.getElementById('product-stock-text');
				const selectedVariationSummary = document.getElementById('selected-variation-summary');
				const quantityMinusBtn = document.getElementById('quantity-minus-btn');
				const quantityPlusBtn = document.getElementById('quantity-plus-btn');
				const quantityDisplay = document.getElementById('quantity-display');
				const variationOptions = document.querySelectorAll('[data-variation-option]');
				const variationDropdown = document.getElementById('variation-dropdown');
				const variationRadios = document.querySelectorAll('[data-variation-radio]');
				const variationCheckCards = document.querySelectorAll('[data-variation-check-card]');
				const baseButtonClass = 'w-full font-black py-4 rounded-[2rem] shadow-xl transition';
				const activeButtonClass = 'bg-blue-600 hover:bg-blue-700 text-white shadow-blue-500/20';
				const disabledButtonClass = 'bg-gray-200 text-gray-500 cursor-not-allowed shadow-none';
				const tracksStock = addToCartBtn?.dataset.trackStock !== 'false';
				const galleryData = document.getElementById('product-gallery-data');
				const galleryImages = JSON.parse(galleryData?.textContent || '[]');
				const galleryPrevBtn = document.getElementById('gallery-prev-btn');
				const galleryNextBtn = document.getElementById('gallery-next-btn');
				const galleryDots = document.querySelectorAll('[data-gallery-dot]');
				const productGallery = document.getElementById('product-gallery');
				let galleryIndex = 0;
				let touchStartX = 0;
				let touchEndX = 0;
				let selectedQuantity = 1;
				let purchaseActionsVisible = false;
				let shareStatusTimeout;
				document.body.classList.add('product-detail-page');

				function showShareStatus(message = 'Enlace copiado') {
					if (!productShareStatus) return;
					productShareStatus.textContent = message;
					productShareStatus.hidden = false;
					requestAnimationFrame(() => productShareStatus.classList.add('is-visible'));
					window.clearTimeout(shareStatusTimeout);
					shareStatusTimeout = window.setTimeout(() => {
						productShareStatus.classList.remove('is-visible');
						window.setTimeout(() => {
							productShareStatus.hidden = true;
						}, 220);
					}, 1800);
				}

				async function copyProductUrl(url) {
					if (navigator.clipboard?.writeText) {
						await navigator.clipboard.writeText(url);
						return true;
					}

					const copyField = document.createElement('textarea');
					copyField.value = url;
					copyField.setAttribute('readonly', '');
					copyField.style.position = 'fixed';
					copyField.style.left = '-9999px';
					copyField.style.top = '0';
					document.body.appendChild(copyField);
					copyField.select();
					const copied = document.execCommand('copy');
					copyField.remove();
					return copied;
				}

				productShareBtn?.addEventListener('click', async () => {
					const shareTitle = String(productShareBtn.dataset.shareTitle || document.title || '').trim();
					const shareText = String(productShareBtn.dataset.shareText || shareTitle || '').trim();
					const shareUrl = String(productShareBtn.dataset.shareUrl || window.location.href).trim();

					if (navigator.share) {
						try {
							await navigator.share({
								title: shareTitle,
								text: shareText,
								url: shareUrl,
							});
						} catch (error) {
							if (error?.name !== 'AbortError') {
								try {
									if (await copyProductUrl(shareUrl)) showShareStatus();
								} catch (_) {}
							}
						}
						return;
					}

					try {
						if (await copyProductUrl(shareUrl)) showShareStatus();
					} catch (_) {}
				});

				function syncFloatingCta() {
					if (!mobileAddToCartBtn || !addToCartBtn) return;
					mobileAddToCartBtn.textContent = addToCartBtn.textContent || '';
					mobileAddToCartBtn.disabled = addToCartBtn.disabled;
					mobileAddToCartBtn.classList.toggle('is-disabled', addToCartBtn.disabled);
				}

				function setPrimaryButtonText(text) {
					if (!addToCartBtn) return;
					addToCartBtn.textContent = text;
					syncFloatingCta();
				}

				function updateFloatingCtaVisibility() {
					if (!mobileCta) return;
					const shouldShow = !purchaseActionsVisible;
					mobileCta.classList.toggle('is-visible', shouldShow);
					mobileCta.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
					document.body.classList.toggle('product-add-floating-active', shouldShow);
				}

				function refreshPurchaseActionsVisibility() {
					if (!purchaseActions) return;
					const rect = purchaseActions.getBoundingClientRect();
					const visibleHeight = Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0);
					purchaseActionsVisible = visibleHeight > Math.min(48, rect.height * 0.08);
					updateFloatingCtaVisibility();
				}

				function updateGallery(index) {
					if (!productMainImage || galleryImages.length === 0) return;
					galleryIndex = (index + galleryImages.length) % galleryImages.length;
					productMainImage.setAttribute('src', galleryImages[galleryIndex]);
					galleryDots.forEach((dot) => {
						const isActive = Number(dot.dataset.index || 0) === galleryIndex;
						dot.className = isActive
							? 'h-2.5 w-5 rounded-full bg-gray-900 transition-all'
							: 'h-2.5 w-2.5 rounded-full bg-gray-300 transition-all hover:bg-gray-400';
					});
				}

				galleryPrevBtn?.addEventListener('click', () => updateGallery(galleryIndex - 1));
				galleryNextBtn?.addEventListener('click', () => updateGallery(galleryIndex + 1));
				galleryDots.forEach((dot) => {
					dot.addEventListener('click', () => updateGallery(Number(dot.dataset.index || 0)));
				});

				productGallery?.addEventListener('touchstart', (event) => {
					touchStartX = event.changedTouches[0]?.screenX || 0;
				});

				productGallery?.addEventListener('touchend', (event) => {
					touchEndX = event.changedTouches[0]?.screenX || 0;
					const distance = touchStartX - touchEndX;
					if (Math.abs(distance) < 45 || galleryImages.length <= 1) return;
					updateGallery(distance > 0 ? galleryIndex + 1 : galleryIndex - 1);
				});

				function getCurrentUnitPrice() {
					return Number(addToCartBtn?.dataset.price || 0);
				}

				function getCurrentStock() {
					return Number(addToCartBtn?.dataset.stock || 0);
				}

				function getCurrentCanPreorder() {
					return addToCartBtn?.dataset.preorder === 'true';
				}

				function getCurrentIsOutOfStock() {
					return addToCartBtn?.dataset.outOfStock === 'true';
				}

				function getMaxQuantity() {
					if (!tracksStock || getCurrentCanPreorder()) return 99;
					return Math.max(1, getCurrentStock());
				}

				function clampQuantity(value) {
					const maxQuantity = getMaxQuantity();
					return Math.min(Math.max(1, Number(value || 1)), maxQuantity);
				}

				function formatVisualPrice(amountUsd) {
					const onlyUsd = addToCartBtn?.dataset.onlyUsd === 'true';
					if (window.PZCurrency?.formatVisualFromUsd) return window.PZCurrency.formatVisualFromUsd(amountUsd, { onlyUsd });
					return '$' + Number(amountUsd || 0).toFixed(2) + ' USD';
				}

				function formatSavingsText(amountUsd) {
					return `Ahorras ${formatVisualPrice(amountUsd)}`;
				}

				function buildButtonText() {
					if (addToCartBtn?.dataset.requiresVariation === 'true' && !addToCartBtn?.dataset.variationId) return 'Selecciona una variacion';
					const isOutOfStock = getCurrentIsOutOfStock();
					const canPreorder = getCurrentCanPreorder();
					if (isOutOfStock && !canPreorder) return 'Agotado';
					const action = canPreorder ? 'Preordenar' : 'Añadir';
					const total = getCurrentUnitPrice() * selectedQuantity;
					return `${action} ${selectedQuantity} al pedido · ${formatVisualPrice(total)}`;
				}

				function updateQuantityUI() {
					selectedQuantity = clampQuantity(selectedQuantity);
					const maxQuantity = getMaxQuantity();
					if (quantityDisplay) quantityDisplay.textContent = String(selectedQuantity);
					if (quantityMinusBtn) quantityMinusBtn.disabled = selectedQuantity <= 1 || addToCartBtn?.disabled;
					if (quantityPlusBtn) quantityPlusBtn.disabled = selectedQuantity >= maxQuantity || addToCartBtn?.disabled;
					setPrimaryButtonText(buildButtonText());
				}

				function stockText({ stock, isOutOfStock, canPreorder }) {
					if (!tracksStock) return 'Disponible';
					if (canPreorder) return 'Disponible por preorder';
					if (isOutOfStock) return 'Agotado';
					return `${stock} disponibles`;
				}

				function setStockClass({ isOutOfStock, canPreorder }) {
					if (!productStockText) return;
					productStockText.className = 'font-bold';
					if (!tracksStock) productStockText.classList.add('text-green-700');
					else if (canPreorder) productStockText.classList.add('text-blue-700');
					else if (isOutOfStock) productStockText.classList.add('text-red-600');
					else productStockText.classList.add('text-gray-800');
				}

				function getCartItemKey(item) {
					return item.variation_id ? `${item.id}::${item.variation_id}` : item.id;
				}

				function parseCart(value) {
					try {
						const parsed = JSON.parse(value || '[]');
						return Array.isArray(parsed) ? parsed : [];
					} catch (_) {
						return [];
					}
				}

				function getStoreCart() {
					if (window.PZCartStorage?.readCart) return window.PZCartStorage.readCart();
					const fallbackKey = window.PZ_CART_STORAGE_KEY || `tusenda84_cart_${window.PZ_CURRENT_STORE_ID || 'powerzona'}`;
					return parseCart(localStorage.getItem(fallbackKey));
				}

				function saveStoreCart(cart) {
					const currentStoreId = String(window.PZ_CURRENT_STORE_ID || '');
					const nextCart = Array.isArray(cart)
						? cart.map((item) => ({ ...item, store_id: item?.store_id || currentStoreId }))
						: [];
					if (window.PZCartStorage?.writeCart) {
						window.PZCartStorage.writeCart(nextCart);
						return;
					}
					const fallbackKey = window.PZ_CART_STORAGE_KEY || `tusenda84_cart_${currentStoreId || 'powerzona'}`;
					const checkoutFallbackKey = window.PZ_CHECKOUT_CART_STORAGE_KEY || `${fallbackKey}_checkout`;
					const payload = JSON.stringify(nextCart);
					localStorage.setItem(fallbackKey, payload);
					if (nextCart.length) sessionStorage.setItem(checkoutFallbackKey, payload);
					else sessionStorage.removeItem(checkoutFallbackKey);
				}

				function syncButtonState({ stock, isOutOfStock, canPreorder }) {
					if (!addToCartBtn) return;
					const disabled = isOutOfStock && !canPreorder;
					addToCartBtn.dataset.outOfStock = isOutOfStock ? 'true' : 'false';
					addToCartBtn.dataset.preorder = canPreorder ? 'true' : 'false';
					addToCartBtn.dataset.stock = String(stock);
					addToCartBtn.disabled = disabled;
					addToCartBtn.className = `${baseButtonClass} ${disabled ? disabledButtonClass : activeButtonClass}`;
					syncFloatingCta();
					selectedQuantity = clampQuantity(selectedQuantity);
					updateQuantityUI();
				}

				function setSelectedVisual(variationId) {
					variationOptions.forEach((item) => {
						const isSelected = item.dataset.id === variationId;
						item.classList.toggle('border-blue-500', isSelected);
						item.classList.toggle('ring-2', isSelected);
						item.classList.toggle('ring-blue-100', isSelected);
						item.classList.toggle('bg-blue-50/40', isSelected);
						item.classList.toggle('border-gray-100', !isSelected);
						item.classList.toggle('bg-white', !isSelected);
					});

					variationCheckCards.forEach((item) => {
						const isSelected = item.dataset.variationId === variationId;
						item.classList.toggle('border-blue-500', isSelected);
						item.classList.toggle('ring-2', isSelected);
						item.classList.toggle('ring-blue-100', isSelected);
						item.classList.toggle('bg-blue-50/40', isSelected);
						item.classList.toggle('border-gray-100', !isSelected);
						item.classList.toggle('bg-white', !isSelected);
					});

					variationRadios.forEach((radio) => {
						radio.checked = radio.value === variationId;
					});

					if (variationDropdown && variationDropdown.value !== variationId) variationDropdown.value = variationId;
				}

				function applyVariation(option) {
					if (!option || !addToCartBtn) return;

					const stock = Number(option.dataset.stock || 0);
					const price = Number(option.dataset.price || 0);
					const regularPrice = Number(option.dataset.regularPrice || price);
					const cost = Number(option.dataset.cost || 0);
					const isOffer = option.dataset.isOffer === 'true' && regularPrice > price;
					const savings = isOffer ? Math.max(0, regularPrice - price) : 0;
					const isOutOfStock = tracksStock && option.dataset.outOfStock === 'true';
					const canPreorder = tracksStock && option.dataset.preorder === 'true';

					addToCartBtn.dataset.price = String(price);
					addToCartBtn.dataset.cost = String(cost);
					addToCartBtn.dataset.isOffer = isOffer ? 'true' : 'false';
					addToCartBtn.dataset.savingsUsd = String(savings);
					addToCartBtn.dataset.regularPrice = String(regularPrice);
					addToCartBtn.dataset.image = option.dataset.image || addToCartBtn.dataset.image || '';
					addToCartBtn.dataset.variationId = option.dataset.id || '';
					addToCartBtn.dataset.variationLabel = option.dataset.label || '';
					addToCartBtn.dataset.variationRef = option.dataset.ref || '';

					setSelectedVisual(option.dataset.id || '');
					if (selectedVariationSummary) selectedVariationSummary.textContent = `${addToCartBtn.dataset.title || ''} \u2014 ${option.dataset.label || ''}`;
					if (productMainImage && option.dataset.image) productMainImage.setAttribute('src', option.dataset.image);
					if (productPrice) { productPrice.setAttribute('data-pz-price-usd', String(price)); productPrice.textContent = formatVisualPrice(price); }
					if (productRegularPrice) {
						productRegularPrice.setAttribute('data-pz-price-usd', String(regularPrice));
						productRegularPrice.textContent = formatVisualPrice(regularPrice);
						productRegularPrice.classList.toggle('hidden', !isOffer);
					}
					if (productSaveText) {
						productSaveText.textContent = formatSavingsText(savings);
						productSaveText.classList.toggle('hidden', !isOffer);
					}
					if (productStockText) productStockText.textContent = stockText({ stock, isOutOfStock, canPreorder });
					setStockClass({ isOutOfStock, canPreorder });
					syncButtonState({ stock, isOutOfStock, canPreorder });
				}

				function findVariationOption(variationId) {
					return Array.from(variationOptions).find((item) => item.dataset.id === variationId);
				}

				variationOptions.forEach((option) => {
					option.addEventListener('click', () => {
						if (option.disabled) return;
						applyVariation(option);
					});
				});

				variationDropdown?.addEventListener('change', () => {
					const option = findVariationOption(variationDropdown.value);
					applyVariation(option);
				});

				variationRadios.forEach((radio) => {
					radio.addEventListener('change', () => {
						if (radio.disabled || !radio.checked) return;
						const option = findVariationOption(radio.value);
						applyVariation(option);
					});
				});

				quantityMinusBtn?.addEventListener('click', () => {
					selectedQuantity -= 1;
					updateQuantityUI();
				});

				quantityPlusBtn?.addEventListener('click', () => {
					selectedQuantity += 1;
					updateQuantityUI();
				});

				window.addEventListener('pz-currency-changed', () => {
					if (productPrice) productPrice.textContent = formatVisualPrice(Number(productPrice.getAttribute('data-pz-price-usd') || getCurrentUnitPrice()));
					if (productRegularPrice) productRegularPrice.textContent = formatVisualPrice(Number(productRegularPrice.getAttribute('data-pz-price-usd') || addToCartBtn?.dataset.regularPrice || getCurrentUnitPrice()));
					if (productSaveText) productSaveText.textContent = formatSavingsText(Number(addToCartBtn?.dataset.savingsUsd || 0));
					updateQuantityUI();
				});

				const initiallySelectedVariation = addToCartBtn?.dataset.variationId ? findVariationOption(addToCartBtn.dataset.variationId) : null;
				if (initiallySelectedVariation) applyVariation(initiallySelectedVariation);
				else updateQuantityUI();

				if (purchaseActions && 'IntersectionObserver' in window) {
					const purchaseObserver = new IntersectionObserver((entries) => {
						purchaseActionsVisible = entries.some((entry) => entry.isIntersecting && entry.intersectionRatio > 0.08);
						updateFloatingCtaVisibility();
					}, {
						root: null,
						threshold: [0, 0.08, 0.2],
						rootMargin: '0px 0px -18% 0px',
					});
					purchaseObserver.observe(purchaseActions);
				}

				window.addEventListener('resize', refreshPurchaseActionsVisibility);
				refreshPurchaseActionsVisibility();

				mobileAddToCartBtn?.addEventListener('click', () => {
					if (mobileAddToCartBtn.disabled) return;
					addToCartBtn?.click();
					requestAnimationFrame(syncFloatingCta);
				});

				addToCartBtn?.addEventListener('click', () => {
					if (addToCartBtn.dataset.requiresVariation === 'true' && !addToCartBtn.dataset.variationId) {
						setPrimaryButtonText('Selecciona una variacion antes de agregar al carrito');
						if (selectedVariationSummary) selectedVariationSummary.textContent = 'Selecciona una variacion antes de agregar al carrito.';
						setTimeout(() => {
							updateQuantityUI();
						}, 1800);
						return;
					}

					if (addToCartBtn.dataset.outOfStock === 'true' && addToCartBtn.dataset.preorder !== 'true') {
						setPrimaryButtonText('Producto agotado');
						setTimeout(() => {
							updateQuantityUI();
						}, 1500);
						return;
					}

					const product = {
						id: addToCartBtn.dataset.id,
						title: addToCartBtn.dataset.title,
						price: Number(addToCartBtn.dataset.price),
						image: addToCartBtn.dataset.image,
						category: addToCartBtn.dataset.category || '',
						subcategory: addToCartBtn.dataset.subcategory || '',
						quantity: selectedQuantity,
						only_usd: addToCartBtn.dataset.onlyUsd === 'true',
						delivery_mode: addToCartBtn.dataset.deliveryMode,
						stock: Number(addToCartBtn.dataset.stock),
						track_stock: addToCartBtn.dataset.trackStock !== 'false',
						preorder: addToCartBtn.dataset.preorder === 'true',
						requires_variation: addToCartBtn.dataset.requiresVariation === 'true',
						variation_id: addToCartBtn.dataset.variationId || '',
						variation_name: addToCartBtn.dataset.variationLabel || '',
						variation_label: addToCartBtn.dataset.variationLabel || '',
						variation_ref: addToCartBtn.dataset.variationRef || '',
						variation_price_usd: Number(addToCartBtn.dataset.price),
						cost_usd: Number(addToCartBtn.dataset.cost || 0),
						variation_cost_usd: Number(addToCartBtn.dataset.cost || 0),
						regular_price_usd: Number(addToCartBtn.dataset.regularPrice || addToCartBtn.dataset.price || 0),
						is_offer: addToCartBtn.dataset.isOffer === 'true',
						savings_usd: Number(addToCartBtn.dataset.savingsUsd || 0),
						store_id: String(window.PZ_CURRENT_STORE_ID || ''),
					};

					let cart = getStoreCart();
					const productKey = getCartItemKey(product);
					const existingProduct = cart.find((item) => getCartItemKey(item) === productKey);

					if (existingProduct) {
						if (product.track_stock !== false && !product.preorder && existingProduct.quantity + product.quantity > product.stock) {
							setPrimaryButtonText('Stock máximo alcanzado');
							setTimeout(() => {
								updateQuantityUI();
							}, 1500);
							return;
						}

						existingProduct.quantity += product.quantity;
						existingProduct.price = product.price;
						existingProduct.image = product.image;
						existingProduct.category = product.category;
						existingProduct.subcategory = product.subcategory;
						existingProduct.stock = product.stock;
						existingProduct.preorder = product.preorder;
						existingProduct.variation_id = product.variation_id;
						existingProduct.variation_name = product.variation_name;
						existingProduct.variation_label = product.variation_label;
						existingProduct.variation_ref = product.variation_ref;
						existingProduct.variation_price_usd = product.variation_price_usd;
						existingProduct.cost_usd = product.cost_usd;
						existingProduct.variation_cost_usd = product.variation_cost_usd;
						existingProduct.regular_price_usd = product.regular_price_usd;
						existingProduct.is_offer = product.is_offer;
						existingProduct.savings_usd = product.savings_usd;
						existingProduct.store_id = product.store_id;
					} else {
						cart.push(product);
					}

					saveStoreCart(cart);
					window.dispatchEvent(new Event('cart-updated'));
					setPrimaryButtonText('Agregado al pedido ✅');

					setTimeout(() => {
						updateQuantityUI();
					}, 1500);
				});
			</script>
		</div>
	</section>

	{reviewsEnabled && (productReviews.length > 0 || productReviewsEnabled) && (
		<section id="opiniones-producto" class="product-reviews-section">
			<div class="product-reviews-head">
				<div class="product-reviews-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 21a9 9 0 1 0-8.5-6"></path>
						<path d="M8 13.5 10.2 16 16 9"></path>
						<path d="M3 21l2.8-1"></path>
					</svg>
				</div>
				<div>
					<h2 class="product-reviews-title">Reseñas del producto</h2>
					<p class="product-reviews-subtitle">Opiniones aprobadas de clientes sobre {product.name}.</p>
				</div>
			</div>

			{productReviewsEnabled && (
				<div class="product-review-form-shell-wrap">
					<button id="product-review-toggle" class="product-reviews-toggle" type="button" aria-expanded="false" aria-controls="product-review-form-shell">
						<span class="product-reviews-toggle-main">
							<span class="product-reviews-toggle-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 20h9"></path>
									<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
								</svg>
							</span>
							<span class="product-reviews-toggle-title">Dejar reseña</span>
						</span>
						<svg class="product-reviews-toggle-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="m6 9 6 6 6-6"></path>
						</svg>
					</button>

					<div id="product-review-form-shell" class="product-review-form-shell" hidden>
						<form id="public-product-review-form" class="product-review-form">
							<h3 class="product-review-form-title">Dejar reseña</h3>
							<div class="product-review-form-grid">
								<label class="product-review-field">
									<span>Nombre</span>
									<input id="product-review-name" name="customer_name" type="text" maxlength="120" required />
								</label>

								<div class="product-review-field">
									<span>Rating</span>
									<div class="product-review-rating" data-product-public-rating>
										<input id="product-review-rating" type="hidden" value="0" />
										<button type="button" data-value="1" aria-label="1 estrella">&#9733;</button>
										<button type="button" data-value="2" aria-label="2 estrellas">&#9733;</button>
										<button type="button" data-value="3" aria-label="3 estrellas">&#9733;</button>
										<button type="button" data-value="4" aria-label="4 estrellas">&#9733;</button>
										<button type="button" data-value="5" aria-label="5 estrellas">&#9733;</button>
									</div>
								</div>

								<label class="product-review-field product-review-field-full">
									<span>Comentario</span>
									<textarea id="product-review-comment" name="comment" rows="4" maxlength="1200" required></textarea>
								</label>
							</div>

							<label class="product-review-honeypot" aria-hidden="true">
								Sitio web
								<input id="product-review-website" name="website" type="text" tabindex="-1" autocomplete="off" />
							</label>

							<p class="product-review-form-note">Tu reseña será revisada antes de publicarse.</p>
							<div id="product-review-alert" class="product-review-alert hidden"></div>
							<button id="product-review-submit" class="product-review-submit" type="submit">Enviar reseña</button>
						</form>
					</div>
				</div>
			)}

			{productReviews.length > 0 && (
				<>
					<div class="product-reviews-list" data-product-reviews-list data-page-size={productReviewsPageSize}>
						{productReviews.map((review, index) => (
							<article class="product-review-card" data-product-review-card data-product-review-index={index} hidden={index >= productReviewsPageSize}>
								<div class="product-review-person">
									<div class="product-review-avatar" aria-hidden="true">{reviewInitials(review.customer_name || 'Cliente')}</div>
									<div>
										<p class="product-review-name">{review.customer_name || 'Cliente'}</p>
										{formatReviewDate(review.created) && <p class="product-review-date">{formatReviewDate(review.created)}</p>}
									</div>
								</div>

								<div class="product-review-body">
									<span class="product-review-stars" aria-label={`${Number(review.rating || 0)} de 5`}>{reviewStars(Number(review.rating || 0))}</span>
									{review.comment && <p class="product-review-comment">{review.comment}</p>}
								</div>

								<span class="product-review-badge" aria-label="Reseña aprobada" title="Reseña aprobada">
									<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
										<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
										<path d="m9 12 2 2 4-5"></path>
									</svg>
								</span>

								{showVerifiedBadge && review.verified_purchase === true && <span class="verified-badge" hidden>Compra verificada</span>}
							</article>
						))}
					</div>

					{productReviews.length > productReviewsPageSize && (
						<div class="product-reviews-pagination" data-product-reviews-pagination>
							<span data-product-reviews-range>Mostrando 1-5 de {reviewCountLabel(productReviews.length)}</span>
							<div class="product-reviews-pages" aria-label="Paginación de reseñas del producto">
								<button class="product-reviews-page-btn" type="button" data-product-review-prev aria-label="Página anterior">‹</button>
								{Array.from({ length: Math.ceil(productReviews.length / productReviewsPageSize) }).map((_, index) => (
									<button class={`product-reviews-page-btn ${index === 0 ? 'active' : ''}`} type="button" data-product-review-page={index + 1} aria-label={`Página ${index + 1}`}>{index + 1}</button>
								))}
								<button class="product-reviews-page-btn" type="button" data-product-review-next aria-label="Página siguiente">›</button>
							</div>
						</div>
					)}
				</>
			)}
		</section>
	)}

	{relatedProducts.length > 0 && (
		<section class="related-section">
			<h2 class="related-section-title">Relacionados</h2>
			<p class="related-section-subtitle">Pueden interesarte también</p>
			<div class="related-grid">
				{relatedProducts.map((item: any) => {
					const offer = getProductOfferState(item);
					return (
						<a class="related-card" href={getPublicPath(`/producto/${item.slug}`, currentStore, currentPathname)}>
							<img class="related-image" src={getProductCardImage(item)} alt={item.name} loading="lazy" />
							<div>
								{offer.hasOffer && <span class="related-badge">Oferta</span>}
								{offer.hasVariations && <span class="related-badge">Varias opciones</span>}
								<h3 class="related-name">{item.name}</h3>
								{item.description && <p class="related-description">{item.description}</p>}
								<div class="related-price-row">
									{offer.hasOffer && <span class="related-old-price" data-pz-price-usd={offer.regularPrice} data-pz-only-usd={item.only_usd ? 'true' : 'false'}>{`$${offer.regularPrice.toFixed(2)} USD`}</span>}
									<span class={`related-price ${offer.hasOffer ? 'offer' : ''}`} data-pz-price-usd={offer.activePrice} data-pz-price-prefix={offer.pricePrefix} data-pz-only-usd={item.only_usd ? 'true' : 'false'}>{`${offer.pricePrefix ? `${offer.pricePrefix} ` : ''}$${offer.activePrice.toFixed(2)} USD`}</span>
								</div>
								<span class="related-buy">{offer.buyText}</span>
							</div>
						</a>
					);
				})}
			</div>
		</section>
	)}

	<script define:vars={{ pocketbaseUrl, currentStoreId, productId: product.id }}>
		(() => {
			const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
			const CURRENT_STORE_ID = String(currentStoreId || '');
			const PRODUCT_ID = String(productId || '');

			const productReviewToggle = document.getElementById('product-review-toggle');
			const productReviewFormShell = document.getElementById('product-review-form-shell');

			function setProductReviewFormOpen(open) {
				if (!productReviewToggle || !productReviewFormShell) return;
				productReviewToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				productReviewFormShell.classList.toggle('is-open', open);
				productReviewFormShell.hidden = !open;
			}

			productReviewToggle?.addEventListener('click', () => {
				setProductReviewFormOpen(productReviewToggle.getAttribute('aria-expanded') !== 'true');
			});

			const productReviewCards = Array.from(document.querySelectorAll('[data-product-review-card]'));
			const productReviewPagination = document.querySelector('[data-product-reviews-pagination]');
			const productReviewRange = document.querySelector('[data-product-reviews-range]');
			const productReviewPageButtons = Array.from(document.querySelectorAll('[data-product-review-page]'));
			const productReviewPrev = document.querySelector('[data-product-review-prev]');
			const productReviewNext = document.querySelector('[data-product-review-next]');
			const productReviewPageSize = Math.max(1, Number(document.querySelector('[data-product-reviews-list]')?.getAttribute('data-page-size') || 5));
			const totalProductReviewPages = Math.max(1, Math.ceil(productReviewCards.length / productReviewPageSize));
			let currentProductReviewPage = 1;

			function renderProductReviewPage(page) {
				currentProductReviewPage = Math.max(1, Math.min(totalProductReviewPages, Number(page || 1)));
				const start = (currentProductReviewPage - 1) * productReviewPageSize;
				const end = Math.min(start + productReviewPageSize, productReviewCards.length);

				productReviewCards.forEach((card, index) => {
					card.hidden = index < start || index >= end;
				});

				if (productReviewRange) {
					productReviewRange.textContent = `Mostrando ${start + 1}-${end} de ${productReviewCards.length} ${productReviewCards.length === 1 ? 'reseña' : 'reseñas'}`;
				}

				productReviewPageButtons.forEach((button) => {
					const isActive = Number(button.getAttribute('data-product-review-page') || 0) === currentProductReviewPage;
					button.classList.toggle('active', isActive);
					button.setAttribute('aria-current', isActive ? 'page' : 'false');
				});

				if (productReviewPrev) productReviewPrev.disabled = currentProductReviewPage === 1;
				if (productReviewNext) productReviewNext.disabled = currentProductReviewPage === totalProductReviewPages;
				if (productReviewPagination) productReviewPagination.hidden = productReviewCards.length <= productReviewPageSize;
			}

			productReviewPageButtons.forEach((button) => {
				button.addEventListener('click', () => renderProductReviewPage(button.getAttribute('data-product-review-page')));
			});

			productReviewPrev?.addEventListener('click', () => renderProductReviewPage(currentProductReviewPage - 1));
			productReviewNext?.addEventListener('click', () => renderProductReviewPage(currentProductReviewPage + 1));

			if (productReviewCards.length) renderProductReviewPage(1);

			const form = document.getElementById('public-product-review-form');
			if (!form) return;

			const ratingInput = document.getElementById('product-review-rating');
			const ratingGroup = form.querySelector('[data-product-public-rating]');
			const alertBox = document.getElementById('product-review-alert');
			const submitBtn = document.getElementById('product-review-submit');

			function setProductReviewAlert(message, type = 'error') {
				if (!alertBox) return;
				alertBox.textContent = message || '';
				alertBox.className = message ? `product-review-alert ${type}` : 'product-review-alert hidden';
			}

			function setRating(value) {
				const rating = Math.max(0, Math.min(5, Number(value || 0)));
				if (ratingInput) ratingInput.value = String(rating);
				ratingGroup?.querySelectorAll('button').forEach((button) => {
					button.classList.toggle('active', Number(button.dataset.value || 0) <= rating);
				});
			}

			ratingGroup?.querySelectorAll('button').forEach((button) => {
				button.addEventListener('click', () => setRating(button.dataset.value));
			});

			async function createProductReview(payload) {
				const response = await fetch(`${POCKETBASE_URL}/api/collections/reviews/records`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});
				const result = await response.json().catch(() => null);
				if (!response.ok) throw new Error(result?.message || 'No se pudo enviar la reseña.');
				return result;
			}

			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				setProductReviewAlert('');

				if (!POCKETBASE_URL || !CURRENT_STORE_ID || !PRODUCT_ID) {
					setProductReviewAlert('No se pudo conectar con la tienda. Inténtalo más tarde.');
					return;
				}

				const honeypot = String(document.getElementById('product-review-website')?.value || '').trim();
				if (honeypot) {
					form.reset();
					setRating(0);
					setProductReviewAlert('Gracias por dejar tu reseña. Será publicada cuando la tienda la apruebe.', 'success');
					return;
				}

				const customerName = String(document.getElementById('product-review-name')?.value || '').trim();
				const rating = Number(ratingInput?.value || 0);
				const comment = String(document.getElementById('product-review-comment')?.value || '').trim().slice(0, 1200);

				if (!customerName) {
					setProductReviewAlert('Escribe tu nombre para enviar la reseña.');
					return;
				}
				if (!Number.isInteger(rating) || rating < 1 || rating > 5) {
					setProductReviewAlert('Elige un rating entre 1 y 5 estrellas.');
					return;
				}
				if (!comment) {
					setProductReviewAlert('Escribe un comentario para enviar la reseña.');
					return;
				}

				const payload = {
					store: CURRENT_STORE_ID,
					product: PRODUCT_ID,
					type: 'product',
					source: 'public_product',
					verified_purchase: false,
					status: 'pending',
					featured: false,
					rating,
					customer_name: customerName,
					comment,
				};

				if (submitBtn) {
					submitBtn.disabled = true;
					submitBtn.textContent = 'Enviando...';
				}

				try {
					await createProductReview(payload);
					form.reset();
					setRating(0);
					setProductReviewAlert('Gracias por dejar tu reseña. Será publicada cuando la tienda la apruebe.', 'success');
				} catch (error) {
					setProductReviewAlert(error?.message || 'No se pudo enviar la reseña.');
				} finally {
					if (submitBtn) {
						submitBtn.disabled = false;
						submitBtn.textContent = 'Enviar reseña';
					}
				}
			});
		})();
	</script>

	<StoreAnalyticsTracker storeId={currentStoreId} pageType="product" entityType="product" entityId={product.id} />
	<PublicFooter settings={settings} />
</Layout>
