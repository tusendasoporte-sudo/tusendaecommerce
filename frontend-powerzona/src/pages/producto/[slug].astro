			{hasPublicVariations && (
				<div class="product-detail-variations bg-white rounded-2xl border border-gray-100 p-5 mb-6">
					<div class="flex items-center justify-between gap-3 mb-3">
						<div>
							<h2 class="font-bold text-gray-900">Selecciona una variación</h2>
							<p class="text-xs text-gray-500 mt-1">El precio, la foto y el stock cambian según la opción.</p>
