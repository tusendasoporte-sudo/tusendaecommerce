---
// PZ-PATCH-V26.5-OFERTA-FINAL-ESTABLE-20260605
import Layout from '../layouts/Layout.astro';
import { getCurrentStore, getPublicPath } from '../lib/stores';

const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const currentStore = await getCurrentStore(Astro);
const currentStoreId = currentStore.id;
const currentPathname = Astro.url.pathname;
const homePath = getPublicPath('/', currentStore, currentPathname);
---

<!-- PZ-CHECKOUT-V19-OFERTA-AHORRO-20260605 -->
<Layout>
	<section class="max-w-5xl mx-auto">
		<div class="mb-6">
			<a href={homePath} class="inline-flex items-center text-sm text-blue-600 font-semibold mb-4">
				← Seguir comprando
			</a>

			<h1 class="text-3xl font-extrabold text-gray-900">
				Revisar pedido
			</h1>

			<p class="text-gray-500 mt-2">
				Confirma tus productos, elige cómo deseas recibir el pedido y completa tus datos.
			</p>
		</div>

		<div id="checkout-empty" class="hidden bg-white rounded-3xl border border-gray-100 shadow-sm p-8 text-center">
			<div class="text-5xl mb-4">🛒</div>

			<h2 class="text-xl font-bold text-gray-900 mb-2">
				Tu carrito está vacío
			</h2>

			<p class="text-gray-500 mb-6">
				No hay productos para realizar el pedido. Te enviaremos nuevamente al catálogo.
			</p>

			<a
				href={homePath}
				class="inline-flex bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-2xl transition"
			>
				Volver al catálogo
			</a>
		</div>

		<div id="checkout-content" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			<div class="lg:col-span-2 space-y-6">
				<div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
					<div class="p-5 border-b border-gray-100">
						<h2 class="text-xl font-bold text-gray-900">
							Productos del pedido
						</h2>

						<p class="text-sm text-gray-500 mt-1">
							Revisa cantidades, stock y subtotal por producto.
						</p>
					</div>

					<div id="checkout-items" class="divide-y divide-gray-100"></div>

					<div id="add-more-products-box" class="p-5 bg-gray-50 border-t border-gray-100">
						<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
							<div>
								<h3 class="font-bold text-gray-900">
									¿Deseas agregar algo más?
								</h3>

								<p class="text-sm text-gray-500 mt-1">
									Puedes volver al catálogo y seguir agregando productos a tu pedido.
								</p>
							</div>

							<a
								href={homePath}
								class="inline-flex justify-center items-center bg-blue-600 hover:bg-blue-700 text-white font-bold px-5 py-3 rounded-2xl transition"
							>
								Volver al catálogo
							</a>
						</div>
					</div>
				</div>

				<div id="manual-coupon-card" class="bg-white rounded-3xl border border-gray-100 shadow-sm p-5">
					<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
						<div>
							<h2 class="text-xl font-bold text-gray-900">Cupón manual</h2>
							<p class="text-sm text-gray-500 mt-1">Solo puedes usar 1 cupón por orden.</p>
							<p id="manual-coupon-multiple-note" class="hidden text-xs text-gray-500 font-semibold mt-1">Si tienes varios cupones disponibles, puedes escoger cuál usar.</p>
						</div>
					</div>
					<div class="flex flex-col sm:flex-row gap-3">
						<input id="manual-coupon-input" type="text" placeholder="¿Tienes un cupón?" autocomplete="off" class="flex-1 bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500 font-bold uppercase" />
						<button id="manual-coupon-apply-btn" type="button" class="bg-slate-900 hover:bg-slate-800 text-white font-bold px-5 py-3 rounded-2xl transition">Aplicar</button>
					</div>
					<div id="manual-coupon-alert" class="hidden mt-3 rounded-2xl border p-3 text-xs font-bold"></div>
					<div id="saved-coupons-list" class="mt-4 grid gap-3"></div>
				</div>

				<form id="checkout-form" class="space-y-6" novalidate>
					<div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-5">
						<h2 class="text-xl font-bold text-gray-900 mb-4">
							Método de entrega
						</h2>

						<div id="delivery-methods" class="grid grid-cols-1 md:grid-cols-3 gap-3">
							<label id="delivery-option-delivery" class="delivery-option border border-gray-200 rounded-2xl p-4 cursor-pointer hover:border-blue-500 transition">
								<input type="radio" name="delivery_method" value="delivery" class="mr-2" />
								<span class="font-bold text-gray-800">Envío</span>
								<p class="text-xs text-gray-500 mt-1">
									Entrega a domicilio.
								</p>
							</label>

							<label id="delivery-option-pickup" class="delivery-option border border-gray-200 rounded-2xl p-4 cursor-pointer hover:border-blue-500 transition">
								<input type="radio" name="delivery_method" value="pickup" class="mr-2" />
								<span class="font-bold text-gray-800">Recogida</span>
								<p class="text-xs text-gray-500 mt-1">
									Se coordina por WhatsApp.
								</p>
							</label>

							<label id="delivery-option-coordinate" class="delivery-option border border-gray-200 rounded-2xl p-4 cursor-pointer hover:border-blue-500 transition">
								<input type="radio" name="delivery_method" value="coordinate" class="mr-2" />
								<span class="font-bold text-gray-800">Coordinar</span>
								<p class="text-xs text-gray-500 mt-1">
									Un admin confirma contigo.
								</p>
							</label>
						</div>

						<p id="delivery-method-error" class="hidden text-xs text-red-500 font-semibold mt-3">
							Selecciona un método de entrega.
						</p>

						<div id="delivery-helper" class="mt-4 bg-blue-50 border border-blue-100 text-blue-800 rounded-2xl p-3 text-xs font-semibold">
							Selecciona cómo deseas recibir el pedido para completar los datos necesarios.
						</div>
					</div>

					<div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-5">
						<h2 class="text-xl font-bold text-gray-900 mb-4">
							Datos del cliente
						</h2>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<div>
								<label for="customer-name" class="block text-sm font-semibold text-gray-700 mb-2">
									Nombre completo <span class="text-red-500">*</span>
								</label>
								<input
									id="customer-name"
									name="customer_name"
									type="text"
									placeholder="Ej: Juan Pérez"
									autocomplete="name"
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
								/>
								<p id="customer-name-error" class="hidden text-xs text-red-500 font-semibold mt-2">
									Escribe el nombre del cliente.
								</p>
							</div>

							<div>
								<label for="customer-phone" class="block text-sm font-semibold text-gray-700 mb-2">
									Teléfono / WhatsApp <span class="text-red-500">*</span>
								</label>
								<input
									id="customer-phone"
									name="customer_phone"
									type="tel"
									placeholder="Ej: +53 5..."
									autocomplete="tel"
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
								/>
								<p id="customer-phone-error" class="hidden text-xs text-red-500 font-semibold mt-2">
									Escribe un teléfono válido para coordinar el pedido.
								</p>
							</div>

							<div id="municipality-field-box" class="hidden">
								<label for="customer-municipality" class="block text-sm font-semibold text-gray-700 mb-2">
									Municipio <span class="text-red-500">*</span>
								</label>
								<select
									id="customer-municipality"
									name="customer_municipality"
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
								disabled
								>
									<option value="">Cargando municipios...</option>
								</select>
								<p id="customer-municipality-error" class="hidden text-xs text-red-500 font-semibold mt-2">
									Selecciona el municipio para calcular el envío.
								</p>
							</div>

							<div id="shipping-zone-field-box" class="hidden">
								<label for="customer-shipping-zone" class="block text-sm font-semibold text-gray-700 mb-2">
									Zona de entrega <span class="text-red-500">*</span>
								</label>
								<select
									id="customer-shipping-zone"
									name="shipping_zone"
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
								disabled
								>
									<option value="">Primero selecciona municipio</option>
								</select>
								<p id="customer-shipping-zone-error" class="hidden text-xs text-red-500 font-semibold mt-2">
									Selecciona la zona de entrega.
								</p>
							</div>

							<div id="address-field-box" class="hidden md:col-span-2">
								<label for="customer-address" class="block text-sm font-semibold text-gray-700 mb-2">
									Dirección o referencia <span class="text-red-500">*</span>
								</label>
								<input
									id="customer-address"
									name="customer_address"
									type="text"
									placeholder="Ej: Calle, número, entrecalles, referencia..."
									autocomplete="street-address"
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
								/>
								<p id="customer-address-error" class="hidden text-xs text-red-500 font-semibold mt-2">
									Escribe una dirección o referencia para la entrega.
								</p>
							</div>

							<div class="md:col-span-2">
								<label for="customer-note" class="block text-sm font-semibold text-gray-700 mb-2">
									Nota adicional
								</label>
								<textarea
									id="customer-note"
									name="customer_note"
									rows="3"
									placeholder="Ej: horario preferido, detalles de entrega, aclaraciones del pedido..."
									class="checkout-field w-full bg-gray-100 rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500 resize-none"
								></textarea>
							</div>
						</div>
					</div>
				</form>
			</div>

			<aside class="lg:col-span-1">
				<div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-5 sticky top-24">
					<h2 class="text-xl font-bold text-gray-900 mb-4">
						Resumen
					</h2>

					<div class="space-y-3 text-sm">
						<div class="flex justify-between">
							<span class="text-gray-500">Productos</span>
							<span id="summary-items" class="font-bold text-gray-900">0</span>
						</div>

						<div class="flex justify-between">
							<span class="text-gray-500">Moneda elegida</span>
							<span id="summary-currency" class="font-bold text-gray-900">USD</span>
						</div>

						<div class="flex justify-between">
							<span class="text-gray-500">Productos</span>
							<span id="summary-subtotal" class="font-bold text-gray-900">$0.00 USD</span>
						</div>

						<div id="summary-discount-row" class="hidden flex justify-between">
							<span class="text-gray-500">Descuento aplicado</span>
							<span id="summary-discount" class="font-bold text-green-700">-$0.00 USD</span>
						</div>

						<div id="summary-discount-promo" class="hidden rounded-2xl bg-green-50 border border-green-100 p-3 text-xs font-black text-green-800"></div>

						<div class="flex justify-between">
							<span class="text-gray-500">Entrega</span>
							<span id="summary-delivery" class="font-bold text-gray-400">Pendiente</span>
						</div>

						<div class="border-t border-gray-100 pt-4 flex justify-between items-center">
							<span class="font-bold text-gray-900">Total estimado</span>
							<span id="summary-total" class="text-2xl font-black text-blue-600">$0.00 USD</span>
						</div>

						<div id="summary-delivery-cost-note" class="hidden rounded-2xl bg-blue-50 border border-blue-100 p-3">
							<div class="flex justify-between gap-3 text-sm">
								<span class="font-bold text-blue-900">Costo de entrega</span>
								<span id="summary-delivery-cost" class="font-black text-blue-700 text-right">$0.00 USD</span>
							</div>
							<p class="text-xs text-blue-700 font-semibold mt-1">
								La entrega se muestra aparte del total estimado.
							</p>
						</div>
					</div>

					<div id="summary-alerts" class="mt-5 space-y-2"></div>
					<div id="checkout-validation-alert" class="mt-4 hidden bg-red-50 border border-red-100 text-red-700 rounded-2xl p-3 text-xs font-semibold"></div>
					<div id="checkout-success-alert" class="mt-4 hidden bg-green-50 border border-green-100 text-green-700 rounded-2xl p-3 text-xs font-semibold"></div>
					<div id="checkout-business-hours-alert" class="mt-4 hidden rounded-2xl border p-3 text-xs font-bold"></div>

					<button
						type="button"
						id="continue-whatsapp-btn"
						class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-2xl shadow-lg transition mt-6 disabled:opacity-50 disabled:cursor-not-allowed"
						disabled
					>
						Realizar Pedido
					</button>

					<p class="text-xs text-gray-400 mt-3 text-center">
						Primero se guardará la orden. Luego podrás abrir WhatsApp sin crear pedidos duplicados.
					</p>
				</div>
			</aside>
		</div>
	</section>

	<script define:vars={{ pocketbaseUrl, currentStoreId, homePath }}>
		const checkoutEmpty = document.getElementById('checkout-empty');
		const checkoutContent = document.getElementById('checkout-content');
		const checkoutItems = document.getElementById('checkout-items');
		const checkoutForm = document.getElementById('checkout-form');

		const customerName = document.getElementById('customer-name');
		const customerPhone = document.getElementById('customer-phone');
		const customerMunicipality = document.getElementById('customer-municipality');
		const customerAddress = document.getElementById('customer-address');
		const customerShippingZone = document.getElementById('customer-shipping-zone');
		const customerNote = document.getElementById('customer-note');

		const municipalityFieldBox = document.getElementById('municipality-field-box');
		const addressFieldBox = document.getElementById('address-field-box');
		const shippingZoneFieldBox = document.getElementById('shipping-zone-field-box');

		const summaryItems = document.getElementById('summary-items');
		const summarySubtotal = document.getElementById('summary-subtotal');
		const summaryDiscountRow = document.getElementById('summary-discount-row');
		const summaryDiscount = document.getElementById('summary-discount');
		const summaryCurrency = document.getElementById('summary-currency');
		const summaryTotal = document.getElementById('summary-total');
		const summaryDelivery = document.getElementById('summary-delivery');
		const summaryDeliveryCostNote = document.getElementById('summary-delivery-cost-note');
		const summaryDeliveryCost = document.getElementById('summary-delivery-cost');
		const summaryAlerts = document.getElementById('summary-alerts');
		const checkoutValidationAlert = document.getElementById('checkout-validation-alert');
		const checkoutSuccessAlert = document.getElementById('checkout-success-alert');
		const checkoutBusinessHoursAlert = document.getElementById('checkout-business-hours-alert');
		const continueWhatsappBtn = document.getElementById('continue-whatsapp-btn');
		const deliveryHelper = document.getElementById('delivery-helper');
		const manualCouponInput = document.getElementById('manual-coupon-input');
		const manualCouponApplyBtn = document.getElementById('manual-coupon-apply-btn');
		const manualCouponAlert = document.getElementById('manual-coupon-alert');
		const savedCouponsList = document.getElementById('saved-coupons-list');
		const manualCouponMultipleNote = document.getElementById('manual-coupon-multiple-note');

		let shippingZones = [];
		let shippingZonesLoaded = false;
		let isSubmittingOrder = false;
		let orderWasCreated = false;
		let savedWhatsappUrl = '';
		let savedOrderNumber = '';
		let pendingOrderFingerprint = '';
		let checkoutLocked = false;
		let activeSettingsCache = null;
		let businessHoursStatus = { mode: 'always_available', isAvailable: true, isClosed: false, title: '', message: '', note: '', allowOrders: true };
		const CURRENT_STORE_ID = currentStoreId || '';
		const COUPON_STORE_KEY = CURRENT_STORE_ID || 'powerzona';
		const SAVED_COUPONS_KEY = `powerzona_saved_coupons_${COUPON_STORE_KEY}`;
		const SELECTED_COUPON_KEY = `powerzona_selected_coupon_${COUPON_STORE_KEY}`;
		if (COUPON_STORE_KEY === 'powerzona' && !localStorage.getItem(SAVED_COUPONS_KEY)) {
			const legacySavedCoupons = localStorage.getItem('powerzona_saved_coupons');
			if (legacySavedCoupons) localStorage.setItem(SAVED_COUPONS_KEY, legacySavedCoupons);
		}
		if (COUPON_STORE_KEY === 'powerzona' && !localStorage.getItem(SELECTED_COUPON_KEY)) {
			const legacySelectedCoupon = localStorage.getItem('powerzona_selected_coupon');
			if (legacySelectedCoupon) localStorage.setItem(SELECTED_COUPON_KEY, legacySelectedCoupon);
		}
		let selectedManualCouponCode = localStorage.getItem(SELECTED_COUPON_KEY) || '';

		const PENDING_ORDER_KEY = `powerzona_pending_checkout_order_${COUPON_STORE_KEY}`;
		const CART_STORAGE_KEY = window.PZ_CART_STORAGE_KEY || `tusenda84_cart_${CURRENT_STORE_ID || 'powerzona'}`;
		const CHECKOUT_CART_STORAGE_KEY = window.PZ_CHECKOUT_CART_STORAGE_KEY || `${CART_STORAGE_KEY}_checkout`;
		const cartStorage = window.PZCartStorage || null;
		const CLOSED_MESSAGE_DEFAULT = 'Estamos fuera de horario, pero puedes realizar tu pedido. Lo atenderemos en horario laboral.';
		const TEMPORARILY_CLOSED_MESSAGE_DEFAULT = 'Estamos cerrados temporalmente. Puedes realizar tu pedido y te responderemos pronto.';
		const BUSINESS_DAY_KEYS = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
		const DEFAULT_BUSINESS_HOURS = {
			monday: { enabled: false, open: '09:00', close: '18:00' },
			tuesday: { enabled: false, open: '09:00', close: '18:00' },
			wednesday: { enabled: false, open: '09:00', close: '18:00' },
			thursday: { enabled: false, open: '09:00', close: '18:00' },
			friday: { enabled: false, open: '09:00', close: '18:00' },
			saturday: { enabled: false, open: '09:00', close: '18:00' },
			sunday: { enabled: false, open: '09:00', close: '18:00' },
		};

		function parseBusinessHours(value) {
			if (!value) return DEFAULT_BUSINESS_HOURS;
			if (typeof value === 'string') {
				try {
					const parsed = JSON.parse(value);
					return parsed && typeof parsed === 'object' ? parsed : DEFAULT_BUSINESS_HOURS;
				} catch (_) {
					return DEFAULT_BUSINESS_HOURS;
				}
			}
			return value && typeof value === 'object' ? value : DEFAULT_BUSINESS_HOURS;
		}

		function timeToMinutes(value) {
			const match = String(value || '').match(/^(\d{1,2}):(\d{2})$/);
			if (!match) return null;
			const hours = Number(match[1]);
			const minutes = Number(match[2]);
			if (hours < 0 || hours > 23 || minutes < 0 || minutes > 59) return null;
			return hours * 60 + minutes;
		}

		function getHavanaNow() {
			const parts = new Intl.DateTimeFormat('en-US', {
				timeZone: 'America/Havana',
				weekday: 'short',
				hour: '2-digit',
				minute: '2-digit',
				hour12: false,
			}).formatToParts(new Date());
			const part = (type) => parts.find((item) => item.type === type)?.value || '';
			const weekdays = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
			return { dayIndex: weekdays[part('weekday')] ?? 0, minutes: Number(part('hour')) * 60 + Number(part('minute')) };
		}

		function isDayOpen(day, minutes) {
			if (!day || day.enabled !== true) return false;
			const open = timeToMinutes(day.open);
			const close = timeToMinutes(day.close);
			if (open === null || close === null || open === close) return false;
			if (open < close) return minutes >= open && minutes < close;
			return minutes >= open || minutes < close;
		}

		function getBusinessHoursStatus(settings) {
			const mode = settings?.business_hours_mode || 'always_available';
			if (mode === 'temporarily_closed') {
				return {
					mode,
					isAvailable: false,
					isClosed: true,
					title: 'Cerrado temporalmente',
					message: settings?.temporarily_closed_message || TEMPORARILY_CLOSED_MESSAGE_DEFAULT,
					note: 'Nota: pedido realizado mientras la tienda estaba cerrada temporalmente.',
					allowOrders: settings?.allow_orders_when_closed !== false,
				};
			}
			if (mode !== 'custom') return { mode: 'always_available', isAvailable: true, isClosed: false, title: '', message: '', note: '', allowOrders: true };
			const now = getHavanaNow();
			const hours = parseBusinessHours(settings?.business_hours);
			const isAvailable = isDayOpen(hours[BUSINESS_DAY_KEYS[now.dayIndex]], now.minutes);
			return {
				mode,
				isAvailable,
				isClosed: !isAvailable,
				title: isAvailable ? 'Disponible ahora' : 'Fuera de horario',
				message: isAvailable ? '' : (settings?.closed_message || CLOSED_MESSAGE_DEFAULT),
				note: isAvailable ? '' : 'Nota: pedido realizado fuera de horario laboral.',
				allowOrders: settings?.allow_orders_when_closed !== false,
			};
		}

			function parseStoredCart(value) {
				try {
					const parsed = JSON.parse(value || '[]');
					return Array.isArray(parsed) ? parsed : [];
				} catch (error) {
					console.warn('Carrito guardado inválido.', error);
					return [];
				}
			}

			function getCart() {
				if (cartStorage?.readCart) return cartStorage.readCart();
				const localCart = parseStoredCart(localStorage.getItem(CART_STORAGE_KEY));
				if (localCart.length) return localCart;

				const checkoutBackup = parseStoredCart(sessionStorage.getItem(CHECKOUT_CART_STORAGE_KEY));
				if (checkoutBackup.length) {
					localStorage.setItem(CART_STORAGE_KEY, JSON.stringify(checkoutBackup));
					return checkoutBackup;
				}

				return [];
			}

			function saveCart(cart) {
				if (checkoutLocked) return;
				const nextCart = Array.isArray(cart)
					? cart.map((item) => ({ ...item, store_id: item?.store_id || CURRENT_STORE_ID }))
					: [];
				if (cartStorage?.writeCart) cartStorage.writeCart(nextCart);
				else {
					const payload = JSON.stringify(nextCart);
					localStorage.setItem(CART_STORAGE_KEY, payload);
					if (nextCart.length) sessionStorage.setItem(CHECKOUT_CART_STORAGE_KEY, payload);
					else sessionStorage.removeItem(CHECKOUT_CART_STORAGE_KEY);
				}
				window.dispatchEvent(new Event('cart-updated'));
				renderCheckout();
			}


		function buildCartFingerprint(cart) {
			return (cart || [])
				.map((item) => `${item?.is_gift ? 'gift' : 'product'}:${item?.id || item?.gift_id || item?.title}:${item?.variation_id || ''}:${Number(item?.quantity || 1)}`)
				.sort()
				.join('|');
		}

		function getPendingCheckoutOrder(cart) {
			try {
				const pending = JSON.parse(sessionStorage.getItem(PENDING_ORDER_KEY) || 'null');
				if (!pending || !pending.whatsappUrl || !pending.cartFingerprint) return null;
				const currentFingerprint = buildCartFingerprint(cart || getCart());
				if (!currentFingerprint || pending.cartFingerprint !== currentFingerprint) {
					sessionStorage.removeItem(PENDING_ORDER_KEY);
					return null;
				}
				return pending;
			} catch (error) {
				sessionStorage.removeItem(PENDING_ORDER_KEY);
				return null;
			}
		}

		function savePendingCheckoutOrder({ orderNumber, whatsappUrl, cartFingerprint }) {
			const payload = { orderNumber, whatsappUrl, cartFingerprint, createdAt: Date.now() };
			sessionStorage.setItem(PENDING_ORDER_KEY, JSON.stringify(payload));
		}

		function clearPendingCheckoutOrder() {
			sessionStorage.removeItem(PENDING_ORDER_KEY);
		}

		function setCheckoutLocked(locked) {
			checkoutLocked = Boolean(locked);
			checkoutForm?.querySelectorAll('input, select, textarea').forEach((field) => {
				field.disabled = checkoutLocked;
			});
			[manualCouponInput, manualCouponApplyBtn].forEach((field) => {
				if (field) field.disabled = checkoutLocked;
			});
			document.querySelectorAll('.delivery-option').forEach((label) => {
				label.classList.toggle('opacity-60', checkoutLocked);
				label.classList.toggle('cursor-not-allowed', checkoutLocked);
			});
			const addMoreBox = document.getElementById('add-more-products-box');
			if (addMoreBox) addMoreBox.classList.toggle('hidden', checkoutLocked);
		}

		function markOrderCreated({ orderNumber, whatsappUrl, cartFingerprint }) {
			orderWasCreated = true;
			isSubmittingOrder = false;
			savedWhatsappUrl = whatsappUrl;
			savedOrderNumber = orderNumber || '';
			pendingOrderFingerprint = cartFingerprint || buildCartFingerprint(getCart());
			if (savedWhatsappUrl) {
				savePendingCheckoutOrder({
					orderNumber: savedOrderNumber,
					whatsappUrl: savedWhatsappUrl,
					cartFingerprint: pendingOrderFingerprint,
				});
			}
			setCheckoutLocked(true);
			continueWhatsappBtn.disabled = false;
			continueWhatsappBtn.textContent = 'Abrir WhatsApp del pedido';
			checkoutValidationAlert.classList.add('hidden');
			checkoutSuccessAlert.innerHTML = `
				<div class="font-black mb-2">Pedido ${escapeHtml(savedOrderNumber || '')} guardado correctamente.</div>
				<div class="mb-3">La orden ya quedó registrada. Ahora abre WhatsApp para enviar el resumen al negocio.</div>
			`;
			checkoutSuccessAlert.classList.remove('hidden');
		}

		function resetOrderCreatedState() {
			orderWasCreated = false;
			isSubmittingOrder = false;
			savedWhatsappUrl = '';
			savedOrderNumber = '';
			pendingOrderFingerprint = '';
			setCheckoutLocked(false);
			clearPendingCheckoutOrder();
		}

		function completeCheckoutAfterWhatsApp() {
			localStorage.removeItem(CART_STORAGE_KEY);
			sessionStorage.removeItem(CHECKOUT_CART_STORAGE_KEY);
			localStorage.removeItem('powerzona_checkout_draft');
			clearPendingCheckoutOrder();
			window.dispatchEvent(new Event('cart-updated'));
			checkoutContent?.classList.add('hidden');
			checkoutEmpty?.classList.remove('hidden');
			setTimeout(() => {
				window.location.href = homePath || '/';
			}, 900);
		}

		function getItemKey(item) {
			if (item?.is_gift) return `gift::${item.gift_id || item.id}`;
			return item?.variation_id ? `${item.id}::${item.variation_id}` : (item.id || item.title);
		}

		function formatUSD(value) {
			return '$' + Number(value || 0).toFixed(2) + ' USD';
		}

		function selectedCurrencyCode() {
			return window.PZCurrency?.selected?.code || localStorage.getItem(`powerzona_currency_${COUPON_STORE_KEY}`) || localStorage.getItem('powerzona_currency') || 'USD';
		}

		function formatVisualFromUsd(value, options = {}) {
			if (window.PZCurrency?.formatVisualFromUsd) return window.PZCurrency.formatVisualFromUsd(value, options);
			return formatUSD(value);
		}

		function convertFromUsd(value, currencyCode = selectedCurrencyCode()) {
			if (window.PZCurrency?.convertFromUsd) return window.PZCurrency.convertFromUsd(value, currencyCode);
			return Number(value || 0);
		}

		function formatShipping(value) {
			if (window.PZCurrency?.formatShipping) return window.PZCurrency.formatShipping(value);
			return formatUSD(value);
		}

		function calculateCartPromotions(cart) {
			return window.PZPromotions?.calculateCartPromotions(cart, window.PZ_AUTOMATIC_PROMOTIONS || []) || {
				items: cart,
				subtotalOriginalUSD: cart.reduce((sum, item) => item.is_gift ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				localCurrencyOriginalTotal: cart.reduce((sum, item) => item.is_gift || item.only_usd ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				usdOnlyOriginalTotal: cart.reduce((sum, item) => item.is_gift || !item.only_usd ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				discountTotalUSD: 0,
				usdOnlyDiscountTotal: 0,
				localCurrencyDiscountTotal: 0,
				subtotalFinalUSD: cart.reduce((sum, item) => item.is_gift ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				localCurrencyTotal: cart.reduce((sum, item) => item.is_gift || item.only_usd ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				usdOnlyTotal: cart.reduce((sum, item) => item.is_gift || !item.only_usd ? sum : sum + Number(item.price || 0) * Number(item.quantity || 1), 0),
				appliedPromotions: [],
				promotionSummary: '',
			};
		}

		function readSavedCouponCodes() {
			try {
				const parsed = JSON.parse(localStorage.getItem(SAVED_COUPONS_KEY) || '[]');
				return Array.isArray(parsed) ? parsed.map((code) => String(code || '').trim().toUpperCase()).filter(Boolean) : [];
			} catch (_) {
				return [];
			}
		}

		function saveCouponCode(code) {
			const normalized = String(code || '').trim().toUpperCase();
			if (!normalized) return;
			const codes = readSavedCouponCodes();
			if (!codes.includes(normalized)) codes.push(normalized);
			localStorage.setItem(SAVED_COUPONS_KEY, JSON.stringify(codes.slice(-12)));
			selectedManualCouponCode = normalized;
			localStorage.setItem(SELECTED_COUPON_KEY, normalized);
		}

		function writeSavedCouponCodes(codes) {
			const cleanCodes = [...new Set((codes || []).map((code) => String(code || '').trim().toUpperCase()).filter(Boolean))];
			localStorage.setItem(SAVED_COUPONS_KEY, JSON.stringify(cleanCodes.slice(-12)));
		}

		function removeSavedCouponCode(code) {
			const normalized = String(code || '').trim().toUpperCase();
			if (!normalized) return;
			writeSavedCouponCodes(readSavedCouponCodes().filter((item) => item !== normalized));
			if (String(selectedManualCouponCode || '').toUpperCase() === normalized) clearSelectedCoupon();
		}

		function clearSelectedCoupon() {
			selectedManualCouponCode = '';
			localStorage.removeItem(SELECTED_COUPON_KEY);
		}

		function getActiveManualCoupons() {
			return (window.PZ_MANUAL_COUPONS || []).map((coupon) => window.PZPromotions?.normalizeCoupon ? window.PZPromotions.normalizeCoupon(coupon) : coupon);
		}

		function getCouponByCode(code) {
			const normalized = String(code || '').trim().toUpperCase();
			if (!normalized) return null;
			return getActiveManualCoupons().find((coupon) => String(coupon.code || '').toUpperCase() === normalized) || null;
		}

		function couponDateTime(value, boundary = 'start') {
			if (!value) return 0;
			const text = String(value);
			if (/^\d{4}-\d{2}-\d{2}$/.test(text)) {
				const [year, month, day] = text.split('-').map(Number);
				const date = boundary === 'end'
					? new Date(year, month - 1, day, 23, 59, 59, 999)
					: new Date(year, month - 1, day, 0, 0, 0, 0);
				return date.getTime();
			}
			const parsed = new Date(text).getTime();
			return Number.isFinite(parsed) ? parsed : 0;
		}

		function couponIsAvailable(coupon) {
			if (!coupon || coupon.active === false) return false;
			const now = Date.now();
			const startsAt = couponDateTime(coupon.starts_at, 'start');
			const endsAt = couponDateTime(coupon.ends_at, 'end');
			if (startsAt && startsAt > now) return false;
			if (endsAt && endsAt < now) return false;
			const maxUses = Number(coupon.max_uses || 0);
			const usedCount = Number(coupon.used_count || 0);
			if (coupon.unlimited_uses === false && maxUses > 0 && usedCount >= maxUses) return false;
			return true;
		}

		function syncSavedCouponsWithActiveCoupons() {
			if (!Array.isArray(window.PZ_MANUAL_COUPONS)) return readSavedCouponCodes();
			const activeCodes = new Set(getActiveManualCoupons().filter(couponIsAvailable).map((coupon) => String(coupon.code || '').toUpperCase()).filter(Boolean));
			const savedCodes = readSavedCouponCodes();
			const nextCodes = savedCodes.filter((code) => activeCodes.has(code));
			if (nextCodes.length !== savedCodes.length) writeSavedCouponCodes(nextCodes);
			if (selectedManualCouponCode && !activeCodes.has(String(selectedManualCouponCode).toUpperCase())) clearSelectedCoupon();
			return nextCodes;
		}

		function setCouponAlert(message = '', type = 'info') {
			if (!manualCouponAlert) return;
			manualCouponAlert.textContent = message || '';
			manualCouponAlert.classList.toggle('hidden', !message);
			manualCouponAlert.className = `mt-3 rounded-2xl border p-3 text-xs font-bold ${message ? '' : 'hidden'} ${
				type === 'error' ? 'bg-red-50 border-red-100 text-red-700' :
				type === 'success' ? 'bg-green-50 border-green-100 text-green-800' :
				'bg-blue-50 border-blue-100 text-blue-800'
			}`;
		}

		function couponDisplayMessage(coupon) {
			return coupon?.customer_message || window.PZPromotions?.couponLabel?.(coupon) || coupon?.name || 'Cupón disponible.';
		}

		function calculateTotalsWithCoupon(cart, shippingZone = null, deliveryMethod = '') {
			const shippingUSD = deliveryMethod === 'delivery' ? getShippingZonePrice(shippingZone) : 0;
			const coupon = getCouponByCode(selectedManualCouponCode);
			return window.PZPromotions?.calculateCartWithManualCoupon
				? window.PZPromotions.calculateCartWithManualCoupon(cart, window.PZ_AUTOMATIC_PROMOTIONS || [], coupon, deliveryMethod, shippingUSD)
				: calculateCartPromotions(cart);
		}

		function getSelectedCurrencyObject() {
			return window.PZCurrency?.selected || { code: selectedCurrencyCode(), id: '', exchange_rate: 1 };
		}

		function formatCheckoutTotals(totals) {
			const selected = selectedCurrencyCode();
			if (selected !== 'USD' && totals.usdOnlyTotal > 0 && totals.localCurrencyTotal > 0) {
				return `${formatVisualFromUsd(totals.localCurrencyTotal, { onlyUsd: false })} + ${formatUSD(totals.usdOnlyTotal)}`;
			}
			if (totals.usdOnlyTotal > 0 && totals.localCurrencyTotal <= 0) return formatUSD(totals.usdOnlyTotal);
			return formatVisualFromUsd(totals.localCurrencyTotal || totals.subtotalUSD, { onlyUsd: false });
		}

		function formatCheckoutOriginalTotals(totals) {
			const selected = selectedCurrencyCode();
			const localOriginal = Number(totals.localCurrencyOriginalTotal ?? totals.localCurrencyTotal ?? 0);
			const usdOriginal = Number(totals.usdOnlyOriginalTotal ?? totals.usdOnlyTotal ?? 0);
			if (selected !== 'USD' && usdOriginal > 0 && localOriginal > 0) {
				return `${formatVisualFromUsd(localOriginal, { onlyUsd: false })} + ${formatUSD(usdOriginal)}`;
			}
			if (usdOriginal > 0 && localOriginal <= 0) return formatUSD(usdOriginal);
			return formatVisualFromUsd(localOriginal || totals.subtotalOriginalUSD || totals.subtotalUSD, { onlyUsd: false });
		}

		function formatCheckoutDiscount(totals) {
			const selected = selectedCurrencyCode();
			const usdOnlyDiscount = Number(totals.usdOnlyDiscountTotal || 0);
			const localDiscount = Number(totals.localCurrencyDiscountTotal || 0);
			if (selected !== 'USD' && usdOnlyDiscount > 0 && localDiscount > 0) {
				return `${formatVisualFromUsd(localDiscount, { onlyUsd: false })} + ${formatUSD(usdOnlyDiscount)}`;
			}
			if (usdOnlyDiscount > 0 && localDiscount <= 0) return formatUSD(usdOnlyDiscount);
			if (localDiscount > 0) return formatVisualFromUsd(localDiscount, { onlyUsd: false });
			return formatVisualFromUsd(totals.discountTotalUSD, { onlyUsd: false });
		}

		function formatCheckoutDiscountWithSign(totals) {
			const selected = selectedCurrencyCode();
			const usdOnlyDiscount = Number(totals.usdOnlyDiscountTotal || 0);
			const localDiscount = Number(totals.localCurrencyDiscountTotal || 0);
			if (selected !== 'USD' && usdOnlyDiscount > 0 && localDiscount > 0) {
				return `-${formatVisualFromUsd(localDiscount, { onlyUsd: false })} + -${formatUSD(usdOnlyDiscount)}`;
			}
			return `-${formatCheckoutDiscount(totals)}`;
		}

		function formatWhatsAppDiscount(totals) {
			const selected = selectedCurrencyCode();
			const usdOnlyDiscount = Number(totals.usdOnlyDiscountTotal || 0);
			const localDiscount = Number(totals.localCurrencyDiscountTotal || 0);
			if (selected !== 'USD' && usdOnlyDiscount > 0 && localDiscount > 0) {
				return `*Descuento ${selected}*: -${formatVisualFromUsd(localDiscount, { onlyUsd: false })}
*Descuento USD*: -${formatUSD(usdOnlyDiscount)}`;
			}
			if (usdOnlyDiscount > 0 && localDiscount <= 0) return `*Descuento aplicado*: -${formatUSD(usdOnlyDiscount)}`;
			if (localDiscount > 0) return `*Descuento aplicado*: -${formatVisualFromUsd(localDiscount, { onlyUsd: false })}`;
			return `*Descuento aplicado*: -${formatVisualFromUsd(totals.discountTotalUSD, { onlyUsd: false })}`;
		}

		function getPromotionReasonText(totals) {
			if (totals?.couponWinner === 'manual_coupon' && totals.manualCoupon?.code) {
				return totals.manualCoupon.scope === 'free_shipping'
					? `${totals.manualCoupon.code} · Envío gratis`
					: `${totals.manualCoupon.code} · ${couponDisplayMessage(totals.manualCoupon)}`;
			}
			const promos = totals?.appliedPromotions || [];
			const labels = promos
				.map((promo) => promo.label || promo.name || '')
				.filter(Boolean)
				.filter((label, index, list) => list.indexOf(label) === index);
			return labels.join(' / ');
		}

		function getCheckoutSummaryCurrencyLabel(totals) {
			const selected = selectedCurrencyCode();
			if (totals.usdOnlyTotal > 0 && totals.localCurrencyTotal <= 0) return 'USD';
			if (selected !== 'USD' && totals.usdOnlyTotal > 0 && totals.localCurrencyTotal > 0) return `${selected} + USD`;
			return selected;
		}

		function escapeHtml(value) {
			return String(value || '')
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#039;');
		}

		function getShippingZonePrice(zone) {
			if (!zone) return 0;
		return Number(zone.price_usd ?? 0);	
		}

		function getSelectedShippingZone() {
			const selectedId = customerShippingZone?.value || '';
			return shippingZones.find((zone) => zone.id === selectedId) || null;
		}

		function getUniqueMunicipalities() {
			return [...new Set(shippingZones.map((zone) => zone.municipality).filter(Boolean))].sort((a, b) => a.localeCompare(b));
		}

		function normalizeDeliveryMode(deliveryMode) {
			const value = String(deliveryMode || 'both').trim().toLowerCase();

			if (value === 'delivery' || value === 'solo_envio' || value === 'solo envío' || value === 'solo envio') {
				return 'delivery';
			}

			if (value === 'pickup' || value === 'solo_recogida' || value === 'solo recogida') {
				return 'pickup';
			}

			return 'both';
		}

		function getDeliveryText(deliveryMode) {
			const normalizedMode = normalizeDeliveryMode(deliveryMode);

			if (normalizedMode === 'delivery') return 'Solo envío';
			if (normalizedMode === 'pickup') return 'Solo recogida';
			return 'Envío o recogida';
		}

		function getSelectedDeliveryMethod() {
			const selected = document.querySelector('input[name="delivery_method"]:checked');
			return selected ? selected.value : '';
		}

		function getDeliveryMethodText(method) {
			if (method === 'delivery') return 'Envío';
			if (method === 'pickup') return 'Para recoger';
			if (method === 'coordinate') return 'Coordinar entrega';
			return 'Pendiente';
		}

		function getWhatsAppDeliveryLine(checkoutData, totals) {
			if (checkoutData?.delivery_method === 'delivery') {
				if (Number(totals?.shippingDiscountUSD || 0) > 0) {
					return `*Cupón aplicado*: ${totals.manualCoupon?.code || 'Envío gratis'}
*Envío*: 0`;
				}
				return `*Total de envío*: ${formatShipping(totals.shippingUSD)}`;
			}

			if (checkoutData?.delivery_method === 'pickup') {
				return '*Entrega*: Para recoger';
			}

			if (checkoutData?.delivery_method === 'coordinate') {
				return '*Entrega*: A coordinar con la tienda';
			}

			return '*Entrega*: Pendiente';
		}

		async function loadShippingZones() {
			if (shippingZonesLoaded) return;

			if (!POCKETBASE_URL) {
				throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el archivo .env del frontend.');
			}

			const filter = encodeURIComponent(CURRENT_STORE_ID ? `active = true && store="${CURRENT_STORE_ID}"` : 'active = true');
			const response = await fetch(
				`${POCKETBASE_URL}/api/collections/shipping_zones/records?filter=${filter}&sort=municipality,zone&perPage=200`
			);
			const result = await response.json().catch(() => null);

			if (!response.ok) {
				console.error('Error leyendo shipping_zones:', result);
				throw new Error('No se pudieron cargar las zonas de envío desde PocketBase.');
			}

			shippingZones = result?.items || [];
			shippingZonesLoaded = true;
			renderMunicipalityOptions();
		}

		function renderMunicipalityOptions() {
			if (!customerMunicipality) return;

			const currentValue = customerMunicipality.value;
			const municipalities = getUniqueMunicipalities();

			if (!municipalities.length) {
				customerMunicipality.innerHTML = '<option value="">No hay municipios disponibles</option>';
				customerMunicipality.disabled = true;
				renderShippingZoneOptions('');
				return;
			}

			customerMunicipality.innerHTML = '<option value="">Selecciona municipio</option>' + municipalities
				.map((municipality) => `<option value="${escapeHtml(municipality)}">${escapeHtml(municipality)}</option>`)
				.join('');

			customerMunicipality.disabled = false;

			if (municipalities.includes(currentValue)) {
				customerMunicipality.value = currentValue;
			}

			renderShippingZoneOptions(customerMunicipality.value);
		}

		function renderShippingZoneOptions(municipality) {
			if (!customerShippingZone) return;

			const currentValue = customerShippingZone.value;
			const zones = shippingZones.filter((zone) => zone.municipality === municipality);

			if (!municipality) {
				customerShippingZone.innerHTML = '<option value="">Primero selecciona municipio</option>';
				customerShippingZone.disabled = true;
				return;
			}

			if (!zones.length) {
				customerShippingZone.innerHTML = '<option value="">No hay zonas para este municipio</option>';
				customerShippingZone.disabled = true;
				return;
			}

			customerShippingZone.innerHTML = '<option value="">Selecciona zona</option>' + zones
				.map((zone) => {
					const label = `${zone.zone || zone.municipality} - ${formatShipping(getShippingZonePrice(zone))}`;
					return `<option value="${zone.id}">${escapeHtml(label)}</option>`;
				})
				.join('');

			customerShippingZone.disabled = false;

			if (zones.some((zone) => zone.id === currentValue)) {
				customerShippingZone.value = currentValue;
			}
		}

		function isValidPhone(value) {
			const digits = String(value || '').replace(/\D/g, '');
			return digits.length >= 6;
		}

		function setError(id, show) {
			const element = document.getElementById(id);
			if (!element) return;

			if (show) {
				element.classList.remove('hidden');
			} else {
				element.classList.add('hidden');
			}
		}

		function setFieldInvalid(field, invalid) {
			if (!field) return;

			if (invalid) {
				field.classList.add('ring-2', 'ring-red-400');
			} else {
				field.classList.remove('ring-2', 'ring-red-400');
			}
		}

		function getAvailableDeliveryMethods(cart) {
			const normalItems = cart.filter((item) => !item.is_gift);
			const normalizedModes = normalItems.map((item) => normalizeDeliveryMode(item.delivery_mode));
			const hasDeliveryOnly = normalizedModes.includes('delivery');
			const hasPickupOnly = normalizedModes.includes('pickup');
			const hasFlexible = normalizedModes.includes('both');

			if (hasPickupOnly && (hasDeliveryOnly || hasFlexible)) {
				return ['coordinate'];
			}

			if (hasDeliveryOnly) {
				return ['delivery', 'coordinate'];
			}

			if (hasPickupOnly) {
				return ['pickup', 'coordinate'];
			}

			return ['delivery', 'pickup', 'coordinate'];
		}

		function updateDeliveryOptions(cart) {
			const availableMethods = getAvailableDeliveryMethods(cart);
			const currentMethod = getSelectedDeliveryMethod();

			document.querySelectorAll('input[name="delivery_method"]').forEach((input) => {
				const label = input.closest('.delivery-option');
				const isAvailable = availableMethods.includes(input.value);

				input.disabled = !isAvailable;

				if (!isAvailable) {
					input.checked = false;
					label?.classList.add('opacity-40', 'cursor-not-allowed', 'bg-gray-50');
					label?.classList.remove('cursor-pointer', 'hover:border-blue-500');
				} else {
					label?.classList.remove('opacity-40', 'cursor-not-allowed', 'bg-gray-50');
					label?.classList.add('cursor-pointer', 'hover:border-blue-500');
				}
			});

			if (!availableMethods.includes(currentMethod)) {
				const firstAvailable = document.querySelector(`input[name="delivery_method"][value="${availableMethods[0]}"]`);
				if (firstAvailable) firstAvailable.checked = true;
			}
		}

		function updateDeliveryUI() {
			const method = getSelectedDeliveryMethod();

			document.querySelectorAll('.delivery-option').forEach((label) => {
				const input = label.querySelector('input[name="delivery_method"]');
				const isChecked = input?.checked;

				label.classList.toggle('border-blue-500', Boolean(isChecked));
				label.classList.toggle('bg-blue-50', Boolean(isChecked));
			});

			if (method === 'delivery') {
				municipalityFieldBox?.classList.remove('hidden');
				shippingZoneFieldBox?.classList.remove('hidden');
				addressFieldBox?.classList.remove('hidden');
				deliveryHelper.textContent = 'Selecciona municipio y zona de entrega. El envío se muestra aparte en USD y equivalente de la moneda elegida.';
			} else if (method === 'pickup') {
				municipalityFieldBox?.classList.add('hidden');
				shippingZoneFieldBox?.classList.add('hidden');
				addressFieldBox?.classList.add('hidden');
				deliveryHelper.textContent = 'La recogida se coordinará por WhatsApp. La dirección fija de recogida no se muestra directamente en la web.';
			} else if (method === 'coordinate') {
				municipalityFieldBox?.classList.add('hidden');
				shippingZoneFieldBox?.classList.add('hidden');
				addressFieldBox?.classList.add('hidden');
				deliveryHelper.textContent = 'Un administrador confirmará contigo la mejor forma de entrega según los productos del pedido.';
			} else {
				municipalityFieldBox?.classList.add('hidden');
				shippingZoneFieldBox?.classList.add('hidden');
				addressFieldBox?.classList.add('hidden');
				deliveryHelper.textContent = 'Selecciona cómo deseas recibir el pedido para completar los datos necesarios.';
			}

			const selectedZone = getSelectedShippingZone();
			if (method === 'delivery' && selectedZone) {
				summaryDelivery.textContent = formatShipping(getShippingZonePrice(selectedZone));
			} else {
				summaryDelivery.textContent = getDeliveryMethodText(method);
			}
			summaryDelivery.classList.toggle('text-gray-400', !method);
			summaryDelivery.classList.toggle('text-gray-900', Boolean(method));
		}

		function getCheckoutData() {
			return {
				customer_name: customerName?.value.trim() || '',
				customer_phone: customerPhone?.value.trim() || '',
				customer_municipality: customerMunicipality?.value.trim() || '',
				customer_address: customerAddress?.value.trim() || '',
				customer_note: customerNote?.value.trim() || '',
				delivery_method: getSelectedDeliveryMethod(),
				shipping_zone: customerShippingZone?.value || '',
			};
		}

		function itemTracksStock(item) {
			return item?.track_stock !== false;
		}

		function getProductsSubtotalUSD(cart = getCart()) {
			return cart
				.filter((item) => !item.is_gift)
				.reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 1), 0);
		}

		function validateGiftRulesOnCheckout() {
			const cart = getCart();
			const subtotal = getProductsSubtotalUSD(cart);
			const gifts = cart.filter((item) => item.is_gift);
			if (!gifts.length) return cart;

			let removed = false;
			const validGifts = [];
			for (const gift of gifts) {
				const min = Number(gift.min_order_usd || 0);
				const stock = Number(gift.stock || 0);
				if (!validGifts.length && subtotal >= min && stock > 0) validGifts.push({ ...gift, quantity: 1, price: 0 });
				else removed = true;
			}

			if (!removed && validGifts.length === gifts.length) return cart;

			const nextCart = cart.filter((item) => !item.is_gift).concat(validGifts.slice(0, 1));
			const nextStoreCart = nextCart.map((item) => ({ ...item, store_id: item?.store_id || CURRENT_STORE_ID }));
			if (cartStorage?.writeCart) {
				cartStorage.writeCart(nextStoreCart);
			} else {
				const payload = JSON.stringify(nextStoreCart);
				localStorage.setItem(CART_STORAGE_KEY, payload);
				if (nextStoreCart.length) sessionStorage.setItem(CHECKOUT_CART_STORAGE_KEY, payload);
				else sessionStorage.removeItem(CHECKOUT_CART_STORAGE_KEY);
			}
			sessionStorage.setItem('powerzona_gift_notice', 'Tu compra no cumplía con las reglas del regalo. Por favor, vuelve a agregarlo después de agregar algo más a tu carrito.');
			return nextStoreCart;
		}

		function getStockProblemItems(cart) {
			return cart.filter((item) => {
				const stock = Number(item.stock || 0);
				const quantity = Number(item.quantity || 1);
				const isPreorder = Boolean(item.preorder);

				return itemTracksStock(item) && !isPreorder && (stock <= 0 || quantity > stock);
			});
		}

		function validateCheckout(showErrors = false) {
			const cart = getCart();
			const data = getCheckoutData();
			const requiresAddress = data.delivery_method === 'delivery';
			const stockProblemItems = getStockProblemItems(cart);

			const errors = {
				cart: cart.filter((item) => !item.is_gift).length === 0,
				stock: stockProblemItems.length > 0,
				name: data.customer_name.length < 2,
				phone: !isValidPhone(data.customer_phone),
				delivery_method: !data.delivery_method,
				municipality: requiresAddress && data.customer_municipality.length < 2,
				shipping_zone: requiresAddress && !data.shipping_zone,
				address: requiresAddress && data.customer_address.length < 5,
				business_hours: businessHoursStatus.isClosed && businessHoursStatus.allowOrders === false,
			};

			if (showErrors) {
				setError('customer-name-error', errors.name);
				setError('customer-phone-error', errors.phone);
				setError('delivery-method-error', errors.delivery_method);
				setError('customer-municipality-error', errors.municipality);
				setError('customer-shipping-zone-error', errors.shipping_zone);
				setError('customer-address-error', errors.address);

				setFieldInvalid(customerName, errors.name);
				setFieldInvalid(customerPhone, errors.phone);
				setFieldInvalid(customerMunicipality, errors.municipality);
				setFieldInvalid(customerShippingZone, errors.shipping_zone);
				setFieldInvalid(customerAddress, errors.address);
			}

			if (errors.stock) {
				const names = stockProblemItems.map((item) => item.title).filter(Boolean).join(', ');
				checkoutValidationAlert.textContent = `Hay productos agotados o con cantidad mayor al stock disponible: ${names}. Elimínalos o ajusta la cantidad para continuar.`;
				checkoutValidationAlert.classList.remove('hidden');
			}

			if (!errors.stock && errors.business_hours) {
				checkoutValidationAlert.textContent = 'La tienda no acepta pedidos fuera de horario en este momento.';
				checkoutValidationAlert.classList.remove('hidden');
			}

			const isValid = !Object.values(errors).some(Boolean);

			if (orderWasCreated) {
				continueWhatsappBtn.disabled = false;
				continueWhatsappBtn.textContent = 'Abrir WhatsApp del pedido';
			} else if (isSubmittingOrder) {
				continueWhatsappBtn.disabled = true;
			} else {
				continueWhatsappBtn.disabled = !isValid;
			}

			if (isValid) {
				checkoutValidationAlert.classList.add('hidden');
			}

			return { isValid, errors, data };
		}

		function renderManualCouponSection(cart, totals) {
			if (!savedCouponsList) return;
			const activeCoupons = getActiveManualCoupons();
			const savedCodes = syncSavedCouponsWithActiveCoupons();
			const visibleCodes = [...new Set([...savedCodes, selectedManualCouponCode].map((code) => String(code || '').toUpperCase()).filter(Boolean))];
			if (manualCouponMultipleNote) manualCouponMultipleNote.classList.toggle('hidden', visibleCodes.length < 2);
			if (manualCouponInput && !manualCouponInput.value && selectedManualCouponCode) manualCouponInput.value = selectedManualCouponCode;

			if (!visibleCodes.length) {
				savedCouponsList.innerHTML = '<div class="rounded-2xl bg-gray-50 border border-gray-100 p-3 text-xs font-bold text-gray-500">No tienes cupones guardados todavía.</div>';
			} else {
				const selectedZone = getSelectedShippingZone();
				const deliveryMethod = getSelectedDeliveryMethod();
				const rows = visibleCodes.map((code) => {
					const coupon = activeCoupons.find((item) => String(item.code || '').toUpperCase() === code);
					const preview = coupon && window.PZPromotions?.calculateCartWithManualCoupon
						? window.PZPromotions.calculateCartWithManualCoupon(cart, window.PZ_AUTOMATIC_PROMOTIONS || [], coupon, deliveryMethod, deliveryMethod === 'delivery' ? getShippingZonePrice(selectedZone) : 0)
						: null;
					const isSelected = selectedManualCouponCode === code;
					const status = preview?.manualCouponStatus;
					const applies = preview?.couponWinner === 'manual_coupon';
					const message = coupon ? (status?.message || couponDisplayMessage(coupon)) : 'El cupón no es válido.';
					const benefit = Number(preview?.couponDiscountUSD || 0) + Number(preview?.shippingDiscountUSD || 0);
					return `
						<article class="rounded-2xl border ${isSelected ? 'border-slate-900 bg-slate-50' : 'border-gray-100 bg-gray-50'} p-3">
							<div class="flex items-start justify-between gap-3">
								<div>
									<p class="font-black text-gray-900">${escapeHtml(code)} ${coupon ? `· ${escapeHtml(window.PZPromotions?.couponScopeLabel?.(coupon) || 'Cupón')}` : ''}</p>
									<p class="text-xs font-semibold ${coupon && status?.ok ? 'text-gray-600' : 'text-red-600'} mt-1">${escapeHtml(message)}</p>
									${benefit > 0 ? `<p class="text-xs font-black text-green-700 mt-1">Beneficio: ${formatUSD(benefit)}</p>` : ''}
								</div>
								<div class="flex flex-col gap-2">
									${isSelected ? '<span class="text-xs font-black text-slate-900 text-right">Seleccionado</span>' : `<button class="text-xs font-black text-blue-700 js-select-coupon" data-coupon-code="${escapeHtml(code)}" type="button">Usar este cupón</button>`}
									${isSelected ? `<button class="text-xs font-black text-gray-500 js-clear-coupon" type="button">Quitar</button>` : ''}
								</div>
							</div>
							${isSelected && applies ? '<p class="text-xs font-black text-green-800 mt-2">Este cupón se aplicará a tu orden.</p>' : ''}
						</article>
					`;
				}).join('');
				savedCouponsList.innerHTML = rows;
			}

			const selectedCoupon = getCouponByCode(selectedManualCouponCode);
			if (!selectedManualCouponCode) {
				setCouponAlert('', 'info');
			} else if (!selectedCoupon) {
				setCouponAlert('El cupón no es válido.', 'error');
			} else if (totals?.couponWinner === 'manual_coupon') {
				setCouponAlert(selectedCoupon.scope === 'free_shipping' ? 'Cupón aplicado: tu envío queda en 0.' : `Cupón aplicado: ${formatUSD(Number(totals.couponDiscountUSD || 0))} de descuento.`, 'success');
			} else if (totals?.manualCouponStatus?.message) {
				setCouponAlert(totals.manualCouponStatus.message, totals.manualCouponStatus.ok ? 'info' : 'error');
			}
		}

		function renderBusinessHoursAlert() {
			if (!checkoutBusinessHoursAlert) return;
			if (!businessHoursStatus.isClosed) {
				checkoutBusinessHoursAlert.className = 'mt-4 hidden rounded-2xl border p-3 text-xs font-bold';
				checkoutBusinessHoursAlert.textContent = '';
				return;
			}
			const blocks = [
				businessHoursStatus.title,
				businessHoursStatus.message,
				businessHoursStatus.allowOrders
					? 'Puedes completar tu pedido. Lo atenderemos en horario laboral.'
					: 'La tienda no acepta pedidos fuera de horario en este momento.',
			].filter(Boolean);
			checkoutBusinessHoursAlert.className = businessHoursStatus.allowOrders
				? 'mt-4 rounded-2xl border border-orange-100 bg-orange-50 text-orange-800 p-3 text-xs font-bold'
				: 'mt-4 rounded-2xl border border-red-100 bg-red-50 text-red-700 p-3 text-xs font-bold';
			checkoutBusinessHoursAlert.innerHTML = blocks.map((line, index) => index === 0 ? `<strong class="block mb-1">${escapeHtml(line)}</strong>` : `<p class="mt-1">${escapeHtml(line)}</p>`).join('');
		}

		function renderCheckout() {
			const cart = validateGiftRulesOnCheckout();

			const giftNotice = sessionStorage.getItem('powerzona_gift_notice');
			if (giftNotice) {
				checkoutValidationAlert.textContent = giftNotice;
				checkoutValidationAlert.classList.remove('hidden');
				sessionStorage.removeItem('powerzona_gift_notice');
			}

			if (!cart.length || cart.filter((item) => !item.is_gift).length === 0) {
				checkoutEmpty.classList.remove('hidden');
				checkoutContent.classList.add('hidden');

				setTimeout(() => {
					window.location.href = homePath || '/';
				}, 1800);

				return;
			}

			checkoutEmpty.classList.add('hidden');
			checkoutContent.classList.remove('hidden');

			let totalUSD = 0;
			let visualConvertibleTotalUSD = 0;
			let usdOnlyTotalUSD = 0;
			let totalItems = 0;
			let hasOnlyUSD = false;
			let hasDeliveryOnly = false;
			let hasPickupOnly = false;
			let hasFlexibleDelivery = false;
			const selectedShippingZone = getSelectedShippingZone();
			const selectedDeliveryMethod = getSelectedDeliveryMethod();
			const renderTotals = calculateTotals(cart, selectedShippingZone, selectedDeliveryMethod);
			const cartForRender = renderTotals.promotionItems || cart;

			checkoutItems.innerHTML = '';

			cartForRender.forEach((item) => {
				const itemKey = getItemKey(item);
				const price = Number(item.price || 0);
				const quantity = Number(item.quantity || 1);
				const stock = Number(item.stock || 0);
				const lineTotal = item.is_gift ? 0 : Number(item.line_subtotal_final_usd ?? (price * quantity));
				const lineOriginal = item.is_gift ? 0 : Number(item.line_subtotal_original_usd ?? (price * quantity));
				const lineDiscount = Number(item.line_discount_usd || 0);
				const regularPrice = Number(item.regular_price_usd || item.original_price_usd || price || 0);
				const hasOffer = Boolean(item.is_offer) && regularPrice > price && price > 0;
				const lineSavings = hasOffer ? (regularPrice - price) * quantity : 0;
				const hasAutomaticPromo = lineDiscount > 0 && Boolean(item.promotion_label);
				const hasManualCoupon = lineDiscount > 0 && Boolean(item.coupon_label);
				const tracksStock = itemTracksStock(item);
				const isPreorder = Boolean(item.preorder);
				const isOutOfStock = tracksStock && stock <= 0 && !isPreorder;
				const isOverStock = tracksStock && !isPreorder && !isOutOfStock && quantity > stock;
				const isGift = Boolean(item.is_gift);
				const isAtMaxStock = isGift || (tracksStock && !isPreorder && !isOutOfStock && quantity >= stock);

				totalUSD += lineTotal;
				if (item.only_usd) usdOnlyTotalUSD += lineTotal;
				else visualConvertibleTotalUSD += lineTotal;
				if (!item.is_gift) totalItems += quantity;

				if (!item.is_gift && item.only_usd) hasOnlyUSD = true;
				if (!item.is_gift && normalizeDeliveryMode(item.delivery_mode) === 'delivery') hasDeliveryOnly = true;
				if (!item.is_gift && normalizeDeliveryMode(item.delivery_mode) === 'pickup') hasPickupOnly = true;
				if (!item.is_gift && normalizeDeliveryMode(item.delivery_mode) === 'both') hasFlexibleDelivery = true;

				checkoutItems.innerHTML += `
					<div class="p-5 flex gap-4">
						<img
							src="${item.image}"
							alt="${item.title}"
							class="w-20 h-20 object-cover rounded-2xl border border-gray-100"
						/>

						<div class="flex-1">
							<div class="flex justify-between gap-3">
								<div>
									<h3 class="font-bold text-gray-900 leading-snug">
										${item.title}
									</h3>

									${item.variation_label ? `
										<p class="text-xs text-gray-500 font-bold mt-1">${item.variation_label}</p>
									` : ''}

									${hasOffer ? `
										<p class="text-xs text-gray-400 font-black mt-1 line-through">${formatVisualFromUsd(regularPrice, { onlyUsd: Boolean(item.only_usd) })}</p>
										<p class="text-sm text-red-600 font-black mt-1">${formatVisualFromUsd(price, { onlyUsd: Boolean(item.only_usd) })}</p>
										<p class="text-xs text-green-700 font-black mt-1">Oferta · Ahorras ${formatVisualFromUsd(lineSavings, { onlyUsd: Boolean(item.only_usd) })}</p>
									` : `
										<p class="text-sm text-blue-600 font-bold mt-1">
											${item.is_gift ? 'Gratis' : formatVisualFromUsd(price, { onlyUsd: Boolean(item.only_usd) })}
										</p>
									`}
								</div>

								<button
									type="button"
									data-key="${itemKey}"
									class="delete-checkout-item text-gray-300 hover:text-red-500 transition"
									title="Eliminar"
								>
									Eliminar
								</button>
							</div>

							<div class="flex flex-wrap gap-2 mt-3">
								${item.is_gift ? `
									<span class="text-xs font-bold bg-green-100 text-green-700 px-3 py-1 rounded-full">Regalo</span>
								` : item.only_usd ? `
									<span class="text-xs font-bold bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full">
										Solo USD
									</span>
								` : ''}

								${hasOffer ? `
									<span class="text-xs font-bold bg-red-100 text-red-700 px-3 py-1 rounded-full">Oferta</span>
								` : ''}

								${hasAutomaticPromo || hasManualCoupon ? `
									<span class="text-xs font-bold bg-green-100 text-green-700 px-3 py-1 rounded-full">${hasManualCoupon ? 'Cupón aplicado' : 'Promo aplicada'}</span>
								` : ''}

								${!item.is_gift ? `
								<span class="text-xs font-bold bg-gray-100 text-gray-700 px-3 py-1 rounded-full">
									${getDeliveryText(item.delivery_mode)}
								</span>` : ''}

								<span class="text-xs font-bold ${isPreorder ? 'bg-blue-100 text-blue-700' : isOutOfStock ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-700'} px-3 py-1 rounded-full">
									${!tracksStock ? 'Disponible' : isPreorder ? 'Preorden' : isOutOfStock ? 'Agotado' : `Stock: ${stock}`}
								</span>
							</div>

							${item.is_gift ? `
								<p class="text-xs text-gray-500 font-black mt-3">Regalo válido desde ${formatUSD(Number(item.min_order_usd || 0))}. Si bajas el carrito por debajo de la regla, se quitará al revisar el pedido.</p>
							` : (hasAutomaticPromo || hasManualCoupon) ? `
								<div class="mt-3 rounded-2xl bg-green-50 border border-green-100 p-3">
									<p class="text-xs text-green-800 font-black">${hasManualCoupon ? 'Cupón aplicado' : 'Promo aplicada'}: ${escapeHtml(item.coupon_label || item.promotion_label)}</p>
									<p class="text-xs text-green-700 font-black mt-1">Subtotal antes: ${formatVisualFromUsd(lineOriginal, { onlyUsd: Boolean(item.only_usd) })}</p>
									<p class="text-xs text-green-700 font-black mt-1">Ahorro: ${formatVisualFromUsd(lineDiscount, { onlyUsd: Boolean(item.only_usd) })}</p>
								</div>
							` : !tracksStock ? `` : isPreorder ? `
								<p class="text-xs text-blue-700 font-black mt-3">Producto en preorder. Disponibilidad a coordinar por WhatsApp.</p>
							` : isOutOfStock ? `
								<p class="text-xs text-red-600 font-black mt-3">Este producto está agotado. Elimínalo del pedido para continuar.</p>
							` : isOverStock ? `
								<p class="text-xs text-orange-600 font-black mt-3">Cantidad mayor al stock disponible (${stock}). Ajusta la cantidad para continuar.</p>
							` : ''}

							<div class="flex items-center justify-between mt-4">
								<div class="flex items-center border border-gray-200 rounded-xl overflow-hidden">
									<button
										type="button"
										data-key="${itemKey}"
										class="decrease-checkout-item px-3 py-2 text-gray-700 hover:bg-gray-100 font-bold"
									>
										−
									</button>

									<span class="px-4 py-2 text-sm font-bold text-gray-800 bg-gray-50">
										${quantity}
									</span>

									<button
										type="button"
										data-key="${itemKey}"
										${(isAtMaxStock || isOutOfStock) ? 'disabled' : ''}
										class="increase-checkout-item px-3 py-2 font-bold ${
											(isAtMaxStock || isOutOfStock)
												? 'text-gray-400 bg-gray-100 cursor-not-allowed opacity-60'
												: 'text-gray-700 hover:bg-gray-100'
										}"
									>
										+
									</button>
								</div>

								<p class="font-black text-gray-900">
									${item.is_gift ? 'Gratis' : formatVisualFromUsd(lineTotal, { onlyUsd: Boolean(item.only_usd) })}
								</p>
							</div>

							${isAtMaxStock && !isOutOfStock ? `
								<p class="text-xs text-orange-600 font-semibold mt-2">
									Stock máximo alcanzado (${stock} disponibles)
								</p>
							` : ''}
						</div>
					</div>
				`;
			});

			renderManualCouponSection(cart, renderTotals);

			summaryItems.textContent = String(totalItems);
			const selectedShippingPrice = getSelectedDeliveryMethod() === 'delivery'
				? getShippingZonePrice(selectedShippingZone)
				: 0;

			if (summaryCurrency) summaryCurrency.textContent = getCheckoutSummaryCurrencyLabel(renderTotals);
			summarySubtotal.textContent = renderTotals.discountTotalUSD > 0
				? formatCheckoutOriginalTotals(renderTotals)
				: formatCheckoutTotals(renderTotals);
			if (summaryDiscountRow && summaryDiscount) {
				summaryDiscountRow.classList.toggle('hidden', !(renderTotals.discountTotalUSD > 0));
				summaryDiscount.textContent = renderTotals.discountTotalUSD > 0 ? formatCheckoutDiscountWithSign(renderTotals) : '';
			}
			const summaryDiscountPromo = document.getElementById('summary-discount-promo');
			if (summaryDiscountPromo) {
				const reasonText = getPromotionReasonText(renderTotals);
				summaryDiscountPromo.classList.toggle('hidden', !(renderTotals.discountTotalUSD > 0 && reasonText));
				summaryDiscountPromo.textContent = reasonText ? `${renderTotals.couponWinner === 'manual_coupon' ? 'Cupón aplicado' : 'Promo aplicada'}: ${reasonText}` : '';
			}
			summaryTotal.textContent = formatCheckoutTotals(renderTotals);

			if (summaryDeliveryCostNote && summaryDeliveryCost) {
				const hasDeliveryCost = getSelectedDeliveryMethod() === 'delivery' && selectedShippingPrice > 0;
				summaryDeliveryCostNote.classList.toggle('hidden', !hasDeliveryCost);
				summaryDeliveryCost.textContent = hasDeliveryCost && renderTotals.shippingDiscountUSD > 0
					? `Antes: ${formatShipping(selectedShippingPrice)} · Ahora: ${formatShipping(renderTotals.shippingUSD)}`
					: (hasDeliveryCost ? formatShipping(selectedShippingPrice) : '');
			}

			summaryAlerts.innerHTML = '';

			if (hasOnlyUSD) {
				summaryAlerts.innerHTML += `
					<div class="bg-yellow-50 border border-yellow-100 text-yellow-800 rounded-2xl p-3 text-xs font-semibold">
						Este pedido contiene productos Solo USD. Si elegiste CUP, se mostrarán separados para no confundir el pago.
					</div>
				`;
			}

			if (hasPickupOnly && (hasDeliveryOnly || hasFlexibleDelivery)) {
				summaryAlerts.innerHTML += `
					<div class="bg-orange-50 border border-orange-100 text-orange-800 rounded-2xl p-3 text-xs font-semibold">
						Esta orden combina productos con reglas de entrega diferentes. Debe coordinarse con la tienda por WhatsApp.
					</div>
				`;
			}

			updateDeliveryOptions(cart);
			updateDeliveryUI();
			renderBusinessHoursAlert();
			validateCheckout(false);

			document.querySelectorAll('.increase-checkout-item').forEach((btn) => {
				btn.addEventListener('click', (event) => {
					const key = event.currentTarget.dataset.key;
					const currentCart = getCart();

					const updatedCart = currentCart.map((item) => {
						if (getItemKey(item) === key) {
							const quantity = Number(item.quantity || 1);
							const stock = Number(item.stock || 0);

							if (item.is_gift || (itemTracksStock(item) && stock > 0 && quantity >= stock)) {
								return item;
							}

							return {
								...item,
								quantity: quantity + 1,
							};
						}

						return item;
					});

					saveCart(updatedCart);
				});
			});

			document.querySelectorAll('.decrease-checkout-item').forEach((btn) => {
				btn.addEventListener('click', (event) => {
					const key = event.currentTarget.dataset.key;
					const currentCart = getCart();

					const updatedCart = currentCart
						.map((item) => {
							if (getItemKey(item) === key) {
								return {
									...item,
									quantity: Number(item.quantity || 1) - 1,
								};
							}

							return item;
						})
						.filter((item) => Number(item.quantity || 0) > 0);

					saveCart(updatedCart);
				});
			});

			document.querySelectorAll('.delete-checkout-item').forEach((btn) => {
				btn.addEventListener('click', (event) => {
					const key = event.currentTarget.dataset.key;
					const currentCart = getCart();
					const updatedCart = currentCart.filter((item) => getItemKey(item) !== key);

					saveCart(updatedCart);
				});
			});
		}

