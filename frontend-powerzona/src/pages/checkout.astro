		const POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');

		function normalizeOrderPrefix(value) {
			const clean = String(value || '').toUpperCase().replace(/[^A-Z]/g, '').slice(0, 3);
			return clean || 'PP';
		}

		function buildOrderNumber(prefix = 'PP') {
			const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
			let code = '';

			for (let i = 0; i < 5; i++) {
				const randomIndex = Math.floor(Math.random() * characters.length);
				code += characters[randomIndex];
			}

			return `${normalizeOrderPrefix(prefix)}-${code}`;
		}

		function buildReceiptToken() {
			const characters = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
			const cryptoValues = new Uint32Array(24);

			if (window.crypto?.getRandomValues) {
				window.crypto.getRandomValues(cryptoValues);
				return Array.from(cryptoValues, (value) => characters[value % characters.length]).join('');
			}

			let token = '';
			for (let i = 0; i < 24; i++) {
				token += characters[Math.floor(Math.random() * characters.length)];
			}
			return token;
		}

		function buildReceiptUrl(orderNumber, token) {
			const origin = window.location.origin;
			return `${origin}/orden/${encodeURIComponent(orderNumber)}/${encodeURIComponent(token)}`;
		}

		function normalizeWhatsAppNumber(phone) {
			return String(phone || '').replace(/\D/g, '');
		}

		function calculateTotals(cart, shippingZone = null, deliveryMethod = '') {
			const promotionTotals = calculateTotalsWithCoupon(cart, shippingZone, deliveryMethod);
			const subtotalUSD = promotionTotals.subtotalFinalUSD;
			const usdOnlyTotal = promotionTotals.usdOnlyTotal;
			const localCurrencyTotal = promotionTotals.localCurrencyTotal;
			const hasUsdOnly = cart.some((item) => !item.is_gift && Boolean(item.only_usd));
			const hasLocalItems = cart.some((item) => !item.is_gift && !item.only_usd);

			const shippingOriginalUSD = deliveryMethod === 'delivery' ? getShippingZonePrice(shippingZone) : 0;
			const shippingDiscountUSD = Number(promotionTotals.shippingDiscountUSD || 0);
			const shippingUSD = Math.max(0, shippingOriginalUSD - shippingDiscountUSD);

			return {
				subtotalUSD,
				subtotalOriginalUSD: promotionTotals.subtotalOriginalUSD,
				localCurrencyOriginalTotal: promotionTotals.localCurrencyOriginalTotal,
				usdOnlyOriginalTotal: promotionTotals.usdOnlyOriginalTotal,
				discountTotalUSD: promotionTotals.discountTotalUSD,
				usdOnlyDiscountTotal: promotionTotals.usdOnlyDiscountTotal,
				localCurrencyDiscountTotal: promotionTotals.localCurrencyDiscountTotal,
				promotionSummary: promotionTotals.promotionSummary,
				promotionItems: promotionTotals.items,
				appliedPromotions: promotionTotals.appliedPromotions,
				manualCoupon: promotionTotals.manualCoupon,
				manualCouponStatus: promotionTotals.manualCouponStatus,
				couponWinner: promotionTotals.couponWinner,
				couponDiscountUSD: Number(promotionTotals.couponDiscountUSD || 0),
				shippingOriginalUSD,
				shippingDiscountUSD,
				shippingUSD,
				totalUSD: subtotalUSD + shippingUSD,
				usdOnlyTotal,
				localCurrencyTotal,
				visualTotalUSD: localCurrencyTotal,
				mixedPayment: selectedCurrencyCode() !== 'USD' && hasUsdOnly && hasLocalItems,
			};
		}

		async function pocketbaseRequest(collectionName, data) {
			if (!POCKETBASE_URL) {
				throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el archivo .env del frontend.');
			}

			const response = await fetch(`${POCKETBASE_URL}/api/collections/${collectionName}/records`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify(data),
			});

			const result = await response.json().catch(() => null);

			if (!response.ok) {
				console.error(`Error creando registro en ${collectionName}:`, result);
				throw new Error(result?.message || `No se pudo crear el registro en ${collectionName}.`);
			}

			return result;
		}

		async function pocketbasePatch(collectionName, recordId, data) {
			if (!POCKETBASE_URL) {
				throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el archivo .env del frontend.');
			}

			const response = await fetch(`${POCKETBASE_URL}/api/collections/${collectionName}/records/${recordId}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(data),
			});
			const result = await response.json().catch(() => null);
			if (!response.ok) {
				console.error(`Error actualizando registro en ${collectionName}:`, result);
				throw new Error(result?.message || `No se pudo actualizar el registro en ${collectionName}.`);
			}
			return result;
		}

		async function getActiveSettings() {
			if (!POCKETBASE_URL) {
				throw new Error('Falta configurar PUBLIC_POCKETBASE_URL en el archivo .env del frontend.');
			}

			const filter = encodeURIComponent(CURRENT_STORE_ID ? `active = true && store="${CURRENT_STORE_ID}"` : 'active = true');

			const response = await fetch(
				`${POCKETBASE_URL}/api/collections/settings/records?filter=${filter}&expand=default_currency&perPage=1`
			);

			const result = await response.json().catch(() => null);

			if (!response.ok) {
				console.error('Error leyendo settings:', result);
				throw new Error('No se pudo leer la configuración activa de la tienda.');
			}

			const settings = result?.items?.[0];

			if (!settings) {
				throw new Error('No hay una configuración activa en PocketBase. Revisa la colección settings.');
			}

			if (!settings.default_currency) {
				throw new Error('La configuración activa no tiene moneda principal asignada.');
			}

			activeSettingsCache = settings;
			businessHoursStatus = getBusinessHoursStatus(settings);
			renderBusinessHoursAlert();
			validateCheckout(false);

			return settings;
		}

		function getCurrencyId(settings) {
			if (Array.isArray(settings.default_currency)) {
				return settings.default_currency[0];
			}

			return settings.default_currency;
		}

		function getExpandedDefaultCurrency(settings) {
			if (Array.isArray(settings.expand?.default_currency)) {
				return settings.expand.default_currency[0];
			}

			return settings.expand?.default_currency;
		}

		function getStorePublicName(settings) {
			return String(settings?.store_name || settings?.stored_name || 'PowerZona').trim() || 'PowerZona';
		}

		function buildWhatsAppMessage({ order, cart, checkoutData, totals, receiptUrl, settings }) {
	const selectedCode = selectedCurrencyCode();
	const storePublicName = getStorePublicName(settings);
	const calculatedItems = totals.promotionItems || calculateCartPromotions(cart).items || cart;
	const productItems = calculatedItems.filter((item) => !item.is_gift);
	const giftItems = calculatedItems.filter((item) => item.is_gift);
	const productLines = productItems.map((item, index) => {
		const quantity = Number(item.quantity || 1);
		const price = Number(item.price || 0);
		const lineTotal = Number(item.line_subtotal_final_usd ?? (price * quantity));
		const lineOriginal = Number(item.line_subtotal_original_usd ?? (price * quantity));
		const lineDiscount = Number(item.line_discount_usd || 0);
		const variationText = item.variation_label ? ` (${item.variation_label})` : '';
		const preorderText = item.preorder ? '  ⚠️ *PREORDEN*' : '';
		const regularPrice = Number(item.regular_price_usd || item.original_price_usd || price || 0);
		const hasOffer = Boolean(item.is_offer) && regularPrice > price && price > 0;
		const hasAutomaticPromo = lineDiscount > 0 && Boolean(item.promotion_label || item.coupon_label);
		const savingsText = hasOffer ? `
   Oferta: antes ${formatVisualFromUsd(regularPrice * quantity, { onlyUsd: Boolean(item.only_usd) })}
   Ahorra: ${formatVisualFromUsd((regularPrice - price) * quantity, { onlyUsd: Boolean(item.only_usd) })}` : '';
		const promoText = hasAutomaticPromo ? `
   ${item.coupon_label ? 'Cupón aplicado' : 'Promo aplicada'}: ${item.coupon_label || item.promotion_label}
   Subtotal antes de promo: ${formatVisualFromUsd(lineOriginal, { onlyUsd: Boolean(item.only_usd) })}
   Ahorro: ${formatVisualFromUsd(lineDiscount, { onlyUsd: Boolean(item.only_usd) })}` : '';
		const visualPrice = formatVisualFromUsd(lineTotal, { onlyUsd: Boolean(item.only_usd) });
		return `${index + 1}. *${item.title}${variationText}*${preorderText}
   Cantidad: ${quantity}${savingsText}${promoText}
   Importe: ${visualPrice}`;
	});
	const giftLines = giftItems.map((item, index) => `${index + 1}. *${item.title}*
   Cantidad: 1
   Importe: Gratis`);

	const addressText = checkoutData.delivery_method === 'delivery'
		? `
*Municipio*: ${checkoutData.customer_municipality}
*Zona*: ${checkoutData.shipping_zone_name || 'No seleccionada'}
*Dirección*: ${checkoutData.customer_address}`
		: '';

	const noteText = checkoutData.customer_note
		? `
*Nota*: ${checkoutData.customer_note}`
		: '';
	const businessNoteText = businessHoursStatus?.note
		? `
${businessHoursStatus.note}`
		: '';

	let totalText = '';
	if (selectedCode !== 'USD' && totals.usdOnlyTotal > 0 && totals.localCurrencyTotal > 0) {
		totalText = `*Total productos ${selectedCode}*: ${formatVisualFromUsd(totals.localCurrencyTotal, { onlyUsd: false })}
*Total productos USD*: ${formatUSD(totals.usdOnlyTotal)}`;
	} else if (selectedCode !== 'USD' && totals.usdOnlyTotal > 0 && totals.localCurrencyTotal <= 0) {
		totalText = `*Total productos USD*: ${formatUSD(totals.usdOnlyTotal)}`;
	} else {
		totalText = `*Total productos ${selectedCode}*: ${formatVisualFromUsd(totals.localCurrencyTotal || totals.subtotalUSD, { onlyUsd: false })}`;
	}
	const promotionReasonText = getPromotionReasonText(totals);
	const discountText = totals.discountTotalUSD > 0 ? `
${formatWhatsAppDiscount(totals)}${promotionReasonText ? `
*Promo aplicada*: ${promotionReasonText}` : ''}` : '';

	return `${storePublicName}

*Orden: ${order.order_number}*

*Cliente*: ${checkoutData.customer_name}
*Teléfono*: ${checkoutData.customer_phone}
*Tipo servicio*: ${getDeliveryMethodText(checkoutData.delivery_method)}
*Moneda elegida*: ${selectedCode}${addressText}${noteText}${businessNoteText}

*Productos:*
${productLines.join('\n')}${giftLines.length ? `\n\n*Regalo incluido:*\n${giftLines.join('\n')}` : ''}

${getWhatsAppDeliveryLine(checkoutData, totals)}
-------------------------------------------------------------------------------------------
${totalText}${discountText}

Gracias.

*Resumen de su orden:*
${receiptUrl || 'Se enviará al confirmar la orden.'}`;
}


		async function createOrderAndItems(validation) {
			const cart = validateGiftRulesOnCheckout();
			const stockProblemItems = getStockProblemItems(cart);

			if (stockProblemItems.length > 0) {
				throw new Error('No se puede realizar el pedido porque hay productos agotados o con cantidad mayor al stock disponible.');
			}

			const settings = await getActiveSettings();
			if (businessHoursStatus.isClosed && businessHoursStatus.allowOrders === false) {
				throw new Error('La tienda no acepta pedidos fuera de horario en este momento.');
			}
			const whatsappNumber = normalizeWhatsAppNumber(settings.whatsapp_number);

			if (!whatsappNumber) {
				throw new Error('La configuración activa no tiene número de WhatsApp.');
			}

			const selectedShippingZone = getSelectedShippingZone();
			const totals = calculateTotals(cart, selectedShippingZone, validation.data.delivery_method);
			const orderNumber = buildOrderNumber(settings.order_prefix);
			const receiptToken = buildReceiptToken();
			const receiptUrl = buildReceiptUrl(orderNumber, receiptToken);

			const selectedCurrency = getSelectedCurrencyObject();
			const currencyId = selectedCurrency?.id || getCurrencyId(settings);
			const expandedCurrency = selectedCurrency?.id ? selectedCurrency : getExpandedDefaultCurrency(settings);
			const selectedCode = selectedCurrency?.code || selectedCurrencyCode();
			const exchangeRateUsed = Number(expandedCurrency?.exchange_rate || 1);
			const visualConvertibleTotal = selectedCode === 'USD' ? totals.localCurrencyTotal : convertFromUsd(totals.localCurrencyTotal, selectedCode);
			const visualShippingTotal = selectedCode === 'USD' ? totals.shippingUSD : convertFromUsd(totals.shippingUSD, selectedCode);

			const shippingZoneName = selectedShippingZone
				? `${selectedShippingZone.municipality} / ${selectedShippingZone.zone || selectedShippingZone.municipality}`
				: '';

			validation.data.shipping_zone_name = shippingZoneName;

			const orderPayload = {
				store: CURRENT_STORE_ID,
				order_number: orderNumber,
				receipt_token: receiptToken,
				customer_name: validation.data.customer_name,
				customer_phone: validation.data.customer_phone,
				customer_address: validation.data.delivery_method === 'delivery'
					? validation.data.customer_address
					: '',
				currency: currencyId,
				subtotal: totals.subtotalUSD,
				shipping: totals.shippingUSD,
				total: totals.totalUSD,
				usd_total: totals.totalUSD,
				subtotal_original_usd: totals.subtotalOriginalUSD,
				discount_total_usd: totals.discountTotalUSD,
				subtotal_after_discount_usd: totals.subtotalUSD,
				promotion_summary: totals.promotionSummary || '',
				coupon_id: totals.couponWinner === 'manual_coupon' ? (totals.manualCoupon?.id || '') : '',
				coupon_code: totals.couponWinner === 'manual_coupon' ? (totals.manualCoupon?.code || '') : '',
				coupon_discount_usd: totals.couponWinner === 'manual_coupon' ? Number(totals.couponDiscountUSD || 0) : 0,
				coupon_summary: totals.couponWinner === 'manual_coupon' ? (totals.promotionSummary || getPromotionReasonText(totals)) : '',
				shipping_original_usd: totals.shippingOriginalUSD,
				shipping_discount_usd: totals.shippingDiscountUSD,
				mixed_payment: totals.mixedPayment,
				delivery_method: validation.data.delivery_method,
				status: 'pending',
				whatsapp_sent: false,
				notes: [
					validation.data.customer_municipality ? `Municipio: ${validation.data.customer_municipality}` : '',
					validation.data.customer_note ? `Nota cliente: ${validation.data.customer_note}` : '',
					`Moneda elegida cliente: ${selectedCode}`,
					`Total productos visual cliente: ${formatCheckoutTotals(totals)}`,
					totals.discountTotalUSD > 0 ? `${totals.couponWinner === 'manual_coupon' ? 'Descuento cupón USD' : 'Descuento automático USD'}: ${formatUSD(totals.discountTotalUSD)}` : '',
					`Envío visual cliente: ${formatShipping(totals.shippingUSD)}`,
					cart.some((item) => item.preorder) ? `Preorder: ${cart.filter((item) => item.preorder).map((item) => item.title).join(', ')}` : '',
					cart.some((item) => item.is_offer) ? `Ahorro por ofertas USD: ${formatUSD(cart.reduce((sum, item) => sum + (item.is_gift ? 0 : Math.max(0, Number(item.regular_price_usd || item.price || 0) - Number(item.price || 0)) * Number(item.quantity || 1)), 0))}` : '',
				].filter(Boolean).join('\n'),
				local_currency_total: visualConvertibleTotal,
				usd_only_total: totals.usdOnlyTotal,
				shipping_cup: visualShippingTotal,
				shipping_zone: selectedShippingZone?.id || '',
				exchange_rate_used: exchangeRateUsed,
			};

			const createdOrder = await pocketbaseRequest('orders', orderPayload);

			const calculatedItems = totals.promotionItems || calculateCartPromotions(cart).items || cart;
			for (const item of calculatedItems) {
				const isGift = Boolean(item.is_gift);
				const quantity = isGift ? 1 : Number(item.quantity || 1);
				const unitPriceUSD = isGift ? 0 : Number(item.price || 0);
				const unitFinalPriceUSD = isGift ? 0 : Number(item.unit_price_final_usd ?? unitPriceUSD);
				const unitCostUSD = isGift ? 0 : Number(item.variation_cost_usd ?? item.cost_usd ?? 0);
				const unitProfitUSD = unitFinalPriceUSD - unitCostUSD;
				const lineOriginalUSD = isGift ? 0 : Number(item.line_subtotal_original_usd ?? (unitPriceUSD * quantity));
				const lineDiscountUSD = isGift ? 0 : Number(item.line_discount_usd || 0);
				const lineTotalUSD = isGift ? 0 : Number(item.line_subtotal_final_usd ?? (unitFinalPriceUSD * quantity));
				const lineProfitUSD = unitProfitUSD * quantity;
				const variationLabel = isGift ? '' : (item.variation_label || item.variation_name || '');
				const variationRef = isGift ? '' : (item.variation_ref || item.variation_internal_ref || '');
				const visualUnitPrice = item.only_usd || selectedCode === 'USD' ? unitFinalPriceUSD : convertFromUsd(unitFinalPriceUSD, selectedCode);
				const visualLineTotal = item.only_usd || selectedCode === 'USD' ? lineTotalUSD : convertFromUsd(lineTotalUSD, selectedCode);
				const orderItemPayload = {
					order: createdOrder.id,
					product_name: item.title,
					variation_name: variationLabel,
					variation_label: variationLabel,
					variation_ref: variationRef,
					quantity,
					unit_price_selected_currency: visualUnitPrice,
					unit_price_usd: unitFinalPriceUSD,
					variation_price_usd: unitFinalPriceUSD,
					unit_price_original_usd: unitPriceUSD,
					unit_price_final_usd: unitFinalPriceUSD,
					unit_profit_usd: unitProfitUSD,
					line_profit_usd: lineProfitUSD,
					line_total_usd: lineTotalUSD,
					line_total_selected_currency: visualLineTotal,
					line_subtotal_original_usd: lineOriginalUSD,
					line_discount_usd: lineDiscountUSD,
					line_subtotal_final_usd: lineTotalUSD,
					promotion_id: item.promotion?.id || '',
					promotion_name: item.promotion?.name || item.promotion_label || '',
					promotion_type: item.promotion?.type || '',
					coupon_id: item.coupon?.id || '',
					coupon_code: item.coupon?.code || '',
					coupon_discount_usd: Number(item.coupon_discount_usd || 0),
					only_usd: Boolean(item.only_usd),
					is_gift: isGift,
					gift_min_order_usd: isGift ? Number(item.min_order_usd || 0) : 0,
				};

				if (isGift) {
					orderItemPayload.gift = item.gift_id;
				} else {
					orderItemPayload.product = item.id;
					orderItemPayload.product_ref = item.id;
					if (item.variation_id) orderItemPayload.variation = item.variation_id;
				}

				await pocketbaseRequest('order_items', orderItemPayload);
			}

			if (totals.couponWinner === 'manual_coupon' && totals.manualCoupon?.id) {
				await pocketbaseRequest('manual_coupon_usages', {
					coupon: totals.manualCoupon.id,
					order: createdOrder.id,
					coupon_code: totals.manualCoupon.code || '',
					customer_name: validation.data.customer_name,
					order_number: orderNumber,
					discount_usd: Number(totals.couponDiscountUSD || 0),
					shipping_discount_usd: Number(totals.shippingDiscountUSD || 0),
				});
				await pocketbasePatch('manual_coupons', totals.manualCoupon.id, {
					used_count: Number(totals.manualCoupon.used_count || 0) + 1,
				});
				const nextUsedCount = Number(totals.manualCoupon.used_count || 0) + 1;
				const maxUses = Number(totals.manualCoupon.max_uses || 0);
				if (totals.manualCoupon.unlimited_uses === false && maxUses > 0 && nextUsedCount >= maxUses) {
					removeSavedCouponCode(totals.manualCoupon.code || '');
				}
			}

			const message = buildWhatsAppMessage({
				order: createdOrder,
				cart,
				checkoutData: validation.data,
				totals,
				receiptUrl,
				settings,
			});

			return {
				createdOrder,
				whatsappNumber,
				message,
				cartFingerprint: buildCartFingerprint(cart),
			};
		}

		continueWhatsappBtn.addEventListener('click', async () => {
			if (orderWasCreated && savedWhatsappUrl) {
				const openedWindow = window.open(savedWhatsappUrl, '_blank', 'noopener');
				completeCheckoutAfterWhatsApp();
				if (!openedWindow) {
					window.location.href = savedWhatsappUrl;
				}
				return;
			}

			if (isSubmittingOrder) return;

			const validation = validateCheckout(true);

			if (!validation.isValid) {
				checkoutValidationAlert.textContent = 'Revisa los campos marcados antes de realizar el pedido.';
				checkoutValidationAlert.classList.remove('hidden');
				checkoutSuccessAlert.classList.add('hidden');
				return;
			}

			isSubmittingOrder = true;
			checkoutValidationAlert.classList.add('hidden');
			checkoutSuccessAlert.classList.add('hidden');
			continueWhatsappBtn.disabled = true;
			continueWhatsappBtn.textContent = 'Guardando pedido...';

			try {
				const { createdOrder, whatsappNumber, message, cartFingerprint } = await createOrderAndItems(validation);
				const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;

				markOrderCreated({
					orderNumber: createdOrder.order_number,
					whatsappUrl,
					cartFingerprint,
				});
			} catch (error) {
				console.error(error);
				isSubmittingOrder = false;
				checkoutValidationAlert.textContent = error?.message || 'No se pudo guardar el pedido. Revisa PocketBase e intenta nuevamente.';
				checkoutValidationAlert.classList.remove('hidden');
				continueWhatsappBtn.disabled = false;
				continueWhatsappBtn.textContent = 'Realizar Pedido';
				validateCheckout(false);
			}
		});

		window.addEventListener('pz-currency-changed', () => renderCheckout());
		window.addEventListener('pz-promotions-updated', () => renderCheckout());
		window.addEventListener('pz-coupons-updated', () => renderCheckout());

		getActiveSettings().catch((error) => {
			console.warn('No se pudo cargar el horario de la tienda en checkout.', error);
		});

		loadShippingZones()
			.catch((error) => {
				console.error(error);
				checkoutValidationAlert.textContent = error?.message || 'No se pudieron cargar las zonas de envío.';
				checkoutValidationAlert.classList.remove('hidden');
			})
			.finally(() => {
				renderCheckout();
			});
	</script>
</Layout>
