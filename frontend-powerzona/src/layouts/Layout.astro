---
import '../styles/global.css';
import Cart from '../components/Cart.astro';
import CurrencySwitcher from '../components/CurrencySwitcher.astro';
import SocialMeta from '../components/SocialMeta.astro';
import { getCurrentStore, getStorePathPrefix, isStoreRoute } from '../lib/stores';

const {
	isBazar = false,
	isMaster = false,
	hideStoreFloatingUi: hideStoreFloatingUiProp = false,
	seo = {},
} = Astro.props;
const pocketbaseUrl = import.meta.env.PUBLIC_POCKETBASE_URL;
const hideStoreFloatingUi = Boolean(isBazar || isMaster || hideStoreFloatingUiProp);
const currentStore = hideStoreFloatingUi ? { id: '', slug: '' } : await getCurrentStore(Astro);
const currentStoreId = currentStore.id;
const currentStoreSlug = currentStore.slug || 'powerzona';
const publicPathPrefix = getStorePathPrefix(currentStore, Astro.url.pathname);
const normalizedPathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCheckoutPage = normalizedPathname === '/checkout' || (isStoreRoute(Astro.url.pathname) && normalizedPathname === `${publicPathPrefix}/checkout`);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
		<link rel="icon" href="/favicon.ico?v=2" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
		<SocialMeta {...seo} />
	</head>
	<body class="bg-gray-50 text-slate-800 font-sans antialiased min-h-screen w-full overflow-x-hidden">
		{!hideStoreFloatingUi && <script define:vars={{ currentStoreId, currentStoreSlug, publicPathPrefix }}>
			(() => {
				const storeId = String(currentStoreId || '').trim();
				const storeSlug = String(currentStoreSlug || '').trim().toLowerCase();
				const storageStoreId = storeId || storeSlug || 'powerzona';
				const cartStorageKey = `tusenda84_cart_${storageStoreId}`;
				const checkoutCartStorageKey = `${cartStorageKey}_checkout`;
				const legacyCartStorageKey = 'powerzona_cart';
				const legacyCheckoutCartStorageKey = 'powerzona_checkout_cart';
				const shouldMigrateLegacy = storeSlug === 'powerzona' || !String(publicPathPrefix || '').trim();

				function parseCart(value) {
					try {
						const parsed = JSON.parse(value || '[]');
						return Array.isArray(parsed) ? parsed : [];
					} catch (_) {
						return [];
					}
				}

				function migrateLegacyCart() {
					if (!shouldMigrateLegacy) return;
					const currentRawCart = localStorage.getItem(cartStorageKey);
					if (currentRawCart !== null) return;
					const legacyCart = parseCart(localStorage.getItem(legacyCartStorageKey));
					if (!legacyCart.length) return;
					const payload = JSON.stringify(legacyCart);
					localStorage.setItem(cartStorageKey, payload);
					if (!sessionStorage.getItem(checkoutCartStorageKey)) {
						sessionStorage.setItem(checkoutCartStorageKey, payload);
					}
				}

				function readCart() {
					migrateLegacyCart();
					const currentRawCart = localStorage.getItem(cartStorageKey);
					if (currentRawCart !== null) return parseCart(currentRawCart);
					const checkoutBackup = parseCart(sessionStorage.getItem(checkoutCartStorageKey));
					if (checkoutBackup.length) {
						localStorage.setItem(cartStorageKey, JSON.stringify(checkoutBackup));
						return checkoutBackup;
					}
					return [];
				}

				function writeCart(cart) {
					const safeCart = Array.isArray(cart) ? cart : [];
					const payload = JSON.stringify(safeCart);
					localStorage.setItem(cartStorageKey, payload);
					if (safeCart.length) sessionStorage.setItem(checkoutCartStorageKey, payload);
					else {
						sessionStorage.removeItem(checkoutCartStorageKey);
						sessionStorage.removeItem(legacyCheckoutCartStorageKey);
						if (shouldMigrateLegacy) {
							localStorage.removeItem(legacyCartStorageKey);
							sessionStorage.removeItem(legacyCheckoutCartStorageKey);
						}
					}
					return safeCart;
				}

				window.addEventListener('storage', (event) => {
					if (event.key === cartStorageKey) {
						if (event.newValue !== null && parseCart(event.newValue).length === 0) {
							sessionStorage.removeItem(checkoutCartStorageKey);
							sessionStorage.removeItem(legacyCheckoutCartStorageKey);
						}
						window.dispatchEvent(new Event('cart-updated'));
					}
					if (event.key === checkoutCartStorageKey || event.key === legacyCheckoutCartStorageKey) return;
				});

				window.PZ_CURRENT_STORE_ID = storeId;
				window.PZ_PUBLIC_PATH_PREFIX = publicPathPrefix || '';
				window.PZ_CART_STORAGE_KEY = cartStorageKey;
				window.PZ_CHECKOUT_CART_STORAGE_KEY = checkoutCartStorageKey;
				window.PZCartStorage = {
					legacyCartStorageKey,
					legacyCheckoutCartStorageKey,
					getCartStorageKey: () => cartStorageKey,
					getCheckoutStorageKey: () => checkoutCartStorageKey,
					migrateLegacyCart,
					readCart,
					writeCart,
					parseCart,
				};
				migrateLegacyCart();
			})();
		</script>}
		{!hideStoreFloatingUi && <script is:inline src="/cart-live-validator.js"></script>}
		
		<main class="flex flex-col min-h-screen w-full min-w-0">
			<div class="w-full max-w-7xl mx-auto p-4 sm:p-6">
				<slot />
			</div>
		</main>

		{!hideStoreFloatingUi && <script is:inline src="/cart-promotions.js"></script>}
		{!hideStoreFloatingUi && <script define:vars={{ pocketbaseUrl, currentStoreId, publicPathPrefix }}>
			window.PZ_POCKETBASE_URL = String(pocketbaseUrl || '').replace(/\/$/, '');
			window.PZ_CURRENT_STORE_ID = currentStoreId || '';
			window.PZ_PUBLIC_PATH_PREFIX = publicPathPrefix || '';
			window.PZ_PROMOTIONS_READY = window.PZPromotions?.loadActivePromotions(window.PZ_POCKETBASE_URL, window.PZ_CURRENT_STORE_ID).then((promotions) => {
				window.PZ_AUTOMATIC_PROMOTIONS = promotions;
				window.dispatchEvent(new Event('pz-promotions-updated'));
				return promotions;
			});
			window.PZ_COUPONS_READY = window.PZPromotions?.loadActiveCoupons(window.PZ_POCKETBASE_URL, window.PZ_CURRENT_STORE_ID).then((coupons) => {
				window.PZ_MANUAL_COUPONS = coupons;
				window.dispatchEvent(new Event('pz-coupons-updated'));
				return coupons;
			});
			(() => {
				const params = new URLSearchParams(window.location.search);
				const code = String(params.get('coupon') || '').trim().toUpperCase();
				if (!code) return;
				const storeKey = String(window.PZ_CURRENT_STORE_ID || 'powerzona');
				const key = `powerzona_saved_coupons_${storeKey}`;
				const selectedKey = `powerzona_selected_coupon_${storeKey}`;
				if (storeKey === 'powerzona' && !localStorage.getItem(key)) {
					const legacySaved = localStorage.getItem('powerzona_saved_coupons');
					if (legacySaved) localStorage.setItem(key, legacySaved);
				}
				if (storeKey === 'powerzona' && !localStorage.getItem(selectedKey)) {
					const legacySelected = localStorage.getItem('powerzona_selected_coupon');
					if (legacySelected) localStorage.setItem(selectedKey, legacySelected);
				}

				const escapeHtml = (value) => String(value || '')
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/"/g, '&quot;')
					.replace(/'/g, '&#039;');

				const dateBoundaryTime = (value, boundary = 'start') => {
					if (!value) return 0;
					const text = String(value);
					if (/^\d{4}-\d{2}-\d{2}$/.test(text)) {
						const [year, month, day] = text.split('-').map(Number);
						const date = boundary === 'end'
							? new Date(year, month - 1, day, 23, 59, 59, 999)
							: new Date(year, month - 1, day, 0, 0, 0, 0);
						return date.getTime();
					}
					const parsed = new Date(text).getTime();
					return Number.isFinite(parsed) ? parsed : 0;
				};

				const couponIsExpired = (coupon) => {
					const now = Date.now();
					const startsAt = dateBoundaryTime(coupon?.starts_at, 'start');
					const endsAt = dateBoundaryTime(coupon?.ends_at, 'end');
					return Boolean((startsAt && startsAt > now) || (endsAt && endsAt < now));
				};

				const couponIsSoldOut = (coupon) => {
					const maxUses = Number(coupon?.max_uses || 0);
					const usedCount = Number(coupon?.used_count || 0);
					return coupon?.unlimited_uses === false && maxUses > 0 && usedCount >= maxUses;
				};

				const expandedName = (coupon, field) => {
					const expanded = coupon?.expand?.[field];
					const item = Array.isArray(expanded) ? expanded[0] : expanded;
					return item?.name || item?.title || '';
				};

				const benefitText = (coupon) => {
					if (!coupon) return '';
					if (coupon.scope === 'free_shipping') return 'Tu envío puede quedar en 0.';
					const value = Number(coupon.discount_value || 0);
					if (coupon.discount_type === 'percentage') return `Ahorras ${value.toFixed(value % 1 ? 2 : 0)}%.`;
					if (coupon.discount_type === 'fixed_usd') return `Ahorras ${value.toFixed(2)} USD.`;
					return coupon.customer_message || 'Cupón disponible.';
				};

				const conditionLines = (coupon) => {
					const lines = [];
					const minSubtotal = Number(coupon?.min_subtotal_usd || 0);
					if (minSubtotal > 0) lines.push(`Compra mínima: ${minSubtotal.toFixed(2)} USD.`);
					if (coupon?.scope === 'product') lines.push(`Producto: ${expandedName(coupon, 'product') || 'producto seleccionado'}.`);
					if (coupon?.scope === 'category') lines.push(`Categoría: ${expandedName(coupon, 'category') || 'categoría seleccionada'}.`);
					if (coupon?.scope === 'subcategory') lines.push(`Subcategoría: ${expandedName(coupon, 'subcategory') || 'subcategoría seleccionada'}.`);
					if (coupon?.scope === 'free_shipping') lines.push('Aplica solo para pedidos con envío.');
					return lines;
				};

				const saveCouponCode = (couponCode) => {
					const saved = (() => {
						try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch (_) { return []; }
					})();
					const list = Array.isArray(saved) ? saved.map((item) => String(item || '').toUpperCase()) : [];
					if (!list.includes(couponCode)) list.push(couponCode);
					localStorage.setItem(key, JSON.stringify(list.slice(-12)));
				};

				const removeCouponCode = (couponCode) => {
					const saved = (() => {
						try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch (_) { return []; }
					})();
					const next = Array.isArray(saved)
						? saved.map((item) => String(item || '').toUpperCase()).filter((item) => item && item !== couponCode)
						: [];
					localStorage.setItem(key, JSON.stringify(next));
					if (localStorage.getItem(selectedKey) === couponCode) {
						localStorage.removeItem(selectedKey);
					}
				};

				const couponAlreadySaved = (couponCode) => {
					const saved = (() => {
						try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch (_) { return []; }
					})();
					return Array.isArray(saved) && saved.map((item) => String(item || '').toUpperCase()).includes(couponCode);
				};

				const cleanCouponFromUrl = () => {
					const url = new URL(window.location.href);
					url.searchParams.delete('coupon');
					const next = `${url.pathname}${url.search}${url.hash}`;
					window.history.replaceState({}, '', next || '/');
				};

				const showCouponModal = ({ title, codeText = '', mainText = '', details = [], finalText = '', tone = 'success', onClose = null }) => {
					document.getElementById('pz-coupon-link-modal')?.remove();
					const overlay = document.createElement('div');
					overlay.id = 'pz-coupon-link-modal';
					overlay.setAttribute('role', 'dialog');
					overlay.setAttribute('aria-modal', 'true');
					overlay.innerHTML = `
						<div class="pz-coupon-link-backdrop"></div>
						<div class="pz-coupon-link-card">
							<div class="pz-coupon-link-icon ${tone === 'success' ? 'is-success' : 'is-warning'}">${tone === 'success' ? '%' : '!'}</div>
							<h2>${escapeHtml(title)}</h2>
							${codeText ? `<p class="pz-coupon-link-code">${escapeHtml(codeText)}</p>` : ''}
							${mainText ? `<p class="pz-coupon-link-main">${escapeHtml(mainText)}</p>` : ''}
							${details.length ? `<div class="pz-coupon-link-details">${details.map((line) => `<p>${escapeHtml(line)}</p>`).join('')}</div>` : ''}
							${finalText ? `<p class="pz-coupon-link-final">${escapeHtml(finalText)}</p>` : ''}
							<button class="pz-coupon-link-ok" type="button">OK</button>
						</div>
					`;
					const style = document.createElement('style');
					style.textContent = `
						#pz-coupon-link-modal { position: fixed; inset: 0; z-index: 99999; display: grid; place-items: center; padding: 18px; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
						.pz-coupon-link-backdrop { position: absolute; inset: 0; background: rgba(15, 23, 42, .48); backdrop-filter: blur(5px); }
						.pz-coupon-link-card { position: relative; width: min(460px, 100%); border-radius: 30px; background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%); border: 1px solid rgba(226, 232, 240, .96); box-shadow: 0 34px 100px rgba(15, 23, 42, .30); padding: 26px; text-align: center; color: #0f172a; }
						.pz-coupon-link-icon { width: 54px; height: 54px; margin: 0 auto 14px; border-radius: 20px; display: grid; place-items: center; font-size: 24px; font-weight: 1000; }
						.pz-coupon-link-icon.is-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
						.pz-coupon-link-icon.is-warning { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
						.pz-coupon-link-card h2 { margin: 0; font-size: clamp(24px, 7vw, 34px); line-height: 1; font-weight: 1000; letter-spacing: 0; }
						.pz-coupon-link-code { width: fit-content; max-width: 100%; margin: 16px auto 0; border-radius: 999px; background: #0f172a; color: #fff; padding: 9px 14px; font-size: 15px; font-weight: 1000; letter-spacing: .04em; word-break: break-word; }
						.pz-coupon-link-main { margin: 16px 0 0; color: #334155; font-size: 16px; line-height: 1.45; font-weight: 900; }
						.pz-coupon-link-details { display: grid; gap: 8px; margin: 16px 0 0; padding: 12px; border-radius: 20px; background: #f1f5f9; border: 1px solid #e2e8f0; text-align: left; }
						.pz-coupon-link-details p { margin: 0; color: #475569; font-size: 13px; line-height: 1.35; font-weight: 800; }
						.pz-coupon-link-final { margin: 16px 0 0; color: #166534; font-size: 13px; line-height: 1.45; font-weight: 950; }
						.pz-coupon-link-ok { width: 100%; margin-top: 18px; border: 0; border-radius: 18px; background: #0f172a; color: #fff; padding: 13px 16px; font-size: 14px; font-weight: 1000; cursor: pointer; box-shadow: 0 14px 30px rgba(15, 23, 42, .18); }
						@media (max-width: 520px) { .pz-coupon-link-card { border-radius: 26px; padding: 22px; } }
					`;
					overlay.appendChild(style);
					const close = () => {
						overlay.remove();
						if (typeof onClose === 'function') onClose();
					};
					overlay.querySelector('.pz-coupon-link-ok')?.addEventListener('click', close);
					overlay.querySelector('.pz-coupon-link-backdrop')?.addEventListener('click', close);
					document.addEventListener('keydown', function onKeydown(event) {
						if (event.key !== 'Escape') return;
						close();
						document.removeEventListener('keydown', onKeydown);
					});
					document.body.appendChild(overlay);
				};

				Promise.resolve(window.PZ_COUPONS_READY).then(() => {
					const coupon = (window.PZ_MANUAL_COUPONS || []).find((item) => String(item.code || '').toUpperCase() === code);
					if (!coupon) {
						removeCouponCode(code);
						showCouponModal({
							title: 'Cupón no disponible',
							mainText: 'Este cupón no está disponible o ya no existe.',
							tone: 'warning',
							onClose: cleanCouponFromUrl,
						});
						return;
					}
					if (couponIsExpired(coupon)) {
						removeCouponCode(code);
						showCouponModal({
							title: 'Cupón vencido',
							mainText: 'Este cupón ya no está disponible.',
							tone: 'warning',
							onClose: cleanCouponFromUrl,
						});
						return;
					}
					if (couponIsSoldOut(coupon)) {
						removeCouponCode(code);
						showCouponModal({
							title: 'Cupón agotado',
							mainText: 'Este cupón ya alcanzó su límite de uso.',
							tone: 'warning',
							onClose: cleanCouponFromUrl,
						});
						return;
					}
					const alreadySaved = couponAlreadySaved(code);
					if (!alreadySaved) saveCouponCode(code);
					showCouponModal({
						title: alreadySaved ? 'Cupón ya listo' : 'Cupón adquirido',
						codeText: coupon.code || code,
						mainText: alreadySaved
							? 'Este cupón ya está guardado para tu próximo pedido.'
							: (coupon.customer_message || benefitText(coupon)),
						details: alreadySaved ? [coupon.customer_message || benefitText(coupon)] : conditionLines(coupon),
						finalText: alreadySaved
							? 'Lo verás cuando vayas a realizar el pedido.'
							: 'Este cupón se guardó. Lo verás cuando vayas a realizar el pedido.',
						tone: 'success',
						onClose: cleanCouponFromUrl,
					});
				});
			})();
		</script>}
		<script is:inline>
		  (() => {
		    if (window.__pzScrollHintReady) return;
		    window.__pzScrollHintReady = true;

		    const SELECTORS = [
		      '[data-pz-scroll-hint]',
		      '.summary-period-actions',
		      '.analytics-tabs',
		      '.visit-analytics-tabs',
		      '.business-summary-tabs',
		      '.expiration-tabs',
		      '.profits-period-tabs',
		      '.settings-tabs',
		      '.rating-reviews-table-wrap',
		      '.hours-table-wrap',
		      '.quick-categories-strip',
		      '.featured-strip'
		    ];

		    const enhanced = new WeakSet();
		    const updaters = new WeakMap();

		    const shouldEnhance = (track) => {
		      if (!(track instanceof HTMLElement)) return false;
		      if (track.closest('.pz-scroll-hint-shell')) return false;
		      if (track.closest('#pz-admin-sidebar')) return false;
		      if (track.matches('.tabs')) return false;
		      return true;
		    };

		    const scrollTrackByArrow = (track, side, update) => {
		      if (!(track instanceof HTMLElement)) return;

		      const distance = Math.max(140, Math.floor(track.clientWidth * 0.72));
		      const left = side === 'right' ? distance : -distance;

		      track.scrollBy({
		        left,
		        behavior: 'smooth'
		      });

		      window.setTimeout(update, 80);
		      window.setTimeout(update, 240);
		      window.setTimeout(update, 520);
		    };

		    const createArrow = (side, track, update) => {
		      const arrow = document.createElement('button');
		      arrow.type = 'button';
		      arrow.className = `pz-scroll-hint-arrow pz-scroll-hint-arrow--${side}`;
		      arrow.setAttribute('aria-label', side === 'right' ? 'Desplazar a la derecha' : 'Desplazar a la izquierda');
		      arrow.setAttribute('tabindex', '-1');

		      arrow.addEventListener('click', (event) => {
		        event.preventDefault();
		        event.stopPropagation();
		        scrollTrackByArrow(track, side, update);
		      });

		      arrow.addEventListener('touchend', (event) => {
		        event.preventDefault();
		        event.stopPropagation();
		        scrollTrackByArrow(track, side, update);
		      }, { passive: false });

		      return arrow;
		    };

		    const updateShellState = (shell, track) => {
		      if (!shell || !track) return;

		      const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
		      const hasOverflow = maxScroll > 8;
		      const canLeft = hasOverflow && track.scrollLeft > 4;
		      const canRight = hasOverflow && track.scrollLeft < maxScroll - 4;

		      shell.dataset.hasOverflow = hasOverflow ? 'true' : 'false';
		      shell.dataset.canLeft = canLeft ? 'true' : 'false';
		      shell.dataset.canRight = canRight ? 'true' : 'false';
		    };

		    const enhanceTrack = (track) => {
		      if (!shouldEnhance(track) || enhanced.has(track)) return;

		      const parent = track.parentNode;
		      if (!parent) return;

		      const shell = document.createElement('div');
		      shell.className = 'pz-scroll-hint-shell';
		      shell.dataset.hasOverflow = 'false';
		      shell.dataset.canLeft = 'false';
		      shell.dataset.canRight = 'false';

		      parent.insertBefore(shell, track);
		      shell.appendChild(track);

		      track.classList.add('pz-scroll-hint-track');
		      enhanced.add(track);

		      const update = () => updateShellState(shell, track);
		      updaters.set(track, update);

		      shell.appendChild(createArrow('left', track, update));
		      shell.appendChild(createArrow('right', track, update));

		      track.addEventListener('scroll', update, { passive: true });
		      window.requestAnimationFrame(update);
		      window.setTimeout(update, 250);
		      window.setTimeout(update, 900);

		      if ('ResizeObserver' in window) {
		        const observer = new ResizeObserver(update);
		        observer.observe(track);
		        observer.observe(shell);
		      }
		    };

		    const initScrollHints = () => {
		      const tracks = new Set();

		      SELECTORS.forEach((selector) => {
		        document.querySelectorAll(selector).forEach((track) => tracks.add(track));
		      });

		      tracks.forEach((track) => enhanceTrack(track));

		      window.requestAnimationFrame(() => {
		        document.querySelectorAll('.pz-scroll-hint-track').forEach((track) => {
		          const update = updaters.get(track);
		          if (typeof update === 'function') update();
		        });
		      });
		    };

		    const refreshScrollHints = () => {
		      window.requestAnimationFrame(() => {
		        document.querySelectorAll('.pz-scroll-hint-track').forEach((track) => {
		          const update = updaters.get(track);
		          if (typeof update === 'function') update();
		        });
		      });
		    };

		    const boot = () => {
		      initScrollHints();

		      window.addEventListener('resize', refreshScrollHints, { passive: true });
		      window.addEventListener('orientationchange', () => window.setTimeout(refreshScrollHints, 250), { passive: true });
		      window.addEventListener('hashchange', () => window.setTimeout(refreshScrollHints, 120), { passive: true });

		      document.addEventListener('click', () => {
		        window.setTimeout(initScrollHints, 80);
		        window.setTimeout(refreshScrollHints, 220);
		      }, true);

		      if ('MutationObserver' in window) {
		        const observer = new MutationObserver(() => {
		          window.requestAnimationFrame(initScrollHints);
		        });

		        observer.observe(document.body, {
		          childList: true,
		          subtree: true
		        });
		      }
		    };

		    if (document.readyState === 'loading') {
		      document.addEventListener('DOMContentLoaded', boot, { once: true });
		    } else {
		      boot();
		    }
		  })();
		</script>
		{!hideStoreFloatingUi && <CurrencySwitcher hideFloatingSwitcher={isCheckoutPage} />}
		{!hideStoreFloatingUi && <Cart />}

	</body>
</html>
